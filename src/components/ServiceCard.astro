---
interface Props {
  title: string;
  description: string;
  href: string;
  image: string;
}

const { title, description, href, image } = Astro.props;
---

<article class="svc-card">
  <div class="svc-card__img-wrap">
    <img
      src={image}
      alt={title}
      class="svc-card__img"
      loading="lazy"
      decoding="async"
      width="640"
      height="360"
    />
  </div>
  <div class="svc-card__body">
    <h3 class="svc-card__title">{title}</h3>
    <p class="svc-card__desc">{description}</p>
    <a href={href} class="svc-card__btn">Ver {title}</a>
  </div>
</article>

<style>
  .svc-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
  }

  .svc-card__img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-bg);
    overflow: hidden;
  }

  .svc-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .svc-card__body {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--spacing-sm);
  }

  .svc-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--line-height-tight);
    margin: 0;
  }

  .svc-card__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .svc-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-size: var(--font-size-sm);
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    margin-top: auto;
    border-radius: var(--border-radius);
    background: var(--color-accent);
    color: var(--color-white);
    text-align: center;
    transition: background-color 0.2s ease;
  }

  .svc-card__btn:hover {
    background: var(--color-accent-dark);
  }
</style>
