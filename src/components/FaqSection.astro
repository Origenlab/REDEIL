---
import { WHATSAPP_NUMBER, PHONE_DISPLAY, PHONE_URL, EMAIL, EMAIL_URL, BUSINESS_HOURS } from '../lib/config';

interface FaqItem {
  pregunta: string;
  respuesta: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="faq-section" id="faq">
  <div class="container">
    <div class="faq-section__grid">
      <!-- FAQ Accordion -->
      <div class="faq-section__list">
        <h2 class="faq-section__title">Preguntas Frecuentes</h2>
        {items.map((item) => (
          <details class="faq-item">
            <summary class="faq-item__q">
              {item.pregunta}
              <span class="faq-item__icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-item__a">
              <p>{item.respuesta}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- Formulario WhatsApp -->
      <div class="faq-section__form-col">
        <div class="faq-form">
          <h3 class="faq-form__title">Cotiza tu evento</h3>
          <p class="faq-form__text">Completa el formulario y te respondemos por WhatsApp en minutos.</p>
          <form id="faq-wa-form" class="faq-form__fields">
            <div class="faq-form__field">
              <label for="faq-nombre">Nombre</label>
              <input type="text" id="faq-nombre" name="nombre" placeholder="Tu nombre" required />
            </div>
            <div class="faq-form__field">
              <label for="faq-evento">Tipo de evento</label>
              <select id="faq-evento" name="evento" required>
                <option value="">Selecciona...</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Fiesta">Fiesta / Cumpleaños</option>
                <option value="Corporativo">Evento Corporativo</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="faq-form__field">
              <label for="faq-fecha">Fecha aproximada</label>
              <input type="date" id="faq-fecha" name="fecha" />
            </div>
            <div class="faq-form__field">
              <label for="faq-mensaje">¿Qué necesitas?</label>
              <textarea id="faq-mensaje" name="mensaje" rows="3" placeholder="Ej: Guirnaldas para boda en jardín, 100 invitados..."></textarea>
            </div>
            <button type="submit" class="faq-form__btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
              Enviar por WhatsApp
            </button>
          </form>
          <div class="faq-form__info">
            <a href={PHONE_URL}>{PHONE_DISPLAY}</a>
            <a href={EMAIL_URL}>{EMAIL}</a>
            <span>{BUSINESS_HOURS.display}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ WHATSAPP_NUMBER }}>
  document.getElementById('faq-wa-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const nombre = document.getElementById('faq-nombre')?.value || '';
    const evento = document.getElementById('faq-evento')?.value || '';
    const fecha = document.getElementById('faq-fecha')?.value || '';
    const mensaje = document.getElementById('faq-mensaje')?.value || '';

    let text = `Hola REDEIL, soy ${nombre}.`;
    if (evento) text += ` Estoy planeando: ${evento}.`;
    if (fecha) text += ` Fecha: ${fecha}.`;
    if (mensaje) text += ` ${mensaje}`;

    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(text)}`;
    window.open(url, '_blank');
  });
</script>

<style>
  .faq-section {
    padding: var(--spacing-3xl) 0;
  }

  .faq-section__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: var(--spacing-lg);
  }

  .faq-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  /* FAQ Items */
  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item__q {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md) 0;
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
  }

  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q:hover { color: var(--color-accent); }

  .faq-item__icon {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-accent);
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(45deg);
  }

  .faq-item__a {
    padding-bottom: var(--spacing-md);
  }

  .faq-item__a p {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
  }

  /* Form Column */
  .faq-form {
    background: var(--color-bg);
    border-radius: var(--border-radius-lg);
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .faq-form__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .faq-form__text {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  .faq-form__fields {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-top: var(--spacing-sm);
  }

  .faq-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .faq-form__field label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .faq-form__field input,
  .faq-form__field select,
  .faq-form__field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: var(--font-size-sm);
    font-family: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background: var(--color-white);
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .faq-form__field input:focus,
  .faq-form__field select:focus,
  .faq-form__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .faq-form__field textarea {
    resize: vertical;
  }

  .faq-form__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem 1.5rem;
    font-size: var(--font-size-base);
    font-weight: 600;
    font-family: inherit;
    border: none;
    border-radius: var(--border-radius);
    background: #25D366;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s;
  }

  .faq-form__btn:hover {
    background: #1ebe57;
  }

  .faq-form__info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: var(--spacing-sm);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .faq-form__info a {
    color: var(--color-accent);
  }

  @media (min-width: 1024px) {
    .faq-section__grid {
      grid-template-columns: 1fr 1fr;
    }

    .faq-section__form-col {
      position: sticky;
      top: calc(var(--header-height) + var(--spacing-lg));
      align-self: start;
    }
  }
</style>
