---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el Paquete Evento Completo de Mesas Picnic?',
    respuesta: 'Incluye 20+ mesas picnic de madera, manteles de tela, centros de mesa decorativos, capacidad para 80 o más personas, diseño integral de producción, transporte, instalación coordinada, técnico en sitio y desmontaje. Es un servicio llave en mano: tú llegas al evento, todo está montado.'
  },
  {
    pregunta: '¿Cuánto cuesta el Paquete Evento Completo?',
    respuesta: 'El paquete tiene un precio desde $9,000 MXN + IVA. Incluye todo: 20+ mesas, manteles, centros de mesa, producción completa, transporte, instalación y desmontaje. El precio final varía según la cantidad exacta de mesas y los accesorios elegidos.'
  },
  {
    pregunta: '¿Puedo personalizar los manteles y centros de mesa?',
    respuesta: 'Sí, completamente. Ofrecemos diferentes paletas de colores y estilos de manteles. Los centros de mesa pueden incluir flores, velas, plantas o elementos decorativos según tu temática. Contáctanos por WhatsApp al 55 4937 5172 para una propuesta personalizada.'
  },
  {
    pregunta: '¿En qué zonas entregan el Paquete Evento Completo?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX. Para ubicaciones más lejanas, cotizamos costo de logística.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el Paquete Evento Completo?',
    respuesta: 'Recomendamos mínimo 6 a 8 semanas de anticipación para poder personalizar manteles y centros de mesa a tu gusto. En temporada alta (noviembre-febrero) es indispensable reservar con tiempo. Contáctanos cuanto antes para asegurar tu fecha.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Evento Completo Mesas Picnic — 20+ mesas | REDEIL',
    description: 'Producción completa de mesas picnic para eventos grandes en CDMX. 20+ mesas de madera con manteles y centros de mesa para 80 o más invitados. Servicio llave en mano desde $9,000 MXN.',
    image: SITE_URL + '/img/paquetes/mesas-picnic/paquete-evento-completo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '9000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/mesas-picnic/paquete-evento-completo/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '18',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Evento Completo Mesas Picnic CDMX | 20+ Mesas con Manteles y Decoración | REDEIL"
  description="Producción completa de mesas picnic para eventos grandes en CDMX. 20+ mesas de madera con manteles y centros de mesa para 80+ invitados. Llave en mano desde $9,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Mesas Picnic', href: '/equipos-para-eventos/mesas-picnic/' }, { name: 'Evento Completo', href: '/equipos-para-eventos/mesas-picnic/paquete-evento-completo/' }]} />

  <Hero
    badge="Producción Completa — 20+ Mesas"
    title="Evento Completo — 20+ Mesas Picnic con Manteles y Decoración"
    description="El servicio de producción más completo: 20 o más mesas picnic de madera con manteles y centros de mesa para 80+ invitados. Llave en mano en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $9,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/mesas-picnic/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete Evento Completo</strong> es para quien no quiere hacer nada el día de su evento más que aparecer y disfrutar. <strong>20 o más mesas picnic</strong> con manteles de tela y centros de mesa decorativos, instaladas en tu espacio en CDMX o Estado de México, listas antes de que llegue el primer invitado.</p>
      <p>No son mesas con una tela encima. Es producción de evento: la madera, el mantel y el centro de mesa trabajan juntos para crear una imagen cohesionada que se ve costosa aunque no lo sea. REDEIL coordina todo — logística, instalación, decoración — para que tú solo te encargues de los invitados.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Mesas Picnic"
    items={[{ label: "4 Mesas", href: "/equipos-para-eventos/mesas-picnic/paquete-4-mesas/" }, { label: "8 Mesas", href: "/equipos-para-eventos/mesas-picnic/paquete-8-mesas/" }, { label: "12 Mesas", href: "/equipos-para-eventos/mesas-picnic/paquete-12-mesas/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/mesas-picnic/paquete-evento-completo.avif" alt="Producción completa con 20+ mesas picnic decoradas con manteles y centros de mesa" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/mesas-picnic.avif" alt="Vista aérea de mesas picnic en producción completa" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/mesas-picnic/sell/manteles.avif" alt="Mesas picnic con manteles de tela blancos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/mesas-picnic/sell/centros-mesa.avif" alt="Centros de mesa florales sobre mesas picnic" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/mesas-picnic/sell/produccion-completa.avif" alt="Evento completo con mesas picnic, guirnaldas y decoración" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Producción Completa — Llave en mano</span>
            <h2 class="prod-info__title">20+ Mesas Picnic con Manteles, Centros de Mesa e Instalación Completa</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$9,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Desde: precio final según cantidad de mesas y personalización. Incluye mesas, manteles, centros de mesa, instalación y desmontaje</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La diferencia entre "unas mesas bonitas" y una producción real</h2>
            <p class="prod-selling__intro">Un mantel bien elegido sobre una mesa de madera cambia todo. El centro de mesa le da escala vertical al espacio. La combinación de los tres — madera, tela y flor — crea una imagen que no se logra solo con mesas. Este paquete es para quien quiere que sus invitados lleguen y digan "wow", no "qué bonito jardín".</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Manteles de tela incluidos — sin ese look de plástico</h3>
                  <p class="prod-hl__desc">Los manteles de tela marcan la diferencia visual. Ofrecemos opciones en blanco, beige, gris y colores sólidos para combinar con tu paleta. La tela cae bien, pesa bien y fotografia increíble. Sin arrugas feas ni esa textura de mesa de jardín con hule.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Centros de mesa que dan escala y profundidad</h3>
                  <p class="prod-hl__desc">Sin centros de mesa, una mesa picnic con mantel se ve plana. Con un centro de altura media — flores, velas, plantas o elementos decorativos — el espacio gana dimensión. Coordina con tu decoradora o elige de nuestra selección estándar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">20+ mesas: escala de producción que se ve desde la entrada</h3>
                  <p class="prod-hl__desc">Cuando un invitado llega a un evento y ve 20 mesas de madera con manteles y centros de mesa alineadas en un jardín, la reacción es automática: "esto es un evento bien producido". Esa primera impresión vale más que cualquier detalle posterior.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Producción llave en mano — tú no mueves nada</h3>
                  <p class="prod-hl__desc">Llegamos horas antes con todo: mesas, manteles, centros de mesa, herramientas. Instalamos, decoramos, ajustamos. Cuando tú llegas, el evento ya está listo. Al terminar, regresamos a desmontar todo. Zero estrés de tu parte.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">20+ mesas picnic de madera</div>
              <div class="prod-feat">Manteles de tela a elegir</div>
              <div class="prod-feat">Centros de mesa decorativos</div>
              <div class="prod-feat">Capacidad para 80+ personas</div>
              <div class="prod-feat">Diseño integral de producción</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y montaje completo</div>
              <div class="prod-feat">Técnico en sitio durante el evento</div>
              <div class="prod-feat">Desmontaje y retiro al finalizar</div>
              <div class="prod-feat">Factura disponible</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Consultoría de producción gratuita</h4>
                  <p class="prod-step__desc">Conversamos sobre tu evento: fecha, venue, número de invitados, paleta de colores y estilo. Diseñamos la propuesta completa con mesas, manteles y centros de mesa según tu visión.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta visual personalizada</h4>
                  <p class="prod-step__desc">Te enviamos un render o moodboard de cómo quedará el espacio, con opciones de manteles y centros de mesa. Ajustamos hasta que quede exactamente como lo imaginas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo — fecha confirmada</h4>
                  <p class="prod-step__desc">Reserva con 50% de anticipo. Para eventos grandes emitimos factura desde el primer pago. Tu fecha queda bloqueada y asignado el equipo de producción.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Producción completa el día del evento</h4>
                  <p class="prod-step__desc">Llegamos con suficiente anticipación para instalar mesas, colocar manteles y montar centros de mesa según el diseño. Al finalizar, desmontamos todo. Tú solo disfrutas.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué el Evento Completo y no solo 12 mesas?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 12 Mesas</span>
                <ul class="prod-compare__list">
                  <li>Solo mesas y bancas</li>
                  <li>Tú consigues la decoración</li>
                  <li>Menos coordinación</li>
                  <li>Hasta 60 personas</li>
                  <li>Desde $5,000 MXN</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Evento Completo</span>
                <ul class="prod-compare__list">
                  <li>Mesas + manteles + centros de mesa</li>
                  <li>Producción completa incluida</li>
                  <li>Un solo proveedor para todo</li>
                  <li>80+ personas con escala real</li>
                  <li>Desde $9,000 MXN</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos la boda de mi hermana en una hacienda en Tlaxcala con 90 invitados. El Paquete Evento Completo fue literalmente lo que nos salvó: REDEIL se encargó de las mesas, los manteles y los centros de mesa mientras nosotros coordinábamos el resto. La producción quedó increíble. El fotógrafo nos dijo que fue de los sets más bonitos que había trabajado."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Mónica Varela</span>
                <span class="prod-quote__event">Boda en Hacienda La Trinidad — 90 invitados, Tlaxcala</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Mesas incluidas</dt><dd>20+ mesas</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>80+ personas</dd></div>
              <div class="ps-specs__row"><dt>Manteles</dt><dd>Tela incluida</dd></div>
              <div class="ps-specs__row"><dt>Centros de mesa</dt><dd>Incluidos</dd></div>
              <div class="ps-specs__row"><dt>Diseño</dt><dd>Integral personalizado</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Factura</dt><dd>Disponible</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex + foráneo</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas grandes</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Activaciones de marca</span>
              <span class="ps-tag">Haciendas y quintas</span>
              <span class="ps-tag">Producciones llave en mano</span>
              <span class="ps-tag">80+ invitados</span>
              <span class="ps-tag">Eventos premium</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/mesas-picnic/paquete-4-mesas/" class="ps-pkg">
              <img src="/img/paquetes/mesas-picnic/paquete-4-mesas.avif" alt="4 Mesas Picnic" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Mesas</span>
                <span class="ps-pkg__price">$2,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/mesas-picnic/paquete-8-mesas/" class="ps-pkg">
              <img src="/img/paquetes/mesas-picnic/paquete-8-mesas.avif" alt="8 Mesas Picnic" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">8 Mesas</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/mesas-picnic/paquete-12-mesas/" class="ps-pkg">
              <img src="/img/paquetes/mesas-picnic/paquete-12-mesas.avif" alt="12 Mesas Picnic" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">12 Mesas</span>
                <span class="ps-pkg__price">$5,000 MXN</span>
              </div>
            </a>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Diseñamos la propuesta completa en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Iluminación Arquitectónica</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; margin-bottom: 2.5rem; }
