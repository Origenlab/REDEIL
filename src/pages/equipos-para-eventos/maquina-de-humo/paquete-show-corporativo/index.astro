---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Show Corporativo de Máquina de Humo?',
    respuesta: 'Incluye 3 máquinas de humo profesionales, controlador DMX para sincronización automática con iluminación, programación de cues para momentos clave del evento, técnico operador, recarga de líquido durante el evento, transporte, instalación y desmontaje. Todo diseñado para eventos corporativos donde el humo debe integrarse perfectamente con la producción de luz.'
  },
  {
    pregunta: '¿Qué es el controlador DMX y para qué sirve en máquina de humo?',
    respuesta: 'El controlador DMX permite que las máquinas de humo se sincronicen automáticamente con el sistema de iluminación del evento. Puedes programar que el humo dispare exactamente cuando entran las cabezas móviles, cuando cambia la escena de luz o en los momentos clave de tu presentación. El resultado es un show de luz y humo perfectamente sincronizado.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Show Corporativo?',
    respuesta: 'El paquete Show Corporativo tiene un precio desde $5,000 MXN + IVA. Incluye 3 máquinas, controlador DMX, programación, recarga, operación profesional, transporte y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿En qué zonas entregan?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar para un evento corporativo?',
    respuesta: 'Para eventos corporativos recomendamos 6 a 8 semanas de anticipación para la programación DMX y coordinación con el proveedor de iluminación. Para fechas próximas, contáctanos por WhatsApp.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Show Corporativo — Máquina de Humo | REDEIL',
    description: 'Paquete Show Corporativo: 3 máquinas de humo + controlador DMX para sincronización perfecta con iluminación en eventos corporativos en CDMX. El humo se integra al show de luces como un solo sistema.',
    image: SITE_URL + '/img/img-index/maquina-de-humo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '5000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-humo/paquete-show-corporativo/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '19',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Show Corporativo — Máquina de Humo en CDMX | REDEIL"
  description="3 máquinas de humo + controlador DMX para eventos corporativos en CDMX. Sincronización perfecta con iluminación. Humo que se activa en tus momentos clave. Desde $5,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Humo', href: '/equipos-para-eventos/maquina-de-humo/' }, { name: 'Show Corporativo', href: '/equipos-para-eventos/maquina-de-humo/paquete-show-corporativo/' }]} />

  <Hero
    badge="Show Corporativo"
    title="Show Corporativo — Máquina de Humo con DMX"
    description="3 máquinas de humo sincronizadas con controlador DMX. El humo se activa exactamente cuando lo necesitas: en la apertura del show, en los cambios de escena, en los momentos clave de tu evento corporativo."
    primaryCta={{ text: 'Cotizar $5,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-humo/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Show Corporativo lleva la máquina de humo a otro nivel: deja de ser un accesorio y se convierte en parte integral del show de luces. Con <strong>3 máquinas y controlador DMX</strong>, el humo se sincroniza automáticamente con el sistema de iluminación — cuando entran las cabezas móviles, el humo ya está en el ambiente. Cuando cambia la escena, el humo cambia con ella.</p>
      <p>Diseñado para <strong>eventos corporativos, lanzamientos de producto, galas y presentaciones</strong> donde la producción visual debe ser impecable. Nuestro técnico programa los cues de humo en coordinación con tu proveedor de iluminación para que todo funcione como un solo sistema.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Humo"
    items={[{ label: "DJ y Fiesta", href: "/equipos-para-eventos/maquina-de-humo/paquete-dj-fiesta/" }, { label: "Noche Completa", href: "/equipos-para-eventos/maquina-de-humo/paquete-noche-completa/" }, { label: "Festival", href: "/equipos-para-eventos/maquina-de-humo/paquete-festival/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/maquina-de-humo/show-corporativo.avif" alt="Show corporativo con 3 máquinas de humo sincronizadas DMX y cabezas móviles" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/maquina-de-humo.avif" alt="Máquina de humo profesional para eventos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-humo/sell/dmx-controller.avif" alt="Controlador DMX para sincronización de humo e iluminación" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-humo/sell/escenario-corporativo.avif" alt="Escenario corporativo con humo sincronizado" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-humo/sell/tres-maquinas.avif" alt="3 máquinas de humo cobertura completa escenario" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Show Corporativo — DMX sincronizado</span>
            <h2 class="prod-info__title">3 Máquinas de Humo + Controlador DMX + Programación de Show</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$5,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 3 máquinas, DMX, programación, recarga, operación profesional, transporte y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando el humo y las luces son un solo show</h2>
            <p class="prod-selling__intro">En un evento corporativo, los detalles de producción importan. El humo que se activa por accidente en el momento equivocado arruina la presentación. El humo que se activa exactamente cuando entran las luces del escenario la convierte en espectacular. La diferencia es el controlador DMX: con él, programamos cada ráfaga de humo con precisión de segundos, sincronizada con tu guión de iluminación.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Controlador DMX — sincronización automática con iluminación</h3>
                  <p class="prod-hl__desc">El controlador DMX conecta las máquinas de humo con el sistema de iluminación del evento. Se programan cues específicos: apertura del show, cambios de escena, entradas de ponentes, momentos climáticos. El humo se activa automáticamente en cada cue, sin intervención manual en el momento crítico.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">3 máquinas = cobertura total del escenario</h3>
                  <p class="prod-hl__desc">Con 3 máquinas posicionadas estratégicamente (centro y flancos del escenario o en 3 puntos del venue), el humo cubre uniformemente todo el espacio de producción. No hay zonas sin cobertura ni gradientes visibles entre una máquina y otra. La densidad es homogénea.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Programación personalizada según tu guión</h3>
                  <p class="prod-hl__desc">Antes del evento, nuestro técnico se reúne (presencial o por videollamada) con tu coordinador de producción para revisar el guión y programar los cues de humo. Cada momento queda definido: intensidad, duración, sincronía con luces. No hay improvisación el día del evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Compatible con cualquier mesa de luces profesional</h3>
                  <p class="prod-hl__desc">El protocolo DMX es universal. Nuestras máquinas se integran con mesas grandMA, Avolites, ChamSys y cualquier controlador que maneje tu empresa de iluminación. No necesitas cambiar ni adaptar tu sistema existente.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">3 máquinas de humo profesionales</div>
              <div class="prod-feat">Controlador DMX incluido</div>
              <div class="prod-feat">Programación de cues de show</div>
              <div class="prod-feat">Reunión previa de producción</div>
              <div class="prod-feat">Recarga de líquido durante evento</div>
              <div class="prod-feat">Técnico operador dedicado</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y cableado certificado</div>
              <div class="prod-feat">Prueba de show (soundcheck)</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Envíanos el guión de producción</h4>
                  <p class="prod-step__desc">Compartenos el guión del evento, el mapa del venue y los datos de contacto de tu proveedor de iluminación. Con eso definimos la posición de las 3 máquinas y los cues de humo.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de coordinación de producción</h4>
                  <p class="prod-step__desc">Nuestro técnico DMX se reúne con tu coordinador para revisar el show y programar cada cue. Te entregamos un documento de cues aprobado por ambas partes. Sin sorpresas el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Soundcheck y prueba de show</h4>
                  <p class="prod-step__desc">El día del evento llegamos con anticipación para instalar, conectar al sistema DMX y hacer una prueba completa del show antes de que lleguen los asistentes. Ajustes en tiempo real si hay cambios de último minuto.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Show impecable, desmontaje limpio</h4>
                  <p class="prod-step__desc">El técnico opera el sistema durante todo el evento según los cues programados. Al finalizar, desmontamos sin dejar rastro. Servicio completo de inicio a fin.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Noche Completa vs Show Corporativo — la diferencia es el DMX</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Noche Completa</span>
                <ul class="prod-compare__list">
                  <li>2 máquinas</li>
                  <li>Control remoto manual</li>
                  <li>Técnico sincroniza a ojo</li>
                  <li>Ideal para bodas y fiestas</li>
                  <li>Sin programación previa</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Show Corporativo</span>
                <ul class="prod-compare__list">
                  <li>3 máquinas</li>
                  <li>Controlador DMX incluido</li>
                  <li>Sincronización automática</li>
                  <li>Ideal para producción corporativa</li>
                  <li>Cues programados con precisión</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Teníamos un lanzamiento de producto con producción de luces y necesitábamos que el humo se sincronizara exactamente. El técnico de REDEIL se reunió con nuestro equipo de producción una semana antes, programaron todo en DMX y el día del lanzamiento fue perfecto — las ráfagas de humo aparecían exactamente cuando el video decía que debían aparecer. Nuestro director de marketing quedó impresionado."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Paola M.</span>
                <span class="prod-quote__event">Lanzamiento de producto — Centro de Convenciones Bancomer</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas</dt><dd>3 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo de humo</dt><dd>Escénico — sube</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>DMX + remoto</dd></div>
              <div class="ps-specs__row"><dt>Protocolo</dt><dd>DMX-512 universal</dd></div>
              <div class="ps-specs__row"><dt>Líquido</dt><dd>Recarga incluida</dd></div>
              <div class="ps-specs__row"><dt>Programación</dt><dd>Cues personalizados</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico dedicado</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Galas empresariales</span>
              <span class="ps-tag">Premiaciones</span>
              <span class="ps-tag">Shows con escenario</span>
              <span class="ps-tag">Convenciones</span>
              <span class="ps-tag">Presentaciones con producción</span>
              <span class="ps-tag">Conciertos privados</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-humo/paquete-dj-fiesta/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-humo/dj-fiesta.avif" alt="DJ y Fiesta 1 máquina" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">DJ y Fiesta</span>
                <span class="ps-pkg__price">$1,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-humo/paquete-noche-completa/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-humo/noche-completa.avif" alt="Noche Completa 2 máquinas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Noche Completa</span>
                <span class="ps-pkg__price">$2,800 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-humo/paquete-festival/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-humo/festival.avif" alt="Festival 6+ máquinas con operador" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Festival</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Festivales o conciertos grandes? El paquete Festival incluye 6+ máquinas con operador especializado.</p>
              <a href="/equipos-para-eventos/maquina-de-humo/paquete-festival/" class="ps-upsell__link">Ver paquete Festival →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/laser/" class="ps-link">Láser</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
              <a href="/equipos-para-eventos/dj/" class="ps-link">DJ</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
