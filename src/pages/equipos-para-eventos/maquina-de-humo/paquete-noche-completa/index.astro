---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Noche Completa de Máquina de Humo?',
    respuesta: 'Incluye 2 máquinas de humo profesionales, recarga de líquido ilimitada durante todo el evento, control DMX o remoto, posicionamiento estratégico en dos puntos del venue, técnico operador durante toda la noche, transporte, instalación y desmontaje. Diseñado para cubrir toda la noche sin quedarte sin humo.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Noche Completa?',
    respuesta: 'El paquete Noche Completa tiene un precio desde $2,800 MXN + IVA. Incluye 2 máquinas, recarga ilimitada, operación profesional, transporte y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Por qué necesito 2 máquinas para una noche completa?',
    respuesta: 'Con una sola máquina, si el espacio tiene ventilación o es muy amplio, el humo se disipa rápido. Con 2 máquinas en posiciones estratégicas aseguramos densidad constante de humo en todo el venue durante las 5-8 horas del evento. La recarga ilimitada garantiza que no te quedes sin líquido en ningún momento.'
  },
  {
    pregunta: '¿En qué zonas entregan?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Noche Completa — Máquina de Humo | REDEIL',
    description: 'Paquete Noche Completa: 2 máquinas de humo con recarga ilimitada para eventos de 5-8 horas en CDMX. Cobertura total del venue durante toda la noche. Operación profesional incluida.',
    image: SITE_URL + '/img/img-index/maquina-de-humo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2800',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-humo/paquete-noche-completa/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Noche Completa — Máquina de Humo en CDMX | REDEIL"
  description="2 máquinas de humo + recarga ilimitada para toda la noche. Cobertura completa de tu venue durante 5-8 horas. Técnico operador incluido. CDMX y Edomex desde $2,800 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Humo', href: '/equipos-para-eventos/maquina-de-humo/' }, { name: 'Noche Completa', href: '/equipos-para-eventos/maquina-de-humo/paquete-noche-completa/' }]} />

  <Hero
    badge="Noche Completa"
    title="Noche Completa — Máquina de Humo"
    description="2 máquinas de humo estratégicamente posicionadas con recarga ilimitada. Cobertura total de tu venue durante toda la noche — de la primera canción al último brindis."
    primaryCta={{ text: 'Cotizar $2,800 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-humo/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Noche Completa está diseñado para <strong>bodas, quinceañeros y fiestas de larga duración</strong> en CDMX. Con 2 máquinas de humo posicionadas en puntos estratégicos del venue y recarga de líquido ilimitada, garantizamos densidad de humo constante durante las 5-8 horas que dura tu evento.</p>
      <p>Una sola máquina puede quedarse corta en venues con ventilación activa o espacios amplios. Con 2 máquinas cubrimos el venue completo desde dos ángulos: el humo escénico que sube llena el ambiente y hace que cada haz de cabeza móvil, láser o luz del DJ sea visible durante toda la noche, no solo en los primeros minutos.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Humo"
    items={[{ label: "DJ y Fiesta", href: "/equipos-para-eventos/maquina-de-humo/paquete-dj-fiesta/" }, { label: "Show Corporativo", href: "/equipos-para-eventos/maquina-de-humo/paquete-show-corporativo/" }, { label: "Festival", href: "/equipos-para-eventos/maquina-de-humo/paquete-festival/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/maquina-de-humo/noche-completa.avif" alt="2 máquinas de humo cubriendo boda completa toda la noche" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/maquina-de-humo.avif" alt="Máquina de humo escénica profesional" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-humo/sell/cobertura-venue.avif" alt="Cobertura completa de venue con 2 máquinas de humo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-humo/sell/recarga-liquido.avif" alt="Recarga de líquido para humo durante el evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-humo/sell/noche-boda.avif" alt="Pista de baile con humo en boda toda la noche" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Noche Completa — Cobertura total de evento</span>
            <h2 class="prod-info__title">2 Máquinas de Humo + Recarga Ilimitada + Técnico toda la noche</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,800</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 2 máquinas, recarga ilimitada, transporte, instalación, operación toda la noche y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Humo constante de la primera canción al último brindis</h2>
            <p class="prod-selling__intro">El problema del paquete de una sola máquina en eventos largos es simple: el líquido se acaba, el humo se disipa y el efecto visual desaparece a mitad de la noche — justo cuando la fiesta está en su mejor momento. El paquete Noche Completa resuelve esto con 2 máquinas y recarga ilimitada: siempre hay humo, siempre hay efecto visual, sin cortes ni pausas.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Recarga ilimitada — nunca se acaba el humo</h3>
                  <p class="prod-hl__desc">El técnico gestiona la recarga de líquido durante el evento. Sin importar cuántas horas dure la fiesta ni qué tan activas estén las máquinas, siempre habrá humo disponible. No hay costo adicional por recarga — está todo incluido en el paquete.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 máquinas = cobertura total del venue</h3>
                  <p class="prod-hl__desc">Posicionamos las 2 máquinas en los extremos del venue o en los puntos de mayor densidad de iluminación. El resultado: humo uniforme en todo el espacio, sin zonas frías donde el efecto visual se pierda. Ideal para salones de más de 200 m² o con ventilación activa.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sincronizado con toda la iluminación del evento</h3>
                  <p class="prod-hl__desc">El técnico coordina las ráfagas de humo con el DJ, con las cabezas móviles y con los momentos clave del evento (entrada de novios, primer baile, salida). El humo aparece antes de los momentos importantes para que el efecto visual esté listo cuando lo necesitas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico dedicado durante toda la noche</h3>
                  <p class="prod-hl__desc">No es solo "instalar y dejar". El técnico permanece en el venue desde la instalación hasta el desmontaje, monitorea ambas máquinas, gestiona las recargas y ajusta la intensidad según el momento. Tú no tienes que preocuparte por nada técnico.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 máquinas de humo profesionales</div>
              <div class="prod-feat">Recarga de líquido ilimitada</div>
              <div class="prod-feat">Control remoto inalámbrico</div>
              <div class="prod-feat">Técnico operador toda la noche</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y configuración dual</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Posicionamiento estratégico</div>
              <div class="prod-feat">Cable eléctrico certificado</div>
              <div class="prod-feat">Soporte técnico en sitio toda la noche</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte el plano o fotos del venue</h4>
                  <p class="prod-step__desc">Con el plano del salón o fotos del espacio, definimos la posición óptima para cada máquina según la iluminación contratada, la ventilación y los momentos clave del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y plan de operación en 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final, mapa de posicionamiento de máquinas y calendario de momentos clave donde el humo tendrá mayor impacto visual.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha</h4>
                  <p class="prod-step__desc">Reserva con 50% de anticipo. Fecha bloqueada y confirmada al instante. El restante se liquida el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Operación profesional toda la noche</h4>
                  <p class="prod-step__desc">Llegamos 2-3 horas antes para instalación y pruebas. El técnico opera ambas máquinas de forma coordinada durante todo el evento y desmonta al finalizar.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">DJ y Fiesta vs Noche Completa — ¿cuál necesitas?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">DJ y Fiesta — 1 máquina</span>
                <ul class="prod-compare__list">
                  <li>Cobertura hasta 200 m²</li>
                  <li>Líquido para ~4 horas</li>
                  <li>1 punto de humo</li>
                  <li>Fiestas cortas (3-4h)</li>
                  <li>Salones con poca ventilación</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Noche Completa — 2 máquinas</span>
                <ul class="prod-compare__list">
                  <li>Cobertura hasta 500 m²</li>
                  <li>Recarga ilimitada toda la noche</li>
                  <li>2 puntos estratégicos de humo</li>
                  <li>Bodas y eventos 5-8h</li>
                  <li>Venues con ventilación activa</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Para nuestra boda contratamos las 2 máquinas toda la noche y fue la decisión correcta. Duramos bailando 6 horas y en ningún momento se les acabó el humo. El técnico sabía exactamente cuándo disparar: cuando entré al salón, en el primer baile, en la víbora. Las fotos del salón con humo y cabezas móviles quedaron de revista."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Daniela y Carlos</span>
                <span class="prod-quote__event">Boda en Salón Jardín Pedregal — 150 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas</dt><dd>2 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo de humo</dt><dd>Escénico — sube</dd></div>
              <div class="ps-specs__row"><dt>Líquido</dt><dd>Recarga ilimitada</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Remoto inalámbrico</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 500 m²</dd></div>
              <div class="ps-specs__row"><dt>Duración</dt><dd>Toda la noche</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Fiestas 5-8 horas</span>
              <span class="ps-tag">Salones grandes</span>
              <span class="ps-tag">Venues con ventilación</span>
              <span class="ps-tag">Shows con DJ profesional</span>
              <span class="ps-tag">Eventos con cabezas móviles</span>
              <span class="ps-tag">Celebraciones privadas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-humo/paquete-dj-fiesta/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-humo/dj-fiesta.avif" alt="DJ y Fiesta 1 máquina" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">DJ y Fiesta</span>
                <span class="ps-pkg__price">$1,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-humo/paquete-show-corporativo/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-humo/show-corporativo.avif" alt="Show Corporativo 3 máquinas DMX" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Corporativo</span>
                <span class="ps-pkg__price">$5,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-humo/paquete-festival/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-humo/festival.avif" alt="Festival 6+ máquinas con operador" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Festival</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Necesitas sincronización DMX con iluminación profesional? El Show Corporativo incluye controlador DMX y 3 máquinas.</p>
              <a href="/equipos-para-eventos/maquina-de-humo/paquete-show-corporativo/" class="ps-upsell__link">Ver Show Corporativo →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/laser/" class="ps-link">Láser</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
              <a href="/equipos-para-eventos/dj/" class="ps-link">DJ</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
