---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 1 Podium de Renta de Podium?',
    respuesta: 'Incluye 1 podium acrílico o de madera barnizada, luz de lectura LED integrada, micrófono de cuello inalámbrico, transporte, instalación profesional, técnico durante el evento y desmontaje. Sin costos ocultos.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 1 Podium?',
    respuesta: 'El paquete 1 Podium tiene un precio desde $2,000 MXN + IVA. Incluye transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Puedo personalizarlo con el logo de mi empresa?',
    respuesta: 'Sí, con costo adicional podemos colocar vinil con tu logotipo en el frente del podium. Escríbenos por WhatsApp al 55 4937 5172 con el archivo para cotizarlo.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 1 Podium?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 2 a 4 semanas de anticipación. Para eventos urgentes, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '1 Podium — Renta de Podium | REDEIL',
    description: 'Paquete básico de renta de podium para conferencias, presentaciones corporativas y eventos en CDMX. 1 podium acrílico o madera con luz LED y micrófono incluido.',
    image: SITE_URL + '/img/img-index/renta-de-podium.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/renta-de-podium/paquete-1-podium/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="1 Podium — Renta de Podium en CDMX | REDEIL"
  description="Renta de podium individual para conferencias y presentaciones en CDMX. Podium acrílico o madera, luz LED, micrófono inalámbrico y técnico incluido. Desde $2,000 MXN + IVA."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Equipos para Eventos', href: '/equipos-para-eventos/' },
    { name: 'Renta de Podium', href: '/equipos-para-eventos/renta-de-podium/' },
    { name: '1 Podium', href: '/equipos-para-eventos/renta-de-podium/paquete-1-podium/' }
  ]} />

  <Hero
    badge="Paquete Básico — 1 Podium"
    title="1 Podium — Renta de Podium para Conferencias"
    description="El punto de partida para presentaciones profesionales. Podium acrílico o madera barnizada con luz de lectura LED y micrófono inalámbrico. Instalación y técnico incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $2,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/renta-de-podium/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete 1 Podium</strong> es la solución ideal para conferencias de un solo ponente, presentaciones corporativas y eventos donde el orador necesita un punto focal profesional. El podium le da autoridad y presencia al expositor, organiza sus materiales y proyecta una imagen impecable frente al público.</p>
      <p>Disponemos de podiums acrílicos de diseño moderno y podiums de madera barnizada para ambientes más clásicos. Ambos incluyen luz de lectura LED integrada y soporte para micrófono. Nuestro técnico llega con anticipación, instala todo en el lugar indicado y permanece durante el evento para cualquier ajuste.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Renta de Podium"
    items={[
      { label: "2 Podiums", href: "/equipos-para-eventos/renta-de-podium/paquete-2-podiums/" },
      { label: "Congreso", href: "/equipos-para-eventos/renta-de-podium/paquete-congreso/" },
      { label: "Escenario Completo", href: "/equipos-para-eventos/renta-de-podium/paquete-escenario-completo/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/renta-de-podium/1-podium.avif" alt="Paquete 1 podium acrílico para conferencia en CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/renta-de-podium.avif" alt="Podium profesional para eventos corporativos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/renta-de-podium/sell/podium-acrilico.avif" alt="Detalle podium acrílico transparente con luz LED" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/renta-de-podium/sell/podium-madera.avif" alt="Podium de madera barnizada para conferencia clásica" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/renta-de-podium/sell/instalacion-podium.avif" alt="Técnico REDEIL instalando podium en sala de eventos" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Básico — Conferencias y Presentaciones</span>
            <h2 class="prod-info__title">1 Podium Acrílico o Madera con Luz LED y Micrófono Inalámbrico</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, técnico durante el evento y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El podium que le da autoridad al ponente frente a cualquier audiencia</h2>
            <p class="prod-selling__intro">Un podium bien colocado cambia por completo la percepción del expositor. No se trata solo de un mueble — es el punto focal del escenario, el organizador de materiales del orador y la señal visual que le indica al público quién tiene la palabra. Con REDEIL, esa pieza llega instalada, probada y lista antes de que llegue el primer invitado.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Dos estilos según la imagen de tu evento</h3>
                  <p class="prod-hl__desc">Podium acrílico transparente para una estética moderna y minimalista, o podium de madera barnizada para ambientes formales y corporativos clásicos. Cuéntanos el tipo de evento y te recomendamos el más adecuado.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Luz de lectura LED integrada — el ponente siempre ve sus notas</h3>
                  <p class="prod-hl__desc">La luz LED direccionable ilumina los apuntes del orador sin generar resplandor hacia el público ni interferir con la fotografía. Funciona con una sola mano y no necesita configuración especial.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Micrófono de cuello inalámbrico — manos libres para el expositor</h3>
                  <p class="prod-hl__desc">El micrófono lavalier inalámbrico va discretamente en la solapa o corbata. El ponente puede gesticular, mover papeles y señalar pantallas con total libertad. Sin cables que interrumpan el look del escenario.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico presente durante todo el evento</h3>
                  <p class="prod-hl__desc">No instalamos y nos vamos. Un técnico permanece disponible para ajustar la posición del podium entre ponentes, verificar el nivel del micrófono y resolver cualquier imprevisto. Tú organizas el evento, nosotros cuidamos la operación.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 podium acrílico o madera barnizada</div>
              <div class="prod-feat">Luz de lectura LED integrada</div>
              <div class="prod-feat">Micrófono de cuello inalámbrico</div>
              <div class="prod-feat">Soporte para materiales del ponente</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables y adaptadores incluidos</div>
              <div class="prod-feat">Ajuste de posición entre ponentes</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, número de ponentes y tipo de evento. Con esos datos elegimos el estilo de podium más adecuado y planificamos la ubicación ideal en el escenario.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Propuesta con precio final, especificaciones del equipo y opciones de personalización (viniles con logo, entre otros). Sin compromiso.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo del 50%</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada al momento. Aceptamos transferencia, efectivo o tarjeta. El resto se liquida el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y operamos</h4>
                  <p class="prod-step__desc">Nuestro técnico llega 2 horas antes, instala el podium en la posición acordada, prueba el micrófono y la luz, y permanece durante todo el evento. Al terminar, desmontamos sin que tengas que preocuparte por nada.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Este paquete o el de 2 Podiums?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">1 Podium — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>1 ponente o presentador</li>
                  <li>Conferencias y presentaciones</li>
                  <li>1 micrófono de cuello</li>
                  <li>Eventos de un solo orador</li>
                  <li>Máxima simplicidad y enfoque</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">2 Podiums — Siguiente nivel</span>
                <ul class="prod-compare__list">
                  <li>2 ponentes simultáneos</li>
                  <li>Paneles de discusión y debates</li>
                  <li>2 micrófonos inalámbricos</li>
                  <li>Moderador + invitado</li>
                  <li>Ahorro vs. contratar por separado</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Rentamos el podium para una conferencia de dirección en nuestra empresa. El equipo llegó a tiempo, instaló todo con discreción y el técnico estuvo disponible durante toda la presentación. Nuestro director quedó muy cómodo con el micrófono y la luz de lectura. Lo volvemos a contratar sin dudarlo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Lic. Alejandra Montoya</span>
                <span class="prod-quote__event">Directora de RH — Evento corporativo en CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Podiums incluidos</dt><dd>1</dd></div>
              <div class="ps-specs__row"><dt>Material</dt><dd>Acrílico o madera</dd></div>
              <div class="ps-specs__row"><dt>Luz de lectura</dt><dd>LED integrada</dd></div>
              <div class="ps-specs__row"><dt>Micrófono</dt><dd>Cuello inalámbrico</dd></div>
              <div class="ps-specs__row"><dt>Personalización</dt><dd>Logo (costo adicional)</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Presente todo el evento</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Conferencias</span>
              <span class="ps-tag">Presentaciones corporativas</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Premiaciones</span>
              <span class="ps-tag">Ceremonias académicas</span>
              <span class="ps-tag">Eventos de un solo orador</span>
              <span class="ps-tag">Seminarios</span>
              <span class="ps-tag">Eventos religiosos</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/renta-de-podium/paquete-2-podiums/" class="ps-pkg">
              <img src="/img/paquetes/renta-de-podium/2-podiums.avif" alt="2 Podiums" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Podiums</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/renta-de-podium/paquete-congreso/" class="ps-pkg">
              <img src="/img/paquetes/renta-de-podium/congreso.avif" alt="Congreso" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Congreso</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/renta-de-podium/paquete-escenario-completo/" class="ps-pkg">
              <img src="/img/paquetes/renta-de-podium/escenario-completo.avif" alt="Escenario Completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Escenario Completo</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Mesa de debate o panel de discusión? El paquete 2 Podiums incluye un segundo podium y micrófono para eventos con moderador e invitado.</p>
              <a href="/equipos-para-eventos/renta-de-podium/paquete-2-podiums/" class="ps-upsell__link">Ver paquete 2 Podiums →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/audio-conferencias/" class="ps-link">Audio Conferencias</a>
              <a href="/renta-de-iluminacion/gobos/" class="ps-link">Gobos</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }

  /* ── Includes ── */
