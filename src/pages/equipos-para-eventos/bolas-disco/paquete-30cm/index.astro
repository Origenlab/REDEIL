---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de Bola Disco de 30 cm?',
    respuesta: 'Incluye 1 bola disco de 30 cm con espejo facetado, motor giratorio, 2 spotlights LED de colores, instalación profesional, operación durante el evento y desmontaje al finalizar. Ideal para crear el efecto retro en espacios íntimos.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de Bola Disco de 30 cm?',
    respuesta: 'El paquete tiene un precio desde $1,500 MXN + IVA. Incluye transporte dentro de CDMX y Estado de México, instalación, operación y desmontaje. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para qué tipo de evento es la bola disco de 30 cm?',
    respuesta: 'Es perfecta para fiestas pequeñas, reuniones en casa, fiestas retro, cumpleaños íntimos y eventos con hasta 50 invitados. Su tamaño compacto funciona en salones, terrazas y jardines medianos.'
  },
  {
    pregunta: '¿En qué zonas entregan este paquete?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 2 a 4 semanas de anticipación. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Bola Disco 30 cm — Renta de Bolas Disco | REDEIL',
    description: 'Paquete de bola disco de 30 cm con motor giratorio e iluminación LED para fiestas pequeñas y retro en CDMX. Instalación profesional incluida.',
    image: SITE_URL + '/img/img-index/bolas-disco.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '1500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/bolas-disco/paquete-30cm/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Bola Disco 30 cm — Renta de Bola Disco en CDMX | REDEIL"
  description="Renta bola disco de 30 cm con motor giratorio e iluminación LED para fiestas retro y reuniones íntimas en CDMX. Instalación y operación incluidas desde $1,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Equipos para Eventos', href: '/equipos-para-eventos/' },
    { name: 'Bolas Disco', href: '/equipos-para-eventos/bolas-disco/' },
    { name: 'Paquete 30 cm', href: '/equipos-para-eventos/bolas-disco/paquete-30cm/' }
  ]} />

  <Hero
    badge="Bola Disco — 30 cm"
    title="Bola Disco 30 cm — Paquete Básico para Fiestas Retro"
    description="La bola disco perfecta para fiestas pequeñas y reuniones íntimas. 30 cm de espejo facetado con motor giratorio e iluminación LED incluida. Instalación profesional en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $1,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/bolas-disco/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>bola disco de 30 cm</strong> es el tamaño ideal para crear ese efecto retro inconfundible en espacios íntimos. Sus facetas de espejo dispersan los haces de luz por toda la habitación, transformando cualquier sala, terraza o jardín pequeño en una pista de baile de los 70s. Perfecta para fiestas de cumpleaños, reuniones en casa y eventos temáticos en <strong>CDMX y Estado de México</strong>.</p>
      <p>El paquete incluye motor giratorio de velocidad constante y 2 spotlights LED de colores que proyectan puntos de luz danzantes sobre la bola. Nuestro técnico instala todo, opera durante el evento y desmonta al terminar. Tú solo disfrutas.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bolas Disco"
    items={[
      { label: "Bola 60 cm", href: "/equipos-para-eventos/bolas-disco/paquete-60cm/" },
      { label: "Bola 90 cm", href: "/equipos-para-eventos/bolas-disco/paquete-90cm/" },
      { label: "Bola 120 cm", href: "/equipos-para-eventos/bolas-disco/paquete-120cm/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco de 30 cm con efecto de luz en fiesta retro" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco girando con spotlights LED de colores" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bolas-disco.avif" alt="Efecto de puntos de luz sobre pista de baile" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Básico — Fiestas Retro</span>
            <h2 class="prod-info__title">Bola Disco de 30 cm con Motor y Spotlights LED</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$1,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Incluye motor, 2 spotlights LED, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">La bola disco que convierte cualquier sala en pista de baile</h2>
            <p class="prod-selling__intro">30 cm de espejo facetado proyectando cientos de puntos de luz por toda la habitación. No importa si es un departamento, una terraza o un jardín pequeño — la bola disco de 30 cm crea un ambiente de fiesta retro auténtico sin ocupar espacio. Es el efecto más reconocible en el mundo del entretenimiento, y en REDEIL lo llevamos con equipo profesional, no con artículos de plástico de baja calidad.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Motor giratorio de velocidad constante — sin interrupciones</h3>
                  <p class="prod-hl__desc">El motor gira a velocidad uniforme durante todo el evento, sin parpadeos ni paradas. El efecto de luz danzante es continuo y fluido, exactamente como en las discotecas profesionales. Sin ruido, sin vibraciones.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 spotlights LED de colores incluidos</h3>
                  <p class="prod-hl__desc">Los spotlights proyectan haces de colores sobre la bola que se dispersan como puntos de luz por techo, paredes y piso. Rojo, verde, azul — el ambiente cambia con la música. No se venden por separado: el paquete completo siempre incluye la iluminación.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Tamaño perfecto para espacios íntimos</h3>
                  <p class="prod-hl__desc">La bola de 30 cm funciona en salones de hasta 80 metros cuadrados con buena cobertura de luz. Ideal para fiestas de 20 a 50 personas. Si tu espacio es más grande, el paquete de 60 cm cubre el doble de área con mayor intensidad visual.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Servicio completo — llegamos, instalamos y desmontamos</h3>
                  <p class="prod-hl__desc">Nuestro técnico llega 1 hora antes del evento, instala la bola en el punto óptimo del techo, calibra los spotlights y hace pruebas de encendido. Al terminar, desmonta todo. Sin que tú tengas que mover un dedo ni preocuparte por el equipo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 bola disco de 30 cm facetada</div>
              <div class="prod-feat">Motor giratorio profesional</div>
              <div class="prod-feat">2 spotlights LED de colores</div>
              <div class="prod-feat">Cables y conexiones</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador en evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar y tipo de evento. Con esos datos confirmamos disponibilidad y te damos precio final sin sorpresas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24 horas</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final, equipo incluido y opciones de personalización. Sin compromiso.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con el 50% de anticipo. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Nosotros nos encargamos de todo</h4>
                  <p class="prod-step__desc">Llegamos 1 hora antes, instalamos, operamos durante el evento y desmontamos al terminar. Tú disfruta.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿30 cm o 60 cm? Elige según tu espacio</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Este paquete — 30 cm</span>
                <ul class="prod-compare__list">
                  <li>Espacios hasta 80 m²</li>
                  <li>20 a 50 invitados</li>
                  <li>2 spotlights LED</li>
                  <li>Fiestas en casa o terraza</li>
                  <li>Precio desde $1,500 MXN</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Paquete 60 cm — Mayor impacto</span>
                <ul class="prod-compare__list">
                  <li>Espacios hasta 200 m²</li>
                  <li>50 a 120 invitados</li>
                  <li>Motor reforzado + 2 reflectores LED</li>
                  <li>Bodas y fiestas en salón</li>
                  <li>Precio desde $2,500 MXN</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"La rentamos para el cumpleaños de mi mamá, una fiesta de unos 35 personas en casa. El técnico llegó puntual, instaló la bola en el centro de la sala y cuando apagamos las luces y encendieron los spotlights, todos aplaudieron. El efecto fue exactamente lo que queríamos. Muy recomendados."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sofía Ramírez</span>
                <span class="prod-quote__event">Cumpleaños en casa — Coyoacán, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Diámetro</dt><dd>30 cm</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Espejo facetado</dd></div>
              <div class="ps-specs__row"><dt>Motor</dt><dd>Giratorio incluido</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>2 spotlights LED</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 80 m²</dd></div>
              <div class="ps-specs__row"><dt>Invitados</dt><dd>20 a 50 personas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas en casa</span>
              <span class="ps-tag">Temática retro / disco</span>
              <span class="ps-tag">Cumpleaños íntimos</span>
              <span class="ps-tag">Reuniones privadas</span>
              <span class="ps-tag">Fiestas de 15 años</span>
              <span class="ps-tag">Eventos pequeños</span>
              <span class="ps-tag">Terrazas y jardines chicos</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/bolas-disco/paquete-60cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 60 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 60 cm</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-90cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 90 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 90 cm</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-120cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 120 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 120 cm</span>
                <span class="ps-pkg__price">$6,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Salón grande o boda? La bola de 60 cm duplica el impacto visual con motor reforzado y 2 reflectores LED.</p>
              <a href="/equipos-para-eventos/bolas-disco/paquete-60cm/" class="ps-upsell__link">Ver paquete 60 cm →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/equipos-para-eventos/dj/" class="ps-link">DJ para Eventos</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/iluminacion-laser/" class="ps-link">Láser</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }

  /* ── Includes ── */
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; margin-bottom: 2.5rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
  .prod-includes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-feat { font-size: 0.875rem; color: var(--color-text-light); padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .prod-feat::before { content: ""; position: absolute; left: 0; top: 0.45rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); }
  @media (max-width: 640px) { .prod-includes__grid { grid-template-columns: 1fr; } }

  /* ── Process Steps ── */
