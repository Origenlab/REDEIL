---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de Bola Disco de 90 cm?',
    respuesta: 'Incluye 1 bola disco de 90 cm con espejo facetado, motor giratorio reforzado, 4 reflectores LED profesionales, instalación profesional, operación durante el evento y desmontaje. Diseñado para salones grandes de 120 a 300 invitados.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de Bola Disco de 90 cm?',
    respuesta: 'El paquete tiene un precio desde $4,000 MXN + IVA. Incluye transporte dentro de CDMX y Estado de México, instalación, operación y desmontaje. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para qué eventos es ideal la bola disco de 90 cm?',
    respuesta: 'Es ideal para bodas grandes, eventos corporativos de gala, XV años en salones amplios y fiestas con 120 a 300 invitados. Sus 90 cm de diámetro y 4 reflectores generan un espectáculo visual de gran formato.'
  },
  {
    pregunta: '¿En qué zonas entregan este paquete?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación para este paquete, especialmente en temporada alta. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Bola Disco 90 cm — Renta de Bolas Disco | REDEIL',
    description: 'Paquete de bola disco de 90 cm con motor reforzado y 4 reflectores LED para salones grandes en CDMX. Instalación profesional incluida desde $4,000 MXN.',
    image: SITE_URL + '/img/img-index/bolas-disco.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/bolas-disco/paquete-90cm/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '22',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Bola Disco 90 cm — Renta para Salones Grandes en CDMX | REDEIL"
  description="Renta bola disco de 90 cm con motor reforzado y 4 reflectores LED para salones grandes en CDMX. Cobertura total para 120 a 300 invitados desde $4,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Equipos para Eventos', href: '/equipos-para-eventos/' },
    { name: 'Bolas Disco', href: '/equipos-para-eventos/bolas-disco/' },
    { name: 'Paquete 90 cm', href: '/equipos-para-eventos/bolas-disco/paquete-90cm/' }
  ]} />

  <Hero
    badge="Bola Disco — 90 cm"
    title="Bola Disco 90 cm — Gran Formato para Salones de Eventos"
    description="La bola disco de gran formato para bodas y eventos en salones amplios. 90 cm de espejo facetado con motor reforzado y 4 reflectores LED de alta potencia. Cobertura total para 120 a 300 invitados en CDMX."
    primaryCta={{ text: 'Cotizar $4,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/bolas-disco/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>bola disco de 90 cm</strong> es para cuando el evento lo exige en grande. Sus 90 cm de diámetro y la combinación de <strong>4 reflectores LED de alta potencia</strong> generan un espectáculo visual que cubre todo el salón: pista de baile, mesas y hasta el fondo del espacio. Es el paquete de referencia para <strong>bodas grandes, galas corporativas y salones de más de 300 metros cuadrados</strong> en CDMX.</p>
      <p>El motor reforzado de este paquete está diseñado para soportar el peso y el volumen de una bola de 90 cm girando continuamente durante horas. La velocidad de rotación es ajustable para adaptarse al ambiente del evento: más rápida para la fiesta, más lenta para momentos especiales.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bolas Disco"
    items={[
      { label: "Bola 30 cm", href: "/equipos-para-eventos/bolas-disco/paquete-30cm/" },
      { label: "Bola 60 cm", href: "/equipos-para-eventos/bolas-disco/paquete-60cm/" },
      { label: "Bola 120 cm", href: "/equipos-para-eventos/bolas-disco/paquete-120cm/" }
    ]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco de 90 cm en salón de eventos con 4 reflectores LED" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bolas-disco.avif" alt="Efecto de luz de bola disco 90 cm cubriendo salón completo" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bolas-disco.avif" alt="4 reflectores LED apuntando a bola disco de 90 cm" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Gran Formato — Salones Grandes</span>
            <h2 class="prod-info__title">Bola Disco de 90 cm con Motor Reforzado y 4 Reflectores LED</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Incluye motor reforzado, 4 reflectores LED, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">90 cm de espejo, 4 reflectores, un salón completo de luz</h2>
            <p class="prod-selling__intro">Hay eventos que necesitan algo más que una bola disco estándar. Cuando el salón tiene capacidad para 150, 200 o 300 personas, necesitas un equipo que esté a la altura. La bola de 90 cm con 4 reflectores LED de alta potencia genera un campo de luz que cubre completamente la pista de baile, llega a las mesas y sube hasta el techo. Es el tipo de efecto que hace que los invitados saquen el teléfono para filmar.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 reflectores LED — cobertura de 360 grados</h3>
                  <p class="prod-hl__desc">Con 4 reflectores posicionados estratégicamente alrededor de la bola, el efecto de luz cubre los 360 grados del salón. No hay punto muerto ni zona oscura en la pista. Cada metro cuadrado del espacio recibe luz danzante.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Motor reforzado — estabilidad total a 90 cm</h3>
                  <p class="prod-hl__desc">El motor de este paquete está diseñado específicamente para bolas de gran formato. Con mecanismo antivibraciones y velocidad ajustable, la bola gira suave y constante durante toda la noche sin riesgo de desbalanceo ni ruidos mecánicos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El impacto visual que diferencia tu evento</h3>
                  <p class="prod-hl__desc">Una bola disco de 90 cm es un elemento focal que define el ambiente de todo el salón. No pasa desapercibida. Domina el espacio y crea ese efecto de discoteca elegante que combina perfectamente con bodas de lujo, galas y eventos de producción.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Instalación especializada para techos altos</h3>
                  <p class="prod-hl__desc">Los salones grandes suelen tener techos de 6 a 10 metros. Nuestro equipo técnico cuenta con el equipo de montaje para instalar la bola a la altura correcta, garantizando que el efecto de luz llegue al piso con la densidad y el ángulo óptimos.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 bola disco de 90 cm facetada</div>
              <div class="prod-feat">Motor giratorio reforzado</div>
              <div class="prod-feat">4 reflectores LED de alta potencia</div>
              <div class="prod-feat">Estructura de montaje para techo alto</div>
              <div class="prod-feat">Cables y conexiones profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación especializada</div>
              <div class="prod-feat">Técnico operador en evento</div>
              <div class="prod-feat">Ajuste de velocidad durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento y espacio</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento, número de invitados y altura del techo. Para bolas grandes necesitamos conocer el espacio con anticipación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y diseño de instalación</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final y el diseño de instalación para tu espacio específico. Calculamos los ángulos de los reflectores para cobertura óptima.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con el 50% de anticipo. Los equipos de gran formato tienen disponibilidad limitada — reservar con tiempo garantiza tu fecha.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 2 horas antes para instalación completa</h4>
                  <p class="prod-step__desc">El montaje de una bola de 90 cm requiere más tiempo. Llegamos 2 horas antes, instalamos, calibramos los 4 reflectores y hacemos pruebas completas antes de que lleguen los invitados.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿60 cm o 90 cm? La diferencia es el salón</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 60 cm</span>
                <ul class="prod-compare__list">
                  <li>Salones hasta 200 m²</li>
                  <li>50 a 120 invitados</li>
                  <li>2 reflectores LED</li>
                  <li>Bodas medianas</li>
                  <li>$2,500 MXN</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Este paquete — 90 cm</span>
                <ul class="prod-compare__list">
                  <li>Salones hasta 500 m²</li>
                  <li>120 a 300 invitados</li>
                  <li>4 reflectores LED + cobertura 360°</li>
                  <li>Bodas grandes y galas</li>
                  <li>$4,000 MXN</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos la bola de 90 cm para la boda de mi hija en un salón con capacidad para 200 personas. La diferencia con lo que habíamos visto antes fue brutal — los 4 reflectores cubrían absolutamente todo el salón y la bola se veía imponente desde cualquier punto. El técnico ajustó la velocidad perfecta para cada momento. Fue el elemento más comentado de la noche."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Patricia Hernández</span>
                <span class="prod-quote__event">Boda en Grand Salón Imperial — Naucalpan — 180 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Diámetro</dt><dd>90 cm</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Espejo facetado</dd></div>
              <div class="ps-specs__row"><dt>Motor</dt><dd>Reforzado, vel. ajustable</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>4 reflectores LED</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 500 m²</dd></div>
              <div class="ps-specs__row"><dt>Invitados</dt><dd>120 a 300 personas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Especializada incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas grandes</span>
              <span class="ps-tag">Galas corporativas</span>
              <span class="ps-tag">XV años en gran salón</span>
              <span class="ps-tag">Eventos de producción</span>
              <span class="ps-tag">Congresos y convenciones</span>
              <span class="ps-tag">Salones 300+ m²</span>
              <span class="ps-tag">Fiestas temáticas grandes</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/bolas-disco/paquete-30cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 30 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 30 cm</span>
                <span class="ps-pkg__price">$1,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-60cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 60 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 60 cm</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-120cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 120 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 120 cm</span>
                <span class="ps-pkg__price">$6,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Producción profesional o evento masivo? La bola gigante de 120 cm con motor reforzado y 6 reflectores es el estándar de producción.</p>
              <a href="/equipos-para-eventos/bolas-disco/paquete-120cm/" class="ps-upsell__link">Ver paquete 120 cm →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/equipos-para-eventos/dj/" class="ps-link">DJ para Eventos</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/iluminacion-laser/" class="ps-link">Láser</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; margin-bottom: 2.5rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
  .prod-includes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-feat { font-size: 0.875rem; color: var(--color-text-light); padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .prod-feat::before { content: ""; position: absolute; left: 0; top: 0.45rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); }
  @media (max-width: 640px) { .prod-includes__grid { grid-template-columns: 1fr; } }
  .prod-process { margin: 2.5rem 0; }
  .prod-process__title { font-size: 1.125rem; font-weight: 800; color: var(--color-text); letter-spacing: -0.02em; margin: 0 0 1.25rem; }
