---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de Bola Disco Gigante de 120 cm?',
    respuesta: 'Incluye 1 bola disco gigante de 120 cm con espejo facetado, motor reforzado de alta potencia, 6 reflectores LED profesionales, estructura de montaje industrial, instalación especializada, operación durante el evento y desmontaje completo.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de Bola Disco de 120 cm?',
    respuesta: 'El paquete tiene un precio desde $6,500 MXN + IVA. Este es el paquete de producción profesional, diseñado para eventos de gran escala. Incluye todo: transporte, montaje industrial, 6 reflectores, operación y desmontaje en CDMX y Edomex.'
  },
  {
    pregunta: '¿Para qué eventos es la bola disco gigante de 120 cm?',
    respuesta: 'Está diseñada para producciones profesionales: festivales, eventos masivos, galas de gran escala, bodas de producción y cualquier evento con más de 300 invitados o en espacios de más de 600 metros cuadrados. Es el estándar de la industria para eventos de alto impacto.'
  },
  {
    pregunta: '¿En qué zonas entregan este paquete?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México. Por las dimensiones del equipo, para eventos fuera de CDMX consultamos disponibilidad de logística de transporte. Contáctanos para coordinar.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Para el paquete de 120 cm recomendamos mínimo 6 semanas de anticipación. El equipo de gran formato requiere coordinación logística especial. Contáctanos cuanto antes para asegurar disponibilidad.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Bola Disco Gigante 120 cm — Producción Profesional | REDEIL',
    description: 'Bola disco gigante de 120 cm con motor reforzado y 6 reflectores LED para producciones profesionales en CDMX. El estándar de la industria para eventos de gran escala.',
    image: SITE_URL + '/img/img-index/bolas-disco.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '6500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/bolas-disco/paquete-120cm/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '14',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Bola Disco Gigante 120 cm — Producción Profesional en CDMX | REDEIL"
  description="Renta bola disco gigante de 120 cm con motor reforzado y 6 reflectores LED para eventos de producción en CDMX. El paquete de mayor impacto visual desde $6,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Equipos para Eventos', href: '/equipos-para-eventos/' },
    { name: 'Bolas Disco', href: '/equipos-para-eventos/bolas-disco/' },
    { name: 'Paquete 120 cm', href: '/equipos-para-eventos/bolas-disco/paquete-120cm/' }
  ]} />

  <Hero
    badge="Bola Disco Gigante — 120 cm"
    title="Bola Disco Gigante 120 cm — El Estándar de Producción Profesional"
    description="La bola disco de mayor impacto visual disponible. 120 cm de espejo facetado con motor reforzado de alta potencia y 6 reflectores LED profesionales. Para producciones masivas y eventos de gran escala en CDMX."
    primaryCta={{ text: 'Cotizar $6,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/bolas-disco/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>bola disco gigante de 120 cm</strong> es el elemento de producción más impactante en renta de iluminación para eventos en México. Con 120 cm de diámetro, sus facetas de espejo proyectan miles de puntos de luz que cubren completamente cualquier espacio, desde pistas de baile hasta áreas de convención de más de 1,000 metros cuadrados. El paquete incluye <strong>6 reflectores LED profesionales de alta potencia</strong> posicionados estratégicamente para cobertura total de 360 grados.</p>
      <p>Este es el paquete que contratan los productores de eventos cuando quieren que el elemento de iluminación sea el protagonista de la noche. No es solo una bola disco — es un statement. El motor reforzado de alta potencia soporta el peso de 120 cm girando continuamente con estabilidad absoluta.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bolas Disco"
    items={[
      { label: "Bola 30 cm", href: "/equipos-para-eventos/bolas-disco/paquete-30cm/" },
      { label: "Bola 60 cm", href: "/equipos-para-eventos/bolas-disco/paquete-60cm/" },
      { label: "Bola 90 cm", href: "/equipos-para-eventos/bolas-disco/paquete-90cm/" }
    ]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco gigante de 120 cm con 6 reflectores LED en evento de producción" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bolas-disco.avif" alt="Efecto de luz de bola disco 120 cm cubriendo espacio masivo" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bolas-disco.avif" alt="6 reflectores LED apuntando a bola disco gigante de 120 cm" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Producción Profesional — El más grande</span>
            <h2 class="prod-info__title">Bola Disco Gigante de 120 cm con Motor de Alta Potencia y 6 Reflectores LED</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$6,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Incluye motor de alta potencia, 6 reflectores LED, montaje industrial, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La bola disco más grande y el espectáculo de luz más impresionante</h2>
            <p class="prod-selling__intro">Cuando el evento es de producción profesional, los detalles tienen que estar a la altura. Una bola disco de 120 cm no es solo más grande — es cualitativamente diferente. El volumen de luz reflejado, la densidad de puntos de color, el efecto visual desde cualquier punto del espacio: todo es de otra categoría. Los asistentes a eventos con una bola disco de 120 cm no olvidan lo que vieron.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">6 reflectores LED — el campo de luz más denso disponible</h3>
                  <p class="prod-hl__desc">Con 6 reflectores posicionados en configuración de producción, la bola de 120 cm genera el campo de luz más denso y uniforme posible. No hay sombras ni zonas muertas en el espacio. Desde cualquier punto donde estés parado, ves el espectáculo completo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Motor de alta potencia — estabilidad para 120 cm</h3>
                  <p class="prod-hl__desc">El motor de este paquete es de categoría industrial: diseñado para soportar el peso y las dimensiones de una bola de 120 cm girando continuamente durante 8 a 12 horas. Velocidad ajustable, mecanismo antivibraciones, operación silenciosa.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura para espacios de cualquier dimensión</h3>
                  <p class="prod-hl__desc">La bola de 120 cm cubre espacios de 600 a más de 1,000 metros cuadrados. Funciona en escenarios, auditorios, salones de convenciones y espacios al aire libre. Es el equipo que los productores de eventos profesionales especifican en sus riders técnicos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Montaje industrial — sin límites de altura o estructura</h3>
                  <p class="prod-hl__desc">El equipo de instalación de REDEIL cuenta con el rigging y estructura necesarios para colgar una bola de 120 cm en cualquier tipo de techo o estructura. Coordinamos con el venue para garantizar que la instalación sea segura y cumpla con cualquier requerimiento técnico.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 bola disco gigante de 120 cm</div>
              <div class="prod-feat">Motor de alta potencia industrial</div>
              <div class="prod-feat">6 reflectores LED profesionales</div>
              <div class="prod-feat">Estructura de rigging industrial</div>
              <div class="prod-feat">Cables y conexiones de producción</div>
              <div class="prod-feat">Transporte con vehículo especializado</div>
              <div class="prod-feat">Montaje industrial especializado</div>
              <div class="prod-feat">Técnico de producción en evento</div>
              <div class="prod-feat">Control de velocidad en tiempo real</div>
              <div class="prod-feat">Desmontaje y retiro completo</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio de producción</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Briefing técnico del evento</h4>
                  <p class="prod-step__desc">Coordinamos con el venue o el productor del evento para revisar planos del espacio, altura del techo, capacidad de carga y logística de acceso. Para 120 cm, la planeación previa es esencial.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta de producción</h4>
                  <p class="prod-step__desc">Te enviamos propuesta completa con diseño de instalación, posicionamiento de los 6 reflectores, precio final y timeline de montaje. Todo documentado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo</h4>
                  <p class="prod-step__desc">Reserva con el 50% de anticipo con mínimo 6 semanas de anticipación. La bola de 120 cm tiene disponibilidad limitada — los eventos de producción se agendan con tiempo.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje el día del evento</h4>
                  <p class="prod-step__desc">Llegamos 3 horas antes con equipo de montaje especializado. Instalamos, calibramos los 6 reflectores, hacemos pruebas completas de luz y velocidad, y coordinamos con el resto del equipo de producción.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿90 cm o 120 cm? La diferencia es la escala del evento</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 90 cm</span>
                <ul class="prod-compare__list">
                  <li>Salones hasta 500 m²</li>
                  <li>120 a 300 invitados</li>
                  <li>4 reflectores LED</li>
                  <li>Bodas grandes y galas</li>
                  <li>$4,000 MXN</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Este paquete — 120 cm</span>
                <ul class="prod-compare__list">
                  <li>Espacios de 600 a 1,000+ m²</li>
                  <li>300+ invitados</li>
                  <li>6 reflectores LED + rigging industrial</li>
                  <li>Producción profesional</li>
                  <li>$6,500 MXN</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Produjimos un evento corporativo para 400 personas en el Centro Banamex. Especificamos la bola disco de 120 cm como elemento central de la pista. El impacto fue exactamente lo que buscábamos — cuando la encendieron, toda la sala volteo a verla. El equipo de REDEIL trabajó de manera muy profesional con nuestro crew de producción. Sin duda la volvemos a contratar."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Mauricio Salinas</span>
                <span class="prod-quote__event">Productor de Eventos — Gala Corporativa Grupo Financiero — 400 asistentes</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Diámetro</dt><dd>120 cm</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Espejo facetado</dd></div>
              <div class="ps-specs__row"><dt>Motor</dt><dd>Alta potencia industrial</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>6 reflectores LED</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>600 m² a 1,000+ m²</dd></div>
              <div class="ps-specs__row"><dt>Invitados</dt><dd>300+ personas</dd></div>
              <div class="ps-specs__row"><dt>Montaje</dt><dd>Industrial incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Producción profesional</span>
              <span class="ps-tag">Festivales</span>
              <span class="ps-tag">Galas masivas</span>
              <span class="ps-tag">Eventos corporativos grandes</span>
              <span class="ps-tag">Bodas de producción</span>
              <span class="ps-tag">Congresos y convenciones</span>
              <span class="ps-tag">Espacios 600+ m²</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/bolas-disco/paquete-30cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 30 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 30 cm</span>
                <span class="ps-pkg__price">$1,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-60cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 60 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 60 cm</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-90cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 90 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 90 cm</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización de producción en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/equipos-para-eventos/dj/" class="ps-link">DJ para Eventos</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/iluminacion-laser/" class="ps-link">Láser</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; margin-bottom: 2.5rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
  .prod-includes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-feat { font-size: 0.875rem; color: var(--color-text-light); padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .prod-feat::before { content: ""; position: absolute; left: 0; top: 0.45rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); }
  @media (max-width: 640px) { .prod-includes__grid { grid-template-columns: 1fr; } }
  .prod-process { margin: 2.5rem 0; }
  .prod-process__title { font-size: 1.125rem; font-weight: 800; color: var(--color-text); letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-steps { display: flex; flex-direction: column; gap: 0; }
