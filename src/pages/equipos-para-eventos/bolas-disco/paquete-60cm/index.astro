---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de Bola Disco de 60 cm?',
    respuesta: 'Incluye 1 bola disco de 60 cm con espejo facetado, motor giratorio, 2 reflectores LED profesionales, instalación profesional, operación durante el evento y desmontaje. Cubre salones medianos con un efecto visual impactante.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de Bola Disco de 60 cm?',
    respuesta: 'El paquete tiene un precio desde $2,500 MXN + IVA. Incluye transporte dentro de CDMX y Estado de México, instalación, operación y desmontaje. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para qué eventos es ideal la bola disco de 60 cm?',
    respuesta: 'Es perfecta para bodas íntimas, fiestas de 15 años, eventos corporativos medianos y celebraciones en salones para 50 a 120 invitados. Su tamaño genera un impacto visual notable en pistas de baile de salón.'
  },
  {
    pregunta: '¿En qué zonas entregan este paquete?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 3 a 4 semanas de anticipación. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Bola Disco 60 cm — Renta de Bolas Disco | REDEIL',
    description: 'Paquete de bola disco de 60 cm con motor giratorio y 2 reflectores LED para bodas y fiestas medianas en CDMX. Instalación profesional incluida desde $2,500 MXN.',
    image: SITE_URL + '/img/img-index/bolas-disco.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/bolas-disco/paquete-60cm/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '35',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Bola Disco 60 cm — Renta de Bola Disco en CDMX | REDEIL"
  description="Renta bola disco de 60 cm con motor giratorio y 2 reflectores LED para bodas y fiestas medianas en CDMX. Instalación profesional incluida desde $2,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Equipos para Eventos', href: '/equipos-para-eventos/' },
    { name: 'Bolas Disco', href: '/equipos-para-eventos/bolas-disco/' },
    { name: 'Paquete 60 cm', href: '/equipos-para-eventos/bolas-disco/paquete-60cm/' }
  ]} />

  <Hero
    badge="Bola Disco — 60 cm"
    title="Bola Disco 60 cm — El Clásico para Bodas y Fiestas Medianas"
    description="La bola disco ideal para bodas íntimas y fiestas de salón. 60 cm de espejo facetado con motor giratorio y 2 reflectores LED profesionales. Impacto visual máximo para 50 a 120 invitados en CDMX."
    primaryCta={{ text: 'Cotizar $2,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/bolas-disco/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>bola disco de 60 cm</strong> es el tamaño más popular para bodas y fiestas de salón. Sus 60 cm de diámetro proyectan un efecto de luz envolvente que cubre toda la pista de baile: cientos de puntos de luz moviéndose sincronizados con la música. Perfecta para <strong>bodas íntimas, XV años y eventos corporativos medianos</strong> en CDMX y Estado de México.</p>
      <p>El paquete incluye motor giratorio de velocidad constante y 2 reflectores LED profesionales de alta potencia. A diferencia de la bola de 30 cm, los reflectores de este paquete tienen mayor alcance y saturación de color, haciendo que el efecto se vea impresionante incluso en salones con techos altos.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bolas Disco"
    items={[
      { label: "Bola 30 cm", href: "/equipos-para-eventos/bolas-disco/paquete-30cm/" },
      { label: "Bola 90 cm", href: "/equipos-para-eventos/bolas-disco/paquete-90cm/" },
      { label: "Bola 120 cm", href: "/equipos-para-eventos/bolas-disco/paquete-120cm/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco de 60 cm girando en pista de baile de boda" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bolas-disco.avif" alt="Efecto de luz de bola disco 60 cm en salón de eventos" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bolas-disco.avif" alt="Reflectores LED apuntando a bola disco en boda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">El favorito para bodas y XV años</span>
            <h2 class="prod-info__title">Bola Disco de 60 cm con Motor y 2 Reflectores LED</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Incluye motor giratorio, 2 reflectores LED, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">60 cm de espejo que llenan de luz toda la pista de baile</h2>
            <p class="prod-selling__intro">La diferencia entre una bola de 30 cm y una de 60 cm no es solo el tamaño: es el impacto. Con el doble de superficie reflectante, la bola de 60 cm proyecta el doble de puntos de luz con mayor alcance y mayor saturación de color. En una boda en salón, cubre completamente la pista de baile y llega hasta las mesas de los invitados. Es el elemento que hace que las fotos de la fiesta se vean espectaculares.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 reflectores LED profesionales — mayor alcance y color</h3>
                  <p class="prod-hl__desc">Los reflectores LED de este paquete son de mayor potencia que los spotlights básicos. Proyectan haces de color más brillantes y con mayor alcance, garantizando que el efecto se vea bien incluso en salones con techos de 4 a 6 metros de altura.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Motor giratorio de velocidad constante para 60 cm</h3>
                  <p class="prod-hl__desc">Una bola de 60 cm necesita un motor más robusto para girar a velocidad constante sin desbalanceo. El motor de este paquete está calibrado específicamente para este tamaño, garantizando movimiento suave y continuo durante horas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura completa para salones de 80 a 200 m²</h3>
                  <p class="prod-hl__desc">La bola de 60 cm cubre con luz danceable desde la pista hasta las mesas de los invitados en salones medianos. Funciona con 50 a 120 personas cómodamente. Si tienes un salón más grande, el paquete de 90 cm es el siguiente paso.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El favorito para bodas íntimas y XV años</h3>
                  <p class="prod-hl__desc">Este es el paquete más solicitado para bodas de entre 50 y 100 invitados. La bola disco de 60 cm es un elemento icónico que añade glamour y nostalgia a cualquier celebración. Tus invitados van a recordarlo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 bola disco de 60 cm facetada</div>
              <div class="prod-feat">Motor giratorio para 60 cm</div>
              <div class="prod-feat">2 reflectores LED profesionales</div>
              <div class="prod-feat">Cables y conexiones</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador en evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento y número de invitados. Con esos datos confirmamos la instalación óptima para tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24 horas</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final y distribución del equipo. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con el 50% de anticipo. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y operamos</h4>
                  <p class="prod-step__desc">Llegamos 1.5 horas antes, instalamos la bola en el punto central, calibramos los reflectores y operamos durante todo el evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 60 cm y no 30 cm?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 30 cm</span>
                <ul class="prod-compare__list">
                  <li>Espacios hasta 80 m²</li>
                  <li>Hasta 50 invitados</li>
                  <li>2 spotlights básicos</li>
                  <li>Fiestas en casa</li>
                  <li>$1,500 MXN</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Este paquete — 60 cm</span>
                <ul class="prod-compare__list">
                  <li>Salones hasta 200 m²</li>
                  <li>50 a 120 invitados</li>
                  <li>2 reflectores LED profesionales</li>
                  <li>Bodas y fiestas formales</li>
                  <li>$2,500 MXN</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"La rentamos para nuestra boda en un salón en Tlalpan. Cuando empezó el baile y prendieron la bola disco, los invitados enloquecieron. Las fotos quedaron increíbles — el efecto de luz en toda la pista hizo que todo se viera muy profesional. El técnico estuvo ahí todo el tiempo ajustando todo. Volveremos a contratar."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Andrea y Roberto</span>
                <span class="prod-quote__event">Boda en Salón Real — Tlalpan, CDMX — 80 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Diámetro</dt><dd>60 cm</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Espejo facetado</dd></div>
              <div class="ps-specs__row"><dt>Motor</dt><dd>Giratorio para 60 cm</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>2 reflectores LED</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 200 m²</dd></div>
              <div class="ps-specs__row"><dt>Invitados</dt><dd>50 a 120 personas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas íntimas</span>
              <span class="ps-tag">XV años en salón</span>
              <span class="ps-tag">Fiestas temáticas</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Aniversarios</span>
              <span class="ps-tag">Fiestas de graduación</span>
              <span class="ps-tag">Salones hasta 200 m²</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/bolas-disco/paquete-30cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 30 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 30 cm</span>
                <span class="ps-pkg__price">$1,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-90cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 90 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 90 cm</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/bolas-disco/paquete-120cm/" class="ps-pkg">
              <img src="/img/img-index/bolas-disco.avif" alt="Bola disco 120 cm" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Bola 120 cm</span>
                <span class="ps-pkg__price">$6,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Salón grande o producción? La bola de 90 cm con 4 reflectores cubre salones hasta 500 m².</p>
              <a href="/equipos-para-eventos/bolas-disco/paquete-90cm/" class="ps-upsell__link">Ver paquete 90 cm →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/equipos-para-eventos/dj/" class="ps-link">DJ para Eventos</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/iluminacion-laser/" class="ps-link">Láser</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }

  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; margin-bottom: 2.5rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
  .prod-includes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-feat { font-size: 0.875rem; color: var(--color-text-light); padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .prod-feat::before { content: ""; position: absolute; left: 0; top: 0.45rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); }
  @media (max-width: 640px) { .prod-includes__grid { grid-template-columns: 1fr; } }

  .prod-process { margin: 2.5rem 0; }
  .prod-process__title { font-size: 1.125rem; font-weight: 800; color: var(--color-text); letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-steps { display: flex; flex-direction: column; gap: 0; }
  .prod-step { display: flex; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--color-border); }
  .prod-step:last-child { border-bottom: none; }
