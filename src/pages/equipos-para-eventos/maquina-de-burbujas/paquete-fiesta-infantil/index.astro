---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Fiesta Infantil de Máquina de Burbujas?',
    respuesta: 'Incluye 1 máquina de burbujas profesional, líquido para 3 horas de operación continua, instalación en el espacio del evento, técnico operador durante toda la fiesta, desmontaje al finalizar y repuestos en sitio. El equipo llega listo para que los niños disfruten desde el primer minuto.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Fiesta Infantil de Máquina de Burbujas?',
    respuesta: 'El paquete tiene un precio desde $1,200 MXN + IVA. Incluye transporte, instalación, operación durante 3 horas y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos ni extras de último momento.'
  },
  {
    pregunta: '¿Cuántos niños pueden disfrutar el paquete Fiesta Infantil?',
    respuesta: 'El paquete está diseñado para grupos de 30 a 80 niños. Una máquina cubre una zona de juego de aproximadamente 4×4 metros con un flujo constante de burbujas. Para eventos más grandes, te recomendamos el paquete Boda o Gigantes con 2 o más máquinas.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Fiesta Infantil?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 2 a 4 semanas de anticipación para fiestas infantiles. Los fines de semana se agotan rápido en temporada alta. Para fechas próximas, escríbenos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Fiesta Infantil — Máquina de Burbujas | REDEIL',
    description: 'El paquete ideal para fiestas infantiles y cumpleaños. 1 máquina de burbujas con líquido para 3 horas, técnico operador incluido. Perfecta para 30-80 niños en CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/maquina-de-burbujas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '1200',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-burbujas/paquete-fiesta-infantil/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Fiesta Infantil — Máquina de Burbujas en CDMX | REDEIL"
  description="Renta de máquina de burbujas para fiestas infantiles y cumpleaños. 1 máquina con líquido para 3 horas y técnico incluido. Ideal para 30-80 niños en CDMX y Edomex desde $1,200."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Burbujas', href: '/equipos-para-eventos/maquina-de-burbujas/' }, { name: 'Fiesta Infantil', href: '/equipos-para-eventos/maquina-de-burbujas/paquete-fiesta-infantil/' }]} />

  <Hero
    badge="Fiesta Infantil"
    title="Fiesta Infantil — Máquina de Burbujas para Cumpleaños"
    description="El paquete perfecto para fiestas infantiles y cumpleaños. 1 máquina con flujo continuo de burbujas, técnico operador y líquido para 3 horas. Instalación profesional en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $1,200 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-burbujas/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>máquina de burbujas para fiesta infantil</strong> convierte cualquier jardín o salón en un mundo de fantasía. El flujo continuo de burbujas genera un ambiente mágico que mantiene a los niños activos y emocionados durante horas. Perfecta para <strong>cumpleaños, kermeses y fiestas de fin de curso</strong> en CDMX y Estado de México.</p>
      <p>Con capacidad para grupos de 30 a 80 niños, este paquete incluye todo lo necesario: máquina profesional, líquido para 3 horas continuas, instalación y un técnico que opera el equipo durante toda la fiesta. Tú disfrutas del festejo, nosotros cuidamos que las burbujas no paren.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Burbujas"
    items={[{ label: "Boda — Entrada", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/" }, { label: "Burbujas Gigantes", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" }, { label: "Producción", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/main.avif" alt="Máquina de burbujas en fiesta infantil con niños jugando en jardín CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img1.avif" alt="Niños corriendo entre burbujas en cumpleaños" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img2.avif" alt="Máquina de burbujas profesional para eventos infantiles" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img3.avif" alt="Flujo continuo de burbujas en jardín para fiesta" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img4.avif" alt="Técnico operando máquina de burbujas en evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Fiesta Infantil — El favorito de los cumpleaños</span>
            <h2 class="prod-info__title">1 Máquina de Burbujas con Líquido para 3 Horas y Técnico Incluido</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$1,200</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, líquido 3h, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">La forma más fácil de hacer felices a 80 niños a la vez</h2>
            <p class="prod-selling__intro">Una máquina de burbujas no es solo entretenimiento — es el momento que todos los niños van a recordar. El flujo continuo de burbujas crea un espacio de juego dinámico que no necesita organización ni instrucciones. Los niños corren, saltan, revientan burbujas y gritan de emoción de forma natural. Tú no tienes que hacer nada: nosotros instalamos, operamos y desmontamos.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Flujo continuo sin pausas — 3 horas de diversión ininterrumpida</h3>
                  <p class="prod-hl__desc">El líquido incluido garantiza 3 horas de producción continua de burbujas. Sin paradas para recargar, sin interrupciones. El técnico monitorea el nivel y ajusta el flujo según el momento: más burbujas para el juego libre, flujo suave para las fotos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Segura para niños desde 2 años — líquido no tóxico</h3>
                  <p class="prod-hl__desc">El líquido que usamos es de fórmula no tóxica, biodegradable y segura para piel sensible. No irrita ojos ni provoca alergias. Cumple con estándares de seguridad para uso en eventos infantiles. Ideal para niños pequeños que inevitablemente van a meter la mano.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico profesional opera todo el evento — tú disfruta</h3>
                  <p class="prod-hl__desc">No dejes el equipo sin supervisión. Nuestro técnico permanece durante toda la fiesta para operar la máquina, ajustar el flujo, recargar líquido y resolver cualquier imprevisto. Los papás pueden estar con los niños sin preocuparse por el equipo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Funciona en interiores y exteriores — jardines, salones y casas</h3>
                  <p class="prod-hl__desc">La máquina opera perfectamente en jardines, patios, salones de fiestas y hasta en interiores de casas. El técnico evalúa el espacio y posiciona el equipo para máxima cobertura. Para interiores, ajustamos el flujo para evitar exceso de humedad en el piso.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 máquina de burbujas profesional</div>
              <div class="prod-feat">Líquido para 3 horas de operación</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y configuración</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Líquido de repuesto en sitio</div>
              <div class="prod-feat">Revisión técnica previa al evento</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre la fiesta</h4>
                  <p class="prod-step__desc">Fecha, domicilio, tipo de espacio (jardín, salón, interior) y cuántos niños se esperan. Con esos datos confirmamos disponibilidad y ajustamos la propuesta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe confirmación en menos de 24h</h4>
                  <p class="prod-step__desc">Te confirmamos disponibilidad, precio final y horario de llegada. Sin costos ocultos ni letras chicas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta la fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con 50% de anticipo por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada de inmediato.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 1 hora antes y nos encargamos de todo</h4>
                  <p class="prod-step__desc">Instalamos la máquina, probamos el flujo y estamos listos antes de que lleguen los invitados. Al finalizar la fiesta, desmontamos y nos llevamos todo. Tú no mueves un dedo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué el paquete Fiesta Infantil y no uno más grande?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sin paquete profesional</span>
                <ul class="prod-compare__list">
                  <li>Máquina de juguete que se apaga sola</li>
                  <li>Líquido que se acaba en 20 minutos</li>
                  <li>Tú tienes que operarla y cuidarla</li>
                  <li>Burbujas pequeñas e inconsistentes</li>
                  <li>Sin soporte si algo falla</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Fiesta Infantil — REDEIL</span>
                <ul class="prod-compare__list">
                  <li>Máquina profesional de alto flujo</li>
                  <li>Líquido para 3 horas continuas</li>
                  <li>Técnico opera todo el evento</li>
                  <li>Burbujas abundantes y constantes</li>
                  <li>Respaldo técnico en sitio</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Renté la máquina de burbujas para el cumpleaños número 5 de mi hijo y fue el hit de la fiesta. Los niños estuvieron 3 horas corriendo y jugando con las burbujas sin parar. El técnico fue muy amable con los niños y ajustaba el flujo cuando les pedíamos más. Todos los papás me preguntaron dónde la renté. 100% la recomiendo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sofía Ramírez</span>
                <span class="prod-quote__event">Cumpleaños infantil en jardín — Naucalpan, Edomex</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas incluidas</dt><dd>1 máquina</dd></div>
              <div class="ps-specs__row"><dt>Tipo de burbujas</dt><dd>Estándar continuas</dd></div>
              <div class="ps-specs__row"><dt>Líquido</dt><dd>3 horas incluidas</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>30-80 niños</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Zona ~4×4 m</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas infantiles</span>
              <span class="ps-tag">Cumpleaños</span>
              <span class="ps-tag">Kermeses</span>
              <span class="ps-tag">Fin de curso</span>
              <span class="ps-tag">Jardines de niños</span>
              <span class="ps-tag">Posadas infantiles</span>
              <span class="ps-tag">Pastorelas</span>
              <span class="ps-tag">Eventos escolares</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Boda Entrada máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda — Entrada</span>
                <span class="ps-pkg__price">$2,200 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Burbujas Gigantes máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Burbujas Gigantes</span>
                <span class="ps-pkg__price">$3,800 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Producción máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$7,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda o evento grande? El paquete Boda incluye 2 máquinas para entrada de novios o pista de baile.</p>
              <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/" class="ps-upsell__link">Ver paquete Boda →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Máquina de Confeti</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
