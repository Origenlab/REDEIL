---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Boda — Entrada de Máquina de Burbujas?',
    respuesta: 'Incluye 2 máquinas de burbujas profesionales posicionadas a ambos lados del pasillo o pista de baile, líquido suficiente para el evento completo, instalación y posicionamiento profesional, técnico operador que activa las máquinas en el momento exacto de la entrada, y desmontaje al finalizar. El técnico coordina con el DJ o coordinador de boda para sincronizar el efecto.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Boda — Entrada?',
    respuesta: 'El paquete tiene un precio desde $2,200 MXN + IVA. Incluye 2 máquinas, transporte, instalación, operación coordinada durante la entrada y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Las burbujas manchan el vestido de novia?',
    respuesta: 'No. El líquido que usamos es de fórmula no tóxica, biodegradable y no deja manchas en telas. Las burbujas se evaporan sin dejar residuo. Es exactamente el mismo tipo de líquido que usan en producciones de cine y televisión para efectos seguros sobre personas.'
  },
  {
    pregunta: '¿Puedo usar el paquete para la entrada Y la pista de baile?',
    respuesta: 'Sí. Las 2 máquinas son versátiles: puedes usarlas para la entrada de los novios y luego reposicionarlas en la pista de baile para el primer baile. El técnico se encarga del movimiento y reconfiguración sin que notes el cambio.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Boda — Entrada?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con un cargo adicional por distancia.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Boda — Entrada — Máquina de Burbujas | REDEIL',
    description: 'El paquete ideal para la entrada de novios o pista de baile. 2 máquinas de burbujas sincronizadas con técnico operador incluido. Crea el efecto mágico en tu boda en CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/maquina-de-burbujas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2200',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '47',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Boda — Entrada — Máquina de Burbujas en CDMX | REDEIL"
  description="2 máquinas de burbujas para la entrada de novios o pista de baile. Técnico operador que sincroniza el efecto con tu música. Bodas en CDMX y Edomex desde $2,200."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Burbujas', href: '/equipos-para-eventos/maquina-de-burbujas/' }, { name: 'Boda — Entrada', href: '/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/' }]} />

  <Hero
    badge="Boda — Entrada"
    title="Boda — Entrada con Máquina de Burbujas para Novios"
    description="El efecto que hace que todos levanten el teléfono al mismo tiempo. 2 máquinas de burbujas a ambos lados del pasillo, sincronizadas por nuestro técnico para el momento exacto de tu entrada."
    primaryCta={{ text: 'Cotizar $2,200 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-burbujas/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>entrada de novios con máquina de burbujas</strong> es el efecto visual que más se comparte en redes sociales después de una boda. Dos máquinas posicionadas a ambos lados del pasillo crean una cortina densa de burbujas que envuelve a los novios mientras caminan. El resultado es una foto y un video que los invitados guardan para siempre.</p>
      <p>El técnico coordina con tu DJ o coordinador para activar las máquinas exactamente cuando empieza la música de entrada. Sin timing fallido, sin burbujas antes de tiempo ni después del momento. Funciona también para el <strong>primer baile en la pista</strong>, con las 2 máquinas reposicionadas alrededor de la pista de baile.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Burbujas"
    items={[{ label: "Fiesta Infantil", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-fiesta-infantil/" }, { label: "Burbujas Gigantes", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" }, { label: "Producción", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/main.avif" alt="Entrada de novios con máquina de burbujas en boda en jardín CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img1.avif" alt="Novios caminando entre burbujas en su entrada de boda" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img2.avif" alt="Dos máquinas de burbujas posicionadas a ambos lados del pasillo" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img3.avif" alt="Efecto de burbujas en pista de baile de boda" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img4.avif" alt="Técnico operando máquinas de burbujas durante boda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Boda — El efecto más fotografiado de la noche</span>
            <h2 class="prod-info__title">2 Máquinas de Burbujas Sincronizadas para Entrada de Novios o Pista de Baile</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,200</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 2 máquinas, transporte, instalación, coordinación con DJ, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El momento de la noche que todos van a recordar — y a fotografiar</h2>
            <p class="prod-selling__intro">Una boda tiene muchos momentos bonitos. Pero hay uno que provoca que todos en el salón levanten el teléfono al mismo tiempo: la entrada de los novios. Con dos máquinas de burbujas a cada lado del pasillo, ese momento se convierte en una escena de película. Las burbujas reflejan la iluminación del salón, vuelan alrededor de los novios y crean una atmósfera que ningún decorador puede replicar con flores o globos.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sincronización exacta con tu música — el técnico coordina con tu DJ</h3>
                  <p class="prod-hl__desc">El momento de activar las máquinas importa tanto como tener las máquinas. Nuestro técnico coordina directamente con tu DJ o coordinador para activar el efecto exactamente cuando comienza la música. Sin burbujas antes del momento ni máquinas que se quedan cortas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 máquinas para cobertura completa del pasillo — de pared a pared</h3>
                  <p class="prod-hl__desc">Una sola máquina cubre la mitad. Con dos máquinas posicionadas estratégicamente, el pasillo completo queda cubierto de burbujas. Los novios caminan envueltos en el efecto desde el primer paso hasta el altar. Sin zonas vacías ni huecos en el momento de las fotos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Seguro para vestido de novia y smoking — líquido no mancha telas</h3>
                  <p class="prod-hl__desc">El líquido es de fórmula profesional, no tóxica y biodegradable. No deja manchas en telas delicadas, no irrita la piel ni los ojos. Es el mismo tipo de solución que se usa en producciones de cine. El vestido de novia y el smoking llegan impecables a las fotos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Reutilizable para el primer baile — sin costo adicional</h3>
                  <p class="prod-hl__desc">Las mismas 2 máquinas se reposicionan alrededor de la pista de baile para el primer baile. El técnico hace el movimiento entre la entrada y el baile en minutos. Dos momentos icónicos de la noche cubiertos con un solo paquete.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 máquinas de burbujas profesionales</div>
              <div class="prod-feat">Líquido para el evento completo</div>
              <div class="prod-feat">Posicionamiento estratégico en pasillo</div>
              <div class="prod-feat">Coordinación con DJ o coordinador</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Reposicionamiento para pista de baile</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y desmontaje incluidos</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte los detalles de tu boda</h4>
                  <p class="prod-step__desc">Fecha, venue, tipo de espacio (salón, jardín, hacienda) y si tienes DJ o coordinador de bodas. Con esa información diseñamos el posicionamiento óptimo de las máquinas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirmamos y coordinamos con tu equipo</h4>
                  <p class="prod-step__desc">Antes del evento, el técnico se pone en contacto con tu DJ o coordinador para acordar el timing exacto de la entrada y el primer baile.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo del 50%</h4>
                  <p class="prod-step__desc">Reserva con transferencia, efectivo o tarjeta. Tu fecha queda bloqueada de inmediato. Agenda confirmada por escrito.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">El técnico llega 2 horas antes y lo prepara todo</h4>
                  <p class="prod-step__desc">Instalamos las máquinas, probamos el flujo, coordinamos posición con el venue y esperamos el momento exacto. Cuando los novios entran, el efecto ya está listo para detonar.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 2 máquinas y no 1 para una boda?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">1 máquina en la entrada</span>
                <ul class="prod-compare__list">
                  <li>Cubre solo un lado del pasillo</li>
                  <li>Zona vacía en las fotos del otro lado</li>
                  <li>Efecto asimétrico y menos impactante</li>
                  <li>No alcanza para pista de baile</li>
                  <li>Momento a medias</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Boda — 2 máquinas REDEIL</span>
                <ul class="prod-compare__list">
                  <li>Cobertura completa de ambos lados</li>
                  <li>Fotos simétricas y espectaculares</li>
                  <li>Efecto envolvente para los novios</li>
                  <li>Se reutiliza en pista de baile</li>
                  <li>El momento que todos recuerdan</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Fue el momento más comentado de toda la boda. Cuando entramos al salón con las burbujas a los dos lados, escuchamos gritos y aplausos de todos los invitados. El fotógrafo nos dijo que esas fotos eran las mejores de la noche. El técnico coordinó todo perfectamente con el DJ. Vale cada peso y más."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Andrea y Rodrigo</span>
                <span class="prod-quote__event">Boda en Salón Palacio — 180 invitados, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas incluidas</dt><dd>2 máquinas</dd></div>
              <div class="ps-specs__row"><dt>Tipo de burbujas</dt><dd>Estándar continuas</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Pasillo completo</dd></div>
              <div class="ps-specs__row"><dt>Usos</dt><dd>Entrada + pista baile</dd></div>
              <div class="ps-specs__row"><dt>Coordinación</dt><dd>Con DJ incluida</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en salón</span>
              <span class="ps-tag">Bodas en jardín</span>
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Entrada de novios</span>
              <span class="ps-tag">Primer baile</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Aniversarios</span>
              <span class="ps-tag">Cenas de gala</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-fiesta-infantil/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Fiesta Infantil máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta Infantil</span>
                <span class="ps-pkg__price">$1,200 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Burbujas Gigantes máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Burbujas Gigantes</span>
                <span class="ps-pkg__price">$3,800 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Producción máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$7,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres burbujas gigantes además de la entrada? El paquete Gigantes combina máquina de burbujas gigantes con 2 estándar.</p>
              <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" class="ps-upsell__link">Ver paquete Gigantes →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu boda</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Máquina de Confeti</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
