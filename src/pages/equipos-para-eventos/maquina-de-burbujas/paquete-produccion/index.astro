---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción de Máquina de Burbujas?',
    respuesta: 'Incluye 4 o más máquinas de burbujas estándar más 1 máquina de burbujas gigantes, control DMX para sincronización con iluminación, operador dedicado durante toda la producción, líquido profesional en cantidad industrial, instalación técnica completa, desmontaje y soporte en sitio. Diseñado para coberturas de 200 o más personas con impacto visual máximo.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción de Máquina de Burbujas?',
    respuesta: 'El paquete tiene un precio desde $7,000 MXN + IVA. Incluye transporte, instalación técnica completa, operador dedicado, control DMX, líquido industrial y desmontaje. Cubre CDMX, Estado de México y eventos en toda la República con cotización personalizada de traslado.'
  },
  {
    pregunta: '¿Para cuántas personas está diseñado el paquete Producción?',
    respuesta: 'El paquete Producción está optimizado para eventos de 200 personas o más. La combinación de 4+ máquinas estándar más la máquina de burbujas gigantes genera una cobertura de efecto espectacular en espacios amplios: foros, jardines grandes, recintos tipo warehouse y escenarios de festival.'
  },
  {
    pregunta: '¿Qué es el control DMX y para qué sirve en este paquete?',
    respuesta: 'El control DMX permite sincronizar las máquinas de burbujas con el sistema de iluminación del evento. Puedes activar ráfagas de burbujas en momentos específicos, coordinar el flujo con música o momentos dramatúrgicos, y crear efectos visuales precisos para grabaciones o transmisiones en vivo. Es el estándar profesional en producciones audiovisuales y shows.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete Producción?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación para producciones y festivales. Los equipos DMX y las máquinas gigantes tienen disponibilidad limitada. Para eventos de lujo o producciones audiovisuales con fechas fijas, contáctanos cuanto antes por WhatsApp para asegurar el equipo.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — Máquina de Burbujas | REDEIL',
    description: 'Paquete de producción completa con 4+ máquinas de burbujas estándar, 1 de burbujas gigantes, control DMX y operador dedicado. Cobertura para 200+ personas. Ideal para festivales, bodas de lujo, producciones audiovisuales y lanzamientos en CDMX.',
    image: SITE_URL + '/img/img-index/maquina-de-burbujas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '7000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-burbujas/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '14',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción — Máquina de Burbujas en CDMX | REDEIL"
  description="Renta de paquete producción de máquina de burbujas: 4+ máquinas estándar + 1 gigantes + DMX + operador dedicado. Cobertura 200+ personas. Festivales, bodas de lujo y producciones audiovisuales en CDMX desde $7,000."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Burbujas', href: '/equipos-para-eventos/maquina-de-burbujas/' }, { name: 'Producción', href: '/equipos-para-eventos/maquina-de-burbujas/paquete-produccion/' }]} />

  <Hero
    badge="Producción"
    title="Producción — Máquina de Burbujas para Festivales y Eventos de Lujo"
    description="El paquete de producción completa para eventos de gran escala. 4+ máquinas de burbujas estándar más 1 gigantes, control DMX, operador dedicado y cobertura para 200+ personas. Para festivales, bodas de lujo, producciones audiovisuales y lanzamientos en CDMX."
    primaryCta={{ text: 'Cotizar $7,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-burbujas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Producción de máquina de burbujas</strong> es la solución de nivel profesional para eventos que requieren impacto visual máximo y coordinación técnica precisa. La combinación de múltiples máquinas estándar con una de <strong>burbujas gigantes</strong> y control <strong>DMX</strong> transforma cualquier recinto en un espectáculo de producción internacional. Diseñado para <strong>festivales, bodas de lujo, lanzamientos de marca y producciones audiovisuales</strong> en CDMX y toda la República.</p>
      <p>Con capacidad de cobertura para 200 personas o más, este paquete incluye todo lo que un director de producción necesita: equipo de alto rendimiento, sincronización DMX con iluminación, operador técnico dedicado y soporte completo de instalación y desmontaje. Nosotros integramos el efecto en tu producción — tú te enfocas en el resultado final.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Burbujas"
    items={[{ label: "Fiesta Infantil", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-fiesta-infantil/" }, { label: "Boda — Entrada", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/" }, { label: "Burbujas Gigantes", href: "/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/main.avif" alt="Paquete producción máquina de burbujas con efecto DMX en festival CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img1.avif" alt="Máquina de burbujas gigantes en producción audiovisual" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img2.avif" alt="Control DMX sincronizado con iluminación en festival" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img3.avif" alt="Múltiples máquinas de burbujas en boda de lujo CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-maquina-de-burbujas-para-eventos-cdmx/img4.avif" alt="Operador dedicado monitoreando equipo en lanzamiento de marca" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Producción — El estándar para eventos de gran escala</span>
            <h2 class="prod-info__title">4+ Máquinas de Burbujas + 1 Gigantes + DMX + Operador Dedicado para 200+ Personas</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$7,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación técnica completa, líquido industrial, control DMX, operador dedicado y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">La producción de burbujas que tus cámaras y tu audiencia van a recordar</h2>
            <p class="prod-selling__intro">En producciones de alto nivel, el efecto visual no puede fallar. El paquete Producción no es solo "más máquinas" — es un sistema coordinado de generación de burbujas diseñado para cobertura total de escena, sincronización con iluminación DMX y operación técnica sin interrupciones. Desde el momento de carga hasta el desmontaje, nuestro operador dedicado integra el equipo en tu flujo de producción. Resultado: un efecto impecable que aparece exactamente cuando y donde lo planeaste.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4+ máquinas estándar + 1 gigantes — cobertura total de escena</h3>
                  <p class="prod-hl__desc">La combinación de múltiples máquinas estándar posicionadas estratégicamente con una máquina de burbujas gigantes al centro genera un efecto de cobertura 360° imposible de replicar con un solo equipo. Las burbujas gigantes crean el impacto visual de gran formato; las estándar llenan el espacio y rodean a la audiencia. Ideal para escenarios, pistas de baile y zonas de activación de marca.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Control DMX — sincronización profesional con iluminación y música</h3>
                  <p class="prod-hl__desc">El protocolo DMX permite activar y desactivar máquinas de forma individual o en conjunto desde la consola de iluminación. Puedes programar ráfagas de burbujas en el drop de una canción, en el momento del primer beso, en la entrada del artista o en el clímax de una presentación. Compatible con consolas MA2, Chamsys, Resolume y cualquier controlador DMX estándar del mercado.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Operador técnico dedicado — integrado en tu equipo de producción</h3>
                  <p class="prod-hl__desc">No es un técnico que espera afuera. Nuestro operador se integra con el director de producción, recibe el script de escena y coordina los momentos de activación con el resto del equipo creativo. Conoce el equipo a fondo: ajusta flujo, reabastece líquido, resuelve imprevistos y ejecuta los efectos con precisión técnica durante toda la producción.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Optimizado para cámara — burbujas que lucen en foto y video</h3>
                  <p class="prod-hl__desc">El tamaño y la densidad de las burbujas del paquete Producción están calibradas para destacar en cámaras profesionales. Con iluminación lateral o contraluz, las burbujas capturan la luz y crean un efecto etéreo que ningún otro elemento logra. Hemos trabajado en videoclips, transmisiones en vivo y coberturas editoriales. El equipo está listo para aparecer en pantalla.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4+ máquinas de burbujas estándar</div>
              <div class="prod-feat">1 máquina de burbujas gigantes</div>
              <div class="prod-feat">Control DMX para sincronización</div>
              <div class="prod-feat">Operador técnico dedicado</div>
              <div class="prod-feat">Líquido industrial para producción completa</div>
              <div class="prod-feat">Transporte de equipo completo</div>
              <div class="prod-feat">Instalación técnica multi-punto</div>
              <div class="prod-feat">Coordinación con equipo de producción</div>
              <div class="prod-feat">Soporte en sitio durante el evento</div>
              <div class="prod-feat">Desmontaje y retiro de equipo</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Briefing de producción</h4>
                  <p class="prod-step__desc">Compártenos el script del evento, plano del recinto, tipo de evento y momentos clave donde se activará el efecto. Con esa información diseñamos el posicionamiento de las máquinas y la programación DMX.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta técnica en 24-48h</h4>
                  <p class="prod-step__desc">Te enviamos la propuesta con layout de posicionamiento, configuración DMX sugerida, lista de equipo y cotización final. Sin costos ocultos ni ajustes de último minuto.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo</h4>
                  <p class="prod-step__desc">Aparta el equipo con 50% de anticipo. Para producciones con fechas fijas te recomendamos reservar con al menos 4 semanas de anticipación — el equipo DMX y las máquinas gigantes tienen disponibilidad limitada.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje técnico y ensayo de sincronización</h4>
                  <p class="prod-step__desc">Llegamos con anticipación suficiente para el montaje completo, configuración DMX, prueba de flujo y ensayo con el equipo de iluminación. El operador queda listo antes de que inicie la producción. Tú enfocas en el resultado creativo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué el paquete Producción y no un paquete menor?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete básico en producción grande</span>
                <ul class="prod-compare__list">
                  <li>Una sola máquina para 200+ personas</li>
                  <li>Sin sincronización con iluminación</li>
                  <li>Operador compartido o sin operador</li>
                  <li>Cobertura parcial de la escena</li>
                  <li>Sin burbujas gigantes para gran formato</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción — REDEIL</span>
                <ul class="prod-compare__list">
                  <li>4+ máquinas + gigantes para cobertura total</li>
                  <li>Control DMX integrado con iluminación</li>
                  <li>Operador técnico dedicado exclusivo</li>
                  <li>Cobertura 360° del espacio</li>
                  <li>Burbujas gigantes para impacto visual máximo</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Usamos el paquete Producción para el lanzamiento de una marca en un foro con 400 personas. La coordinación DMX fue perfecta — las burbujas se activaron exactamente en el momento del reveal del producto y el efecto quedó espectacular en cámara. El operador se integró sin problema con nuestro equipo de producción. Sin duda el mejor efecto de toda la noche."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Rodrigo Mendoza</span>
                <span class="prod-quote__event">Director de Producción — Lanzamiento de marca, Foro Indie, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas estándar</dt><dd>4+ máquinas</dd></div>
              <div class="ps-specs__row"><dt>Máquina gigantes</dt><dd>1 incluida</dd></div>
              <div class="ps-specs__row"><dt>Control DMX</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>200+ personas</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Producción completa</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Operador dedicado</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Técnica multi-punto</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Producciones audiovisuales</span>
              <span class="ps-tag">Festivales</span>
              <span class="ps-tag">Bodas de lujo</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Shows en vivo</span>
              <span class="ps-tag">Transmisiones en vivo</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Videoclips</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-fiesta-infantil/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Fiesta Infantil máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta Infantil</span>
                <span class="ps-pkg__price">$1,200 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Boda Entrada máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda — Entrada</span>
                <span class="ps-pkg__price">$2,200 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-burbujas-gigantes/" class="ps-pkg">
              <img src="/img/img-index/maquina-de-burbujas.avif" alt="Paquete Burbujas Gigantes máquina de burbujas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Burbujas Gigantes</span>
                <span class="ps-pkg__price">$3,800 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento íntimo o boda sin gran producción? El paquete Boda Entrada cubre hasta 120 personas con 2 máquinas para entrada de novios.</p>
              <a href="/equipos-para-eventos/maquina-de-burbujas/paquete-boda-entrada/" class="ps-upsell__link">Ver paquete Boda →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Propuesta técnica personalizada en menos de 48 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Máquina de Confeti</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
