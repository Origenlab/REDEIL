---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción de Máquina de Confeti?',
    respuesta: 'Incluye 8 o más cañones de confeti de alta presión, control DMX para disparos sincronizados con música e iluminación, confeti metalizado o biodegradable según necesidades, múltiples recargas durante el evento, técnico senior de producción y coordinación con el equipo de sonido e iluminación.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción de Confeti?',
    respuesta: 'El paquete tiene un precio desde $9,000 MXN + IVA. El precio varía según el número de cañones (8+), número de disparos y complejidad de la programación DMX. Solicita cotización para una propuesta personalizada.'
  },
  {
    pregunta: '¿Qué es el control DMX y para qué sirve en el confeti?',
    respuesta: 'DMX es el protocolo de control profesional que permite disparar los cañones de confeti de forma precisa y sincronizada con la música, las luces o cualquier señal del espectáculo. Esto significa que el confeti puede disparar exactamente en el beat de la música, en sintonía con los efectos de iluminación o en secuencias programadas para un impacto máximo.'
  },
  {
    pregunta: '¿Para qué tipo de eventos es el paquete Producción?',
    respuesta: 'Está diseñado para eventos de alto impacto: conciertos, festivales de música, shows corporativos de gran escala, finales de temporada, bodas de producción premium o cualquier evento donde el confeti sea parte de un espectáculo coordinado, no solo un accesorio decorativo.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Producción?',
    respuesta: 'Cubrimos CDMX, Estado de México y toda la República. Para eventos fuera del área metropolitana coordinamos transporte, hospedaje del equipo técnico y logística completa. Solicita cotización con tu ubicación específica.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — Máquina de Confeti | REDEIL',
    description: 'Paquete de producción completa con 8+ cañones de confeti y control DMX para shows, conciertos y eventos corporativos de alto impacto en CDMX.',
    image: SITE_URL + '/img/paquetes/maquina-de-confeti/produccion.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '9000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-confeti/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '22',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción — Máquina de Confeti con DMX en CDMX | REDEIL"
  description="Paquete de producción con 8+ cañones de confeti y control DMX. Shows, conciertos y eventos corporativos de alto impacto. Confeti sincronizado con música e iluminación en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Confeti', href: '/equipos-para-eventos/maquina-de-confeti/' }, { name: 'Producción', href: '/equipos-para-eventos/maquina-de-confeti/paquete-produccion/' }]} />

  <Hero
    badge="Producción — Show nivel concierto"
    title="8+ Cañones de Confeti con Control DMX — Producción Completa"
    description="El nivel más alto de confeti en eventos. 8 o más cañones sincronizados mediante DMX con la música y la iluminación. Para shows corporativos, conciertos, festivales y bodas de producción premium en CDMX."
    primaryCta={{ text: 'Cotizar desde $9,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-confeti/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Producción de confeti</strong> no es para un momento puntual — es para eventos donde el confeti es parte integral del espectáculo. Con <strong>8 o más cañones controlados por DMX</strong>, el confeti puede disparar sincronizado con el beat de la música, la apertura de un telón, el clímax de un discurso o cualquier momento que la producción defina. Es la diferencia entre un accesorio y un elemento de producción.</p>
      <p>Incluye coordinación completa con el equipo de sonido e iluminación del evento, técnico senior de producción de efectos especiales y programación DMX personalizada. Para eventos que exigen el más alto nivel de profesionalismo en cada detalle.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Confeti"
    items={[{ label: "2 Cañones", href: "/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/" }, { label: "4 Cañones", href: "/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" }, { label: "Biodegradable", href: "/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/maquina-de-confeti/produccion.avif" alt="8 cañones de confeti con control DMX en show corporativo" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/maquina-de-confeti.avif" alt="Producción de confeti nivel concierto" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/confeti-metalizado.avif" alt="Lluvia masiva de confeti en festival" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/momento-brindis.avif" alt="Control DMX de cañones de confeti en show" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/tecnico-operador.avif" alt="Técnico senior programando DMX para confeti" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Producción Completa — DMX + 8+ cañones</span>
            <h2 class="prod-info__title">8+ Cañones de Confeti con Programación DMX y Técnico Senior</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$9,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Desde $9,000. Precio final según número de cañones, disparos y complejidad DMX. Solicita cotización.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">El confeti como elemento de producción, no como decoración de último minuto</h2>
            <p class="prod-selling__intro">En un show de producción, el confeti no se dispara porque sí. Se dispara en el momento preciso, en sincronía con la música, coordinado con el cambio de iluminación, respondiendo a la narrativa del evento. El control DMX hace posible esa precisión. 8 o más cañones hacen que el impacto sea total — que el confeti llene el espacio y que todos los presentes lo vivan al mismo tiempo.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Control DMX — confeti sincronizado con música e iluminación</h3>
                  <p class="prod-hl__desc">El DMX permite programar los disparos como si fueran un instrumento más del show. El confeti dispara en el beat exacto, en el clímax de la canción, en el fade del iluminador. No hay error humano — hay programación de precisión milimétrica ejecutada por un técnico senior.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">8+ cañones = impacto total en todo el venue</h3>
                  <p class="prod-hl__desc">Con 8 o más unidades distribuidas estratégicamente en el venue, el confeti cubre desde la primera fila hasta el fondo del espacio. No hay invitado que no lo sienta. Es la diferencia entre un efecto bonito y un momento que hace que la gente deje de respirar por 3 segundos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Coordinación completa con producción del evento</h3>
                  <p class="prod-hl__desc">Nuestro técnico senior se integra al equipo de producción del evento desde el planning. Asiste a la reunión de producción, coordina con el DJ, el iluminador y el coordinador general para que el confeti esté integrado en el guion del show, no improvisado al final.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Múltiples recargas — confeti cuando lo necesites</h3>
                  <p class="prod-hl__desc">El paquete de producción incluye recargas suficientes para los momentos clave del evento. No hay límite de "2 disparos y ya". Coordinamos contigo los momentos críticos y aseguramos que haya confeti para cada uno.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">8 o más cañones de confeti</div>
              <div class="prod-feat">Control DMX incluido</div>
              <div class="prod-feat">Programación DMX personalizada</div>
              <div class="prod-feat">Múltiples recargas de confeti</div>
              <div class="prod-feat">Técnico senior de producción</div>
              <div class="prod-feat">Reunión de producción previa</div>
              <div class="prod-feat">Coordinación con sonido e iluminación</div>
              <div class="prod-feat">Transporte y logística completa</div>
              <div class="prod-feat">Instalación y configuración DMX</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio de producción</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de producción — integramos el confeti al show</h4>
                  <p class="prod-step__desc">Nuestro técnico senior asiste a tu reunión de producción o coordina directamente con tu equipo. Definimos los momentos de disparo, la programación DMX y el posicionamiento de los 8+ cañones en el venue.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta técnica y cotización personalizada</h4>
                  <p class="prod-step__desc">Número exacto de cañones, tipo de confeti, número de disparos y programación DMX. Precio final según alcance. Sin sorpresas en el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje, pruebas y configuración DMX</h4>
                  <p class="prod-step__desc">El equipo llega con suficiente antelación para montar, conectar DMX, hacer pruebas de disparo y sincronizar con el equipo de sonido e iluminación. Todo probado antes de que lleguen los invitados.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Ejecución perfecta y desmontaje profesional</h4>
                  <p class="prod-step__desc">El técnico senior opera desde el puesto de control durante todo el show. Cada disparo ocurre exactamente como fue programado. Al finalizar, desmonte rápido y limpio.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">Producción vs paquetes estándar — distinto nivel</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquetes 2-6 Cañones</span>
                <ul class="prod-compare__list">
                  <li>Disparos manuales a señal</li>
                  <li>2-3 momentos fijos</li>
                  <li>Sin integración DMX</li>
                  <li>Para eventos sociales</li>
                  <li>Operación básica</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>Control DMX automatizado</li>
                  <li>Múltiples disparos programados</li>
                  <li>Sincronía total con show</li>
                  <li>Shows, conciertos, corporativos</li>
                  <li>Técnico senior de producción</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Para el evento anual de nuestra empresa contratamos el paquete de producción con 10 cañones y DMX. El equipo de REDEIL estuvo en nuestra reunión de producción dos semanas antes y coordinó todo con el DJ y el iluminador. En el momento del brindis, los 10 cañones dispararon exactamente en el cambio de canción, sincronizados con las luces. 300 personas vitorearon al mismo tiempo. Fue impresionante."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Gabriela Torres</span>
                <span class="prod-quote__event">Directora de Eventos, Tech Summit CDMX — 300 asistentes</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones</dt><dd>8+ unidades</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>DMX profesional</dd></div>
              <div class="ps-specs__row"><dt>Tipo de confeti</dt><dd>Metalizado o biodegradable</dd></div>
              <div class="ps-specs__row"><dt>Disparos</dt><dd>Múltiples</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Senior de producción</dd></div>
              <div class="ps-specs__row"><dt>Integración</dt><dd>Sonido + iluminación</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Venue completo</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + República</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Conciertos</span>
              <span class="ps-tag">Shows corporativos</span>
              <span class="ps-tag">Festivales</span>
              <span class="ps-tag">Eventos de 200+ personas</span>
              <span class="ps-tag">Bodas premium</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Finales de temporada</span>
              <span class="ps-tag">Galas de premiación</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/2-canones.avif" alt="2 Cañones confeti" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Cañones</span>
                <span class="ps-pkg__price">$2,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/4-canones.avif" alt="4 Cañones confeti" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cañones</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/biodegradable.avif" alt="Confeti biodegradable eco-friendly" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Confeti Biodegradable</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Propuesta técnica personalizada en 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Solicitar Propuesta</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-sonido/dj-para-bodas/" class="ps-link">DJ para Bodas</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
