---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 2 Cañones de Máquina de Confeti?',
    respuesta: 'Incluye 2 cañones de confeti metalizado de alta presión, recarga de confeti para el disparo pactado, posicionamiento estratégico en el escenario, técnico operador durante el evento y desmontaje al finalizar. El cañón dispara en el momento exacto que tú indiques: brindis, mordida del pastel o primer baile.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 2 Cañones?',
    respuesta: 'El paquete tiene un precio desde $2,000 MXN + IVA. Incluye transporte, montaje, operación y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para qué tipo de evento es ideal el paquete 2 Cañones?',
    respuesta: 'Es perfecto para eventos con un momento especial puntual: la mordida del pastel en una boda o XV años, el brindis de año nuevo, la entrada de los novios o una sorpresa de cumpleaños. Dos cañones generan el impacto visual suficiente para un instante memorable sin saturar el espacio.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 2 Cañones?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con cargo por traslado.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 3 a 4 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp y verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '2 Cañones — Máquina de Confeti | REDEIL',
    description: 'Paquete de 2 cañones de confeti para el momento especial de tu evento: brindis, mordida del pastel o entrada de novios. Ideal para bodas y XV años en CDMX.',
    image: SITE_URL + '/img/paquetes/maquina-de-confeti/2-canones.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '34',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="2 Cañones — Máquina de Confeti en CDMX | REDEIL"
  description="Paquete de 2 cañones de confeti para el momento especial de tu evento. Disparo en brindis, mordida del pastel o entrada de novios. Operador incluido en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Confeti', href: '/equipos-para-eventos/maquina-de-confeti/' }, { name: '2 Cañones', href: '/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/' }]} />

  <Hero
    badge="2 Cañones — El impacto puntual"
    title="2 Cañones — Máquina de Confeti para tu Momento Especial"
    description="Dos cañones de confeti metalizado disparados en sincronía en el instante exacto que tú decidas. Brindis, mordida del pastel o entrada de novios — ese momento queda grabado en foto y en memoria."
    primaryCta={{ text: 'Cotizar $2,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-confeti/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete 2 Cañones de confeti</strong> está diseñado para eventos donde hay un momento puntual que merece una explosión visual: la <strong>mordida del pastel en bodas y XV años</strong>, el brindis de año nuevo, la entrada de los novios o una sorpresa de cumpleaños. Dos cañones posicionados estratégicamente generan el impacto justo en un espacio íntimo sin saturar el ambiente.</p>
      <p>Un técnico operador permanece en tu evento para disparar en el momento exacto que tú indiques. No hay botón que presionar, no hay accidente anticipado — el confeti cae exactamente cuando más lo necesitas, justo cuando el fotógrafo tiene el encuadre listo.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Confeti"
    items={[{ label: "4 Cañones", href: "/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" }, { label: "Confeti Biodegradable", href: "/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" }, { label: "Producción", href: "/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/maquina-de-confeti/2-canones.avif" alt="Disparo de confeti en boda con 2 cañones de alta presión" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/maquina-de-confeti.avif" alt="Cañón de confeti profesional en evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/confeti-metalizado.avif" alt="Confeti metalizado plateado y dorado en vuelo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/momento-brindis.avif" alt="Disparo de confeti en el momento del brindis" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/tecnico-operador.avif" alt="Técnico operando cañón de confeti en evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Esencial — Un momento, dos cañones</span>
            <h2 class="prod-info__title">2 Cañones de Confeti Metalizado con Técnico Operador</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, montaje, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El momento que todos recuerdan, capturado en una explosión de confeti</h2>
            <p class="prod-selling__intro">Hay eventos donde no necesitas confeti durante toda la noche — necesitas que un instante específico sea perfecto. Ese instante: la mordida del pastel, el primer brindis, la entrada de los novios. Dos cañones en sincronía generan una lluvia de confeti que dura entre 8 y 12 segundos, suficiente para que el fotógrafo capture todo y los invitados lo celebren.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Disparo a tu señal — el técnico espera tu momento</h3>
                  <p class="prod-hl__desc">No hay temporizador ni botón que presionar en el caos del evento. Nuestro técnico operador está atento y dispara en el instante exacto que tú le indiques. Si el fotógrafo necesita 10 segundos más, esperamos. El confeti cae cuando el momento es perfecto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Confeti metalizado — el efecto visual que brilla en fotos</h3>
                  <p class="prod-hl__desc">El confeti metalizado plateado y dorado refleja la luz del flash y los reflectores. En la foto queda como una lluvia de estrellas. En el video queda como una escena de película. Es el tipo de confeti que hace que las fotos de tu evento parezcan de revista.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Posicionamiento estratégico para el ángulo correcto</h3>
                  <p class="prod-hl__desc">Los 2 cañones se colocan a ambos lados del punto focal del evento — mesa del pastel, arco de ceremonia, pista de baile — para que el confeti caiga simétricamente sobre los protagonistas. Resultado: fotos con encuadre limpio y lluvia perfecta.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Ideal para espacios cerrados — no satura el ambiente</h3>
                  <p class="prod-hl__desc">Dos cañones generan impacto visual sin llenar el suelo de confeti en los primeros 20 minutos. Es el paquete que no molesta a los invitados ni al personal del salón, y que produce el efecto justo para un momento puntual.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 cañones de confeti de alta presión</div>
              <div class="prod-feat">Confeti metalizado plateado/dorado</div>
              <div class="prod-feat">1 disparo por cañón (sincronizado)</div>
              <div class="prod-feat">Posicionamiento estratégico</div>
              <div class="prod-feat">Técnico operador en el evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y montaje previo</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos el momento que quieres marcar</h4>
                  <p class="prod-step__desc">Fecha, lugar y el instante exacto donde quieres el disparo: brindis, mordida del pastel, entrada, primer baile. Diseñamos el posicionamiento de los cañones para ese momento específico.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y reserva en 24 horas</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final. Reserva con anticipo del 50%. Fecha bloqueada al confirmar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y esperamos tu señal</h4>
                  <p class="prod-step__desc">El técnico llega 1 hora antes, monta los cañones, prueba presión y espera tu indicación. Tú controlas el momento — nosotros ejecutamos perfecto.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Disparo y desmontaje</h4>
                  <p class="prod-step__desc">En el momento acordado, los dos cañones disparan en sincronía. Después del evento el técnico desmonta el equipo de forma discreta sin interrumpir la celebración.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿2 cañones o 4? Elige según tu evento</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">2 Cañones — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>1 momento especial puntual</li>
                  <li>Espacios pequeños/medianos</li>
                  <li>Eventos íntimos 30-80 personas</li>
                  <li>Impacto focalizado</li>
                  <li>Ideal: mordida, brindis</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">4 Cañones — Paquete siguiente</span>
                <ul class="prod-compare__list">
                  <li>2 momentos especiales</li>
                  <li>Mayor cobertura del salón</li>
                  <li>Eventos 80-150 personas</li>
                  <li>Confeti por toda la pista</li>
                  <li>Ideal: boda completa, XV años</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos los 2 cañones solo para el momento de la mordida del pastel. El técnico esperó exactamente hasta que el fotógrafo estuvo listo y disparó en el segundo perfecto. Las fotos quedaron increíbles — el confeti plateado brilla con el flash. Valió cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sandra y Rodrigo</span>
                <span class="prod-quote__event">Boda en Salón Versalles CDMX — 65 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones</dt><dd>2 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo de confeti</dt><dd>Metalizado</dd></div>
              <div class="ps-specs__row"><dt>Disparos</dt><dd>1 por cañón</dd></div>
              <div class="ps-specs__row"><dt>Duración disparo</dt><dd>8–12 segundos</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Zona focal</dd></div>
              <div class="ps-specs__row"><dt>Operador</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas íntimas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Mordida del pastel</span>
              <span class="ps-tag">Brindis</span>
              <span class="ps-tag">Entrada de novios</span>
              <span class="ps-tag">Cumpleaños sorpresa</span>
              <span class="ps-tag">Revelación de género</span>
              <span class="ps-tag">Aniversarios</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/4-canones.avif" alt="4 Cañones confeti" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cañones</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/biodegradable.avif" alt="Confeti biodegradable eco-friendly" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Confeti Biodegradable</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/produccion.avif" alt="Producción confeti 8 cañones DMX" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda completa con más momentos? El paquete 4 Cañones cubre 2 disparos y mayor cobertura del salón.</p>
              <a href="/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" class="ps-upsell__link">Ver paquete 4 Cañones →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-sonido/dj-para-bodas/" class="ps-link">DJ para Bodas</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
