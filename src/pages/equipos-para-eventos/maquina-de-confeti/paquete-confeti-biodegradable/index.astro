---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Confeti Biodegradable?',
    respuesta: 'Incluye 6 cañones de confeti biodegradable de alta presión, confeti fabricado con papel de seda 100% biodegradable en colores personalizables, posicionamiento estratégico para cobertura completa del área, técnico operador con hasta 3 disparos coordinados y desmontaje al finalizar.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Confeti Biodegradable?',
    respuesta: 'El paquete tiene un precio desde $5,500 MXN + IVA. Incluye transporte, montaje, confeti biodegradable, hasta 3 disparos, operación y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Qué diferencia tiene el confeti biodegradable del confeti metálico tradicional?',
    respuesta: 'El confeti biodegradable está fabricado con papel de seda o almidón de maíz — se desintegra con la humedad en días, no deja residuos plásticos y es apto para jardines, haciendas y espacios al aire libre. Muchos venues con política sustentable o áreas verdes solo permiten confeti biodegradable.'
  },
  {
    pregunta: '¿Funciona el confeti biodegradable en espacios cerrados?',
    respuesta: 'Sí, funciona perfectamente en interiores. La diferencia es ecológica, no visual. El efecto de lluvia de confeti es igual de impactante que el metalizado. En espacios cerrados también se desintegra más rápido al contacto con humedad ambiental.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Confeti Biodegradable?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km de CDMX con cargo por traslado.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Confeti Biodegradable — Máquina de Confeti | REDEIL',
    description: 'Paquete de 6 cañones de confeti biodegradable eco-friendly para bodas sustentables en jardines y haciendas de CDMX. Confeti de papel de seda que no contamina.',
    image: SITE_URL + '/img/paquetes/maquina-de-confeti/biodegradable.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '5500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Confeti Biodegradable — Máquina de Confeti en CDMX | REDEIL"
  description="Paquete de 6 cañones de confeti biodegradable eco-friendly para bodas en jardines y haciendas. Confeti de papel de seda 100% biodegradable. Impacto visual sin impacto ambiental."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Confeti', href: '/equipos-para-eventos/maquina-de-confeti/' }, { name: 'Confeti Biodegradable', href: '/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/' }]} />

  <Hero
    badge="Confeti Biodegradable — Eco-friendly"
    title="6 Cañones de Confeti Biodegradable — Impacto Visual sin Impacto Ambiental"
    description="Seis cañones de confeti fabricado con papel de seda 100% biodegradable. El mismo efecto visual impactante, sin residuos plásticos, sin contaminar el jardín. Ideal para bodas sustentables en haciendas y venues al aire libre."
    primaryCta={{ text: 'Cotizar $5,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-confeti/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete de confeti biodegradable</strong> es la solución para parejas que quieren el espectáculo visual del confeti sin comprometer su compromiso con el medio ambiente o violar la política de su venue. Muchos jardines y haciendas en CDMX prohíben el confeti metálico — el biodegradable es bienvenido porque se desintegra con la humedad en días sin dejar residuos.</p>
      <p>Con <strong>6 cañones posicionados estratégicamente</strong> y hasta 3 disparos coordinados, este paquete genera una cobertura masiva que envuelve a todos los invitados. El confeti de papel de seda refleja la luz de manera diferente al metalizado — el efecto es más suave, más orgánico, y encaja perfectamente con la estética de bodas en jardín.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Confeti"
    items={[{ label: "2 Cañones", href: "/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/" }, { label: "4 Cañones", href: "/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" }, { label: "Producción", href: "/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/maquina-de-confeti/biodegradable.avif" alt="Confeti biodegradable de papel de seda en boda jardín hacienda" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/maquina-de-confeti.avif" alt="Cañones de confeti biodegradable en hacienda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/confeti-metalizado.avif" alt="Confeti biodegradable en colores pasteles cayendo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/momento-brindis.avif" alt="Boda al aire libre con lluvia de confeti biodegradable" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/tecnico-operador.avif" alt="6 cañones biodegradables posicionados en jardín" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Eco-Friendly — 6 cañones, impacto sin huella</span>
            <h2 class="prod-info__title">6 Cañones de Confeti Biodegradable con hasta 3 Disparos</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$5,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, confeti biodegradable, 3 disparos, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La boda sustentable no renuncia al espectáculo — lo hace mejor</h2>
            <p class="prod-selling__intro">El confeti biodegradable no es un compromiso inferior al metálico — es una elección distinta. El papel de seda produce una caída más suave y etérea que encaja perfectamente con la estética romántica de bodas al aire libre. Y el hecho de que se disuelva en días, no en décadas, lo hace aceptable en prácticamente cualquier venue con política sustentable.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Aceptado en jardines, haciendas y venues con política verde</h3>
                  <p class="prod-hl__desc">Muchos venues en CDMX, Cuernavaca y Tepoztlán prohíben el confeti metálico por el daño al suelo y las plantas. El biodegradable está permitido en casi todos porque se desintegra de forma natural sin contaminar. Confirma con tu venue antes de elegir — nosotros podemos asesorarte.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">6 cañones = cobertura total del espacio</h3>
                  <p class="prod-hl__desc">Con 6 unidades posicionadas en puntos estratégicos del área, el confeti llega a todos los invitados simultáneamente. No hay zona muerta ni esquina donde el efecto no llegue. Es el paquete que hace que toda la sala se sienta parte del momento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Colores personalizables según tu paleta de boda</h3>
                  <p class="prod-hl__desc">El confeti biodegradable viene en una amplia gama de colores: blanco, marfil, dorado, rosé, lila, verde salvia. Podemos combinarlo con tu paleta cromática para que el confeti sea parte del diseño visual de tu boda, no solo un efecto genérico.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Hasta 3 disparos coordinados — más momentos, más memorias</h3>
                  <p class="prod-hl__desc">Con 3 recargas tienes flexibilidad para marcar los momentos más importantes de la noche: entrada de novios, brindis y apertura de pista. El técnico coordina cada disparo según tu programa, con recargas rápidas entre momentos.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">6 cañones de confeti de alta presión</div>
              <div class="prod-feat">Confeti 100% biodegradable</div>
              <div class="prod-feat">Hasta 3 disparos coordinados</div>
              <div class="prod-feat">Color personalizable según boda</div>
              <div class="prod-feat">Posicionamiento estratégico</div>
              <div class="prod-feat">Técnico operador en el evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y montaje previo</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Asesoría de color y momentos</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Elige tu paleta de colores y momentos</h4>
                  <p class="prod-step__desc">Comparte tu paleta de boda y los 3 momentos que quieres marcar. Seleccionamos el confeti que complementa tu decoración y diseñamos el posicionamiento de los 6 cañones.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y reserva en 24 horas</h4>
                  <p class="prod-step__desc">Propuesta con color de confeti, posicionamiento y precio final. Reserva con anticipo del 50%. Fecha bloqueada al confirmar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje coordinado con tu decorador</h4>
                  <p class="prod-step__desc">El técnico llega con anticipación y coordina la posición de los cañones con tu decorador o coordinador de evento para que no interfieran con la decoración.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">3 disparos perfectos, sin residuos duraderos</h4>
                  <p class="prod-step__desc">El operador ejecuta cada disparo en el momento indicado. El confeti biodegradable se integra al ambiente del jardín y se disuelve de forma natural en días.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">Biodegradable vs Metalizado — ¿cuál es tu boda?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Confeti Metalizado</span>
                <ul class="prod-compare__list">
                  <li>Brillo metálico en fotos</li>
                  <li>Solo en interiores</li>
                  <li>Plástico o aluminio</li>
                  <li>Prohibido en muchos jardines</li>
                  <li>Persiste en el suelo</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Confeti Biodegradable — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>Caída suave y etérea</li>
                  <li>Interior y exterior</li>
                  <li>Papel de seda natural</li>
                  <li>Permitido en jardines</li>
                  <li>Se disuelve en días</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"La hacienda donde tuvimos la boda solo permitía confeti biodegradable. REDEIL nos ofreció confeti color blanco marfil y verde salvia que combinaba perfectamente con nuestros arreglos florales. El efecto con los 6 cañones fue impresionante — el fotógrafo dijo que era la lluvia de confeti más fotogénica que había visto. Y al día siguiente el jardín estaba limpio."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Fernanda y Arturo</span>
                <span class="prod-quote__event">Boda en Hacienda Temixco, Morelos — 140 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones</dt><dd>6 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo de confeti</dt><dd>Biodegradable</dd></div>
              <div class="ps-specs__row"><dt>Material</dt><dd>Papel de seda</dd></div>
              <div class="ps-specs__row"><dt>Disparos</dt><dd>Hasta 3</dd></div>
              <div class="ps-specs__row"><dt>Colores</dt><dd>Personalizable</dd></div>
              <div class="ps-specs__row"><dt>Uso</dt><dd>Interior y exterior</dd></div>
              <div class="ps-specs__row"><dt>Operador</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en jardín</span>
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Venues sustentables</span>
              <span class="ps-tag">Bodas al aire libre</span>
              <span class="ps-tag">Bodas en Tepoztlán</span>
              <span class="ps-tag">Bodas en Valle de Bravo</span>
              <span class="ps-tag">XV años en hacienda</span>
              <span class="ps-tag">Eventos eco-friendly</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/2-canones.avif" alt="2 Cañones confeti" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Cañones</span>
                <span class="ps-pkg__price">$2,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/4-canones.avif" alt="4 Cañones confeti metalizado" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cañones</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/produccion.avif" alt="Producción confeti 8+ cañones DMX" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Producción completa con DMX y más de 8 cañones? El paquete Producción es para shows de alto impacto.</p>
              <a href="/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-sonido/dj-para-bodas/" class="ps-link">DJ para Bodas</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
