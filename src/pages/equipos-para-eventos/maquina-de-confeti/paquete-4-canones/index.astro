---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 4 Cañones de Máquina de Confeti?',
    respuesta: 'Incluye 4 cañones de confeti de alta presión, 2 recargas de confeti metalizado (uno por momento), posicionamiento estratégico en dos puntos del salón, técnico operador que coordina los disparos y desmontaje al finalizar. Puedes elegir los 2 momentos que quieres marcar.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 4 Cañones?',
    respuesta: 'El paquete tiene un precio desde $3,500 MXN + IVA. Incluye transporte, montaje, 2 operaciones y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Cuáles son los 2 momentos recomendados para el paquete 4 Cañones?',
    respuesta: 'Los más populares: brindis + mordida del pastel, entrada de novios + primer baile, o apertura de pista + cierre de evento. Tú decides cuándo y el técnico ejecuta perfectamente en ambos instantes.'
  },
  {
    pregunta: '¿El paquete 4 Cañones funciona en espacios grandes como salones con 150 personas?',
    respuesta: 'Sí. Con 4 cañones posicionados en dos puntos del salón, el confeti cubre una área mayor y llega a más invitados. Es el paquete ideal para bodas y XV años con 80 a 150 invitados en salones estándar.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 4 Cañones?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km de CDMX con cargo por traslado.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '4 Cañones — Máquina de Confeti | REDEIL',
    description: 'Paquete de 4 cañones de confeti para 2 momentos especiales o cobertura amplia del salón. Ideal para bodas y XV años de 80-150 personas en CDMX.',
    image: SITE_URL + '/img/paquetes/maquina-de-confeti/4-canones.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '51',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="4 Cañones — Máquina de Confeti en CDMX | REDEIL"
  description="Paquete de 4 cañones de confeti para 2 momentos especiales o cobertura amplia del salón. Ideal para bodas y XV años con 80-150 invitados en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Máquina de Confeti', href: '/equipos-para-eventos/maquina-de-confeti/' }, { name: '4 Cañones', href: '/equipos-para-eventos/maquina-de-confeti/paquete-4-canones/' }]} />

  <Hero
    badge="4 Cañones — El más popular"
    title="4 Cañones — Confeti en 2 Momentos o Cobertura Amplia del Salón"
    description="Cuatro cañones posicionados estratégicamente para 2 momentos especiales o para cubrir toda la pista de baile. El paquete que eligen la mayoría de bodas y XV años en CDMX."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/maquina-de-confeti/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete 4 Cañones de confeti</strong> es la elección más popular para <strong>bodas y XV años en CDMX</strong> porque resuelve dos necesidades a la vez: puedes marcar 2 momentos distintos durante la noche, o posicionar los 4 cañones juntos para una cobertura masiva en la pista de baile. Más confeti, más área cubierta, más invitados dentro del efecto.</p>
      <p>Un técnico operador coordina ambos disparos según tu programa de evento. Tú defines los momentos, él ejecuta con precisión. El resultado: dos explosiones de confeti que tu fotógrafo puede anticipar y capturar desde el ángulo perfecto.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Máquina de Confeti"
    items={[{ label: "2 Cañones", href: "/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/" }, { label: "Confeti Biodegradable", href: "/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" }, { label: "Producción", href: "/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/maquina-de-confeti/4-canones.avif" alt="4 cañones de confeti en boda con cobertura amplia del salón" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/maquina-de-confeti.avif" alt="Cañón de confeti profesional disparando" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/confeti-metalizado.avif" alt="Confeti metalizado cubriendo pista de baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/momento-brindis.avif" alt="Brindis con explosión de confeti en boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/maquina-de-confeti/sell/tecnico-operador.avif" alt="Operador de confeti preparando segundo disparo" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Más Popular — 2 momentos + cobertura amplia</span>
            <h2 class="prod-info__title">4 Cañones de Confeti Metalizado para 2 Momentos Especiales</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, montaje, 2 disparos coordinados, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Dos explosiones de confeti. Dos momentos que nadie va a olvidar.</h2>
            <p class="prod-selling__intro">Con 4 cañones tienes dos caminos: posicionarlos en dos puntos del salón para marcar momentos distintos — brindis en la mesa de honor, apertura de pista en la pista de baile — o agruparlos en un solo punto para una lluvia masiva de confeti que llega a toda la sala. Ambas estrategias funcionan. Tú eliges según tu evento.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 disparos coordinados — brindis y pista, o dos sorpresas</h3>
                  <p class="prod-hl__desc">El técnico opera desde una posición central y coordina ambos disparos según tu programa. Si el primer momento se retrasa 15 minutos, esperamos. La segunda recarga está lista para cuando la necesites.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura para salones de 80 a 150 invitados</h3>
                  <p class="prod-hl__desc">4 cañones en sincronía generan una cortina de confeti de 8 a 10 metros de ancho. Suficiente para cubrir una pista de baile estándar y que todos los invitados sientan el efecto, no solo los que están cerca.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Confeti metalizado dorado y plateado — brilla en fotos y video</h3>
                  <p class="prod-hl__desc">El confeti metalizado refleja perfectamente la iluminación del salón y el flash del fotógrafo. En video queda como lluvia de luz. Tus memorias de ese momento van a lucir exactamente como las que ves en Pinterest.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Estrategia de posicionamiento incluida</h3>
                  <p class="prod-hl__desc">Antes del evento revisamos el plano del salón contigo y definimos la posición óptima de cada cañón para maximizar el efecto visual. No improvisamos — llegamos con un plan.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 cañones de confeti de alta presión</div>
              <div class="prod-feat">2 recargas de confeti metalizado</div>
              <div class="prod-feat">2 disparos coordinados</div>
              <div class="prod-feat">Posicionamiento estratégico</div>
              <div class="prod-feat">Técnico operador en el evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y montaje previo</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Asesoría de momentos incluida</div>
              <div class="prod-feat">Repuestos y recambios en sitio</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Define los 2 momentos que quieres marcar</h4>
                  <p class="prod-step__desc">Brindis y mordida, entrada y pista, sorpresa y cierre — tú decides. Con esa información diseñamos el posicionamiento de los 4 cañones para maximizar el impacto en cada momento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y reserva en 24 horas</h4>
                  <p class="prod-step__desc">Propuesta detallada con precio final. Reserva con anticipo del 50%. Fecha bloqueada al confirmar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje estratégico 1 hora antes</h4>
                  <p class="prod-step__desc">El técnico llega con tiempo, monta los 4 cañones en posición, carga las dos recargas y confirma comunicación contigo para los disparos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Dos disparos perfectos y desmontaje limpio</h4>
                  <p class="prod-step__desc">El operador ejecuta cada disparo en el momento exacto. Al terminar, desmonta discretamente sin interrumpir el evento.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">4 Cañones vs Confeti Biodegradable — ¿cuál te conviene?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">4 Cañones — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>2 momentos puntales</li>
                  <li>Confeti metalizado clásico</li>
                  <li>Espacios cerrados</li>
                  <li>Bodas, XV años, fiestas</li>
                  <li>$3,500 MXN</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Biodegradable — Siguiente nivel</span>
                <ul class="prod-compare__list">
                  <li>6 cañones, mayor impacto</li>
                  <li>Confeti eco-friendly</li>
                  <li>Jardines y espacios abiertos</li>
                  <li>Bodas sustentables</li>
                  <li>$5,500 MXN</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Usamos los 4 cañones en dos momentos: el vals y la apertura de pista. El técnico estaba pendiente de todo y disparó justo cuando el DJ cambió la música. Los 120 invitados lo vivieron al mismo tiempo — fue la parte que más recordaron de la noche. Las fotos quedaron impresionantes."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Valeria y Emilio</span>
                <span class="prod-quote__event">Boda en Hacienda San Ángel — 120 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones</dt><dd>4 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo de confeti</dt><dd>Metalizado</dd></div>
              <div class="ps-specs__row"><dt>Disparos</dt><dd>2 coordinados</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>8-10 metros ancho</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>80-150 invitados</dd></div>
              <div class="ps-specs__row"><dt>Operador</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas 80-150 personas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Apertura de pista</span>
              <span class="ps-tag">Vals</span>
              <span class="ps-tag">Brindis + mordida</span>
              <span class="ps-tag">Fiestas de empresa</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Cumpleaños 50+</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-2-canones/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/2-canones.avif" alt="2 Cañones confeti" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Cañones</span>
                <span class="ps-pkg__price">$2,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/biodegradable.avif" alt="Confeti biodegradable eco-friendly" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Confeti Biodegradable</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/maquina-de-confeti/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/maquina-de-confeti/produccion.avif" alt="Producción confeti 8+ cañones DMX" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Venue al aire libre o compromiso con el medio ambiente? El Biodegradable usa confeti eco-friendly en 6 cañones.</p>
              <a href="/equipos-para-eventos/maquina-de-confeti/paquete-confeti-biodegradable/" class="ps-upsell__link">Ver Confeti Biodegradable →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-sonido/dj-para-bodas/" class="ps-link">DJ para Bodas</a>
              <a href="/equipos-para-eventos/bolas-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; margin-bottom: 2.5rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
  .prod-includes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
