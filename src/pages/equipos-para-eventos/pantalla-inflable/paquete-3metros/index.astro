---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Pantalla 3 metros de Cine al Aire Libre?',
    respuesta: 'Incluye pantalla inflable de 3 metros diagonal, proyector HD 3500 lúmenes, audio estéreo integrado, soplador eléctrico silencioso, transporte, instalación profesional, operación durante el evento y desmontaje. Equipo probado y listo para usar en tu jardín o patio.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Pantalla 3 metros?',
    respuesta: 'El paquete tiene un precio desde $3,000 MXN + IVA. Precio todo incluido: transporte, montaje, operación y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para cuántas personas alcanza la pantalla de 3 metros?',
    respuesta: 'La pantalla de 3 metros diagonal es ideal para grupos de 30 a 50 personas. Funciona perfectamente en jardines pequeños, patios y terrazas. Para eventos más grandes, recomendamos el paquete de 5 metros o superior.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Pantalla 3 metros?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 2 a 4 semanas de anticipación. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento y confirmamos en minutos.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Pantalla 3 metros — Cine al Aire Libre | REDEIL',
    description: 'Renta de pantalla inflable 3 metros con proyector HD para cine al aire libre en jardines y patios de CDMX. Ideal para 30-50 personas. Instalación profesional incluida.',
    image: SITE_URL + '/img/img-index/pantalla-inflable.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/pantalla-inflable/paquete-3metros/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '34',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Pantalla Inflable 3 metros — Cine al Aire Libre en CDMX | REDEIL"
  description="Renta pantalla inflable 3 metros con proyector HD para cine al aire libre. Ideal para 30-50 personas en jardines y patios de CDMX. Instalación y operación incluida."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Pantalla Inflable', href: '/equipos-para-eventos/pantalla-inflable/' }, { name: 'Pantalla 3 metros', href: '/equipos-para-eventos/pantalla-inflable/paquete-3metros/' }]} />

  <Hero
    badge="Pantalla 3 metros — Cine al Aire Libre"
    title="Pantalla Inflable 3 metros — Cine al Aire Libre"
    description="La opción perfecta para jardines y patios. Pantalla inflable de 3 metros diagonal con proyector HD para grupos de 30 a 50 personas. Instalación incluida en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $3,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/pantalla-inflable/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de <strong>pantalla inflable 3 metros</strong> convierte cualquier jardín o patio en un <strong>cine al aire libre</strong> con imagen de alta definición. Con proyector HD de 3500 lúmenes y audio estéreo integrado, creates una experiencia cinematográfica para tus invitados en <strong>CDMX y Estado de México</strong>.</p>
      <p>Ideal para cumpleaños infantiles, noches de película en familia, reuniones entre amigos y pequeños eventos privados. Nuestro equipo instala todo en menos de 45 minutos: pantalla, proyector, audio y cable. Tú solo elige la película.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Pantalla Inflable"
    items={[{ label: "Pantalla 5 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-5metros/" }, { label: "Pantalla 8 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-8metros/" }, { label: "Producción 12m+", href: "/equipos-para-eventos/pantalla-inflable/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/pantalla-inflable/3metros.avif" alt="Pantalla inflable 3 metros cine al aire libre jardín" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/pantalla-inflable.avif" alt="Cine al aire libre pantalla inflable noche" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/proyector-hd.avif" alt="Proyector HD 3500 lúmenes para pantalla inflable" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/montaje.avif" alt="Técnico instalando pantalla inflable en jardín" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/familia.avif" alt="Familia viendo película en pantalla inflable jardín" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Jardín — El más accesible</span>
            <h2 class="prod-info__title">Pantalla Inflable 3 metros con Proyector HD y Audio Estéreo</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, montaje, proyector HD, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cine en tu jardín desde $3,000 — sin complicaciones</h2>
            <p class="prod-selling__intro">Una pantalla de 3 metros diagonal crea una experiencia cinematográfica real para hasta 50 personas. No es una sábana y un proyector casero: es equipo profesional con imagen HD nítida incluso con algo de luz ambiente. Lo montamos, lo operamos y lo retiramos — tú solo disfrutas la noche.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Proyector HD 3500 lúmenes — imagen nítida al anochecer</h3>
                  <p class="prod-hl__desc">Con 3500 lúmenes proyectamos imagen HD clara apenas cae el sol. No necesitas oscuridad total: desde las 7:30pm ya tienes una película nítida y brillante sobre la pantalla inflable. Perfecto para eventos que empiezan con algo de luz.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Pantalla inflable profesional — imagen perfectamente plana</h3>
                  <p class="prod-hl__desc">La tela especial tensada uniformemente elimina arrugas y distorsiones. La imagen se mantiene plana, centrada y sin bordes oscuros. Se auto-infla en 5 minutos con el soplador silencioso y se mantiene firme durante todo el evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Audio estéreo integrado — se escucha en todo el jardín</h3>
                  <p class="prod-hl__desc">Las bocinas estéreo llenan el espacio con sonido limpio y equilibrado. Volumen adecuado para 50 personas sin molestar a los vecinos. Conexión HDMI directa desde laptop, Chromecast, Apple TV o cualquier dispositivo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">45 minutos de instalación — sin estorbar tu evento</h3>
                  <p class="prod-hl__desc">Llegamos 1.5 horas antes, instalamos la pantalla, calibramos proyector y audio, hacemos prueba de imagen y dejamos todo listo. Cuando lleguen tus invitados ya está funcionando. Discreción y rapidez garantizadas.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Pantalla inflable 3m diagonal</div>
              <div class="prod-feat">Proyector HD 3500 lúmenes</div>
              <div class="prod-feat">Audio estéreo 2 bocinas</div>
              <div class="prod-feat">Soplador eléctrico silencioso</div>
              <div class="prod-feat">Cables HDMI y extensiones</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador en sitio</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Soporte técnico durante el evento</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, dirección, número de invitados y qué quieres proyectar. Con esos datos confirmamos disponibilidad y te enviamos cotización en menos de 2 horas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirma y aparta tu fecha</h4>
                  <p class="prod-step__desc">Reserva con anticipo del 50%. Tu fecha queda bloqueada y te enviamos confirmación con todos los detalles del servicio por escrito.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 1.5 horas antes</h4>
                  <p class="prod-step__desc">Instalamos pantalla, proyector y audio. Calibramos imagen y sonido, hacemos prueba completa. Cuando lleguen tus invitados, todo está listo y funcionando.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Disfrutas la noche, nosotros cuidamos el equipo</h4>
                  <p class="prod-step__desc">El técnico permanece durante la función, controla el equipo y resuelve cualquier imprevisto. Al finalizar, desmontamos todo sin dejar rastro.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Cuándo elegir 3 metros y cuándo el de 5?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Pantalla 3 metros</span>
                <ul class="prod-compare__list">
                  <li>Jardines y patios pequeños</li>
                  <li>30-50 personas</li>
                  <li>Audio estéreo básico</li>
                  <li>Proyector HD 3500 lm</li>
                  <li>El más económico</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Pantalla 5 metros</span>
                <ul class="prod-compare__list">
                  <li>Jardines medianos</li>
                  <li>50-100 personas</li>
                  <li>Audio profesional incluido</li>
                  <li>Proyector Full HD 5000 lm</li>
                  <li>Mayor impacto visual</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Rentamos la pantalla de 3 metros para el cumpleaños de mi hija en el jardín de la casa. Invitamos a 35 niños y sus papás. La imagen se veía perfectísima, el técnico estuvo ahí todo el tiempo y al final recogió todo. Mis vecinos me preguntan dónde la renté porque quieren hacer lo mismo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sofía Mendoza</span>
                <span class="prod-quote__event">Cumpleaños infantil en jardín — Coyoacán, 38 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Tamaño pantalla</dt><dd>3m diagonal</dd></div>
              <div class="ps-specs__row"><dt>Proyector</dt><dd>HD 3500 lúmenes</dd></div>
              <div class="ps-specs__row"><dt>Resolución</dt><dd>HD 720p/1080p</dd></div>
              <div class="ps-specs__row"><dt>Audio</dt><dd>Estéreo 2 bocinas</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>30-50 personas</dd></div>
              <div class="ps-specs__row"><dt>Espacio mínimo</dt><dd>4×4 metros</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Cumpleaños infantiles</span>
              <span class="ps-tag">Noches de película</span>
              <span class="ps-tag">Reuniones familiares</span>
              <span class="ps-tag">Jardines pequeños</span>
              <span class="ps-tag">Fiestas entre amigos</span>
              <span class="ps-tag">Patios y terrazas</span>
              <span class="ps-tag">Eventos íntimos</span>
              <span class="ps-tag">Proyecciones privadas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-5metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/5metros.avif" alt="Pantalla 5 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 5 metros</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-8metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/8metros.avif" alt="Pantalla 8 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 8 metros</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/produccion.avif" alt="Producción 12m+" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción 12m+</span>
                <span class="ps-pkg__price">$18,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Más de 50 personas? El paquete de 5 metros incluye proyector Full HD y audio profesional para el doble de audiencia.</p>
              <a href="/equipos-para-eventos/pantalla-inflable/paquete-5metros/" class="ps-upsell__link">Ver paquete 5 metros →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 2 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/mesas-picnic/" class="ps-link">Mesas Picnic</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/" class="ps-link">Bocinas para Fiestas</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }

