---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de Producción de Pantalla Inflable?',
    respuesta: 'Incluye pantalla inflable de 12 metros o más según el espacio, proyector láser de alta potencia, sistema de audio line array profesional, técnico de producción dedicado, estructura de soporte industrial, cables y conexiones de producción, transporte, instalación y desmontaje. Solución completa para festivales y eventos masivos.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de Producción?',
    respuesta: 'El paquete de Producción tiene un precio desde $18,000 MXN + IVA. El precio final depende del tamaño exacto de pantalla requerido, configuración de audio line array y logística del evento. Cotizamos a medida para cada proyecto.'
  },
  {
    pregunta: '¿Para cuántas personas es el paquete de Producción?',
    respuesta: 'El paquete de Producción está diseñado para eventos de 200 personas en adelante. Con pantalla de 12m+ y proyector láser, cubre auditorios al aire libre, festivales privados, eventos corporativos masivos y cualquier producción de gran formato.'
  },
  {
    pregunta: '¿Qué es el audio line array y por qué lo necesito en eventos grandes?',
    respuesta: 'El line array es un sistema de bocinas apiladas verticalmente que distribuye el sonido de forma homogénea a lo largo de toda la audiencia, sin importar si estás a 5 o 50 metros de la fuente. Elimina las zonas muertas y los picos de volumen, garantizando que todos los asistentes escuchen con la misma claridad.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete de Producción?',
    respuesta: 'Para el paquete de Producción recomendamos 6 a 8 semanas de anticipación. Incluye visita técnica previa al venue para diseñar la instalación óptima. Contáctanos por WhatsApp para iniciar el proceso de cotización personalizada.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — Pantalla Inflable 12m+ | REDEIL',
    description: 'Renta de pantalla inflable 12 metros o más con proyector láser y audio line array para eventos masivos en CDMX. Técnico de producción dedicado. Festivales, eventos corporativos y producciones de gran formato.',
    image: SITE_URL + '/img/img-index/pantalla-inflable.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '18000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/pantalla-inflable/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '17',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Pantalla Inflable Producción 12m+ — Proyector Láser y Line Array en CDMX | REDEIL"
  description="Renta pantalla inflable 12m+ con proyector láser y audio line array para eventos masivos en CDMX. Técnico de producción dedicado. Festivales y producciones desde $18,000."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Pantalla Inflable', href: '/equipos-para-eventos/pantalla-inflable/' }, { name: 'Producción 12m+', href: '/equipos-para-eventos/pantalla-inflable/paquete-produccion/' }]} />

  <Hero
    badge="Producción 12m+ — Nivel festival"
    title="Pantalla Inflable Producción — Proyector Láser y Line Array"
    description="La solución para eventos masivos. Pantalla inflable 12 metros o más, proyector láser de alta potencia y audio line array profesional. Técnico de producción dedicado. Para festivales, eventos corporativos y producciones de gran escala en CDMX."
    primaryCta={{ text: 'Cotizar $18,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/pantalla-inflable/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de <strong>Producción</strong> es para quienes no aceptan compromisos: <strong>pantalla inflable de 12 metros o más</strong>, <strong>proyector láser</strong> con brillo y color estables durante horas, y <strong>audio line array</strong> que distribuye el sonido de forma homogénea para miles de espectadores. La solución que usan las productoras de eventos en <strong>CDMX y todo México</strong>.</p>
      <p>Incluye técnico de producción dedicado que coordina con tu equipo de producción, visita técnica previa al venue y diseño personalizado de la instalación. Cada detalle se planea para que la ejecución sea perfecta el día del evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Pantalla Inflable"
    items={[{ label: "Pantalla 3 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-3metros/" }, { label: "Pantalla 5 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-5metros/" }, { label: "Pantalla 8 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-8metros/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/pantalla-inflable/produccion.avif" alt="Pantalla inflable producción 12 metros festival cine al aire libre" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/pantalla-inflable.avif" alt="Producción pantalla inflable gran formato" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/proyector-laser.avif" alt="Proyector láser alta potencia para pantalla inflable 12 metros" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/line-array.avif" alt="Sistema de audio line array profesional para eventos masivos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/festival.avif" alt="Festival al aire libre con pantalla inflable producción" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Producción — Nivel profesional</span>
            <h2 class="prod-info__title">Pantalla Inflable 12m+ con Proyector Láser y Audio Line Array</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$18,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Desde $18,000 — precio final según tamaño de pantalla y configuración de audio. Cotización personalizada incluida.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">La tecnología que usan los festivales de cine al aire libre</h2>
            <p class="prod-selling__intro">El proyector láser no se degrada con el uso: mismo brillo y mismos colores en la primera hora que en la quinta. El line array no tiene zonas sin sonido: el espectador de la primera fila y el de la última escuchan con la misma calidad. A esta escala, no hay margen para compromiso — y este paquete no lo tiene.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Proyector láser — brillo y color estables durante todo el evento</h3>
                  <p class="prod-hl__desc">A diferencia de los proyectores de lámpara, el láser mantiene el mismo nivel de brillo y calibración de color durante toda la proyección. Sin degradación en la segunda hora, sin cambios de temperatura de color. La imagen se ve igual a las 9pm que a la medianoche.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Audio line array — sonido homogéneo para toda la audiencia</h3>
                  <p class="prod-hl__desc">El sistema line array distribuye el sonido verticalmente con pérdida de 3dB cada vez que se dobla la distancia, frente a los 6dB de un sistema convencional. Resultado: la persona de la última fila escucha casi al mismo volumen que la primera, sin necesidad de subir hasta distorsionar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Pantalla 12m+ — visible desde 100 metros de distancia</h3>
                  <p class="prod-hl__desc">A esta escala, la pantalla domina el horizonte visual del evento. No hay ángulo malo, no hay espectador que no vea. La estructura de soporte industrial garantiza tensión perfecta y estabilidad incluso con viento moderado. Se puede instalar en parques abiertos sin estructuras de soporte adicionales.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico de producción — un especialista dedicado exclusivamente a tu evento</h3>
                  <p class="prod-hl__desc">El técnico de producción hace visita previa al venue, diseña el layout de pantalla y audio, coordina con tu equipo de producción el día del evento y opera el sistema en tiempo real. No es un técnico que también atiende otros eventos — está exclusivamente en el tuyo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Pantalla inflable 12m+ diagonal</div>
              <div class="prod-feat">Proyector láser alta potencia</div>
              <div class="prod-feat">Sistema audio line array</div>
              <div class="prod-feat">Soplador industrial de alta presión</div>
              <div class="prod-feat">Estructura de soporte industrial</div>
              <div class="prod-feat">Cables y conexiones de producción</div>
              <div class="prod-feat">Visita técnica previa al venue</div>
              <div class="prod-feat">Diseño personalizado de instalación</div>
              <div class="prod-feat">Técnico de producción dedicado</div>
              <div class="prod-feat">Transporte, montaje y desmontaje</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio de Producción</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Briefing inicial del proyecto</h4>
                  <p class="prod-step__desc">Fecha, venue, número de asistentes, programa del evento y requerimientos técnicos. Con esta información preparamos una propuesta técnica detallada y cotización en menos de 48 horas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Visita técnica al venue</h4>
                  <p class="prod-step__desc">El técnico de producción visita el espacio para medir, evaluar superficies, planear el layout de pantalla y audio, e identificar tomas de corriente y logística de acceso. Sin sorpresas el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje profesional el día del evento</h4>
                  <p class="prod-step__desc">Llegamos 4 horas antes del evento. Montamos pantalla, instalar line array, calibramos proyector láser y hacemos prueba técnica completa. Todo listo y checado antes de que abran puertas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Operación y coordinación en tiempo real</h4>
                  <p class="prod-step__desc">El técnico opera el sistema durante el evento, coordina con dirección de producción y resuelve cualquier imprevisto técnico en tiempo real. Al finalizar, desmontaje profesional sin alterar el cierre del evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué Producción y no el paquete de 8 metros?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Pantalla 8 metros</span>
                <ul class="prod-compare__list">
                  <li>Hasta 200 personas</li>
                  <li>Audio envolvente estándar</li>
                  <li>Proyector 4K convencional</li>
                  <li>Técnico dedicado incluido</li>
                  <li>Sin visita técnica previa</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción 12m+</span>
                <ul class="prod-compare__list">
                  <li>200+ personas sin límite</li>
                  <li>Audio line array profesional</li>
                  <li>Proyector láser estable</li>
                  <li>Técnico de producción senior</li>
                  <li>Visita técnica y diseño previo</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos el cine de clausura de nuestro festival de cultura con 350 asistentes en el parque. REDEIL hizo la visita técnica una semana antes, diseñaron el layout de audio para el espacio irregular y el día del evento todo funcionó a la perfección. El proyector láser se veía espectacular incluso con algo de neblina. Profesionales de primer nivel."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Miguel Ángel Torres</span>
                <span class="prod-quote__event">Festival de Cultura al Aire Libre — Parque Hundido, 350 asistentes</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Tamaño pantalla</dt><dd>12m+ diagonal</dd></div>
              <div class="ps-specs__row"><dt>Proyector</dt><dd>Láser alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Resolución</dt><dd>4K / según evento</dd></div>
              <div class="ps-specs__row"><dt>Audio</dt><dd>Line array profesional</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>200+ personas</dd></div>
              <div class="ps-specs__row"><dt>Espacio mínimo</dt><dd>15×15 metros</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>De producción senior</dd></div>
              <div class="ps-specs__row"><dt>Visita previa</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX y todo México</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Festivales al aire libre</span>
              <span class="ps-tag">Eventos corporativos masivos</span>
              <span class="ps-tag">Conciertos con pantalla</span>
              <span class="ps-tag">Cierres de congreso</span>
              <span class="ps-tag">Bodas en hacienda grande</span>
              <span class="ps-tag">200+ personas</span>
              <span class="ps-tag">Producciones profesionales</span>
              <span class="ps-tag">Parques y plazas abiertas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-3metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/3metros.avif" alt="Pantalla 3 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 3 metros</span>
                <span class="ps-pkg__price">$3,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-5metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/5metros.avif" alt="Pantalla 5 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 5 metros</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-8metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/8metros.avif" alt="Pantalla 8 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 8 metros</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">Para eventos más pequeños, el paquete de 8 metros cubre hasta 200 personas con proyector 4K y audio envolvente.</p>
              <a href="/equipos-para-eventos/pantalla-inflable/paquete-8metros/" class="ps-upsell__link">Ver paquete 8 metros →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización técnica personalizada en menos de 48 horas. Incluye visita al venue.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/mesas-picnic/" class="ps-link">Mesas Picnic</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/" class="ps-link">Bocinas para Fiestas</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
