---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Pantalla 8 metros de Cine al Aire Libre?',
    respuesta: 'Incluye pantalla inflable de 8 metros diagonal, proyector 4K de alta potencia, sistema de audio envolvente multicanal, soplador industrial, estructura de soporte reforzada, transporte, instalación profesional, técnico operador durante el evento y desmontaje. Experiencia cinematográfica real para hasta 200 personas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Pantalla 8 metros?',
    respuesta: 'El paquete tiene un precio desde $9,000 MXN + IVA. Todo incluido: transporte, montaje, proyector 4K, audio envolvente, técnico operador, desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para cuántas personas es la pantalla de 8 metros?',
    respuesta: 'La pantalla de 8 metros es ideal para eventos de 100 a 200 personas. Perfecta para cine al aire libre en parques, haciendas grandes, eventos corporativos y festivales privados. Para producciones de mayor escala, consulta nuestro paquete de Producción con pantalla de 12m+.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Pantalla 8 metros?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX. Para eventos fuera de este radio, consultamos costo de traslado.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete 8 metros?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación. El equipo de 8 metros tiene alta demanda en temporada alta. Para fechas próximas, contáctanos por WhatsApp para verificar disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Pantalla 8 metros — Cine al Aire Libre | REDEIL',
    description: 'Renta de pantalla inflable 8 metros con proyector 4K y audio envolvente para cine al aire libre en CDMX. Ideal para 100-200 personas en haciendas y eventos grandes. Instalación y técnico incluidos.',
    image: SITE_URL + '/img/img-index/pantalla-inflable.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '9000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/pantalla-inflable/paquete-8metros/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Pantalla Inflable 8 metros — Cine al Aire Libre en CDMX | REDEIL"
  description="Renta pantalla inflable 8 metros con proyector 4K y audio envolvente para eventos de 100-200 personas en CDMX. Técnico incluido. Instalación profesional desde $9,000."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Pantalla Inflable', href: '/equipos-para-eventos/pantalla-inflable/' }, { name: 'Pantalla 8 metros', href: '/equipos-para-eventos/pantalla-inflable/paquete-8metros/' }]} />

  <Hero
    badge="Pantalla 8 metros — Experiencia cinematográfica"
    title="Pantalla Inflable 8 metros — Cine al Aire Libre"
    description="La experiencia cinematográfica real para eventos grandes. Pantalla de 8 metros con proyector 4K y audio envolvente para 100 a 200 personas. Técnico dedicado incluido en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $9,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/pantalla-inflable/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>pantalla inflable de 8 metros</strong> no es una pantalla más grande — es una experiencia completamente diferente. La imagen <strong>4K</strong> a esa escala captura la atención de 200 personas al mismo tiempo, y el <strong>audio envolvente</strong> envuelve el espacio con sonido de cine real. Para eventos en <strong>CDMX</strong> que merecen producción cinematográfica.</p>
      <p>Ideal para cines al aire libre en haciendas y parques, fiestas temáticas de alto impacto, eventos corporativos y bodas que quieren algo diferente. El técnico dedicado coordina todo: instalación, calibración 4K, configuración de audio y operación durante el evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Pantalla Inflable"
    items={[{ label: "Pantalla 3 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-3metros/" }, { label: "Pantalla 5 metros", href: "/equipos-para-eventos/pantalla-inflable/paquete-5metros/" }, { label: "Producción 12m+", href: "/equipos-para-eventos/pantalla-inflable/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/pantalla-inflable/8metros.avif" alt="Pantalla inflable 8 metros cine al aire libre evento grande" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/pantalla-inflable.avif" alt="Cine al aire libre pantalla 8 metros noche" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/proyector-4k.avif" alt="Proyector 4K de alta potencia para pantalla inflable 8 metros" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/audio-envolvente.avif" alt="Sistema de audio envolvente para cine al aire libre" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/pantalla-inflable/sell/evento-grande.avif" alt="Audiencia grande viendo película en pantalla inflable 8 metros" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Grande — Experiencia 4K</span>
            <h2 class="prod-info__title">Pantalla Inflable 8 metros con Proyector 4K y Audio Envolvente</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$9,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, montaje, proyector 4K, audio envolvente, técnico dedicado y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">8 metros de imagen 4K — el cine al aire libre que tus invitados van a recordar</h2>
            <p class="prod-selling__intro">A esta escala, la imagen no solo se ve — se siente. El proyector 4K de alta potencia llena los 8 metros de pantalla con detalle que se aprecia hasta desde la última fila. El audio envolvente rodea a los espectadores desde múltiples puntos del espacio. No es solo ver una película — es vivir la experiencia.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Proyector 4K de alta potencia — detalle real en 8 metros</h3>
                  <p class="prod-hl__desc">La resolución 4K en una pantalla de 8 metros significa que cada textura, cada color, cada detalle se ve nítido desde cualquier distancia. La imagen no se pixela ni se pierde al escalar. Es calidad de sala de cine, al aire libre.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Audio envolvente multicanal — el sonido rodea a los espectadores</h3>
                  <p class="prod-hl__desc">El sistema de audio envolvente coloca múltiples bocinas en puntos estratégicos alrededor del área de espectadores. El sonido llega desde adelante y los lados, creando la sensación de estar dentro de la película. Sin zonas sin sonido ni picos de volumen.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Estructura de soporte reforzada — estable aunque haya viento</h3>
                  <p class="prod-hl__desc">La pantalla de 8 metros requiere estructura de soporte reforzada para mantenerse completamente plana y estable. El soplador industrial mantiene la presión constante incluso con viento leve. Seguridad y tensión perfecta durante todo el evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico dedicado — él se encarga, tú disfrutas</h3>
                  <p class="prod-hl__desc">Un técnico especializado trabaja exclusivamente en tu evento: calibra la imagen 4K, balancea el audio multicanal, monitorea el equipo y resuelve cualquier imprevisto en tiempo real. No hay evento de esta escala sin técnico dedicado.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Pantalla inflable 8m diagonal</div>
              <div class="prod-feat">Proyector 4K alta potencia</div>
              <div class="prod-feat">Audio envolvente multicanal</div>
              <div class="prod-feat">Soplador industrial silencioso</div>
              <div class="prod-feat">Estructura de soporte reforzada</div>
              <div class="prod-feat">Cables HDMI y conexiones 4K</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico dedicado en sitio</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, dirección, número de invitados, dimensiones del espacio y qué quieres proyectar. Con estos datos diseñamos la distribución del audio y la posición óptima de pantalla y proyector.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirmamos y apartamos tu fecha</h4>
                  <p class="prod-step__desc">Reserva con anticipo del 50%. Tu fecha queda bloqueada y recibes confirmación con todos los detalles, incluyendo el perfil del técnico asignado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 3 horas antes</h4>
                  <p class="prod-step__desc">Instalamos pantalla, proyector 4K y sistema de audio multicanal. Calibramos imagen, balanceamos audio y hacemos prueba completa antes de que lleguen tus invitados.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Producción en tiempo real durante el evento</h4>
                  <p class="prod-step__desc">El técnico dedicado opera el sistema durante todo el evento: ajusta imagen, controla audio y coordina con tu equipo de producción. Al finalizar, desmontamos todo sin interrumpir el cierre de la fiesta.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué elegir 8 metros sobre 5?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Pantalla 5 metros</span>
                <ul class="prod-compare__list">
                  <li>Hasta 100 personas</li>
                  <li>Audio profesional estéreo</li>
                  <li>Proyector Full HD</li>
                  <li>Jardines medianos</li>
                  <li>Técnico compartido</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Pantalla 8 metros</span>
                <ul class="prod-compare__list">
                  <li>Hasta 200 personas</li>
                  <li>Audio envolvente multicanal</li>
                  <li>Proyector 4K</li>
                  <li>Haciendas y espacios grandes</li>
                  <li>Técnico dedicado exclusivo</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos un cine al aire libre en la hacienda para 160 personas. La pantalla de 8 metros era impresionante — desde la última fila la imagen se veía perfecta. El audio envolvente hacía que te sintieras dentro de la película. El técnico coordinó todo con nuestro equipo de eventos sin problema. Sin duda lo repetiremos."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Alejandra Fuentes</span>
                <span class="prod-quote__event">Cine al aire libre en hacienda — Estado de México, 160 personas</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Tamaño pantalla</dt><dd>8m diagonal</dd></div>
              <div class="ps-specs__row"><dt>Proyector</dt><dd>4K alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Resolución</dt><dd>4K Ultra HD</dd></div>
              <div class="ps-specs__row"><dt>Audio</dt><dd>Envolvente multicanal</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>100-200 personas</dd></div>
              <div class="ps-specs__row"><dt>Espacio mínimo</dt><dd>10×10 metros</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Dedicado incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Cine al aire libre grande</span>
              <span class="ps-tag">Haciendas y parques</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Festivales privados</span>
              <span class="ps-tag">Bodas con pantalla</span>
              <span class="ps-tag">XV años premium</span>
              <span class="ps-tag">Graduaciones masivas</span>
              <span class="ps-tag">100-200 personas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-3metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/3metros.avif" alt="Pantalla 3 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 3 metros</span>
                <span class="ps-pkg__price">$3,000 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-5metros/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/5metros.avif" alt="Pantalla 5 metros" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Pantalla 5 metros</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/pantalla-inflable/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/pantalla-inflable/produccion.avif" alt="Producción 12m+" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción 12m+</span>
                <span class="ps-pkg__price">$18,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Más de 200 personas o producción profesional? El paquete de Producción incluye pantalla 12m+, proyector láser y técnico de producción.</p>
              <a href="/equipos-para-eventos/pantalla-inflable/paquete-produccion/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/mesas-picnic/" class="ps-link">Mesas Picnic</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/" class="ps-link">Bocinas para Fiestas</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
