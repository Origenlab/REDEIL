---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿El humo bajo es seguro durante toda una recepción?',
    respuesta: 'Sí. El efecto es vapor de agua condensado — no hay combustión, no hay químicos, no hay residuos. Se puede usar en presencia de niños, adultos mayores y personas con alergias respiratorias sin ningún problema. Los efectos se activan solo durante los momentos especiales, no de forma continua durante toda la noche.'
  },
  {
    pregunta: '¿3 máquinas activan los detectores de humo del salón?',
    respuesta: 'No. Los detectores de humo reaccionan a partículas de combustión, no a vapor de agua. Sin importar cuántas máquinas uses, el principio es el mismo: es niebla pura. Trabajamos regularmente con venues en CDMX — Hacienda de los Morales, Salones del WTC, Camino Real — con sistemas de seguridad activos y sin incidentes en más de 5 años.'
  },
  {
    pregunta: '¿Cuántos momentos cubre el paquete Recepción Completa?',
    respuesta: 'Hasta 3 momentos distintos — uno por máquina. Lo más común: entrada de la novia (ceremonia), primer baile y vals de papá-hija o vals de quince. También se pueden usar 2 máquinas simultáneamente para un momento de mayor impacto y reservar la tercera para otro. Lo definimos según el programa de tu evento.'
  },
  {
    pregunta: '¿Qué diferencia hay entre Recepción Completa y Doble Cobertura?',
    respuesta: 'El Doble Cobertura tiene 2 máquinas para 2 momentos o pista grande. La Recepción Completa tiene 3 máquinas — una más que cubre un tercer momento, o que trabaja simultáneamente con las otras dos para bodas grandes (más de 150 invitados) donde necesitas mayor densidad de nube en toda la pista.'
  },
  {
    pregunta: '¿Qué incluye el paquete Recepción Completa?',
    respuesta: 'Incluye 3 máquinas de humo bajo profesionales, hielo seco para todos los efectos programados, transporte, instalación de las 3 unidades, técnico operador que coordina cada activación con tu DJ, y desmontaje completo. Precio todo incluido dentro de CDMX y Edomex.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Recepción Completa — Humo Bajo para Bodas | REDEIL',
    description: '3 máquinas de humo bajo para cubrir toda la recepción. Hasta 3 momentos especiales o cobertura completa de pistas grandes. Ideal para bodas medianas-grandes y XV años completos. CDMX.',
    image: SITE_URL + '/img/img-index/humo-bajo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '8500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '52',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Recepción Completa — Humo Bajo para Bodas en CDMX | REDEIL"
  description="3 máquinas de humo bajo para toda la recepción. Hasta 3 momentos especiales flotando entre nubes. Ideal para bodas medianas-grandes. Desde $8,500 MXN en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Humo Bajo', href: '/equipos-para-eventos/humo-bajo/' }, { name: 'Recepción Completa', href: '/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/' }]} />

  <Hero
    badge="Recepción Completa — 3 máquinas, hasta 3 momentos"
    title="Recepción Completa — Humo Bajo con 3 Máquinas Profesionales"
    description="Toda tu recepción transformada. 3 máquinas para ceremonia, primer baile y vals — o cobertura total de pista grande. El paquete favorito de bodas medianas-grandes en CDMX."
    primaryCta={{ text: 'Cotizar $8,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/humo-bajo/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete Recepción Completa de humo bajo</strong> es para quienes no quieren elegir un solo momento mágico — lo quieren en toda la recepción. Tres máquinas independientes cubren hasta 3 momentos distintos: la entrada de la novia al pasillo, el primer baile y el vals de papá e hija. Cada uno perfectamente coordinado. Cada uno inolvidable.</p>
      <p>También es el paquete ideal para bodas de 150 invitados o más, donde una pista de baile grande necesita las 3 máquinas trabajando simultáneamente para crear una nube densa y pareja en todo el espacio. Nuestro técnico posiciona estratégicamente cada unidad según la forma y dimensión exacta de tu pista.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Humo Bajo"
    items={[{ label: "Vals Único", href: "/equipos-para-eventos/humo-bajo/paquete-vals-unico/" }, { label: "Doble Cobertura", href: "/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/" }, { label: "Producción Premium", href: "/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/humo-bajo/recepcion-completa.avif" alt="Pista de boda grande completamente cubierta con humo bajo — 3 máquinas" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/humo-bajo.avif" alt="Efecto humo bajo recepción boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/tres-maquinas.avif" alt="3 máquinas humo bajo posicionadas en salón" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/cobertura-total.avif" alt="Cobertura total de pista grande con 3 máquinas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/xv-anos.avif" alt="Vals de XV años con efecto de humo bajo" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Recepción Completa — El más popular en bodas medianas</span>
            <h2 class="prod-info__title">Humo Bajo con 3 Máquinas — Ceremonia, Primer Baile y Vals Completos</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$8,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: hielo seco para todos los efectos, transporte, instalación, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">No un momento mágico — una recepción completa de momentos mágicos</h2>
            <p class="prod-selling__intro">Las bodas que se recuerdan 20 años después no son las que tuvieron el pastel más caro ni el vestido más elaborado. Son las que tuvieron los momentos más emotivos. El humo bajo convierte momentos ordinarios en experiencias que te quiebran. Tres máquinas significan tres oportunidades de que tus invitados lloren, aplaudan y saquen el celular al mismo tiempo.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Tres momentos distintos — cada uno perfectamente cronometrado</h3>
                  <p class="prod-hl__desc">Entrada de la novia en el pasillo. Primer baile. Vals de papá e hija. Tres momentos que ya eran emotivos se convierten en algo de otra dimensión con una nube de humo bajo. Nuestro técnico coordina cada uno directamente con tu DJ o músico.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Pistas grandes cubiertas de forma perfectamente uniforme</h3>
                  <p class="prod-hl__desc">En bodas de 150+ invitados con pistas de 8×10 metros o más, 2 máquinas dejan zonas sin cobertura. Con 3 unidades posicionadas en triángulo, la nube es completamente uniforme sin importar qué tan grande o qué forma tenga la pista.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El paquete más popular para XV años completos</h3>
                  <p class="prod-hl__desc">Una quinceañera tiene múltiples momentos de vals: el primer vals, el vals sorpresa y el vals final. Con 3 máquinas cubrimos cada uno. También ideal para la entrada de la quinceañera — la nube en la escalinata es uno de los momentos más dramáticos y fotografiados de cualquier XV.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Un técnico dedicado coordina las 3 máquinas en tiempo real</h3>
                  <p class="prod-hl__desc">No improvisamos. Llegamos con el programa completo de tu evento, mapeamos cada momento y el técnico está listo con cada máquina precargada. No hay tiempos muertos, no hay esperas. Cada efecto ocurre exactamente cuando debe ocurrir.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">3 máquinas de humo bajo profesionales</div>
              <div class="prod-feat">Hielo seco para hasta 3 efectos</div>
              <div class="prod-feat">Cobertura de hasta 60m²</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación estratégica de las 3 unidades</div>
              <div class="prod-feat">Técnico operador dedicado todo el evento</div>
              <div class="prod-feat">Coordinación con DJ, músico y fotógrafo</div>
              <div class="prod-feat">Mapeo de posición según plano del venue</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte el programa de tu evento</h4>
                  <p class="prod-step__desc">Cuéntanos qué momentos quieres cubrir, el venue y si tienes plano del espacio. Diseñamos la posición óptima de las 3 máquinas para cada momento y para la cobertura de pista.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Plan detallado en menos de 24h</h4>
                  <p class="prod-step__desc">Te entregamos propuesta con el mapa de posición de las máquinas, cronograma de activaciones y precio final. Si tienes fotógrafo o videógrafo, podemos coordinar con ellos para los ángulos óptimos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo del 50%</h4>
                  <p class="prod-step__desc">Tu fecha y las 3 máquinas quedan bloqueadas. Aceptamos transferencia, efectivo o tarjeta. Saldo al día del evento antes de la instalación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Operación completa el día del evento</h4>
                  <p class="prod-step__desc">Llegamos 2-3 horas antes, instalamos las 3 máquinas según el plan, coordinamos con el equipo del evento, ejecutamos cada efecto en el momento exacto y desmontamos sin interrumpir la celebración.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Doble Cobertura vs Recepción Completa</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Doble Cobertura — 2 máquinas</span>
                <ul class="prod-compare__list">
                  <li>2 momentos en la noche</li>
                  <li>Pistas hasta 40m²</li>
                  <li>Bodas hasta ~120 invitados</li>
                  <li>Cobertura de 2 zonas</li>
                  <li>2 efectos independientes</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Recepción Completa — 3 máquinas</span>
                <ul class="prod-compare__list">
                  <li>Hasta 3 momentos distintos</li>
                  <li>Pistas hasta 60m²</li>
                  <li>Bodas 150+ invitados</li>
                  <li>Cobertura total uniforme</li>
                  <li>Toda la recepción transformada</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos las 3 máquinas para la XV de mi hija. La entrada de la escalinata con el humo, el vals sorpresa y el primer vals — los tres con el efecto. Mi esposa y yo lloramos en los tres. Pero lo más increíble fue ver la cara de mi hija cuando salió de la escalinata y vio la nube. No tiene precio. El equipo de REDEIL lo coordinó todo perfectamente con el DJ. Salón Versalles, CDMX."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Roberto y Familia Garza</span>
                <span class="prod-quote__event">XV Años en Salón Versalles, CDMX — 180 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas</dt><dd>3 unidades</dd></div>
              <div class="ps-specs__row"><dt>Efecto</dt><dd>Humo bajo (niebla)</dd></div>
              <div class="ps-specs__row"><dt>Momentos</dt><dd>Hasta 3 distintos</dd></div>
              <div class="ps-specs__row"><dt>Duración</dt><dd>3-4 min por efecto</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 60m²</dd></div>
              <div class="ps-specs__row"><dt>Fluido</dt><dd>Hielo seco + agua</dd></div>
              <div class="ps-specs__row"><dt>Tóxico</dt><dd>No — 100% inocuo</dd></div>
              <div class="ps-specs__row"><dt>Alarmas</dt><dd>No activa detectores</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas 100-200 invitados</span>
              <span class="ps-tag">XV años completos</span>
              <span class="ps-tag">3 momentos distintos</span>
              <span class="ps-tag">Pistas grandes</span>
              <span class="ps-tag">Haciendas y salones</span>
              <span class="ps-tag">Vals múltiples</span>
              <span class="ps-tag">Entrada dramática</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/humo-bajo/paquete-vals-unico/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/vals-unico.avif" alt="Vals Único humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Vals Único</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/doble-cobertura.avif" alt="Doble Cobertura humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Doble Cobertura</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/produccion-premium.avif" alt="Producción Premium humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Premium</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda de lujo o producción audiovisual? La Producción Premium incluye 5+ máquinas y efecto continuo.</p>
              <a href="/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" class="ps-upsell__link">Ver Producción Premium →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Máquina de Confeti</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
