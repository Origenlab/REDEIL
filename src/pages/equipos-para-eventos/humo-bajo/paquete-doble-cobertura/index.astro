---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿El humo bajo es tóxico o perjudicial para la salud?',
    respuesta: 'No. El efecto se genera con hielo seco (CO₂ sólido) y agua caliente — el resultado es vapor de agua condensado, exactamente como la niebla natural. Es 100% inocuo para personas, mascotas y plantas. No irrita garganta, no irrita ojos. Usado profesionalmente en teatros, bodas y producciones de cine.'
  },
  {
    pregunta: '¿Dos máquinas activan más fácil los detectores de humo?',
    respuesta: 'No. Sin importar cuántas máquinas uses, el efecto es vapor de agua puro — no partículas de combustión. Los detectores de humo reaccionan a partículas, no al vapor. Con 2 máquinas lo que cambia es la cobertura y la densidad de la nube, no el riesgo de activar alarmas. Hemos operado configuraciones de 2 máquinas en hoteles y salones de Ciudad de México sin incidentes.'
  },
  {
    pregunta: '¿Puedo usar las 2 máquinas simultáneamente o en momentos distintos?',
    respuesta: 'Ambas opciones son posibles. Para mayor impacto visual en una pista grande, las operamos simultáneamente. Para cubrir 2 momentos distintos (ceremonia + primer baile, por ejemplo), usamos cada máquina de forma independiente con su propia carga de hielo seco. Lo definimos contigo al cotizar según el programa de tu evento.'
  },
  {
    pregunta: '¿Qué pista cubre el Doble Cobertura?',
    respuesta: 'Con 2 máquinas cubrimos hasta 40m² de manera uniforme — suficiente para pistas de 6×7 metros aproximadamente. Si tu pista es más grande o tiene forma irregular, adaptamos la posición de las máquinas. Solo necesitamos medidas o fotos del espacio para confirmarte la cobertura exacta.'
  },
  {
    pregunta: '¿Qué incluye el paquete Doble Cobertura de Humo Bajo?',
    respuesta: 'Incluye 2 máquinas de humo bajo profesionales, hielo seco suficiente para 2 efectos completos o 1 efecto extendido en pista grande, transporte, instalación, técnico operador que coordina ambas máquinas durante el evento y desmontaje. Precio todo incluido dentro de CDMX y Edomex.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Doble Cobertura — Humo Bajo para Bodas | REDEIL',
    description: 'Paquete de humo bajo con 2 máquinas profesionales para 2 momentos distintos o cobertura de pista grande. Ideal para ceremonia + primer baile o bodas con pista amplia. CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/humo-bajo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '5500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '44',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Doble Cobertura — Humo Bajo para Bodas en CDMX | REDEIL"
  description="2 máquinas de humo bajo para 2 momentos distintos o pista grande. Ceremonia + primer baile flotando entre nubes. Desde $5,500 MXN con técnico incluido en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Humo Bajo', href: '/equipos-para-eventos/humo-bajo/' }, { name: 'Doble Cobertura', href: '/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/' }]} />

  <Hero
    badge="Doble Cobertura — 2 máquinas, 2 momentos"
    title="Doble Cobertura — Humo Bajo con 2 Máquinas Profesionales"
    description="Ceremonia y primer baile, ambos entre nubes. 2 máquinas independientes para 2 momentos distintos o cobertura completa de pista grande. CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $5,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/humo-bajo/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete Doble Cobertura de humo bajo</strong> es la elección de las parejas que no quieren elegir entre la ceremonia o el primer baile — lo quieren todo. Dos máquinas profesionales trabajando de forma independiente: una cubre el pasillo de entrada de la novia durante la ceremonia, la otra cubre la pista para el vals. Dos momentos. Dos explosiones emocionales. Dos sets de fotos que te van a quitar el aliento.</p>
      <p>También es la solución perfecta para pistas de baile grandes donde una sola máquina no alcanza a cubrir todo el espacio de forma uniforme. Con 2 máquinas estratégicamente colocadas, la nube es densa y pareja de lado a lado.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Humo Bajo"
    items={[{ label: "Vals Único", href: "/equipos-para-eventos/humo-bajo/paquete-vals-unico/" }, { label: "Recepción Completa", href: "/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/" }, { label: "Producción Premium", href: "/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/humo-bajo/doble-cobertura.avif" alt="Dos máquinas de humo bajo cubriendo pista grande en boda CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/humo-bajo.avif" alt="Efecto humo bajo primer baile nubes piso" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/ceremonia-nubes.avif" alt="Pasillo ceremonial con efecto de humo bajo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/pista-grande.avif" alt="Pista de baile amplia cubierta con humo bajo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/dos-maquinas.avif" alt="Dos máquinas profesionales posicionadas en evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Doble Cobertura — 2 máquinas, máximo impacto</span>
            <h2 class="prod-info__title">Humo Bajo con 2 Máquinas — Ceremonia + Primer Baile o Pista Grande</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$5,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: hielo seco para 2 efectos, transporte, instalación, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Dos momentos que nadie va a olvidar — ni tú, ni tus invitados</h2>
            <p class="prod-selling__intro">La mayoría de las parejas que contratan el Vals Único nos llaman después del evento para decirnos que ojalá lo hubieran tenido también en la entrada de la novia. El Doble Cobertura existe exactamente para eso: para que no tengas que elegir. Dos máquinas, dos cargas de hielo seco, dos momentos completamente distintos, un solo precio.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Entrada de la novia sobre una nube — el pasillo más emotivo</h3>
                  <p class="prod-hl__desc">Imagina a la novia caminando por el pasillo de ceremonia con una nube densa cubriéndole los pies. Es uno de los momentos más fotografiados del mundo entero. Una máquina al inicio del pasillo lo hace real, sin trucos, en vivo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Pista grande cubierta de forma uniforme, de lado a lado</h3>
                  <p class="prod-hl__desc">En salones con pistas de más de 6×6 metros, una sola máquina crea zonas sin cobertura. Con 2 máquinas posicionadas en esquinas opuestas, la nube se encuentra al centro y cubre toda la pista de forma pareja. Sin huecos, sin zonas sin efecto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Máquinas independientes — cada momento tiene su propio efecto</h3>
                  <p class="prod-hl__desc">Las 2 máquinas se operan de forma independiente. Si el plan es ceremonia + vals, cada una tiene su propia carga de hielo seco. El técnico activa cada una en el momento exacto coordinado con tu DJ. No hay interferencia entre efectos, no hay humo residual.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El favorito de fotógrafos y videógrafos profesionales</h3>
                  <p class="prod-hl__desc">Los fotógrafos de bodas en CDMX nos lo dicen: la doble cobertura produce el material más vendible del reportaje. Dos momentos de humo bajo = dos portafolios distintos. Si tu fotógrafo sabe que vas a tener este efecto, llegará preparado con los ángulos perfectos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 máquinas de humo bajo profesionales</div>
              <div class="prod-feat">Hielo seco para 2 efectos completos</div>
              <div class="prod-feat">Cobertura de hasta 40m²</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación estratégica de ambas máquinas</div>
              <div class="prod-feat">Técnico operador controla ambas</div>
              <div class="prod-feat">Coordinación con DJ o músico</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Flexibilidad: simultáneo o momentos distintos</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Define tus 2 momentos especiales</h4>
                  <p class="prod-step__desc">¿Ceremonia + primer baile? ¿Entrada de la novia + vals? ¿Pista grande con cobertura completa? Cuéntanos el programa y el espacio — diseñamos la posición óptima para cada máquina.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización detallada en menos de 24h</h4>
                  <p class="prod-step__desc">Te confirmamos precio final, mapa de posición de las máquinas y opciones de personalización. Si tienes fotógrafo, coordinamos para que esté listo en ambos momentos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo del 50%</h4>
                  <p class="prod-step__desc">Tu fecha y equipo quedan bloqueados al confirmar. Aceptamos transferencia, efectivo o tarjeta. Saldo al día del evento antes de la instalación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">El día del evento — ambas máquinas listas</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes, instalamos las 2 máquinas en posición, coordinamos tiempos con tu DJ, ejecutamos cada efecto en el momento exacto y desmontamos sin interrumpir la celebración.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Vals Único vs Doble Cobertura — ¿cuál necesito?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Vals Único — 1 máquina</span>
                <ul class="prod-compare__list">
                  <li>Un solo momento cubierto</li>
                  <li>Pistas pequeñas (hasta 20m²)</li>
                  <li>Solo vals o solo ceremonia</li>
                  <li>Bodas pequeñas o íntimas</li>
                  <li>Presupuesto ajustado</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Doble Cobertura — 2 máquinas</span>
                <ul class="prod-compare__list">
                  <li>2 momentos completamente distintos</li>
                  <li>Pistas grandes (hasta 40m²)</li>
                  <li>Ceremonia + primer baile</li>
                  <li>Bodas medianas con varios momentos</li>
                  <li>Máximo impacto por precio</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Usamos una máquina para la entrada en la ceremonia y otra para el vals. El momento en que entré al pasillo entre el humo fue algo que ningún invitado va a olvidar. Varios lloraron. Luego el vals fue igual de mágico. Nuestro fotógrafo dijo que jamás había tenido tanto material tan bueno en una sola boda. Hacienda de los Morales, sala Capilla, pista completa cubierta."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Valentina y Andrés</span>
                <span class="prod-quote__event">Boda en Hacienda de los Morales, CDMX — 120 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas</dt><dd>2 unidades</dd></div>
              <div class="ps-specs__row"><dt>Efecto</dt><dd>Humo bajo (niebla)</dd></div>
              <div class="ps-specs__row"><dt>Momentos</dt><dd>2 independientes</dd></div>
              <div class="ps-specs__row"><dt>Duración</dt><dd>3-4 min por efecto</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 40m²</dd></div>
              <div class="ps-specs__row"><dt>Fluido</dt><dd>Hielo seco + agua</dd></div>
              <div class="ps-specs__row"><dt>Tóxico</dt><dd>No — 100% inocuo</dd></div>
              <div class="ps-specs__row"><dt>Alarmas</dt><dd>No activa detectores</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Ceremonia + primer baile</span>
              <span class="ps-tag">Entrada de la novia</span>
              <span class="ps-tag">Pistas grandes</span>
              <span class="ps-tag">Bodas 80-150 invitados</span>
              <span class="ps-tag">Vals de XV años</span>
              <span class="ps-tag">Salones con pista amplia</span>
              <span class="ps-tag">2 momentos especiales</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/humo-bajo/paquete-vals-unico/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/vals-unico.avif" alt="Vals Único humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Vals Único</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/recepcion-completa.avif" alt="Recepción Completa humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Recepción Completa</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/produccion-premium.avif" alt="Producción Premium humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Premium</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda mediana con varios momentos a cubrir? La Recepción Completa incluye 3 máquinas para toda la noche.</p>
              <a href="/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/" class="ps-upsell__link">Ver Recepción Completa →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Máquina de Confeti</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
