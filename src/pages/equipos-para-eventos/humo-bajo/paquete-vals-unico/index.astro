---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿El humo bajo es tóxico o perjudicial para la salud?',
    respuesta: 'No. El efecto se produce con hielo seco (CO₂ sólido) y agua caliente. El humo que ves es vapor de agua condensado — exactamente lo mismo que la niebla natural. Es 100% inocuo para personas, mascotas y plantas. No irrita garganta ni ojos. Se usa en bodas, hospitales para filmaciones médicas y teatros profesionales.'
  },
  {
    pregunta: '¿Activa los detectores de humo del salón?',
    respuesta: 'No. Los detectores de humo reaccionan a partículas de combustión. El humo bajo con hielo seco es vapor de agua puro — no contiene partículas, no activa alarmas. Llevamos años trabajando en venues de CDMX como Hacienda de los Morales, salones del WTC y hoteles cinco estrellas sin ningún incidente.'
  },
  {
    pregunta: '¿Cuánto dura el efecto del paquete Vals Único?',
    respuesta: 'El efecto visible dura entre 3 y 4 minutos de manera continua — exactamente lo que dura un vals o primer baile. Coordinamos el inicio del efecto con la música para que sea perfectamente sincronizado. No hay efecto residual: el humo se disipa solo sin dejar rastro ni olor.'
  },
  {
    pregunta: '¿Cómo funciona el humo bajo — por qué no sube?',
    respuesta: 'El hielo seco a -78°C enfría el vapor de agua al contacto, haciéndolo más denso que el aire. Esa densidad hace que el humo caiga y se extienda al nivel del piso en lugar de subir. El resultado es una nube densa a la altura de los tobillos que crea el efecto "bailando entre nubes". Es física pura, sin efectos artificiales ni químicos.'
  },
  {
    pregunta: '¿Qué incluye el paquete Vals Único de Humo Bajo?',
    respuesta: 'Incluye 1 máquina de humo bajo profesional, hielo seco suficiente para el efecto completo, transporte, instalación, técnico operador que coordina el inicio del efecto con tu música y desmontaje. Llegamos 2 horas antes para preparar. El precio es todo incluido dentro de CDMX y Edomex.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Vals Único — Humo Bajo para Bodas | REDEIL',
    description: 'Paquete de humo bajo para 1 momento especial: vals, primer baile o momento pastel. 1 máquina profesional, efecto 3-4 minutos, técnico incluido. El efecto "bailando entre nubes" para tu momento más fotografiado.',
    image: SITE_URL + '/img/img-index/humo-bajo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/equipos-para-eventos/humo-bajo/paquete-vals-unico/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Vals Único — Humo Bajo para Bodas en CDMX | REDEIL"
  description="Paquete de humo bajo para 1 momento especial. Primer baile o vals flotando entre nubes — efecto 3-4 minutos con técnico incluido. Desde $3,500 MXN en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Equipos para Eventos', href: '/equipos-para-eventos/' }, { name: 'Humo Bajo', href: '/equipos-para-eventos/humo-bajo/' }, { name: 'Vals Único', href: '/equipos-para-eventos/humo-bajo/paquete-vals-unico/' }]} />

  <Hero
    badge="Vals Único — 1 momento especial"
    title="Vals Único — Humo Bajo para Primer Baile o Vals"
    description="Tu primer baile flotando entre nubes. El efecto de humo bajo más icónico de las bodas — 1 máquina profesional, efecto 3-4 minutos sincronizado con tu música. CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/equipos-para-eventos/humo-bajo/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete Vals Único de humo bajo</strong> está diseñado para un solo momento — pero ese momento lo recordarás toda la vida. Una máquina profesional llena la pista de una nube densa a nivel del suelo: tú y tu pareja bailan el vals o el primer baile literalmente flotando entre nubes. Las fotos que salen de ese momento son las que más se comparten, las que más se enmarca y las que tus invitados no pueden dejar de mirar.</p>
      <p>El efecto dura 3 a 4 minutos — exactamente lo que dura un vals. Nuestro técnico coordina el inicio con tu DJ o músico para que el humo aparezca en el primer compás. No tóxico, no activa alarmas, no deja residuo. Solo el momento perfecto.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Humo Bajo"
    items={[{ label: "Doble Cobertura", href: "/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/" }, { label: "Recepción Completa", href: "/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/" }, { label: "Producción Premium", href: "/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/humo-bajo/vals-unico.avif" alt="Pareja bailando vals con efecto de humo bajo — nubes a nivel del piso" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/humo-bajo.avif" alt="Efecto humo bajo primer baile boda CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/maquina.avif" alt="Máquina de humo bajo profesional REDEIL" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/nubes-piso.avif" alt="Nube densa a nivel del piso primer baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/humo-bajo/sell/tecnico.avif" alt="Técnico operando máquina de humo bajo en evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Vals Único — Para 1 momento especial</span>
            <h2 class="prod-info__title">Humo Bajo para Vals o Primer Baile — 1 Máquina Profesional</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: hielo seco, transporte, instalación, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El momento más fotografiado de tu boda, garantizado</h2>
            <p class="prod-selling__intro">El humo bajo no es decoración — es una experiencia. En el momento en que empieza tu vals y el humo cubre la pista, el tiempo se detiene. Tus invitados sacan el celular. Tu fotógrafo lo tiene en el encuadre hace 10 minutos. Lo que capturan ahí no se puede replicar con ningún otro efecto: dos personas flotando en nubes, sin trucos, sin Photoshop, en tiempo real.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sincronizado con tu música — el humo aparece en el primer compás</h3>
                  <p class="prod-hl__desc">Nuestro técnico coordina el inicio del efecto con tu DJ o músico. El humo empieza a salir justo cuando comienza tu canción. No hay que esperar a que "se llene" la pista — llega listo desde el primer segundo del vals.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">3-4 minutos de efecto continuo — dura todo el vals</h3>
                  <p class="prod-hl__desc">No es un destello de 30 segundos. La nube se mantiene densa y visible durante toda la duración de un vals estándar. Si tu canción es más larga, podemos ajustar la carga de hielo seco en la cotización.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">No tóxico, no activa alarmas — funciona en cualquier venue</h3>
                  <p class="prod-hl__desc">El efecto es 100% vapor de agua. No hay químicos, no hay humo real, no activa detectores de incendio. Hemos operado en más de 200 bodas en venues con sistemas de alarma activos sin ningún incidente. Llevamos el permiso técnico si el venue lo solicita.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Ideal para bodas íntimas y presupuestos cuidados</h3>
                  <p class="prod-hl__desc">No necesitas un salón de 500 personas para tener este efecto. Una boda de 40 invitados con humo bajo en el primer baile produce fotos que parecen de producción cinematográfica. Es el mejor retorno de inversión en efectos especiales para eventos pequeños.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 máquina de humo bajo profesional</div>
              <div class="prod-feat">Hielo seco para efecto de 3-4 minutos</div>
              <div class="prod-feat">Cobertura de pista hasta 20m²</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y preparación previa</div>
              <div class="prod-feat">Técnico operador durante el efecto</div>
              <div class="prod-feat">Coordinación con DJ o músico</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos tu momento especial</h4>
                  <p class="prod-step__desc">¿Vals de boda, primer baile, vals XV años o momento pastel? Necesitamos la canción, la duración aproximada y el tamaño de la pista. Con esos datos cotizamos la carga exacta de hielo seco.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos precio final, detalles técnicos y confirmamos disponibilidad para tu fecha. Si tienes fotógrafo o videógrafo, podemos coordinarnos con ellos para optimizar el ángulo del efecto.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada al confirmar. Aceptamos transferencia, efectivo o tarjeta. El saldo restante lo liquidas el día del evento antes de la instalación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">El día del evento, nos encargamos de todo</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes, instalamos la máquina en posición estratégica, coordinamos con tu DJ el momento exacto, ejecutamos el efecto y desmontamos sin interrumpir el flujo del evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Hielo seco "de bricolaje" vs equipo profesional</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Hielo seco comprado en tienda</span>
                <ul class="prod-compare__list">
                  <li>Efecto irregular, desigual</li>
                  <li>Riesgo de quemaduras al manipular</li>
                  <li>Sin control de volumen ni timing</li>
                  <li>Puede activar alarmas si hay demasiado CO₂</li>
                  <li>Nadie supervisa — tú lo manejas</li>
                  <li>Resultado impredecible en fotos</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Vals Único — REDEIL Profesional</span>
                <ul class="prod-compare__list">
                  <li>Nube densa y uniforme garantizada</li>
                  <li>Equipo de seguridad profesional</li>
                  <li>Técnico controla volumen en tiempo real</li>
                  <li>Vapor de agua puro — sin riesgo de alarmas</li>
                  <li>Coordinación con DJ y fotógrafo</li>
                  <li>Resultado cinematográfico en fotos y video</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Pensamos que el humo bajo era 'demasiado' para nuestra boda pequeña — éramos solo 45 invitados en el Jardín San Ángel. Nos equivocamos completamente. Cuando empezó el vals y salió el humo, TODOS sacaron el celular al mismo tiempo. Nuestra fotógrafa dijo que fue el mejor momento del reportaje. Fue el único efecto especial que contratamos y valió cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Claudia y Rodrigo</span>
                <span class="prod-quote__event">Boda en Jardín San Ángel, CDMX — 45 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Máquinas</dt><dd>1 unidad</dd></div>
              <div class="ps-specs__row"><dt>Efecto</dt><dd>Humo bajo (niebla)</dd></div>
              <div class="ps-specs__row"><dt>Duración</dt><dd>3-4 minutos</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 20m²</dd></div>
              <div class="ps-specs__row"><dt>Momentos</dt><dd>1 (vals o primer baile)</dd></div>
              <div class="ps-specs__row"><dt>Fluido</dt><dd>Hielo seco + agua</dd></div>
              <div class="ps-specs__row"><dt>Tóxico</dt><dd>No — 100% inocuo</dd></div>
              <div class="ps-specs__row"><dt>Alarmas</dt><dd>No activa detectores</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Primer baile boda</span>
              <span class="ps-tag">Vals de XV años</span>
              <span class="ps-tag">Bodas íntimas</span>
              <span class="ps-tag">Momento pastel</span>
              <span class="ps-tag">Bodas civiles</span>
              <span class="ps-tag">Boda 30-80 invitados</span>
              <span class="ps-tag">Pistas pequeñas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/doble-cobertura.avif" alt="Doble Cobertura humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Doble Cobertura</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/humo-bajo/paquete-recepcion-completa/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/recepcion-completa.avif" alt="Recepción Completa humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Recepción Completa</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/equipos-para-eventos/humo-bajo/paquete-produccion-premium/" class="ps-pkg">
              <img src="/img/paquetes/humo-bajo/produccion-premium.avif" alt="Producción Premium humo bajo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Premium</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Tienes ceremonia y recepción? El Doble Cobertura cubre 2 momentos distintos con 2 máquinas.</p>
              <a href="/equipos-para-eventos/humo-bajo/paquete-doble-cobertura/" class="ps-upsell__link">Ver Doble Cobertura →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Máquina de Confeti</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Máquina de Burbujas</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
