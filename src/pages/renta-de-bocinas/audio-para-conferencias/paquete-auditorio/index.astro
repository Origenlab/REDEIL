---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Auditorio de Audio para Conferencias?',
    respuesta: 'Incluye sistema line array profesional (2 torres de 2 gabinetes cada una), 6 micrófonos inalámbricos UHF, consola de audio digital de 16 canales, grabación multipista, streaming de audio/video, técnico de audio, técnico de streaming, cables y accesorios, transporte, instalación y desmontaje completo.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Auditorio?',
    respuesta: 'El paquete tiene un precio desde $12,000 MXN + IVA. Incluye equipo de línea array, 6 micrófonos, consola digital, grabación multipista, streaming en vivo, dos técnicos especializados y todo el servicio logístico dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Para cuántas personas es este paquete?',
    respuesta: 'Está diseñado para auditorios y espacios de 200 a 500 personas. El sistema line array distribuye el sonido uniformemente desde la primera hasta la última fila sin importar la distancia ni la acústica del recinto.'
  },
  {
    pregunta: '¿Qué plataformas soporta el streaming?',
    respuesta: 'Transmitimos en vivo a YouTube, Facebook Live, Zoom, Teams, Webex o cualquier plataforma con entrada RTMP. El técnico de streaming configura la transmisión antes del evento y monitorea calidad de señal durante toda la conferencia.'
  },
  {
    pregunta: '¿La grabación multipista qué ventajas tiene sobre la grabación estéreo?',
    respuesta: 'La grabación multipista guarda cada micrófono en una pista independiente. Esto permite editar en postproducción: bajar el ruido de un micrófono específico, cortar intervenciones, ecualizar individualmente cada ponente. El resultado final es de calidad de broadcast.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Para auditorios y eventos de esta escala, recomendamos reservar con 4 a 8 semanas de anticipación para coordinar visita técnica previa al recinto, prueba de acústica y configuración del line array.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Auditorio — Audio para Conferencias | REDEIL',
    description: 'Sistema de audio profesional line array para auditorios de 200-500 personas en CDMX. 6 micrófonos inalámbricos + consola digital + grabación multipista + streaming en vivo.',
    image: SITE_URL + '/img/paquetes/audio-conferencias/auditorio.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '12000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Auditorio — Audio para Conferencias en CDMX | REDEIL"
  description="Audio profesional line array para auditorios de 200-500 personas en CDMX. 6 micrófonos + consola digital + grabación multipista + streaming en vivo. Dos técnicos incluidos. Desde $12,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Audio para Conferencias', href: '/renta-de-bocinas/audio-para-conferencias/' },
    { name: 'Auditorio', href: '/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/' }
  ]} />

  <Hero
    badge="Auditorio — 200 a 500 personas"
    title="Audio para Conferencias — Paquete Auditorio"
    description="Sistema line array profesional para auditorios y congresos de gran formato. 6 micrófonos inalámbricos + consola digital + grabación multipista + streaming en vivo. Dos técnicos especializados incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $12,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/audio-para-conferencias/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Auditorio es la solución de audio para <strong>congresos, foros y eventos de 200 a 500 personas</strong> en auditorios, centros de convenciones y recintos de gran formato en <strong>CDMX y Estado de México</strong>. El sistema line array proyecta sonido uniforme desde la primera hasta la última fila, resolviendo el reto acústico de espacios grandes donde las bocinas convencionales pierden cobertura y claridad.</p>
      <p>El paquete incluye grabación multipista y streaming simultáneo. Mientras el evento ocurre en vivo, la transmisión llega a todos los asistentes virtuales. Al terminar, se entrega el archivo multipista listo para postproducción, distribución o archivo institucional.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Audio para Conferencias"
    items={[
      { label: "Sala de Juntas", href: "/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/" },
      { label: "Conferencia Salón", href: "/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" },
      { label: "Producción Congreso", href: "/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/audio-conferencias/auditorio.avif" alt="Sistema line array en auditorio para conferencia de 300 personas" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/audio-conferencias/line-array.avif" alt="Torres de line array profesional instaladas en auditorio" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/consola-digital.avif" alt="Consola de audio digital 16 canales para eventos corporativos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/streaming-setup.avif" alt="Setup de streaming en vivo para congreso" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/micros-congreso.avif" alt="6 micrófonos inalámbricos en mesa de panelistas" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Auditorio — Line array + streaming + grabación multipista</span>
            <h2 class="prod-info__title">Line Array + 6 Micrófonos Inalámbricos + Consola Digital + Grabación + Streaming</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$12,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: equipo line array, grabación multipista, streaming, 2 técnicos y logística completa en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El sistema que hace que un auditorio de 400 personas suene como una sala de 30</h2>
            <p class="prod-selling__intro">El mayor error en conferencias de gran formato es escalar el equipo incorrecto. Dos bocinas en las esquinas no resuelven 400 personas — crean eco, zonas muertas y distorsión en las filas del fondo. El line array es la solución técnica correcta: múltiples gabinetes apilados que dirigen el sonido como un rayo horizontal, cubriendo toda la sala con nivel uniforme sin importar la distancia.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sistema line array — cobertura uniforme de fila 1 a fila 40</h3>
                  <p class="prod-hl__desc">Dos torres de gabinetes line array flanquean el escenario y proyectan un campo de sonido horizontal que mantiene nivel constante en toda la sala. La persona en la última fila escucha exactamente igual que la de la primera. Sin eco, sin distorsión, sin zonas muertas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">6 micrófonos inalámbricos — panel, preguntas y presentador simultáneos</h3>
                  <p class="prod-hl__desc">Seis micrófonos UHF en frecuencias independientes: tres para la mesa del panel, uno para el moderador, uno de mano para preguntas del público y uno de solapa para el presentador principal. El técnico gestiona activaciones sin que ninguno interfiera con otro.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Consola digital 16 canales — control total de cada fuente</h3>
                  <p class="prod-hl__desc">La consola digital permite ecualización individual por micrófono, compresión dinámica, efectos de sala y monitoreo de niveles en tiempo real. El técnico de audio hace ajustes fino durante el evento sin que la audiencia perciba ningún cambio.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Grabación multipista + streaming simultáneo — evento presencial y virtual en uno</h3>
                  <p class="prod-hl__desc">Mientras el evento ocurre en sala, un segundo técnico gestiona la transmisión en vivo a YouTube, Zoom o cualquier plataforma. La grabación multipista captura cada micrófono por separado para edición profesional en postproducción. Dos entregables, un solo evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema line array (2 torres)</div>
              <div class="prod-feat">6 micrófonos inalámbricos UHF</div>
              <div class="prod-feat">Consola digital 16 canales</div>
              <div class="prod-feat">Subwoofers de refuerzo de graves</div>
              <div class="prod-feat">Grabación multipista de audio</div>
              <div class="prod-feat">Streaming en vivo a plataformas</div>
              <div class="prod-feat">Técnico de audio especializado</div>
              <div class="prod-feat">Técnico de streaming dedicado</div>
              <div class="prod-feat">Visita técnica previa al recinto</div>
              <div class="prod-feat">Cables y accesorios profesionales</div>
              <div class="prod-feat">Transporte y logística completa</div>
              <div class="prod-feat">Instalación, prueba y desmontaje</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Visita técnica previa al recinto</h4>
                  <p class="prod-step__desc">Para auditorios, hacemos visita previa para medir acústica, planear posicionamiento del line array y definir rutas de cables. Esto garantiza que el día del evento todo fluya sin sorpresas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta técnica y rider</h4>
                  <p class="prod-step__desc">Te entregamos rider técnico completo con plano de distribución, listado de equipo, requerimientos de espacio y energía eléctrica. Listo para compartir con el venue.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo del 50%</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada. Para eventos de esta escala el equipo se reserva con exclusividad para tu fecha desde el momento del anticipo.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación el día anterior o 3 horas antes</h4>
                  <p class="prod-step__desc">Dependiendo del recinto, instalamos el día anterior para soundcheck completo, o llegamos 3 horas antes el día del evento. Los dos técnicos permanecen hasta el desmontaje final.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué Auditorio y no Conferencia Salón?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Conferencia Salón</span>
                <ul class="prod-compare__list">
                  <li>50 a 150 personas</li>
                  <li>2 bocinas convencionales</li>
                  <li>4 micrófonos inalámbricos</li>
                  <li>Grabación estéreo WAV</li>
                  <li>Sin streaming en vivo</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Auditorio — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>200 a 500 personas</li>
                  <li>Sistema line array profesional</li>
                  <li>6 micrófonos inalámbricos</li>
                  <li>Grabación multipista</li>
                  <li>Streaming en vivo incluido</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos el Foro Nacional de Innovación con 380 asistentes en el Centro Banamex. El equipo de REDEIL llegó el día anterior para instalación. El sonido fue impecable durante las 8 horas del foro: sin un acople, sin bajones de señal, el streaming estuvo activo todo el tiempo. La grabación multipista que entregaron al día siguiente la usamos para el podcast del evento. Impecable."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Ing. Carlos Fuentes</span>
                <span class="prod-quote__event">Foro Nacional de Innovación — 380 asistentes — Centro Banamex CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Aforo</dt><dd>200-500 personas</dd></div>
              <div class="ps-specs__row"><dt>Sistema</dt><dd>Line array (2 torres)</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>6 inalámbricos UHF</dd></div>
              <div class="ps-specs__row"><dt>Consola</dt><dd>Digital 16 canales</dd></div>
              <div class="ps-specs__row"><dt>Grabación</dt><dd>Multipista incluida</dd></div>
              <div class="ps-specs__row"><dt>Streaming</dt><dd>En vivo incluido</dd></div>
              <div class="ps-specs__row"><dt>Técnicos</dt><dd>2 especializados</dd></div>
              <div class="ps-specs__row"><dt>Visita previa</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Auditorios universitarios</span>
              <span class="ps-tag">Foros nacionales</span>
              <span class="ps-tag">Congresos anuales</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Eventos híbridos</span>
              <span class="ps-tag">Convenciones gremiales</span>
              <span class="ps-tag">Keynotes corporativos</span>
              <span class="ps-tag">Seminarios broadcast</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/sala-juntas.avif" alt="Paquete Sala de Juntas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Sala de Juntas</span>
                <span class="ps-pkg__price">$3,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/conferencia-salon.avif" alt="Paquete Conferencia Salón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Conferencia Salón</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/produccion-congreso.avif" alt="Paquete Producción Congreso" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Congreso</span>
                <span class="ps-pkg__price">$25,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿500+ personas o multi-sala? El paquete Producción Congreso incluye traducción simultánea y director de producción.</p>
              <a href="/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" class="ps-upsell__link">Ver Producción Congreso →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu auditorio</h3>
            <p class="ps-widget__desc">Cotización + rider técnico en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/gobos/" class="ps-link">Gobos (Logo Empresa)</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/podium/" class="ps-link">Podium</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/equipos-para-eventos/city-light/" class="ps-link">City Light</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
