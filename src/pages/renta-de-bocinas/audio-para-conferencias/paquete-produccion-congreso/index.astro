---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción Congreso de Audio para Conferencias?',
    respuesta: 'Incluye sistema multi-sala de audio (line array principal + fill + monitor), sistema de traducción simultánea con cabinas y receptores para idiomas ilimitados, streaming en múltiples plataformas, grabación multipista de todas las salas, director de producción dedicado, equipo técnico completo (audio, streaming, traducción), visita técnica previa, y soporte completo durante el evento.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción Congreso?',
    respuesta: 'El paquete tiene un precio desde $25,000 MXN + IVA. El precio varía según el número de salas, idiomas para traducción simultánea, días del evento y requerimientos específicos. Contacta por WhatsApp para una cotización personalizada.'
  },
  {
    pregunta: '¿Para cuántas personas y cuántas salas es este paquete?',
    respuesta: 'Está diseñado para congresos de 500 o más personas con operación en múltiples salas simultáneas. Podemos equipar sala principal, salas paralelas y foyer con sistemas independientes coordinados desde un centro de producción central.'
  },
  {
    pregunta: '¿Cuántos idiomas soporta el sistema de traducción simultánea?',
    respuesta: 'El sistema soporta idiomas ilimitados. Cada idioma requiere una cabina de interpretación y el número de receptores que necesiten los asistentes. Trabajamos con español, inglés, francés, portugués, alemán, chino mandarín y cualquier otro idioma con intérprete disponible.'
  },
  {
    pregunta: '¿Qué hace diferente a un director de producción?',
    respuesta: 'El director de producción coordina todo el equipo técnico (audio, video, streaming, traducción) y sirve como punto único de contacto durante el evento. Anticipa problemas, toma decisiones en tiempo real y libera al organizador de cualquier preocupación técnica. Es la diferencia entre un evento que fluye y uno que se detiene por problemas técnicos.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo contratar?',
    respuesta: 'Para congresos de esta escala, recomendamos contactar con 8 a 12 semanas de anticipación. Esto permite visita técnica al recinto, coordinación con el venue, diseño del sistema multi-sala, pruebas de traducción y setup completo antes del día del evento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción Congreso — Audio para Conferencias | REDEIL',
    description: 'Producción de audio completa para congresos de 500+ personas en CDMX. Sistema multi-sala + traducción simultánea + streaming + director de producción. Todo incluido.',
    image: SITE_URL + '/img/paquetes/audio-conferencias/produccion-congreso.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '25000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '14',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción Congreso — Audio para Conferencias en CDMX | REDEIL"
  description="Producción de audio completa para congresos de 500+ personas en CDMX. Multi-sala + traducción simultánea + streaming + director de producción. Desde $25,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Audio para Conferencias', href: '/renta-de-bocinas/audio-para-conferencias/' },
    { name: 'Producción Congreso', href: '/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/' }
  ]} />

  <Hero
    badge="Producción Congreso — 500+ personas · Multi-sala"
    title="Audio para Conferencias — Paquete Producción Congreso"
    description="Producción de audio completa para congresos internacionales. Sistema multi-sala + traducción simultánea + streaming en vivo + grabación + director de producción. Para eventos de 500 personas o más en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $25,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/audio-para-conferencias/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Producción Congreso es la solución completa para <strong>congresos internacionales, convenciones nacionales y eventos de 500 o más personas</strong> con múltiples salas simultáneas en <strong>CDMX y Estado de México</strong>. Un director de producción dedicado coordina todo el equipo técnico: audio multi-sala, traducción simultánea en idiomas ilimitados, streaming en vivo y grabación multipista de todas las salas.</p>
      <p>Es el único paquete donde el organizador no tiene que preocuparse por nada técnico. Desde la visita de avanzada hasta el último cable desmontado, REDEIL se hace cargo de toda la producción de audio. El resultado: un congreso que suena como un evento internacional, porque técnicamente lo es.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Audio para Conferencias"
    items={[
      { label: "Sala de Juntas", href: "/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/" },
      { label: "Conferencia Salón", href: "/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" },
      { label: "Auditorio", href: "/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/audio-conferencias/produccion-congreso.avif" alt="Producción completa de audio para congreso internacional con 600 asistentes" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/audio-conferencias/multi-sala.avif" alt="Sistema multi-sala de audio para congreso con salas paralelas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/traduccion-simultanea.avif" alt="Cabinas de traducción simultánea con intérpretes profesionales" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/director-produccion.avif" alt="Director de producción coordinando equipo técnico en congreso" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/streaming-congreso.avif" alt="Setup de streaming profesional para congreso internacional" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Premium — Producción completa de congreso</span>
            <h2 class="prod-info__title">Sistema Multi-Sala + Traducción Simultánea + Streaming + Director de Producción</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$25,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Precio base para congreso de 500 personas, 1 sala principal. Cotización personalizada para multi-sala y días adicionales.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El congreso que organizas una vez al año no puede fallar en el audio</h2>
            <p class="prod-selling__intro">Un congreso nacional o internacional representa meses de trabajo, cientos de registros y la reputación de la institución organizadora. Un fallo técnico en el audio — feedback en medio de la keynote, traducción simultánea que se corta, streaming que pierde señal — lo arruina todo. El paquete Producción Congreso elimina ese riesgo con equipo profesional, redundancia técnica y un director de producción que prevé problemas antes de que ocurran.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de producción dedicado — tu interlocutor único para todo lo técnico</h3>
                  <p class="prod-hl__desc">El director de producción es tu punto de contacto desde la visita técnica previa hasta el desmontaje final. Coordina al equipo de audio, streaming y traducción. Toma decisiones en tiempo real. Tienes un solo número que llamar si necesitas algo, y ese número lo resuelve todo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sistema multi-sala — sala principal + salas paralelas + foyer coordinados</h3>
                  <p class="prod-hl__desc">Cada sala tiene su propio sistema de audio independiente pero coordinado desde el centro de producción central. La sala principal con line array completo, las salas paralelas con sistemas escalados según aforo, el foyer con música ambiental o relay del plenario. Todo sincronizado, todo controlado.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Traducción simultánea — idiomas ilimitados sin cables visibles para el público</h3>
                  <p class="prod-hl__desc">Cabinas de traducción instaladas discreta mente en la sala. Receptores inalámbricos distribuidos a asistentes que los necesitan. El sistema soporta idiomas ilimitados en simultáneo: todos escuchan en su idioma, el ponente habla en el suyo. Sin earphones incómodos, sin cables, sin interrupciones para traducir.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Streaming + grabación multipista — el congreso vive más allá del día del evento</h3>
                  <p class="prod-hl__desc">Streaming simultáneo en hasta 3 plataformas, con señal de video y audio de calidad broadcast. Grabación multipista de cada sala. Los asistentes virtuales tienen la misma experiencia que los presenciales. Y después del evento, el contenido grabado se convierte en material educativo, podcast, o memoria del congreso.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema line array principal (sala mayor)</div>
              <div class="prod-feat">Sistemas de audio para salas paralelas</div>
              <div class="prod-feat">Micrófonos inalámbricos (configuración según salas)</div>
              <div class="prod-feat">Consolas digitales en cada sala</div>
              <div class="prod-feat">Sistema de traducción simultánea</div>
              <div class="prod-feat">Cabinas de interpretación profesionales</div>
              <div class="prod-feat">Receptores inalámbricos para asistentes</div>
              <div class="prod-feat">Streaming en vivo (hasta 3 plataformas)</div>
              <div class="prod-feat">Grabación multipista de todas las salas</div>
              <div class="prod-feat">Director de producción dedicado</div>
              <div class="prod-feat">Equipo técnico completo (3+ personas)</div>
              <div class="prod-feat">Visita técnica previa al recinto</div>
              <div class="prod-feat">Rider técnico para el venue</div>
              <div class="prod-feat">Instalación, operación y desmontaje</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona la producción</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de briefing y visita técnica al venue</h4>
                  <p class="prod-step__desc">El director de producción se reúne contigo para entender el programa del congreso, idiomas, número de salas y requerimientos específicos. Luego hace visita técnica al recinto para diseñar el sistema.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Plan técnico y rider para el venue</h4>
                  <p class="prod-step__desc">Entregamos plan técnico completo con planos de distribución por sala, requerimientos eléctricos, lista de equipo y cronograma de instalación. El venue recibe un rider profesional listo para firma.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva y coordinación pre-evento</h4>
                  <p class="prod-step__desc">Con el 50% de anticipo inicia la reserva de equipo y coordinación con intérpretes. Para congresos multi-día, el director de producción hace llamada de seguimiento semanal hasta el evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación el día anterior + soundcheck completo</h4>
                  <p class="prod-step__desc">El equipo llega el día anterior para instalación completa. Soundcheck con todos los ponentes confirmados, prueba de traducción simultánea, prueba de streaming y revisión de todas las salas. El día del evento solo hay que encender los equipos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué Producción Congreso y no Auditorio?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Auditorio</span>
                <ul class="prod-compare__list">
                  <li>200 a 500 personas, 1 sala</li>
                  <li>Line array en sala única</li>
                  <li>6 micrófonos inalámbricos</li>
                  <li>Sin traducción simultánea</li>
                  <li>2 técnicos</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción Congreso — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>500+ personas, multi-sala</li>
                  <li>Sistema multi-sala coordinado</li>
                  <li>Micrófonos según configuración</li>
                  <li>Traducción simultánea incluida</li>
                  <li>Director + equipo completo</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos el Congreso Internacional de Medicina del Trabajo con 650 asistentes, 4 salas paralelas y traducción al inglés y portugués. REDEIL se encargó de absolutamente todo el audio. El director de producción fue invaluable: resolvió tres situaciones técnicas que yo ni siquiera me enteré. Los asistentes internacionales comentaron que el sistema de traducción era de calidad europea. Fue el congreso mejor producido en los 12 años de historia de nuestra asociación."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Dra. Mónica Villanueva</span>
                <span class="prod-quote__event">Congreso Internacional de Medicina del Trabajo — 650 asistentes — WTC CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Aforo</dt><dd>500+ personas</dd></div>
              <div class="ps-specs__row"><dt>Salas</dt><dd>Multi-sala</dd></div>
              <div class="ps-specs__row"><dt>Sistema</dt><dd>Line array + fill</dd></div>
              <div class="ps-specs__row"><dt>Traducción</dt><dd>Simultánea incluida</dd></div>
              <div class="ps-specs__row"><dt>Idiomas</dt><dd>Ilimitados</dd></div>
              <div class="ps-specs__row"><dt>Grabación</dt><dd>Multipista todas salas</dd></div>
              <div class="ps-specs__row"><dt>Streaming</dt><dd>Hasta 3 plataformas</dd></div>
              <div class="ps-specs__row"><dt>Director</dt><dd>Producción dedicado</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Congresos internacionales</span>
              <span class="ps-tag">Convenciones nacionales</span>
              <span class="ps-tag">Foros multi-sala</span>
              <span class="ps-tag">Cumbres empresariales</span>
              <span class="ps-tag">Eventos institucionales</span>
              <span class="ps-tag">Congresos científicos</span>
              <span class="ps-tag">Asambleas internacionales</span>
              <span class="ps-tag">Eventos con prensa</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/sala-juntas.avif" alt="Paquete Sala de Juntas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Sala de Juntas</span>
                <span class="ps-pkg__price">$3,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/conferencia-salon.avif" alt="Paquete Conferencia Salón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Conferencia Salón</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/auditorio.avif" alt="Paquete Auditorio" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Auditorio</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Congreso de menos de 200 personas sin multi-sala? El paquete Auditorio cubre lo que necesitas a menor costo.</p>
              <a href="/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" class="ps-upsell__link">Ver Auditorio →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu congreso</h3>
            <p class="ps-widget__desc">Cotización detallada + plan técnico en menos de 48 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/gobos/" class="ps-link">Gobos (Logo Empresa)</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/podium/" class="ps-link">Podium</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/equipos-para-eventos/city-light/" class="ps-link">City Light</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
