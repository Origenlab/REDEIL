---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Conferencia Salón de Audio para Conferencias?',
    respuesta: 'Incluye 2 bocinas de alta potencia JBL, 4 micrófonos inalámbricos UHF, mezcladora profesional de 8 canales, grabación de audio en formato MP3/WAV, cables y accesorios, transporte, instalación profesional, técnico operador durante todo el evento y desmontaje. Entrega del archivo de audio en 24 horas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Conferencia Salón?',
    respuesta: 'El paquete tiene un precio desde $6,000 MXN + IVA. Incluye todo: transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México, más grabación de audio completa del evento.'
  },
  {
    pregunta: '¿Para cuántas personas es este paquete?',
    respuesta: 'Está diseñado para eventos de 50 a 150 personas en salones corporativos, auditorios medianos y centros de convenciones. Las 2 bocinas de alta potencia garantizan cobertura uniforme en toda la sala.'
  },
  {
    pregunta: '¿Cómo funciona la grabación de audio?',
    respuesta: 'La grabación se realiza directamente desde la mezcladora, capturando todos los micrófonos con balance óptimo. El archivo final en formato WAV de alta resolución se entrega por transferencia digital en menos de 24 horas después del evento.'
  },
  {
    pregunta: '¿Puedo conectar proyector y presentaciones con audio simultáneo?',
    respuesta: 'Sí. La mezcladora de 8 canales permite conectar hasta 2 laptops, retroproyector con audio y los 4 micrófonos al mismo tiempo. El técnico gestiona los niveles para que cada fuente suene balanceada.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 3 a 6 semanas de anticipación para confirmar disponibilidad. Para congresos o eventos con más de 100 personas, sugerimos reservar con 2 meses de antelación.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Conferencia Salón — Audio para Conferencias | REDEIL',
    description: 'Sistema de audio profesional para conferencias de 50-150 personas en CDMX. 2 bocinas JBL + 4 micrófonos inalámbricos + mezcladora + grabación incluida.',
    image: SITE_URL + '/img/paquetes/audio-conferencias/conferencia-salon.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '6000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '47',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Conferencia Salón — Audio para Conferencias en CDMX | REDEIL"
  description="Audio profesional para conferencias de 50-150 personas en CDMX. 2 bocinas JBL + 4 micrófonos inalámbricos + mezcladora + grabación. Instalación y técnico incluidos. Desde $6,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Audio para Conferencias', href: '/renta-de-bocinas/audio-para-conferencias/' },
    { name: 'Conferencia Salón', href: '/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/' }
  ]} />

  <Hero
    badge="Conferencia Salón — 50 a 150 personas"
    title="Audio para Conferencias — Paquete Conferencia Salón"
    description="Sistema de audio completo para conferencias y seminarios medianos. 2 bocinas JBL + 4 micrófonos inalámbricos + mezcladora + grabación de audio. Instalación y técnico incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $6,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/audio-para-conferencias/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Conferencia Salón está diseñado para <strong>eventos de 50 a 150 personas</strong> en salones corporativos, centros de convenciones y auditorios medianos de <strong>CDMX y Estado de México</strong>. Dos bocinas JBL de alta potencia cubren toda la sala con audio uniforme, sin zonas muertas. Cuatro micrófonos inalámbricos permiten dinámicas de panel, preguntas del público y presentadores simultáneos.</p>
      <p>La grabación de audio está incluida en el paquete: el archivo en WAV de alta resolución se entrega en menos de 24 horas. Ideal para congresos que necesitan actas sonoras, webinars grabados o contenido de capacitación para distribuir después del evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Audio para Conferencias"
    items={[
      { label: "Sala de Juntas", href: "/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/" },
      { label: "Auditorio", href: "/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" },
      { label: "Producción Congreso", href: "/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/audio-conferencias/conferencia-salon.avif" alt="Sistema de audio para conferencia en salón con 2 bocinas JBL y panel de micrófonos" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/audio-conferencias/bocinas-dobles.avif" alt="Par de bocinas JBL de alta potencia para conferencias" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/panel-conferencia.avif" alt="Panel de ponentes con micrófonos inalámbricos en conferencia" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/mixer-profesional.avif" alt="Mezcladora profesional 8 canales para eventos corporativos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/grabacion-audio.avif" alt="Grabación profesional de audio en conferencia corporativa" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Conferencia Salón — Con grabación incluida</span>
            <h2 class="prod-info__title">2 Bocinas JBL + 4 Micrófonos Inalámbricos + Mezcladora + Grabación de Audio</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$6,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, técnico operador, grabación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El paquete que eligen las empresas que organizan conferencias recurrentes</h2>
            <p class="prod-selling__intro">Cuando hay más de 50 personas en una sala, una sola bocina no alcanza. El paquete Conferencia Salón resuelve cobertura, dinamismo de panel y grabación en un solo precio. Las empresas que hacen eventos recurrentes lo contratan una vez y ya saben qué esperar: equipo JBL, técnico profesional y archivo de audio listo al día siguiente.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 bocinas JBL de alta potencia — cobertura total en salas de hasta 300 m²</h3>
                  <p class="prod-hl__desc">El sistema estéreo crea un campo de sonido uniforme. No importa si estás en la primera fila o en el fondo del salón: el nivel de audio es el mismo. Sin zonas de sombra, sin resonancias en las paredes. El técnico posiciona y calibra cada bocina antes del evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 micrófonos inalámbricos — panel de ponentes sin cables enredados</h3>
                  <p class="prod-hl__desc">Cuatro micrófonos UHF operando en frecuencias independientes. Dos para la mesa del panel, uno para el moderador y uno de mano para preguntas del público. El técnico gestiona en tiempo real qué micro está activo para evitar acoples y ruidos de fondo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Grabación de audio incluida — archivo WAV en menos de 24 horas</h3>
                  <p class="prod-hl__desc">La grabación se hace directo desde la mezcladora con mezcla profesional. No es una grabación de ambient con celular — es la captura limpia de todos los micrófonos con balance óptimo. El archivo te llega por transferencia digital al día siguiente del evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mezcladora 8 canales — presentaciones, videos y ponentes en simultáneo</h3>
                  <p class="prod-hl__desc">Dos laptops, retroproyector y los 4 micrófonos conectados al mismo tiempo. El técnico hace transiciones suaves entre fuentes sin cortes ni pausas incómodas. Cuando la presentación pone un video con audio, sube el canal. Cuando el ponente habla, sube el micro. Sin pedirte nada.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 bocinas JBL de alta potencia</div>
              <div class="prod-feat">4 micrófonos inalámbricos UHF</div>
              <div class="prod-feat">Mezcladora profesional 8 canales</div>
              <div class="prod-feat">Grabación de audio WAV completa</div>
              <div class="prod-feat">Entrega de archivo en 24 horas</div>
              <div class="prod-feat">Entrada auxiliar para 2 laptops</div>
              <div class="prod-feat">Cables y accesorios profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y calibración</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Prueba de sonido previa</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu conferencia</h4>
                  <p class="prod-step__desc">Fecha, lugar, número de asistentes, número de ponentes y si necesitas grabación para distribución. Con esos datos confirmamos configuración y logramos la propuesta exacta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24 horas</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final, plano de distribución de bocinas y checklist técnico para el día del evento. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada con anticipo del 50%. Confirmación inmediata por escrito. El saldo restante se liquida el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 90 min antes, instalamos y operamos</h4>
                  <p class="prod-step__desc">El técnico llega 90 minutos antes para instalación, posicionamiento de bocinas, distribución de micrófonos y prueba de sonido completa. Opera durante el evento y entrega archivo de grabación al día siguiente.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué Conferencia Salón y no Sala de Juntas?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sala de Juntas</span>
                <ul class="prod-compare__list">
                  <li>10 a 30 personas</li>
                  <li>1 bocina compacta</li>
                  <li>2 micrófonos inalámbricos</li>
                  <li>Sin grabación de audio</li>
                  <li>Mixer 4 canales básico</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Conferencia Salón — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>50 a 150 personas</li>
                  <li>2 bocinas de alta potencia</li>
                  <li>4 micrófonos inalámbricos</li>
                  <li>Grabación WAV incluida</li>
                  <li>Mixer 8 canales profesional</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos un congreso médico para 120 asistentes en el Hotel Camino Real. El equipo de REDEIL llegó con tiempo, instalaron rápido y la calidad del sonido fue impecable todo el día. El panel de 4 ponentes funcionó sin un solo acople. Y el archivo de grabación llegó al día siguiente perfectamente editado. Definitivamente los volvemos a contratar."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Dra. Patricia Sánchez</span>
                <span class="prod-quote__event">Congreso Médico Nacional — 120 asistentes — Hotel Camino Real CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Aforo</dt><dd>50-150 personas</dd></div>
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>2 JBL alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>4 inalámbricos UHF</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>8 canales</dd></div>
              <div class="ps-specs__row"><dt>Grabación</dt><dd>Incluida (WAV)</dd></div>
              <div class="ps-specs__row"><dt>Entrega archivo</dt><dd>En 24 horas</dd></div>
              <div class="ps-specs__row"><dt>Streaming</dt><dd>No incluido</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Congresos médicos</span>
              <span class="ps-tag">Seminarios corporativos</span>
              <span class="ps-tag">Convenciones de ventas</span>
              <span class="ps-tag">Capacitaciones masivas</span>
              <span class="ps-tag">Foros empresariales</span>
              <span class="ps-tag">Paneles de expertos</span>
              <span class="ps-tag">Asambleas generales</span>
              <span class="ps-tag">Eventos de gremio</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/sala-juntas.avif" alt="Paquete Sala de Juntas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Sala de Juntas</span>
                <span class="ps-pkg__price">$3,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/auditorio.avif" alt="Paquete Auditorio" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Auditorio</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/produccion-congreso.avif" alt="Paquete Producción Congreso" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Congreso</span>
                <span class="ps-pkg__price">$25,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Más de 150 personas o necesitas streaming? El paquete Auditorio incluye line array y transmisión en vivo.</p>
              <a href="/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" class="ps-upsell__link">Ver Auditorio →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu conferencia</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/gobos/" class="ps-link">Gobos (Logo Empresa)</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/podium/" class="ps-link">Podium</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/equipos-para-eventos/city-light/" class="ps-link">City Light</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
