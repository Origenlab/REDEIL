---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Sala de Juntas de Audio para Conferencias?',
    respuesta: 'Incluye 1 bocina JBL profesional de alta eficiencia, 2 micrófonos inalámbricos de mano (UHF), mezcladora de 4 canales, cables y accesorios, transporte, instalación profesional, técnico operador durante el evento y desmontaje. El equipo llega calibrado y listo para usar.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Sala de Juntas?',
    respuesta: 'El paquete tiene un precio desde $3,000 MXN + IVA. Incluye todo: transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos ni cargos adicionales por el técnico.'
  },
  {
    pregunta: '¿Para cuántas personas es este paquete?',
    respuesta: 'Está dimensionado para salas de 10 a 30 personas. Cubre espacios de hasta 60 m² con claridad de audio uniforme en toda la sala, sin zonas de sombra ni puntos muertos.'
  },
  {
    pregunta: '¿Puedo conectar mi laptop o presentación al sistema?',
    respuesta: 'Sí. La mezcladora incluye entrada auxiliar para laptop, tablet o reproductor. Puedes proyectar tu presentación con audio integrado. Solo necesitas cable HDMI o adaptador para video (no incluido).'
  },
  {
    pregunta: '¿En qué zonas hacen entrega?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con cotización de traslado.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 2 a 4 semanas de anticipación para garantizar disponibilidad. Para eventos de último momento, contáctanos por WhatsApp — verificamos disponibilidad al instante.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Sala de Juntas — Audio para Conferencias | REDEIL',
    description: 'Paquete de audio profesional para salas de juntas y conferencias pequeñas en CDMX. 1 bocina JBL + 2 micrófonos inalámbricos + mezcladora. Ideal para 10-30 personas.',
    image: SITE_URL + '/img/paquetes/audio-conferencias/sala-juntas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '34',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Sala de Juntas — Audio para Conferencias en CDMX | REDEIL"
  description="Renta de audio profesional para sala de juntas en CDMX. 1 bocina JBL + 2 micrófonos inalámbricos + mixer. Instalación, operación y desmontaje incluidos. Desde $3,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Audio para Conferencias', href: '/renta-de-bocinas/audio-para-conferencias/' },
    { name: 'Sala de Juntas', href: '/renta-de-bocinas/audio-para-conferencias/paquete-sala-juntas/' }
  ]} />

  <Hero
    badge="Sala de Juntas — 10 a 30 personas"
    title="Audio para Conferencias — Paquete Sala de Juntas"
    description="Sistema de audio completo para juntas ejecutivas y conferencias pequeñas. 1 bocina JBL + 2 micrófonos inalámbricos + mezcladora. Instalación y técnico incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $3,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/audio-para-conferencias/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Sala de Juntas está diseñado para <strong>conferencias de 10 a 30 personas</strong> en salas corporativas, salones privados y espacios compactos de <strong>CDMX y Estado de México</strong>. Con una bocina JBL de alta eficiencia y dos micrófonos inalámbricos UHF, cada ponente se escucha con claridad sin interferencias ni retroalimentación.</p>
      <p>La mezcladora de 4 canales permite conectar la presentación de laptop simultáneamente con los micrófonos, sin saltar entre fuentes. Un técnico de REDEIL llega con anticipación, instala, calibra y opera el sistema durante toda la conferencia. Tú te concentras en el contenido.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Audio para Conferencias"
    items={[
      { label: "Conferencia Salón", href: "/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" },
      { label: "Auditorio", href: "/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" },
      { label: "Producción Congreso", href: "/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/audio-conferencias/sala-juntas.avif" alt="Sistema de audio para sala de juntas con bocina JBL y micrófonos inalámbricos" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/audio-conferencias/microfono-inalambrico.avif" alt="Micrófono inalámbrico UHF para conferencias corporativas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/mixer-4-canales.avif" alt="Mezcladora de 4 canales para sala de juntas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/bocina-jbl.avif" alt="Bocina JBL profesional compacta para eventos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/audio-conferencias/conferencia-corporativa.avif" alt="Conferencia corporativa con audio profesional REDEIL" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Sala de Juntas — Entrada al audio profesional</span>
            <h2 class="prod-info__title">1 Bocina JBL + 2 Micrófonos Inalámbricos + Mezcladora 4 Canales</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Audio limpio para que tus ponentes se entiendan al 100%</h2>
            <p class="prod-selling__intro">En una sala de juntas, el audio importa más que en cualquier otro evento. Una conferencia donde nadie se escucha bien pierde credibilidad al instante. El paquete Sala de Juntas resuelve eso con equipo JBL profesional, micrófonos de frecuencia UHF sin interferencias y un técnico que calibra el sistema antes de que llegue el primer asistente.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 micrófonos inalámbricos UHF — sin cables, sin interferencias</h3>
                  <p class="prod-hl__desc">Los micrófonos UHF operan en frecuencias limpias y evitan interferencias con WiFi o celulares. Los ponentes se mueven libremente. No hay cable que tropezar, no hay zona sin señal dentro de la sala.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Bocina JBL profesional calibrada para voz — sin distorsión</h3>
                  <p class="prod-hl__desc">No es una bocina de evento genérica. Es equipo JBL calibrado específicamente para reproducción de voz en espacios cerrados. Claridad plana, sin reverberación, sin feedback. Los 30 asistentes escuchan igual de bien desde cualquier punto de la sala.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mezcladora 4 canales — laptop + micros sin cambiar cables</h3>
                  <p class="prod-hl__desc">La mezcladora recibe los 2 micrófonos y la señal de tu laptop al mismo tiempo. Cuando el ponente habla, el técnico sube el micro. Cuando pasan el video de la presentación, sube el audio de la laptop. Sin pausas, sin "espera, ¿cómo conecto esto?"</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico profesional presente — tú solo te preocupas por el contenido</h3>
                  <p class="prod-hl__desc">Llega 60 minutos antes, instala, calibra y hace prueba de sonido. Durante la conferencia opera la mezcladora en tiempo real. Si hay algún imprevisto técnico, lo resuelve en segundos sin interrumpir la presentación.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 bocina JBL profesional compacta</div>
              <div class="prod-feat">2 micrófonos inalámbricos UHF</div>
              <div class="prod-feat">Mezcladora de 4 canales</div>
              <div class="prod-feat">Cables y conexiones profesionales</div>
              <div class="prod-feat">Entrada auxiliar para laptop</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y calibración</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Prueba de sonido previa</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu conferencia</h4>
                  <p class="prod-step__desc">Fecha, lugar, número de asistentes y tipo de evento. Con esos datos confirmamos que el paquete Sala de Juntas cubre tu espacio correctamente.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24 horas</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, equipo exacto y opciones adicionales si las necesitas. Sin compromiso.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada con anticipo del 50% por transferencia, efectivo o tarjeta. Confirmación inmediata.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 60 min antes, instalamos y operamos</h4>
                  <p class="prod-step__desc">El técnico llega con tiempo suficiente, instala el sistema, calibra el audio y hace prueba de sonido. Durante el evento opera la mezcladora. Al terminar, desmontamos todo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Sala de Juntas o Conferencia Salón?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sala de Juntas — Este paquete</span>
                <ul class="prod-compare__list">
                  <li>10 a 30 personas</li>
                  <li>1 bocina compacta JBL</li>
                  <li>2 micrófonos inalámbricos</li>
                  <li>Mixer 4 canales</li>
                  <li>Sin grabación de audio</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Conferencia Salón — Siguiente nivel</span>
                <ul class="prod-compare__list">
                  <li>50 a 150 personas</li>
                  <li>2 bocinas de alta potencia</li>
                  <li>4 micrófonos inalámbricos</li>
                  <li>Mixer profesional + grabación</li>
                  <li>Grabación de audio incluida</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Rentamos el paquete Sala de Juntas para una presentación a clientes en nuestra oficina de Santa Fe. El técnico llegó puntual, instaló rápido y durante la presentación se encargó de todo el audio. Los clientes escucharon perfectamente sin que yo tuviera que preocuparme por nada técnico. Vale cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Roberto Mendez</span>
                <span class="prod-quote__event">Presentación corporativa — 22 asistentes — Santa Fe CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Aforo</dt><dd>10-30 personas</dd></div>
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>1 JBL compacta</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>2 inalámbricos UHF</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>4 canales</dd></div>
              <div class="ps-specs__row"><dt>Grabación</dt><dd>No incluida</dd></div>
              <div class="ps-specs__row"><dt>Streaming</dt><dd>No incluido</dd></div>
              <div class="ps-specs__row"><dt>Entrada laptop</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Juntas ejecutivas</span>
              <span class="ps-tag">Presentaciones a clientes</span>
              <span class="ps-tag">Capacitaciones internas</span>
              <span class="ps-tag">Conferencias pequeñas</span>
              <span class="ps-tag">Salas de entrenamiento</span>
              <span class="ps-tag">Seminarios reducidos</span>
              <span class="ps-tag">Talleres corporativos</span>
              <span class="ps-tag">Asambleas de consejo</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/conferencia-salon.avif" alt="Paquete Conferencia Salón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Conferencia Salón</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-auditorio/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/auditorio.avif" alt="Paquete Auditorio" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Auditorio</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/audio-para-conferencias/paquete-produccion-congreso/" class="ps-pkg">
              <img src="/img/paquetes/audio-conferencias/produccion-congreso.avif" alt="Paquete Producción Congreso" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Congreso</span>
                <span class="ps-pkg__price">$25,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Más de 30 asistentes? El paquete Conferencia Salón incluye 2 bocinas, 4 micrófonos y grabación de audio.</p>
              <a href="/renta-de-bocinas/audio-para-conferencias/paquete-conferencia-salon/" class="ps-upsell__link">Ver Conferencia Salón →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu conferencia</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/gobos/" class="ps-link">Gobos (Logo Empresa)</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/podium/" class="ps-link">Podium</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
              <a href="/equipos-para-eventos/city-light/" class="ps-link">City Light</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
