---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete XV con DJ y Luces para XV Años?',
    respuesta: 'Incluye sistema completo de audio (bocinas, subwoofers, mixer), DJ profesional para toda la fiesta, 4 cabezas móviles, 8 PAR LEDs, máquina de humo bajo, micrófonos inalámbricos, transporte, instalación, operación durante todo el evento y desmontaje.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete XV con DJ y Luces?',
    respuesta: 'El paquete XV con DJ y Luces tiene un precio desde $15,000 MXN + IVA. Incluye DJ profesional, sistema de audio completo, show de luces con cabezas móviles y máquina de humo. Todo dentro de CDMX y Estado de México sin costo adicional de traslado.'
  },
  {
    pregunta: '¿Qué tipo de música toca el DJ del paquete XV con DJ y Luces?',
    respuesta: 'Nuestros DJs manejan todos los géneros para XV años: reguetón, pop, grupero, cumbia, bachata, música de antros y las canciones especiales que elijas para el vals y la primera sorpresa. Puedes enviar tu lista de canciones obligatorias con anticipación.'
  },
  {
    pregunta: '¿Qué son las cabezas móviles y para qué sirven?',
    respuesta: 'Las cabezas móviles son focos robotizados que se mueven, cambian de color y siguen el ritmo de la música. Crean un show de luces dinámico sobre la pista de baile, especialmente para la primera sorpresa y cuando sube la intensidad de la música.'
  },
  {
    pregunta: '¿La máquina de humo bajo es peligrosa para los invitados?',
    respuesta: 'No, el humo bajo es completamente seguro. Se genera con hielo seco o líquido especial y se disipa en segundos a nivel del piso. El efecto es visual y fotogénico — crea una atmósfera de nube baja para el vals o la primera sorpresa sin afectar la respiración.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'XV con DJ y Luces — Bocinas para XV Años | REDEIL',
    description: 'Paquete completo para XV años con DJ profesional, sistema de audio, cabezas móviles, PAR LEDs y máquina de humo bajo. Producción completa para eventos de 150+ personas en CDMX.',
    image: SITE_URL + '/img/paquetes/bocinas/xv-dj-luces.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '15000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '61',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="XV con DJ y Luces — Bocinas para XV Años en CDMX desde $15,000 | REDEIL"
  description="Paquete completo para XV años: DJ profesional + sistema de audio + cabezas móviles + PAR LEDs + humo bajo. Show completo para eventos de 150+ personas. CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Bocinas para XV Años', href: '/renta-de-bocinas/bocinas-para-xv-anos/' },
    { name: 'XV con DJ y Luces', href: '/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/' }
  ]} />

  <Hero
    badge="XV con DJ y Luces — Sistema completo + show"
    title="XV con DJ y Luces — Bocinas para XV Años"
    description="DJ profesional + sistema completo de audio + cabezas móviles + humo bajo. La producción que convierte los XV años en show. Para 150+ invitados en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $15,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-xv-anos/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete XV con DJ y Luces es para cuando quieres que los <strong>XV años se sientan como producción real</strong>, no como fiesta improvisada. Un <strong>DJ profesional</strong> lee la pista, sube la energía cuando toca y baja el ritmo para los momentos emotivos. Las <strong>4 cabezas móviles</strong> crean un show de luces que sigue la música en tiempo real — cuando entra la quinceañera, las luces la siguen.</p>
      <p>La <strong>máquina de humo bajo</strong> hace que el primer vals parezca sacado de una película: la cumpleañera camina sobre nubes mientras las luces la iluminan. Son los 3 minutos que todos van a recordar y van a grabar. Incluye <strong>sistema de audio completo</strong> con subwoofers para que el bajo se sienta en el pecho.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para XV Años"
    items={[
      { label: "XV Básico", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-basico/" },
      { label: "XV Completo", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-completo/" },
      { label: "XV Producción", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/bocinas/xv-dj-luces.avif" alt="Paquete XV con DJ y Luces cabezas móviles y humo bajo para XV años CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/bocinas/sell/cabezas-moviles-xv.avif" alt="Cabezas móviles creando show de luces en XV años" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/humo-bajo-xv.avif" alt="Máquina de humo bajo efecto nube en vals XV años" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/dj-booth.avif" alt="DJ profesional operando en XV años CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/par-leds-pista.avif" alt="PAR LEDs iluminando pista de baile XV años" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete XV con DJ y Luces — Show completo</span>
            <h2 class="prod-info__title">DJ Profesional + Sistema de Audio + 4 Cabezas Móviles + Humo Bajo</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$15,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Show completo: DJ + audio + cabezas móviles + PAR LEDs + humo bajo. Todo incluido en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El XV años que queda en el recuerdo — y en los videos de todos</h2>
            <p class="prod-selling__intro">Un XV años con buen audio y buenas luces se siente completamente diferente. No es exageración: cuando las cabezas móviles siguen la música, cuando el humo bajo sale para el vals, cuando el DJ lanza el track perfecto en el momento exacto — los invitados lo sienten y no pueden dejar de grabar. Este paquete está diseñado para que esos momentos pasen de verdad.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">DJ profesional especializado en XV años</h3>
                  <p class="prod-hl__desc">Nuestros DJs conocen el formato de un XV años: tiempos de la ceremonia, el vals, la primera sorpresa, los brindis y la fiesta. No solo ponen música — leen la sala, suben la energía cuando toca y crean los momentos que todos van a recordar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 cabezas móviles — show de luces en tiempo real</h3>
                  <p class="prod-hl__desc">Las cabezas móviles se mueven, cambian de color y siguen el beat de la música. Para la primera sorpresa son mágicas: escena oscura, entra la quinceañera, un spot la ilumina, las cabezas barren el salón con colores. Es el momento para la foto perfecta.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Humo bajo — el efecto que todos quieren</h3>
                  <p class="prod-hl__desc">La nube baja de hielo seco que ves en los mejores XV años. La quinceañera camina sobre nubes durante el vals padre-hija. Dura 60-90 segundos, se disipa limpio y el resultado en foto y video es espectacular. Seguro para los invitados, mágico para el recuerdo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sistema de audio completo — graves que se sienten</h3>
                  <p class="prod-hl__desc">Bocinas profesionales + subwoofers para que el bajo del reguetón y la cumbia se sienta en el cuerpo, no solo se escuche. Cuando el DJ manda el drop, todo el salón lo siente. Ese es el audio que convierte una fiesta en experiencia.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema completo de audio profesional</div>
              <div class="prod-feat">Subwoofers para graves profundos</div>
              <div class="prod-feat">DJ profesional todo el evento</div>
              <div class="prod-feat">4 cabezas móviles robotizadas</div>
              <div class="prod-feat">8 PAR LEDs con colores</div>
              <div class="prod-feat">Máquina de humo bajo (2 usos)</div>
              <div class="prod-feat">Micrófonos inalámbricos</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y montaje completo</div>
              <div class="prod-feat">Técnico de audio y luces incluido</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Briefing completo de tu XV años</h4>
                  <p class="prod-step__desc">Fecha, salón, número de invitados, lista de canciones especiales, tiempos del vals, primera sorpresa y momentos clave. El DJ estudia tu evento antes de llegar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y coordinación en 24h</h4>
                  <p class="prod-step__desc">Propuesta detallada con distribución de equipo, rider técnico y plan de show para las cabezas móviles y el humo bajo. Todo coordinado desde antes del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva tu fecha</h4>
                  <p class="prod-step__desc">50% de anticipo. Tu fecha y tu DJ quedan apartados de inmediato. Confirmación por escrito con todos los detalles del servicio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 4 horas antes — show garantizado</h4>
                  <p class="prod-step__desc">Instalamos equipo, probamos audio y luces, coordinamos con el salón y la coordinadora. Cuando empieza tu XV, todo está listo. El DJ y el técnico operan hasta el final del evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿XV con DJ y Luces o XV Producción?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">XV con DJ y Luces — $15,000</span>
                <ul class="prod-compare__list">
                  <li>DJ profesional incluido</li>
                  <li>4 cabezas móviles</li>
                  <li>Humo bajo (2 usos)</li>
                  <li>Sistema de audio completo</li>
                  <li>Show coordinado</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--upgrade">
                <span class="prod-compare__label">XV Producción — $28,000</span>
                <ul class="prod-compare__list">
                  <li>Line array profesional</li>
                  <li>DJ + director de producción</li>
                  <li>Show completo con script</li>
                  <li>Efectos especiales full</li>
                  <li>Producción nivel evento masivo</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Los XV de mi hija fueron perfectos gracias a este paquete. El DJ leyó perfectamente el salón: empezó suave para la cena, subió la energía después del vals y a las 11pm tenía a los 180 invitados bailando. Las cabezas móviles para la primera sorpresa son espectaculares — todos sacaron el teléfono. El humo bajo para el vals padre-hija fue el momento más emocionante de la noche."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Roberto y Claudia Mendoza</span>
                <span class="prod-quote__event">XV años de Sofía en Salón Pedregal — 180 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Audio</dt><dd>Sistema completo</dd></div>
              <div class="ps-specs__row"><dt>DJ</dt><dd>Profesional incluido</dd></div>
              <div class="ps-specs__row"><dt>Cabezas móviles</dt><dd>4 unidades</dd></div>
              <div class="ps-specs__row"><dt>PAR LEDs</dt><dd>8 unidades</dd></div>
              <div class="ps-specs__row"><dt>Humo bajo</dt><dd>2 usos incluidos</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>Inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>150-200 personas</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años con show</span>
              <span class="ps-tag">150-200 invitados</span>
              <span class="ps-tag">Primera sorpresa épica</span>
              <span class="ps-tag">Vals con humo bajo</span>
              <span class="ps-tag">Sin DJ externo</span>
              <span class="ps-tag">Salones grandes</span>
              <span class="ps-tag">Fiesta hasta tarde</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes XV Años</h3>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-basico/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-basico.avif" alt="XV Básico" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Básico</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-completo/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-completo.avif" alt="XV Completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Completo</span>
                <span class="ps-pkg__price">$8,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-produccion.avif" alt="XV Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Producción</span>
                <span class="ps-pkg__price">$28,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres line array profesional y director de producción? El XV Producción es el siguiente nivel.</p>
              <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/" class="ps-upsell__link">Ver XV Producción →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu XV años</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón</a>
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
