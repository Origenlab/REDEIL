---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete XV Producción de Bocinas para XV Años?',
    respuesta: 'Incluye sistema line array profesional, DJ de alto nivel, director de producción para coordinar todo el show, cabezas móviles premium, efectos especiales completos (humo bajo, confeti, sky tracker), iluminación arquitectónica y micrófonos. Es la producción completa para XV años de gran escala.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete XV Producción?',
    respuesta: 'El paquete XV Producción tiene un precio desde $28,000 MXN + IVA. Incluye line array, DJ profesional de alto perfil, director de producción, show completo de luces y efectos especiales. Es el paquete premium para XV años que quieren ser memorables.'
  },
  {
    pregunta: '¿Qué es un line array y por qué es mejor que bocinas normales?',
    respuesta: 'Un line array es un sistema de altavoces en columna que proyecta el sonido de forma uniforme a lo largo y ancho de un espacio grande. A diferencia de las bocinas estándar, el sonido llega con la misma intensidad y claridad a 5 metros que a 30 metros. Es el sistema que ves en conciertos y eventos masivos.'
  },
  {
    pregunta: '¿Qué hace el director de producción en mi XV años?',
    respuesta: 'El director de producción coordina toda la producción técnica: crea el guión del show, sincroniza DJ, luces y efectos especiales, coordina con el salón y la coordinadora de eventos, dirige los momentos clave (entrada, vals, primera sorpresa, brindis) y garantiza que todo fluya sin interrupciones ni tiempos muertos.'
  },
  {
    pregunta: '¿Cuántas personas caben con el paquete XV Producción?',
    respuesta: 'El sistema line array está dimensionado para 200 a 400 personas. Es el paquete ideal para eventos grandes en salones de lujo, haciendas grandes o espacios abiertos donde el audio estándar no alcanza para cubrir todo el espacio con calidad uniforme.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'XV Producción — Bocinas para XV Años | REDEIL',
    description: 'Paquete premium de producción para XV años con line array profesional, DJ de alto nivel, director de producción y show completo de efectos especiales. Para eventos de 200-400 personas en CDMX.',
    image: SITE_URL + '/img/paquetes/bocinas/xv-produccion.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '28000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="XV Producción — Bocinas para XV Años en CDMX desde $28,000 | REDEIL"
  description="Producción premium para XV años. Line array profesional + DJ + director de producción + show completo de efectos. Para eventos de 200-400 personas. CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Bocinas para XV Años', href: '/renta-de-bocinas/bocinas-para-xv-anos/' },
    { name: 'XV Producción', href: '/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/' }
  ]} />

  <Hero
    badge="XV Producción — Nivel concierto"
    title="XV Producción — Bocinas para XV Años"
    description="Line array profesional + DJ de alto nivel + director de producción + show completo. Los XV años que parecen producción de concierto. Para 200-400 invitados en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $28,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-xv-anos/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete XV Producción es para las familias que quieren que los XV de su hija sean un <strong>evento de producción real</strong> — el tipo de fiesta que los invitados recuerdan años después. Con un <strong>sistema line array profesional</strong>, el sonido llega perfectamente a los 300 invitados del fondo igual que a los de la primera fila. Sin zonas muertas, sin audio deficiente en los extremos.</p>
      <p>El <strong>director de producción</strong> crea el guión completo del show: cada entrada, cada efecto, cada cambio de luces está coreografiado para los momentos que importan. El resultado no es una fiesta con buenas bocinas — es un <strong>show coordinado</strong> donde el vals, la primera sorpresa y los efectos especiales funcionan en perfecta sincronía.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para XV Años"
    items={[
      { label: "XV Básico", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-basico/" },
      { label: "XV Completo", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-completo/" },
      { label: "XV con DJ y Luces", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/bocinas/xv-produccion.avif" alt="Paquete XV Producción line array y show completo para XV años CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/bocinas/sell/line-array.avif" alt="Sistema line array profesional para evento XV años grande" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/show-luces-xv.avif" alt="Show completo de luces y efectos en XV años producción" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/sky-tracker-xv.avif" alt="Sky tracker efecto especial XV años" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/confeti-xv.avif" alt="Cañón de confeti para XV años producción" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete XV Producción — Nivel premium</span>
            <h2 class="prod-info__title">Line Array Profesional + DJ + Director de Producción + Show Completo</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$28,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Producción completa: line array, DJ, director, show de luces y efectos especiales. CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Los XV años que parecen producción de concierto — porque lo son</h2>
            <p class="prod-selling__intro">Hay XV años y hay XV años. El paquete XV Producción no es "más bocinas" — es una producción completa con guión, director, line array, show de luces y efectos especiales que funcionan en coordinación perfecta. Cuando el director dice "luces" en el momento del vals, las cabezas móviles, el sky tracker, el humo bajo y el confeti activan en secuencia. Eso no pasa por accidente — pasa porque hay un profesional diseñando cada segundo del show.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Line array profesional — el sonido que se siente a 300 personas de distancia</h3>
                  <p class="prod-hl__desc">El line array proyecta el sonido en forma de columna, llegando con la misma claridad y volumen a todos los invitados sin importar dónde estén sentados. Sin el fenómeno de "en el fondo no se escucha" — el audio es uniforme de pared a pared, de primera fila al fondo del salón.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de producción — el cerebro detrás del show</h3>
                  <p class="prod-hl__desc">El director crea el guión completo de tu XV: tiempos exactos de cada momento, coreografía de luces para cada canción, activación de efectos en los instantes precisos, coordinación con salón y fotógrafo. Tú describes tu visión, él la ejecuta con precisión profesional.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Show completo de efectos — humo, confeti, sky tracker y cabezas</h3>
                  <p class="prod-hl__desc">Humo bajo para el vals, confeti en el momento de la primera sorpresa, sky trackers iluminando el cielo si es exterior, cabezas móviles creando el show en la pista. Cada efecto tiene su momento, su duración y su propósito dentro del guión del show.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">DJ de alto perfil — que conoce XV años de este nivel</h3>
                  <p class="prod-hl__desc">Un DJ que ha trabajado en producciones grandes sabe que en un XV de este nivel los tiempos son exactos: el track del vals empieza en el segundo indicado, la música de fondo para los discursos tiene el volumen correcto, y la fiesta sube de energía de forma controlada y programada.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema line array profesional</div>
              <div class="prod-feat">Subwoofers de alto rendimiento</div>
              <div class="prod-feat">DJ de alto perfil para XV años</div>
              <div class="prod-feat">Director de producción</div>
              <div class="prod-feat">Cabezas móviles premium</div>
              <div class="prod-feat">Show de luces coreografiado</div>
              <div class="prod-feat">Máquina de humo bajo</div>
              <div class="prod-feat">Cañón de confeti</div>
              <div class="prod-feat">Sky tracker (si aplica)</div>
              <div class="prod-feat">Micrófonos inalámbricos múltiples</div>
              <div class="prod-feat">Transporte y logística completa</div>
              <div class="prod-feat">Coordinación con salón y staff</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de producción — diseñamos tu show</h4>
                  <p class="prod-step__desc">El director de producción se reúne contigo (presencial o videollamada) para diseñar el guión completo: entrada, vals, primera sorpresa, tiempos, efectos y coreografía de luces. Tu visión se convierte en un plan técnico ejecutable.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta técnica en 48h</h4>
                  <p class="prod-step__desc">Recibes la propuesta completa con rider técnico, distribución de equipo en el salón, guión del show con tiempos exactos y precio final. Revisamos juntos hasta que quede perfecto.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva y coordinación previa</h4>
                  <p class="prod-step__desc">50% de anticipo para reservar fecha. En las semanas previas, el director coordina con el salón, confirma tiempos con coordinadora y finaliza el guión con el DJ. El día del evento no hay improvisación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 5 horas antes — producción nivel profesional</h4>
                  <p class="prod-step__desc">Montaje completo de line array, luces y efectos con pruebas de cada elemento. El director ensaya los momentos clave. Cuando entran los invitados, todo está listo y calibrado. Operamos hasta el final de la fiesta.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué XV Producción y no XV con DJ y Luces?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">XV con DJ y Luces — $15,000</span>
                <ul class="prod-compare__list">
                  <li>Sistema de bocinas estándar</li>
                  <li>DJ profesional</li>
                  <li>4 cabezas móviles</li>
                  <li>Humo bajo (2 usos)</li>
                  <li>Hasta 200 personas</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">XV Producción — $28,000</span>
                <ul class="prod-compare__list">
                  <li>Line array — sonido uniforme</li>
                  <li>DJ de alto perfil + director</li>
                  <li>Show de luces coreografiado</li>
                  <li>Efectos especiales completos</li>
                  <li>200-400 personas</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Invertimos en el paquete de producción y fue la mejor decisión. El director llegó dos semanas antes para planear cada detalle. El día del evento, todo funcionó como reloj: la entrada de Valentina con el humo bajo y las cabezas móviles, el vals con el sky tracker iluminando el jardín, el confeti cuando entró la primera sorpresa. Los invitados pensaron que habíamos contratado producción de TV. Vale cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Familia Gutiérrez Vázquez</span>
                <span class="prod-quote__event">XV años de Valentina en Hacienda Los Morales — 280 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Audio</dt><dd>Line array profesional</dd></div>
              <div class="ps-specs__row"><dt>DJ</dt><dd>Alto perfil incluido</dd></div>
              <div class="ps-specs__row"><dt>Director</dt><dd>Producción incluido</dd></div>
              <div class="ps-specs__row"><dt>Cabezas móviles</dt><dd>Premium</dd></div>
              <div class="ps-specs__row"><dt>Efectos</dt><dd>Humo + confeti + sky</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>Show coreografiado</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>200-400 personas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>5h antes del evento</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años premium</span>
              <span class="ps-tag">200-400 invitados</span>
              <span class="ps-tag">Haciendas y salones de lujo</span>
              <span class="ps-tag">Show completo coordinado</span>
              <span class="ps-tag">Espacios grandes</span>
              <span class="ps-tag">Eventos memorables</span>
              <span class="ps-tag">Producción nivel concierto</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes XV Años</h3>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-basico/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-basico.avif" alt="XV Básico" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Básico</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-completo/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-completo.avif" alt="XV Completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Completo</span>
                <span class="ps-pkg__price">$8,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-dj-luces.avif" alt="XV con DJ y Luces" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV con DJ y Luces</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">Este es el paquete más completo para XV años. Para eventos de 200+ personas que merecen producción real.</p>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu XV años</h3>
            <p class="ps-widget__desc">Producción personalizada. Reunión sin costo, propuesta en 48h.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón</a>
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
