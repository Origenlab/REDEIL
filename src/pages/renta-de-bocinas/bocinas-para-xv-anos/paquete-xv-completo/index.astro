---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete XV Completo de Bocinas para XV Años?',
    respuesta: 'Incluye 4 bocinas JBL profesionales de 15 pulgadas, 2 subwoofers 18 pulgadas, mezcladora de 8 canales, 3 micrófonos inalámbricos, iluminación básica con 6 PAR LEDs, cables y conexiones, transporte, instalación profesional, técnico de audio y operador de luces durante todo el evento y desmontaje.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete XV Completo?',
    respuesta: 'El paquete XV Completo tiene un precio desde $8,000 MXN + IVA. Incluye todo: transporte, instalación, audio, iluminación básica, técnico operador y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Qué iluminación básica incluye el paquete XV Completo?',
    respuesta: 'Incluye 6 PAR LEDs con colores personalizables, ideal para iluminar la pista de baile y crear ambiente. Si quieres un show de luces más elaborado con cabezas móviles o efectos especiales, te recomendamos el paquete XV con DJ y Luces.'
  },
  {
    pregunta: '¿Para cuántas personas alcanza el paquete XV Completo?',
    respuesta: 'El paquete XV Completo está dimensionado para salones de 100 a 150 personas. Las 4 bocinas JBL 15 pulgadas con 2 subwoofers cubren salones medianos y grandes con claridad, profundidad de graves y presencia para que la música se sienta en todo el recinto.'
  },
  {
    pregunta: '¿Necesito contratar DJ aparte con el XV Completo?',
    respuesta: 'Sí, el paquete XV Completo incluye el sistema de audio y la iluminación básica, pero no incluye DJ. Puedes contratar tu DJero externo o pedir playlist desde Spotify/USB. Si quieres DJ incluido, te recomendamos el paquete XV con DJ y Luces desde $15,000.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'XV Completo — Bocinas para XV Años | REDEIL',
    description: 'Paquete de audio e iluminación para XV años con 4 bocinas JBL 15 pulgadas, 2 subwoofers, mixer, micrófonos e iluminación básica. Hasta 150 personas en CDMX y Edomex. Técnico incluido.',
    image: SITE_URL + '/img/paquetes/bocinas/xv-completo.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '8000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-completo/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '47',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="XV Completo — Bocinas para XV Años en CDMX desde $8,000 | REDEIL"
  description="Paquete audio + iluminación para XV años. 4 bocinas JBL 15 pulgadas, 2 subwoofers, mixer, 3 micrófonos y PAR LEDs incluidos. Hasta 150 personas. Técnico en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Bocinas para XV Años', href: '/renta-de-bocinas/bocinas-para-xv-anos/' },
    { name: 'XV Completo', href: '/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-completo/' }
  ]} />

  <Hero
    badge="XV Completo — Audio + Iluminación básica"
    title="XV Completo — Bocinas para XV Años"
    description="El paquete más popular para XV años. 4 bocinas JBL 15 pulgadas + 2 subwoofers + mixer + 3 micrófonos + iluminación básica. Todo para salones de hasta 150 personas en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $8,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-xv-anos/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete XV Completo es el <strong>favorito de las familias que organizan XV años en salones medianos</strong>. Con <strong>4 bocinas JBL de 15 pulgadas y 2 subwoofers</strong>, el sonido cubre todo el salón con potencia y claridad — el vals se escucha perfecto en la pista y en las mesas del fondo. La <strong>iluminación básica con 6 PAR LEDs</strong> transforma el ambiente sin necesidad de contratar un show de luces aparte.</p>
      <p>Los <strong>3 micrófonos inalámbricos</strong> cubren todos los momentos: el papá en el brindis, la presentación del chambelán, el discurso de la abuela. Un técnico de REDEIL opera audio y luces durante todo el evento para que tú y tu familia estén en la fiesta, no resolviendo problemas técnicos.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para XV Años"
    items={[
      { label: "XV Básico", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-basico/" },
      { label: "XV con DJ y Luces", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/" },
      { label: "XV Producción", href: "/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/bocinas/xv-completo.avif" alt="Paquete XV Completo bocinas e iluminación para XV años en salón CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/bocinas-para-xv-anos.avif" alt="4 bocinas JBL 15 en salón de XV años" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/par-leds.avif" alt="Iluminación PAR LED coloreando pista de baile XV años" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/mixer-8ch.avif" alt="Mezcladora 8 canales para evento XV años" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas/sell/subwoofer.avif" alt="Subwoofer 18 pulgadas para XV años" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete XV Completo — El más popular</span>
            <h2 class="prod-info__title">4 Bocinas JBL 15 pulgadas + 2 Subwoofers + Mixer + 3 Micros + Iluminación Básica</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$8,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Audio + iluminación básica: transporte, instalación, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Audio e iluminación en un solo paquete — el XV que suena y se ve bien</h2>
            <p class="prod-selling__intro">El error más común en XV años es contratar solo bocinas y olvidar las luces, o contratar luces sin suficiente audio. El paquete XV Completo resuelve los dos en uno: 4 bocinas JBL para que la música llene el salón, más iluminación básica con PAR LEDs para que la pista tenga ambiente desde el primer vals. No necesitas coordinar dos proveedores distintos ni preocuparte por compatibilidad de equipo.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 bocinas JBL — cobertura completa para salones medianos</h3>
                  <p class="prod-hl__desc">Con 4 bocinas estratégicamente ubicadas, el sonido llega parejo a todos los rincones del salón: pista, mesas laterales, zona de buffet. No hay puntos muertos de audio ni zonas donde la música llega distorsionada o muy baja.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Iluminación básica con 6 PAR LEDs — el ambiente que necesitas</h3>
                  <p class="prod-hl__desc">Los PAR LEDs colorean la pista de baile y crean el ambiente de fiesta sin el costo de un show de luces completo. Rojo para el vals, azul para las canciones lentas, multicolor para que todos bailen. Tú eliges el mood de cada momento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">3 micrófonos inalámbricos — para todos los momentos</h3>
                  <p class="prod-hl__desc">Tres micros simultáneos para el papá en el brindis, la chambelana presentando la sorpresa y el MC o animador si lo tienes. Sin tiempo muerto esperando que liberen el micrófono, sin cables que estorban cuando la quinceañera camina al centro.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Un equipo que coordina audio y luces — sin dramas técnicos</h3>
                  <p class="prod-hl__desc">Cuando el vals empieza, el técnico sube el volumen y cambia el color de las luces en simultáneo. No necesitas estar coordinando dos equipos distintos en el día más importante de tu hija. Nosotros nos entendemos solos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 bocinas JBL 15 pulgadas profesionales</div>
              <div class="prod-feat">2 subwoofers 18 pulgadas para graves</div>
              <div class="prod-feat">Mezcladora 8 canales</div>
              <div class="prod-feat">3 micrófonos inalámbricos</div>
              <div class="prod-feat">6 PAR LEDs con colores</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico de audio y luces</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables y conexiones incluidas</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre el XV años</h4>
                  <p class="prod-step__desc">Fecha, salón, número de invitados, si tienes DJero externo y qué momentos especiales tienes planeados (primera sorpresa, vals padre-hija, coronación). Diseñamos la distribución exacta de audio y luces para tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Propuesta detallada con precio final, equipo específico y cómo se distribuye el audio y la iluminación en tu salón. Sin cargos sorpresa.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">50% de anticipo por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada de inmediato para que nadie más la tome.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 3 horas antes y lo manejamos todo</h4>
                  <p class="prod-step__desc">Instalamos audio y luces según el diseño acordado, hacemos prueba de sonido y prueba de luces. Durante el evento operamos todo. Al terminar, desmontamos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿XV Completo o XV con DJ y Luces?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">XV Completo — $8,000</span>
                <ul class="prod-compare__list">
                  <li>4 bocinas JBL 15 pulgadas</li>
                  <li>Iluminación básica (PAR LEDs)</li>
                  <li>Tu DJero o playlist externa</li>
                  <li>Hasta 150 invitados</li>
                  <li>Técnico de audio y luces</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--upgrade">
                <span class="prod-compare__label">XV con DJ y Luces — $15,000</span>
                <ul class="prod-compare__list">
                  <li>Sistema completo de audio</li>
                  <li>DJ profesional incluido</li>
                  <li>Cabezas móviles + máquina de humo</li>
                  <li>Show de luces coordinado</li>
                  <li>Producción completa del evento</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete completo para los XV de mi niña en un salón de Tlalpan. Lo que más me gustó fue que el audio y las luces venían del mismo proveedor: todo coordinado, todo a tiempo, todo perfecto. El vals con las luces cambiando de color fue el momento más bonito de la noche. Ya lo recomendé con dos mamás del colegio."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Lupita Hernández</span>
                <span class="prod-quote__event">XV años en Salón Jardines Tlalpan — 130 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>4× JBL 15 pulgadas</dd></div>
              <div class="ps-specs__row"><dt>Subwoofer</dt><dd>2× 18 pulgadas</dd></div>
              <div class="ps-specs__row"><dt>Mixer</dt><dd>8 canales</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>3 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>6 PAR LEDs</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>Hasta 150 personas</dd></div>
              <div class="ps-specs__row"><dt>DJ</dt><dd>No incluido</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años en salón mediano</span>
              <span class="ps-tag">100-150 invitados</span>
              <span class="ps-tag">Con DJero externo</span>
              <span class="ps-tag">Audio + luces sin DJ</span>
              <span class="ps-tag">Vals + coronación</span>
              <span class="ps-tag">Salones con pista grande</span>
              <span class="ps-tag">CDMX y Edomex</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes XV Años</h3>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-basico/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-basico.avif" alt="XV Básico" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Básico</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-dj-luces.avif" alt="XV con DJ y Luces" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV con DJ y Luces</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-produccion/" class="ps-pkg">
              <img src="/img/paquetes/bocinas/xv-produccion.avif" alt="XV Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">XV Producción</span>
                <span class="ps-pkg__price">$28,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres DJ + cabezas móviles + humo? El XV con DJ y Luces incluye todo por $15,000.</p>
              <a href="/renta-de-bocinas/bocinas-para-xv-anos/paquete-xv-dj-luces/" class="ps-upsell__link">Ver XV con DJ y Luces →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu XV años</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón</a>
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
