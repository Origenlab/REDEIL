---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Fiesta Masiva de bocinas para fiestas?',
    respuesta: 'Incluye sistema line array profesional, DJ profesional, iluminación completa (cabezas móviles, cañones, efectos), subwoofers de alta potencia, mezcladora digital, 4 micrófonos inalámbricos, estructura de truss, técnico de sonido e ingeniero de iluminación. Para eventos de 200 a 500 personas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Fiesta Masiva?',
    respuesta: 'El paquete tiene un precio desde $15,000 MXN + IVA. Es una producción completa que incluye line array, DJ profesional, iluminación espectacular, técnico de sonido e iluminación. Para eventos donde el audio y el ambiente son el centro de la experiencia.'
  },
  {
    pregunta: '¿El DJ del paquete Masiva puede tocar el género musical que yo pida?',
    respuesta: 'Sí. El DJ profesional de REDEIL se adapta al estilo musical que necesitas: pop, electrónica, reggaetón, banda, música latina, años 80 y 90, o una mezcla. Coordinas con él antes del evento para definir el set según el perfil de tus invitados.'
  },
  {
    pregunta: '¿Qué diferencia al line array de bocinas convencionales?',
    respuesta: 'Un line array es un sistema de bocinas apiladas que proyecta el sonido en línea horizontal, logrando que llegue con la misma intensidad a largas distancias sin perder claridad. Para eventos de 200-500 personas en espacios grandes, es la única forma de lograr cobertura pareja con calidad profesional.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Fiesta Masiva?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo, Querétaro y destinos similares. Para eventos fuera de 100 km de CDMX se aplica cargo por traslado.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete Masiva?',
    respuesta: 'Para producción de esta escala recomendamos reservar con 6 a 8 semanas de anticipación mínimo. El line array y el DJ profesional tienen alta demanda en temporada alta. Contáctanos por WhatsApp para verificar disponibilidad.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Fiesta Masiva — Bocinas para Fiestas | REDEIL',
    description: 'Producción completa de audio e iluminación para eventos masivos de 200-500 personas. Line array + DJ profesional + iluminación completa. CDMX y Estado de México.',
    image: SITE_URL + '/img/paquetes/bocinas-fiestas/fiesta-masiva.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '15000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '29',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Fiesta Masiva — Bocinas para Fiestas en CDMX | REDEIL"
  description="Producción completa de audio e iluminación para eventos de 200-500 personas. Line array + DJ profesional + iluminación completa. Instalación en CDMX desde $15,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Bocinas para Fiestas', href: '/renta-de-bocinas/bocinas-para-fiestas/' },
    { name: 'Fiesta Masiva', href: '/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/' }
  ]} />

  <Hero
    badge="Fiesta Masiva"
    title="Fiesta Masiva — Producción Completa para Eventos Grandes"
    description="Line array profesional + DJ + iluminación completa para eventos de 200 a 500 personas. La producción de un concierto aplicada a tu fiesta. CDMX y Estado de México."
    primaryCta={{ text: 'Cotizar $15,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-fiestas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Fiesta Masiva</strong> es producción real para eventos grandes. Cuando tienes 200 o más personas en un espacio, las bocinas convencionales no alcanzan — necesitas un sistema <strong>line array</strong> que proyecte el sonido con potencia y claridad hasta los puntos más lejanos del espacio. Más un <strong>DJ profesional</strong> que lee al público y mantiene la energía, e <strong>iluminación completa</strong> con cabezas móviles, cañones y efectos que transforman cualquier espacio en un ambiente de producción premium.</p>
      <p>En <strong>REDEIL</strong> llevamos esta producción a <strong>CDMX y Estado de México</strong> con un equipo técnico especializado que opera todo para que tú solo te dediques a celebrar.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Fiestas"
    items={[
      { label: "Fiesta en Casa", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-casa/" },
      { label: "Fiesta en Jardín", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-jardin/" },
      { label: "Fiesta en Salón", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-masiva.avif" alt="Paquete Fiesta Masiva line array con iluminación completa para evento grande" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/bocinas-fiestas/line-array.avif" alt="Sistema line array profesional de alta potencia para eventos masivos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/dj-profesional.avif" alt="DJ profesional en cabina de mezclas para fiesta masiva" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/iluminacion-completa.avif" alt="Producción de iluminación con cabezas móviles y efectos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/fiesta-masiva-ambiente.avif" alt="Evento masivo con producción completa de audio e iluminación REDEIL" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Fiesta Masiva — Producción completa</span>
            <h2 class="prod-info__title">Line Array + DJ Profesional + Iluminación Completa para 200-500 Personas</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$15,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Producción completa: line array, DJ, iluminación, técnico de sonido, ingeniero de luces, transporte y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando la fiesta es grande, la producción tiene que estar a la altura</h2>
            <p class="prod-selling__intro">Un evento de 200 a 500 personas no se produce con bocinas de salón escaladas. La física del sonido en espacios grandes requiere sistemas diseñados para eso: line arrays que proyectan el audio en línea horizontal, subwoofers que se sienten en el pecho, iluminación que crea momentos y un DJ que lee al público. El paquete Fiesta Masiva es exactamente eso — la producción de un festival privado para tu evento.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sistema line array — sonido de concierto en tu evento</h3>
                  <p class="prod-hl__desc">El line array proyecta el sonido horizontalmente con una dispersión uniforme. El invitado que está en la primera fila y el que está al fondo del salón escuchan con la misma claridad e intensidad, sin que el volumen tenga que ser molesto cerca de las bocinas para llegar al fondo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">DJ profesional — el corazón de la fiesta</h3>
                  <p class="prod-hl__desc">No es una playlist automática. El DJ de REDEIL lee al público, mezcla en tiempo real y mantiene la energía exactamente donde necesita estar en cada momento: entrada, cena, discursos, primer baile, baile libre. Coordinas el set con él previamente para que conozca el perfil de tus invitados.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Iluminación completa — el ambiente que transforma el espacio</h3>
                  <p class="prod-hl__desc">Cabezas móviles, cañones de luz, luces de efectos y sistemas de colores crean un espectáculo visual sincronizado con la música. El salón deja de ser un espacio genérico y se convierte en un ambiente de producción premium que tus invitados no van a olvidar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Equipo técnico especializado — técnico de sonido + ingeniero de luces</h3>
                  <p class="prod-hl__desc">Para eventos de esta escala, el DJ no opera el sonido solo. Un técnico de sonido independiente maneja el sistema de PA, los micrófonos y el monitoreo. Un ingeniero de iluminación opera el cuadro de luces. Tres profesionales dedicados exclusivamente a tu evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema line array de alta potencia</div>
              <div class="prod-feat">Subwoofers profesionales</div>
              <div class="prod-feat">DJ profesional</div>
              <div class="prod-feat">Mezcladora digital</div>
              <div class="prod-feat">4 micrófonos inalámbricos</div>
              <div class="prod-feat">Cabezas móviles inteligentes</div>
              <div class="prod-feat">Cañones y efectos de luz</div>
              <div class="prod-feat">Estructura de truss para rigging</div>
              <div class="prod-feat">Técnico de sonido en sitio</div>
              <div class="prod-feat">Ingeniero de iluminación</div>
              <div class="prod-feat">Transporte y logística completa</div>
              <div class="prod-feat">Montaje, operación y desmontaje</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Visita o briefing del espacio</h4>
                  <p class="prod-step__desc">Para eventos de esta escala hacemos una visita previa al venue o un briefing detallado por video. Necesitamos conocer las dimensiones, la acústica y los puntos de rigging disponibles para diseñar el sistema correctamente.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta técnica personalizada</h4>
                  <p class="prod-step__desc">Diseñamos el sistema de sonido e iluminación específico para tu espacio y número de invitados. Te enviamos propuesta detallada con render de distribución y especificaciones técnicas completas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Coordinación con DJ y briefing musical</h4>
                  <p class="prod-step__desc">Una vez confirmado el servicio, coordinas directamente con el DJ el set list, estilo musical, momentos especiales del evento y cualquier canción específica que necesites. Todo queda documentado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje profesional con 4-6 horas de anticipación</h4>
                  <p class="prod-step__desc">El equipo técnico completo llega con 4-6 horas de anticipación para montar el line array, cablear el sistema, instalar la iluminación y hacer pruebas exhaustivas de sonido. Cuando llegan los primeros invitados, todo está impecable.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Cuándo necesitas Masiva en lugar de Salón?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Fiesta en Salón — $7,000</span>
                <ul class="prod-compare__list">
                  <li>4 bocinas convencionales</li>
                  <li>Hasta 200 personas</li>
                  <li>1 técnico operando todo</li>
                  <li>Iluminación LED básica</li>
                  <li>Sin DJ profesional incluido</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Fiesta Masiva — $15,000</span>
                <ul class="prod-compare__list">
                  <li>Line array para espacios grandes</li>
                  <li>200-500 personas sin problema</li>
                  <li>Técnico de sonido + ingeniero de luces</li>
                  <li>Iluminación completa con cabezas móviles</li>
                  <li>DJ profesional que opera todo el evento</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos un evento corporativo de fin de año para 350 empleados. REDEIL llegó con un equipo increíble — el line array llenaba todo el espacio perfectamente, el DJ leyó perfecto a nuestros colaboradores y la iluminación hizo que el lugar pareciera un venue de primer nivel. Varios compañeros preguntaron si habíamos rentado el lugar especialmente para la producción. Definitivamente los volvemos a contratar."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Lic. Torres — Directora de Recursos Humanos</span>
                <span class="prod-quote__event">Evento corporativo fin de año — 350 asistentes, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Sistema PA</dt><dd>Line array profesional</dd></div>
              <div class="ps-specs__row"><dt>Subwoofers</dt><dd>Alta potencia</dd></div>
              <div class="ps-specs__row"><dt>DJ</dt><dd>Profesional incluido</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>Digital multicanal</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>4 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>Completa + cabezas móviles</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>200-500 personas</dd></div>
              <div class="ps-specs__row"><dt>Técnicos</dt><dd>Sonido + iluminación</dd></div>
              <div class="ps-specs__row"><dt>Montaje</dt><dd>4-6h antes del evento</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas masivas</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Bodas grandes</span>
              <span class="ps-tag">XV años de producción</span>
              <span class="ps-tag">Festivales privados</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Fiestas de empresa</span>
              <span class="ps-tag">Reuniones de 300+ personas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-casa/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-casa.avif" alt="Fiesta en Casa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Casa</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-jardin/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-jardin.avif" alt="Fiesta en Jardín" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Jardín</span>
                <span class="ps-pkg__price">$4,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-salon.avif" alt="Fiesta en Salón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Salón</span>
                <span class="ps-pkg__price">$7,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento más pequeño? El paquete Salón para 100-200 personas tiene todo lo necesario a menor costo.</p>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/" class="ps-upsell__link">Ver paquete Salón →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Para eventos de esta escala hacemos propuesta técnica personalizada. Contáctanos.</p>
            <a href="/cotizar/" class="ps-widget__btn">Solicitar propuesta</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Burbujas</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
