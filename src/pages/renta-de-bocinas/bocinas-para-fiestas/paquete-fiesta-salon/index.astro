---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Fiesta en Salón de bocinas para fiestas?',
    respuesta: 'Incluye 4 bocinas profesionales, mezcladora de 8 canales, 2 micrófonos inalámbricos, iluminación LED para pista de baile, Bluetooth, cables, transporte, instalación profesional, técnico operador durante el evento y desmontaje. Ideal para salones de 100 a 200 personas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Fiesta en Salón?',
    respuesta: 'El paquete tiene un precio desde $7,000 MXN + IVA. Incluye todo: transporte, instalación, 4 bocinas, mixer, 2 micrófonos, iluminación LED y técnico en sitio. Sin costos ocultos dentro de CDMX y Edomex.'
  },
  {
    pregunta: '¿La iluminación que incluye es suficiente para toda la fiesta?',
    respuesta: 'La iluminación LED incluida está diseñada para la pista de baile y crea un ambiente festivo para el evento. Si necesitas producción de iluminación más completa (cabezas móviles, cañones de luz, efectos adicionales), podemos combinar servicios con descuento especial.'
  },
  {
    pregunta: '¿Para qué sirven los 2 micrófonos en una fiesta de salón?',
    respuesta: 'Con 2 micrófonos puedes tener un animador/DJ presentando mientras otro micrófono está listo para el festejado, padrinos o quien dé un discurso. Ideal para XV años, bodas y fiestas con programa de actividades donde hay varios momentos con micrófono.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Fiesta en Salón?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación para eventos de salón. Para fechas en temporada alta (noviembre-enero), reserva con más tiempo. Contáctanos por WhatsApp para verificar disponibilidad al instante.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Fiesta en Salón — Bocinas para Fiestas | REDEIL',
    description: 'Paquete de audio e iluminación para fiestas en salón de 100-200 personas. 4 bocinas + mixer 8 canales + 2 micrófonos + iluminación LED. Instalación profesional en CDMX.',
    image: SITE_URL + '/img/paquetes/bocinas-fiestas/fiesta-salon.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '7000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '67',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Fiesta en Salón — Bocinas para Fiestas en CDMX | REDEIL"
  description="Audio e iluminación profesional para fiestas en salón de 100-200 personas. 4 bocinas + mixer + 2 micrófonos + iluminación LED. Instalación incluida en CDMX desde $7,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Bocinas para Fiestas', href: '/renta-de-bocinas/bocinas-para-fiestas/' },
    { name: 'Fiesta en Salón', href: '/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/' }
  ]} />

  <Hero
    badge="Fiesta en Salón"
    title="Fiesta en Salón — Audio e Iluminación para Fiestas"
    description="Producción completa de audio e iluminación para eventos en salón de 100 a 200 personas. 4 bocinas, mixer, 2 micrófonos e iluminación LED. Todo operado por técnico profesional."
    primaryCta={{ text: 'Cotizar $7,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-fiestas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Fiesta en Salón</strong> es la solución integral para eventos de mediana escala en <strong>CDMX y Estado de México</strong>. Un salón de 100 a 200 personas necesita más que 2 bocinas: necesita cobertura en todas las zonas del espacio, control preciso de niveles con un mixer de 8 canales, dos micrófonos para que el programa fluya sin interrupciones, e iluminación que cree el ambiente festivo en la pista.</p>
      <p>Un técnico de <strong>REDEIL</strong> lo opera todo de principio a fin para que tu evento tenga la producción de un profesional sin necesidad de contratar un DJ o una empresa de producción completa por separado.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Fiestas"
    items={[
      { label: "Fiesta en Casa", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-casa/" },
      { label: "Fiesta en Jardín", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-jardin/" },
      { label: "Fiesta Masiva", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-salon.avif" alt="Paquete Fiesta en Salón 4 bocinas con iluminación LED para evento" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/bocinas-fiestas/4-bocinas-salon.avif" alt="4 bocinas profesionales distribuidas en salón de eventos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/mixer-8-canales.avif" alt="Mezcladora de 8 canales para control profesional de audio" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/iluminacion-salon.avif" alt="Iluminación LED para pista de baile en salón de fiestas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/fiesta-salon-ambiente.avif" alt="Salón de fiestas con audio e iluminación profesional REDEIL" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Fiesta en Salón — Audio + Iluminación incluidos</span>
            <h2 class="prod-info__title">4 Bocinas + Mixer 8 Canales + 2 Micrófonos + Iluminación LED para 100-200 Personas</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$7,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 4 bocinas, mixer, 2 micrófonos, iluminación, técnico, transporte y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Un salón de 100-200 personas necesita producción real — no una sola bocina escalada</h2>
            <p class="prod-selling__intro">Cuando el salón tiene más de 100 personas, el audio se vuelve un reto: hay que cubrir mesas lejos del escenario, zona de baile, área de entrada y quizás terrazas adyacentes. Además, los momentos del evento (entrada, cena, discursos, baile) requieren niveles completamente distintos. El paquete Fiesta en Salón lo resuelve todo con 4 bocinas distribuidas, mixer de 8 canales, 2 micrófonos e iluminación LED — operados por un técnico especializado.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 bocinas — cobertura total del salón sin puntos muertos</h3>
                  <p class="prod-hl__desc">Con 4 bocinas estratégicamente posicionadas, el audio llega con la misma calidad e intensidad a cada rincón del salón. Ningún invitado queda en zona de silencio y no hay que subir tanto el volumen que resulte molesto en las mesas cercanas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mixer de 8 canales — control total para cada momento del evento</h3>
                  <p class="prod-hl__desc">El técnico puede manejar simultáneamente 2 micrófonos, la música principal, música de respaldo y efectos de audio. Transiciones suaves entre discursos y baile, sin silencios incómodos ni cambios abruptos de volumen que incomoden a los invitados.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 micrófonos — animador y festejado al mismo tiempo</h3>
                  <p class="prod-hl__desc">Con dos micrófonos simultáneos, el animador puede presentar mientras el festejado tiene su propio micrófono para el brindis o agradecimientos. Sin que nadie tenga que esperar a que el otro termine ni se pase el micrófono de mano en mano.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Iluminación LED incluida — ambiente festivo desde el primer momento</h3>
                  <p class="prod-hl__desc">El paquete incluye iluminación LED para la pista de baile. Colores, efectos y sincronización con la música crean el ambiente festivo que convierte una reunión en una fiesta memorable. Todo configurado y operado por el técnico.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 bocinas profesionales</div>
              <div class="prod-feat">Mezcladora de 8 canales</div>
              <div class="prod-feat">2 micrófonos inalámbricos</div>
              <div class="prod-feat">Iluminación LED para pista</div>
              <div class="prod-feat">Conectividad Bluetooth + AUX</div>
              <div class="prod-feat">Amplificadores de potencia</div>
              <div class="prod-feat">Soportes y estructuras</div>
              <div class="prod-feat">Cables profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador en sitio</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, nombre del salón o dirección, número de invitados y programa del evento. Con esos datos diseñamos la distribución de las 4 bocinas para cobertura óptima en tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Propuesta detallada con precio final, distribución de equipo y opciones de personalización. Sin compromisos ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta con anticipo</h4>
                  <p class="prod-step__desc">Reserva con 50% de anticipo. Para salones en temporada alta recomendamos asegurar la fecha lo antes posible — el equipo tiene disponibilidad limitada los fines de semana.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje 3 horas antes del evento</h4>
                  <p class="prod-step__desc">El equipo técnico llega 3 horas antes para instalar y configurar todo. Hacemos pruebas de sonido, calibramos iluminación y dejamos todo listo antes de que lleguen los invitados.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Qué cambia del paquete Jardín al paquete Salón?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Fiesta en Jardín — $4,500</span>
                <ul class="prod-compare__list">
                  <li>2 bocinas para 50-100 personas</li>
                  <li>Mixer de 6 canales</li>
                  <li>1 micrófono inalámbrico</li>
                  <li>Sin iluminación incluida</li>
                  <li>Ideal para espacios medianos</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Fiesta en Salón — $7,000</span>
                <ul class="prod-compare__list">
                  <li>4 bocinas para 100-200 personas</li>
                  <li>Mixer de 8 canales con más control</li>
                  <li>2 micrófonos simultáneos</li>
                  <li>Iluminación LED incluida</li>
                  <li>Producción completa para salón</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete de salón para los XV años de mi hija. El técnico era super profesional — llegó a tiempo, instaló todo sin que nos dimos cuenta y durante la fiesta manejó los micrófonos de los padrinos, el animador y la quinceañera sin ningún problema. La iluminación de la pista era increíble. Nuestros invitados preguntaban que quién era el DJ profesional."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sra. Morales</span>
                <span class="prod-quote__event">XV Años — Salón Cristal, Naucalpan, Estado de México</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>4 bocinas profesionales</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>8 canales</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>2 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>LED para pista</dd></div>
              <div class="ps-specs__row"><dt>Conectividad</dt><dd>Bluetooth + AUX</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>100-200 personas</dd></div>
              <div class="ps-specs__row"><dt>Montaje</dt><dd>3h antes del evento</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Toda la duración</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años en salón</span>
              <span class="ps-tag">Bodas</span>
              <span class="ps-tag">Cumpleaños grandes</span>
              <span class="ps-tag">Fiestas de empresa</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Aniversarios</span>
              <span class="ps-tag">Salones de eventos</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-casa/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-casa.avif" alt="Fiesta en Casa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Casa</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-jardin/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-jardin.avif" alt="Fiesta en Jardín" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Jardín</span>
                <span class="ps-pkg__price">$4,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-masiva.avif" alt="Fiesta Masiva" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta Masiva</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Más de 200 personas o quieres DJ profesional e iluminación completa? El paquete Masiva lo tiene todo.</p>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/" class="ps-upsell__link">Ver paquete Masiva →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Burbujas</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
