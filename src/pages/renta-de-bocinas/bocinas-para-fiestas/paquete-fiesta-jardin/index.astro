---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Fiesta en Jardín de bocinas para fiestas?',
    respuesta: 'Incluye 2 bocinas profesionales de alta potencia, mezcladora de 6 canales, 1 micrófono inalámbrico, Bluetooth, cables, transporte, instalación, técnico operador durante el evento y desmontaje. Diseñado para jardines y espacios al aire libre de 50 a 100 personas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Fiesta en Jardín?',
    respuesta: 'El paquete tiene un precio desde $4,500 MXN + IVA. Incluye transporte, instalación, operación técnica y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Por qué necesito 2 bocinas para una fiesta en jardín?',
    respuesta: 'Los espacios al aire libre absorben el sonido — una sola bocina no logra una cobertura pareja. Con 2 bocinas ubicadas estratégicamente, el volumen llega uniforme a todos los puntos del jardín sin zonas de silencio ni puntos donde el volumen molesta a los vecinos.'
  },
  {
    pregunta: '¿El mixer viene operado por un técnico o yo lo uso?',
    respuesta: 'Viene operado por el técnico de REDEIL. Él ajusta los niveles del micrófono y la música durante el evento para que todo suene bien en todo momento. Tú no tienes que tocar nada.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Fiesta en Jardín?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 3 a 5 semanas de anticipación. Para fines de semana en temporada alta (octubre-enero), reserva antes. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Fiesta en Jardín — Bocinas para Fiestas | REDEIL',
    description: 'Paquete de bocinas para fiestas al aire libre de 50-100 personas. 2 bocinas + mixer + micrófono inalámbrico. Instalación profesional en CDMX y Estado de México.',
    image: SITE_URL + '/img/paquetes/bocinas-fiestas/fiesta-jardin.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-jardin/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '52',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Fiesta en Jardín — Bocinas para Fiestas en CDMX | REDEIL"
  description="Audio profesional para fiestas al aire libre de 50-100 personas. 2 bocinas + mixer + micrófono inalámbrico. Instalación incluida en CDMX y Edomex desde $4,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[
    { name: 'Renta de Bocinas', href: '/renta-de-bocinas/' },
    { name: 'Bocinas para Fiestas', href: '/renta-de-bocinas/bocinas-para-fiestas/' },
    { name: 'Fiesta en Jardín', href: '/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-jardin/' }
  ]} />

  <Hero
    badge="Fiesta en Jardín"
    title="Fiesta en Jardín — Bocinas para Fiestas al Aire Libre"
    description="Audio profesional para eventos exteriores de 50 a 100 personas. 2 bocinas de alta potencia con mixer y micrófono inalámbrico. Cobertura pareja en todo el jardín, sin zonas de silencio."
    primaryCta={{ text: 'Cotizar $4,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-fiestas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Fiesta en Jardín</strong> está diseñado para resolver el problema real de los eventos al aire libre: el sonido se dispersa. Una sola bocina no es suficiente — necesitas dos puntos de emisión bien ubicados para lograr cobertura pareja en un jardín de mediano a grande sin que ningún invitado se quede sin escuchar ni sin que los vecinos llamen a quejarse.</p>
      <p>Con 2 bocinas de alta potencia, mezcladora de 6 canales y micrófono inalámbrico operados por un técnico de <strong>REDEIL</strong>, tu fiesta en jardín de 50 a 100 personas suena profesional de inicio a fin en <strong>CDMX y Estado de México</strong>.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Fiestas"
    items={[
      { label: "Fiesta en Casa", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-casa/" },
      { label: "Fiesta en Salón", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/" },
      { label: "Fiesta Masiva", href: "/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/" }
    ]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-jardin.avif" alt="Paquete Fiesta en Jardín 2 bocinas para evento al aire libre" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/bocinas-fiestas/bocinas-dobles-jardin.avif" alt="2 bocinas profesionales de alta potencia en jardín" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/mixer-jardin.avif" alt="Mezcladora de 6 canales para eventos al aire libre" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/fiesta-jardin-setup.avif" alt="Técnico configurando audio para fiesta en jardín" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/bocinas-fiestas/fiesta-jardin-ambiente.avif" alt="Fiesta en jardín con cobertura de audio profesional" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Fiesta en Jardín — Más popular para exteriores</span>
            <h2 class="prod-info__title">2 Bocinas + Mixer 6 Canales + Micrófono Inalámbrico para 50-100 Personas al Aire Libre</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, técnico durante el evento y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El paquete correcto para jardines — donde el sonido se escapa por todos lados</h2>
            <p class="prod-selling__intro">Outdoor audio es completamente diferente a indoor. El espacio abierto absorbe el sonido, el viento lo desplaza, y los vecinos son una preocupación real. El paquete Fiesta en Jardín resuelve todo eso: 2 bocinas estratégicamente ubicadas para cobertura pareja, mixer para controlar niveles en tiempo real y micrófono inalámbrico operado por un técnico que sabe lo que hace.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 bocinas — cobertura pareja en todo el jardín</h3>
                  <p class="prod-hl__desc">Con dos puntos de emisión bien calculados, el audio llega con la misma intensidad al área de mesas, a la pista de baile y a la barra. Nadie queda en una zona de silencio y nadie se sienta directamente frente a un bafle ensordecedor.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mixer de 6 canales — música y micrófono en perfecta proporción</h3>
                  <p class="prod-hl__desc">La mezcladora permite que el técnico balance en tiempo real: sube el micrófono para el brindis, baja la música cuando alguien habla, sube la música cuando empieza el baile. Todo sin interrupciones ni niveles mal ajustados.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Micrófono inalámbrico — libertad de movimiento total</h3>
                  <p class="prod-hl__desc">El festejado, el animador o quien haga el brindis puede caminar por todo el jardín con el micrófono sin cables que estorben. Sin retroalimentación ni interferencias en exteriores.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico especializado en audio para exteriores</h3>
                  <p class="prod-hl__desc">El técnico de REDEIL llega con anticipación, evalúa el espacio, posiciona las bocinas en los puntos óptimos y opera el equipo durante todo el evento. Conoce los retos del audio al aire libre y los resuelve antes de que sean un problema.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 bocinas profesionales de alta potencia</div>
              <div class="prod-feat">Mezcladora de 6 canales</div>
              <div class="prod-feat">1 micrófono inalámbrico</div>
              <div class="prod-feat">Conectividad Bluetooth + AUX</div>
              <div class="prod-feat">Soportes y bases para bocinas</div>
              <div class="prod-feat">Cables profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, dirección, número de invitados y dimensiones aproximadas del jardín. Con esos datos planificamos la distribución de las 2 bocinas para cobertura óptima.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Precio final con todos los detalles incluidos. Sin extras de último minuto ni cargos por zonas dentro de CDMX y Edomex.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con 50% de anticipo. Tu fecha queda bloqueada al instante por transferencia, efectivo o tarjeta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, evaluamos y montamos</h4>
                  <p class="prod-step__desc">El técnico llega con 2 horas de anticipación, evalúa el espacio, posiciona los equipos, hace pruebas de sonido y opera todo el sistema durante tu evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué no usar el paquete Casa para una fiesta en jardín?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Fiesta en Casa — $2,500</span>
                <ul class="prod-compare__list">
                  <li>1 bocina para interiores</li>
                  <li>El sonido no alcanza todo el jardín</li>
                  <li>Sin mixer para balancear niveles</li>
                  <li>Ideal solo para 30-50 personas</li>
                  <li>No compensa la dispersión exterior</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Fiesta en Jardín — $4,500</span>
                <ul class="prod-compare__list">
                  <li>2 bocinas para cobertura pareja</li>
                  <li>Diseñado para espacios exteriores</li>
                  <li>Mixer para control en tiempo real</li>
                  <li>Capacidad 50-100 personas</li>
                  <li>Técnico experto en audio outdoor</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Fiesta de quinceañera en el jardín de la casa, como 80 personas. El técnico llegó temprano y colocó las bocinas de una forma que el sonido se escuchaba igual en todas las mesas. Para el brindis subió el micrófono perfecto y luego la música siguió sin problema. Muy profesionales desde que llegaron hasta que se fueron."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Familia Reséndiz</span>
                <span class="prod-quote__event">XV Años en jardín privado — Ecatepec, Estado de México</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>2 bocinas de alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>6 canales</dd></div>
              <div class="ps-specs__row"><dt>Micrófono</dt><dd>1 inalámbrico</dd></div>
              <div class="ps-specs__row"><dt>Conectividad</dt><dd>Bluetooth + AUX</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>50-100 personas</dd></div>
              <div class="ps-specs__row"><dt>Espacio ideal</dt><dd>Jardines y exteriores</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Durante el evento</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas en jardín</span>
              <span class="ps-tag">XV años al aire libre</span>
              <span class="ps-tag">Cumpleaños en azotea</span>
              <span class="ps-tag">Bodas pequeñas</span>
              <span class="ps-tag">Eventos en terraza</span>
              <span class="ps-tag">Palapas</span>
              <span class="ps-tag">Reuniones en rancho</span>
              <span class="ps-tag">Fiestas familiares</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-casa/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-casa.avif" alt="Fiesta en Casa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Casa</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-salon.avif" alt="Fiesta en Salón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta en Salón</span>
                <span class="ps-pkg__price">$7,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-masiva/" class="ps-pkg">
              <img src="/img/paquetes/bocinas-fiestas/fiesta-masiva.avif" alt="Fiesta Masiva" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Fiesta Masiva</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento con más de 100 personas o salón grande? El paquete Salón incluye 4 bocinas, 2 micrófonos e iluminación.</p>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/paquete-fiesta-salon/" class="ps-upsell__link">Ver paquete Salón →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu fiesta</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/equipos-para-eventos/bola-disco/" class="ps-link">Bola Disco</a>
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/maquina-de-burbujas/" class="ps-link">Burbujas</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
