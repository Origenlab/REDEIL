---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción Boda?',
    respuesta: 'Incluye sistema line array profesional, subwoofers de alto impacto, DJ profesional con consola Pioneer NXS2, director de audio para operación en vivo, iluminación completa (cabezas móviles, uplighting, guirnaldas, par LED), 6 micrófonos inalámbricos, sistema de monitoreo, transporte, instalación, prueba de sonido y desmontaje.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción Boda?',
    respuesta: 'El paquete Producción Boda tiene un precio desde $22,000 MXN + IVA. Incluye line array, DJ, director de audio, iluminación completa, micrófonos, transporte, instalación y desmontaje en CDMX y Estado de México. Para venues grandes o bodas de 300+ invitados, es la opción más completa.'
  },
  {
    pregunta: '¿Qué diferencia hay entre un line array y bocinas convencionales?',
    respuesta: 'Un line array proyecta el sonido de forma uniforme a lo largo de toda la sala o jardín, sin zonas muertas ni puntos con volumen excesivo. Para bodas de 300+ invitados en jardines grandes o salones de techo alto, el line array es la única forma de garantizar audio uniforme en todo el espacio.'
  },
  {
    pregunta: '¿Qué iluminación completa incluye?',
    respuesta: 'El paquete incluye cabezas móviles para efectos de pista, uplighting para paredes y columnas, guirnaldas LED para ambiente, par LED RGB para color y un operador de iluminación dedicado. Es una producción completa de luz y sonido para tu boda.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete Producción Boda?',
    respuesta: 'Recomendamos reservar con 8 a 12 semanas de anticipación para este paquete, ya que requiere coordinación avanzada de equipo, DJ, director de audio y operador de iluminación. Contáctanos para verificar disponibilidad de tu fecha.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción Boda — Bocinas para Bodas | REDEIL',
    description: 'Producción completa de audio e iluminación para bodas: line array profesional + DJ + director de audio + iluminación completa. Para eventos de 300+ personas en CDMX. Desde $22,000 MXN.',
    image: SITE_URL + '/img/img-index/bocinas-para-bodas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '22000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '22',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción Boda — Line Array + DJ + Iluminación Completa en CDMX | REDEIL"
  description="Producción completa para tu boda: line array profesional + DJ Pioneer NXS2 + director de audio + iluminación completa. 300+ invitados. Desde $22,000 MXN en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Bocinas', href: '/renta-de-bocinas/' }, { name: 'Bocinas para Bodas', href: '/renta-de-bocinas/bocinas-para-bodas/' }, { name: 'Producción Boda', href: '/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/' }]} />

  <Hero
    badge="Producción Boda"
    title="Producción Boda — Line Array + DJ + Iluminación Completa"
    description="Producción profesional completa: line array + DJ Pioneer NXS2 + director de audio + iluminación total. Para bodas de 300+ invitados. Desde $22,000 MXN."
    primaryCta={{ text: 'Cotizar $22,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-bodas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Producción Boda es para parejas que quieren que su boda suene y se vea como un concierto de alto nivel. <strong>Sistema line array profesional</strong> para audio uniforme en todo el espacio, <strong>DJ con consola Pioneer NXS2</strong>, <strong>director de audio dedicado</strong> que opera el sistema en vivo, e <strong>iluminación completa</strong> que cubre pista, paredes y ambiente.</p>
      <p>Este no es un paquete ampliado — es una producción completa. Llega un equipo de 4 personas: DJ, director de audio, técnico de iluminación y coordinador general. Cada detalle está planificado con anterioridad. El resultado es una boda que se ve y suena de nivel profesional en cada momento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Bodas"
    items={[{ label: "Solo Ceremonia", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/" }, { label: "Boda Completa", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" }, { label: "Boda con DJ", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/bocinas-para-bodas.avif" alt="Line array profesional y producción completa en boda de alto nivel" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Sistema line array para boda de 300 invitados en jardín" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="DJ con consola Pioneer NXS2 en producción de boda" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Iluminación completa uplighting y cabezas móviles en boda" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Director de audio operando consola en producción de boda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Producción Boda — El nivel más alto</span>
            <h2 class="prod-info__title">Line Array + DJ Pioneer NXS2 + Director de Audio + Iluminación Completa</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$22,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Producción completa: audio, DJ, dirección de audio e iluminación total. Para bodas de 300+ invitados en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando la boda merece una producción, no solo un servicio</h2>
            <p class="prod-selling__intro">Hay bodas donde el audio "suficientemente bueno" no es suficiente. Venues grandes, jardines abiertos, salones de techo alto — espacios donde el sonido se pierde o se distorsiona con sistemas convencionales. El line array resuelve ese problema técnicamente. El director de audio lo opera en tiempo real. La iluminación completa convierte cada espacio en escena. Es la diferencia entre una boda con buen audio y una boda que parece producida.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Line array profesional — audio uniforme en cada rincón del venue</h3>
                  <p class="prod-hl__desc">El line array proyecta el sonido en columnas de audio que mantienen la consistencia de volumen y claridad a 5 metros igual que a 50 metros. No hay zona muerta al fondo del jardín ni zona con demasiado volumen junto a los altavoces. Funciona en espacios de cualquier tamaño.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de audio dedicado — el sistema se opera en vivo, no en automático</h3>
                  <p class="prod-hl__desc">El director de audio es la persona que opera la consola principal durante todo el evento. Ajusta niveles de micrófonos en tiempo real, controla la mezcla entre DJ y micrófonos, y garantiza que cada momento suene exactamente como debe. No es el técnico de instalación — es un operador de sonido profesional.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Iluminación completa — cada espacio del venue tiene su tratamiento</h3>
                  <p class="prod-hl__desc">Uplighting en columnas y paredes, cabezas móviles para la pista, guirnaldas para el jardín, par LED RGB para los efectos cromáticos. Un operador de iluminación dedicado que programa los momentos clave: entrada, primer baile, brindis, hora loca. No hay un momento sin iluminación pensada.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">DJ con consola Pioneer NXS2 — el rider técnico más completo del mercado</h3>
                  <p class="prod-hl__desc">La Pioneer NXS2 es la consola estándar de los mejores DJs en México. Permite mezcla de 4 canales simultáneos, efectos de alta gama y sincronización con el sistema de iluminación. El resultado es una pista de baile con audio e iluminación que se mueven juntos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema line array profesional</div>
              <div class="prod-feat">Subwoofers de alto impacto</div>
              <div class="prod-feat">DJ profesional certificado</div>
              <div class="prod-feat">Consola Pioneer NXS2</div>
              <div class="prod-feat">Director de audio dedicado</div>
              <div class="prod-feat">6 micrófonos inalámbricos</div>
              <div class="prod-feat">Cabezas móviles para pista</div>
              <div class="prod-feat">Uplighting para columnas y paredes</div>
              <div class="prod-feat">Guirnaldas LED para jardín</div>
              <div class="prod-feat">Par LED RGB para efectos</div>
              <div class="prod-feat">Operador de iluminación dedicado</div>
              <div class="prod-feat">Sistema de monitoreo en escenario</div>
              <div class="prod-feat">Brief de producción previo</div>
              <div class="prod-feat">Transporte y logística completa</div>
              <div class="prod-feat">Instalación y prueba de sonido</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de producción inicial</h4>
                  <p class="prod-step__desc">Fecha, venue, número de invitados y programa completo del evento. Asignamos tu director de producción que coordina todos los elementos del paquete.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Brief técnico y musical detallado</h4>
                  <p class="prod-step__desc">Visita técnica al venue para medir el espacio y planificar la distribución del line array. Brief musical con el DJ para conocer tus preferencias. Diseño del plan de iluminación por zonas y momentos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50%. El equipo completo (DJ, director de audio, técnico de iluminación) queda bloqueado para tu fecha. Recomendamos reservar con 8-12 semanas de anticipación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje profesional y producción completa</h4>
                  <p class="prod-step__desc">Llegamos 6 horas antes con un equipo de 4 personas. Montaje del line array, configuración de iluminación, prueba de sonido con todos los micrófonos. Producción desde la ceremonia hasta el último baile. Desmontaje discreto al terminar.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Boda con DJ o Producción Boda?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Boda con DJ — $12,000</span>
                <ul class="prod-compare__list">
                  <li>Sistema JBL convencional</li>
                  <li>Iluminación básica de pista</li>
                  <li>Hasta 250 invitados</li>
                  <li>Técnico + DJ (2 personas)</li>
                  <li>Venues medianos</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción Boda — $22,000</span>
                <ul class="prod-compare__list">
                  <li>Line array profesional</li>
                  <li>Iluminación completa todas zonas</li>
                  <li>300+ invitados</li>
                  <li>DJ + director de audio + iluminador</li>
                  <li>Venues grandes, jardines, haciendas</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos Producción Boda para una boda de 380 personas en una hacienda en Valle de Bravo. El line array cubrió el jardín completamente — los invitados en las mesas más alejadas escuchaban igual que los de primera fila. El director de audio coordinó todos los micrófonos durante la ceremonia y los discursos sin un solo error. La iluminación transformó el jardín en tres escenas distintas. Fue literalmente una producción profesional."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Fernanda y Eduardo</span>
                <span class="prod-quote__event">Boda en Hacienda Vista Hermosa, Valle de Bravo — 380 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Sistema audio</dt><dd>Line array profesional</dd></div>
              <div class="ps-specs__row"><dt>DJ</dt><dd>Pioneer NXS2</dd></div>
              <div class="ps-specs__row"><dt>Director audio</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>6 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Iluminación</dt><dd>Completa todas zonas</dd></div>
              <div class="ps-specs__row"><dt>Equipo humano</dt><dd>4 personas</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>300+ personas</dd></div>
              <div class="ps-specs__row"><dt>Brief técnico</dt><dd>Visita al venue</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex + 100 km</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">300+ invitados</span>
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Jardines grandes</span>
              <span class="ps-tag">Venues de techo alto</span>
              <span class="ps-tag">Producción completa</span>
              <span class="ps-tag">Bodas premium</span>
              <span class="ps-tag">Salones de gala</span>
              <span class="ps-tag">Bodas con ceremonia + recepción + show</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Solo Ceremonia" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Solo Ceremonia</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Boda Completa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda Completa</span>
                <span class="ps-pkg__price">$7,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Boda con DJ" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda con DJ</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Necesitas solo audio sin DJ? El paquete Boda Completa cubre todo el evento con 4 bocinas, subwoofer y mixer de 8 canales.</p>
              <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" class="ps-upsell__link">Ver Boda Completa →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización detallada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
