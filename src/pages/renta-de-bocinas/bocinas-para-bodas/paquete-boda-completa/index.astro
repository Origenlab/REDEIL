---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Boda Completa?',
    respuesta: 'Incluye 4 bocinas JBL activas de 12 pulgadas, 1 subwoofer de 18 pulgadas, mixer de 8 canales, 4 micrófonos inalámbricos, procesador de señal, cables y extensiones profesionales, transporte, instalación, técnico operador durante todo el evento y desmontaje. Cubre ceremonia, coctel, recepción y pista de baile.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Boda Completa?',
    respuesta: 'El paquete tiene un precio desde $7,500 MXN + IVA. Incluye todo: transporte, instalación, 4 micrófonos inalámbricos, mixer de 8 canales, operación durante todo el evento y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿El audio cubre tanto la ceremonia como la fiesta?',
    respuesta: 'Sí, el sistema se configura en etapas. Para la ceremonia se usan 2 bocinas con micrófonos. Al pasar a recepción y pista de baile activamos el sistema completo: 4 bocinas + subwoofer para reproducir música sin DJ a volumen de fiesta. Si tú o alguien de tu equipo pondrá la música, este paquete es la solución completa.'
  },
  {
    pregunta: '¿Cuántos invitados puede cubrir este sistema?',
    respuesta: 'El sistema de 4 bocinas JBL + subwoofer 18 pulgadas cubre cómodamente eventos de hasta 300 personas en jardines, salones y haciendas. Para eventos más grandes, considera el paquete Boda con DJ o Producción Boda.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Boda Completa — Bocinas para Bodas | REDEIL',
    description: 'Sistema de audio completo para boda: 4 bocinas JBL 12 pulgadas + subwoofer 18 pulgadas + mixer 8 canales + 4 micrófonos. Cubre ceremonia, recepción y pista de baile. Hasta 300 personas en CDMX.',
    image: SITE_URL + '/img/img-index/bocinas-para-bodas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '7500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '58',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Boda Completa — Bocinas para Boda en CDMX | REDEIL"
  description="4 bocinas JBL + subwoofer + mixer + 4 micrófonos para toda tu boda. Ceremonia, recepción y pista de baile cubiertos. Desde $7,500 MXN en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Bocinas', href: '/renta-de-bocinas/' }, { name: 'Bocinas para Bodas', href: '/renta-de-bocinas/bocinas-para-bodas/' }, { name: 'Boda Completa', href: '/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/' }]} />

  <Hero
    badge="Boda Completa"
    title="Boda Completa — Bocinas para Boda"
    description="Audio profesional JBL para toda tu boda: ceremonia, recepción y pista de baile. 4 bocinas + subwoofer + mixer 8 canales + 4 micrófonos. Desde $7,500 MXN."
    primaryCta={{ text: 'Cotizar $7,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-bodas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Boda Completa cubre cada momento de tu boda con audio profesional de nivel. <strong>4 bocinas JBL activas de 12 pulgadas + subwoofer de 18 pulgadas</strong> para la pista de baile, <strong>4 micrófonos inalámbricos</strong> para ceremonia y discursos, y un <strong>mixer de 8 canales</strong> que permite conectar tu música y micrófonos simultáneamente sin interrupciones.</p>
      <p>Nuestro técnico opera el sistema durante todo el evento: calibra el audio para la ceremonia, reconfigura para la recepción y maximiza la potencia del subwoofer cuando comienza el baile. Tú y tus invitados disfrutan. Nosotros cuidamos el sonido.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Bodas"
    items={[{ label: "Solo Ceremonia", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/" }, { label: "Boda con DJ", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" }, { label: "Producción Boda", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/bocinas-para-bodas.avif" alt="Sistema de audio completo JBL para boda en salón" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="4 bocinas JBL y subwoofer para recepción de boda" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Mixer de 8 canales para boda con múltiples micrófonos" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Pista de baile con sistema de audio profesional" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Técnico de audio en recepción de boda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Boda Completa — El más popular</span>
            <h2 class="prod-info__title">4 Bocinas JBL + Subwoofer 18 pulgadas + Mixer 8 Canales + 4 Micrófonos</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$7,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operación completa y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Un sistema de audio para cada momento de tu boda</h2>
            <p class="prod-selling__intro">La ceremonia necesita claridad y sutileza. La recepción necesita presencia y calidez. La pista de baile necesita potencia y graves que se sientan. Un solo paquete, tres configuraciones distintas, un técnico que gestiona cada transición. El paquete Boda Completa está diseñado exactamente para esto: cubrir toda la jornada sin compromisos.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Subwoofer 18 pulgadas — la diferencia entre "suena bien" y "se siente"</h3>
                  <p class="prod-hl__desc">El subwoofer de 18 pulgadas añade los graves que hacen que la música se sienta en el pecho. La pista de baile cobra vida. Los invitados bailan más. Es la diferencia entre un sistema básico y un sistema que realmente mueve a la gente.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 micrófonos inalámbricos — ceremonia y discursos sin limitaciones</h3>
                  <p class="prod-hl__desc">Officiante, lector, testigos y brindis — todos con micrófono. No hay que esperar turnos ni pasar un solo micrófono. Cuatro canales independientes en el mixer permiten controlar cada uno por separado.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mixer 8 canales — conecta tu música y micrófonos simultáneamente</h3>
                  <p class="prod-hl__desc">Conecta tu playlist desde Spotify, Apple Music o USB mientras los micrófonos están activos. El técnico balancea los niveles en tiempo real: sube el micro para el brindis, baja la música, sube la música para el baile. Sin interrupciones, sin cortes.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico operador durante todo el evento — no solo la ceremonia</h3>
                  <p class="prod-hl__desc">A diferencia del paquete básico, el técnico permanece durante toda la boda: ceremonia, coctel, recepción, brindis y baile. Gestiona cada transición para que el audio siempre sea el correcto para el momento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 bocinas JBL activas 12 pulgadas</div>
              <div class="prod-feat">1 subwoofer 18 pulgadas</div>
              <div class="prod-feat">4 micrófonos inalámbricos</div>
              <div class="prod-feat">Mixer de 8 canales</div>
              <div class="prod-feat">Procesador de señal</div>
              <div class="prod-feat">Cables y extensiones</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Prueba de sonido previa</div>
              <div class="prod-feat">Técnico operador todo el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu boda</h4>
                  <p class="prod-step__desc">Fecha, lugar, número de invitados y el programa del evento (ceremonia, coctel, recepción, baile). Con esos datos diseñamos la distribución del sistema en tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, distribución del sistema y plan de operación por etapas. Sin costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Nosotros nos encargamos de todo</h4>
                  <p class="prod-step__desc">Llegamos 3 horas antes, instalamos el sistema completo, hacemos prueba de sonido y operamos durante todo el evento. Ceremonia, recepción y baile. Al terminar, desmontamos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Boda Completa o Boda con DJ?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Boda Completa — $7,500</span>
                <ul class="prod-compare__list">
                  <li>Sistema JBL completo</li>
                  <li>4 bocinas + subwoofer</li>
                  <li>Tú pones tu música</li>
                  <li>4 micrófonos inalámbricos</li>
                  <li>Técnico operador incluido</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Boda con DJ — $12,000</span>
                <ul class="prod-compare__list">
                  <li>Sistema JBL + DJ profesional</li>
                  <li>Consola Pioneer + controlador</li>
                  <li>DJ mezcla en vivo</li>
                  <li>Iluminación básica incluida</li>
                  <li>Una sola contratación</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete Boda Completa porque ya teníamos nuestra playlist armada y solo necesitábamos el sistema. El técnico fue increíble — manejó la transición de la ceremonia al baile sin que nadie se diera cuenta. En el coctel sonaba suave, y cuando empezó el baile subió el subwoofer y la pista se llenó inmediatamente. Todos preguntaban quién era el DJ."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Andrea y Carlos</span>
                <span class="prod-quote__event">Boda en Hacienda San Gabriel, Tláhuac — 180 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>4× JBL 12 pulgadas activas</dd></div>
              <div class="ps-specs__row"><dt>Subwoofer</dt><dd>1× 18 pulgadas</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>4 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>8 canales</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>Hasta 300 personas</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Evento completo</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Todo el evento</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en jardín</span>
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Bodas en salón</span>
              <span class="ps-tag">100-300 invitados</span>
              <span class="ps-tag">Con playlist propia</span>
              <span class="ps-tag">Ceremonias + recepción</span>
              <span class="ps-tag">Pista de baile</span>
              <span class="ps-tag">Sin DJ pero con música</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Solo Ceremonia" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Solo Ceremonia</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Boda con DJ" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda con DJ</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Producción Boda" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Boda</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres DJ profesional + iluminación incluida? El paquete Boda con DJ lo tiene todo en una contratación.</p>
              <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" class="ps-upsell__link">Ver paquete Boda con DJ →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu boda</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
