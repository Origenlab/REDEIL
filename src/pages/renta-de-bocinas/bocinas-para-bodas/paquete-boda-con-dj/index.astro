---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Boda con DJ?',
    respuesta: 'Incluye sistema de audio completo JBL/QSC, DJ profesional con consola Pioneer DDJ, controlador de luces, iluminación básica para pista (cabezas móviles + par LED), 4 micrófonos inalámbricos, transporte, instalación, operación y desmontaje. El DJ coordina con tu wedding planner o familia para seguir el programa del evento.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Boda con DJ?',
    respuesta: 'El paquete tiene un precio desde $12,000 MXN + IVA. Incluye DJ profesional, sistema de audio completo, iluminación básica para pista, micrófonos, transporte, instalación y desmontaje en CDMX y Estado de México. Una sola contratación para audio, DJ e iluminación.'
  },
  {
    pregunta: '¿Puedo dar playlist o referencias musicales al DJ?',
    respuesta: 'Sí, el DJ trabaja con tus referencias. Te pedimos una reunión previa (presencial o por videollamada) para conocer tu estilo musical, géneros favoritos, canciones especiales y momentos clave del evento. El DJ adapta la mezcla a tu gusto, no al suyo.'
  },
  {
    pregunta: '¿Qué iluminación básica incluye?',
    respuesta: 'El paquete incluye 2 cabezas móviles + 4 par LED RGB para iluminación de pista de baile. Si necesitas uplighting, guirnaldas o producción de iluminación más completa, podemos cotizarlo por separado o considerar el paquete Producción Boda.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 6 a 8 semanas de anticipación para este paquete, ya que incluye DJ profesional cuya agenda se llena rápido en temporada alta. Contáctanos por WhatsApp para verificar disponibilidad de fecha.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Boda con DJ — Bocinas para Bodas | REDEIL',
    description: 'Sistema completo de audio JBL + DJ profesional con consola Pioneer + iluminación básica para tu boda en CDMX. Todo en una contratación desde $12,000 MXN.',
    image: SITE_URL + '/img/img-index/bocinas-para-bodas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '12000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '47',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Boda con DJ — Audio + DJ + Iluminación para Boda en CDMX | REDEIL"
  description="Sistema JBL completo + DJ profesional Pioneer + iluminación para pista. Todo incluido desde $12,000 MXN. Una sola contratación para el audio y DJ de tu boda."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Bocinas', href: '/renta-de-bocinas/' }, { name: 'Bocinas para Bodas', href: '/renta-de-bocinas/bocinas-para-bodas/' }, { name: 'Boda con DJ', href: '/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/' }]} />

  <Hero
    badge="Boda con DJ"
    title="Boda con DJ — Audio + DJ Profesional + Iluminación"
    description="Sistema completo JBL + DJ profesional con consola Pioneer + iluminación básica para pista. Todo en una contratación. Desde $12,000 MXN en CDMX."
    primaryCta={{ text: 'Cotizar $12,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-bodas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Boda con DJ resuelve tres servicios en una contratación: <strong>sistema de audio profesional JBL/QSC</strong>, <strong>DJ con consola Pioneer</strong> que mezcla en vivo según el momento, e <strong>iluminación básica para la pista de baile</strong>. No tienes que coordinar con tres proveedores distintos — nosotros llegamos con todo.</p>
      <p>El DJ trabaja con tus referencias musicales. Antes del evento hacen una reunión para entender tu estilo, las canciones especiales y el programa de la boda. Durante el evento, el DJ lee al público y ajusta la música para que la pista se mantenga llena. La iluminación de cabezas móviles refuerza cada momento musical.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Bodas"
    items={[{ label: "Solo Ceremonia", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/" }, { label: "Boda Completa", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" }, { label: "Producción Boda", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/bocinas-para-bodas.avif" alt="DJ profesional con consola Pioneer en boda con iluminación" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Consola Pioneer DDJ para DJ de bodas en CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Cabezas móviles e iluminación de pista de baile en boda" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Sistema JBL completo para boda con DJ profesional" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Pista de baile con iluminación y audio profesional en boda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Boda con DJ — Audio + DJ + Iluminación</span>
            <h2 class="prod-info__title">Sistema JBL Completo + DJ Pioneer + Iluminación para Pista</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$12,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Audio, DJ profesional e iluminación básica. Una contratación, sin coordinación con múltiples proveedores</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">La pista de baile que recordarán por años — sin coordinar tres proveedores</h2>
            <p class="prod-selling__intro">La mayoría de las parejas que contratan este paquete lo hacen por una razón simple: no quieren lidiar con "el DJ tiene su propio equipo pero no sé si es bueno" ni "el equipo de audio es el del salón y suena mal". Con este paquete, el equipo JBL/QSC, la consola Pioneer y la iluminación son de REDEIL. El DJ los conoce porque los usa siempre. Y tú solo haces una llamada.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">DJ profesional con consola Pioneer — mezcla en vivo, no playlists</h3>
                  <p class="prod-hl__desc">La diferencia entre un DJ profesional y una playlist es que el DJ lee al público. Si la pista se vacía, cambia el género. Si hay mucha energía, la sostiene. La consola Pioneer permite transiciones suaves, efectos y un sonido que no suena a "shuffle en Spotify".</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Iluminación para pista incluida — cabezas móviles + par LED</h3>
                  <p class="prod-hl__desc">Las 2 cabezas móviles se sincronizan con la música para crear efectos dinámicos en la pista. Los 4 par LED RGB bañan el espacio en color. Sin iluminación de pista, el baile se ve plano. Con ella, el ambiente cambia completamente.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Reunión previa de brief musical — el DJ aprende tu estilo</h3>
                  <p class="prod-hl__desc">Antes de tu boda, el DJ hace una videollamada contigo para conocer tus géneros favoritos, las canciones que no pueden faltar, las que definitivamente no quieres, y el programa del evento. El resultado es una mezcla que se siente personal, no genérica.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Un solo proveedor para audio, DJ e iluminación</h3>
                  <p class="prod-hl__desc">El DJ, el técnico de audio y el operador de luces son del mismo equipo. Se coordinan entre ellos. Los tiempos están sincronizados. No hay "el DJ empezó antes de que el técnico subiera el volumen" ni "las luces no entraron cuando debían".</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Sistema de audio JBL/QSC completo</div>
              <div class="prod-feat">Subwoofer de alta potencia</div>
              <div class="prod-feat">DJ profesional certificado</div>
              <div class="prod-feat">Consola Pioneer DDJ</div>
              <div class="prod-feat">4 micrófonos inalámbricos</div>
              <div class="prod-feat">2 cabezas móviles</div>
              <div class="prod-feat">4 par LED RGB para pista</div>
              <div class="prod-feat">Reunión de brief musical previa</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y prueba de sonido</div>
              <div class="prod-feat">Operación durante todo el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu boda y estilo musical</h4>
                  <p class="prod-step__desc">Fecha, venue, número de invitados y tus géneros musicales favoritos. Agendamos una reunión con el DJ para que te conozca antes del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Brief musical con el DJ</h4>
                  <p class="prod-step__desc">El DJ hace una videollamada contigo para conocer tus preferencias musicales, las canciones especiales y el programa del evento. Esta reunión es clave para que el resultado suene a tu boda, no a cualquier boda.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50%. Tu fecha y el DJ quedan bloqueados al instante. Recomendamos apartar con 6-8 semanas de anticipación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">El equipo llega y se encarga de todo</h4>
                  <p class="prod-step__desc">Llegamos 4 horas antes, instalamos audio e iluminación, hacemos prueba de sonido y el DJ prepara el setup. Durante el evento, el equipo opera en sincronía. Al terminar, desmontamos todo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Boda con DJ o Producción Boda?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Boda con DJ — $12,000</span>
                <ul class="prod-compare__list">
                  <li>Sistema JBL + DJ Pioneer</li>
                  <li>Iluminación básica de pista</li>
                  <li>Hasta 250 invitados</li>
                  <li>1 DJ profesional</li>
                  <li>Audio, DJ y luces básicas</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción Boda — $22,000</span>
                <ul class="prod-compare__list">
                  <li>Line array profesional</li>
                  <li>Iluminación completa incluida</li>
                  <li>300+ invitados</li>
                  <li>DJ + director de audio</li>
                  <li>Producción total del evento</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Habíamos cotizado DJ y equipo de audio por separado y era un caos coordinar dos proveedores. Con REDEIL fue diferente — el DJ y el técnico llegaron juntos, se conocían, y durante la boda el traspaso entre la ceremonia y la pista fue perfecto. La pista estuvo llena desde el primer vals hasta las 2 de la madrugada. El DJ leyó increíble a nuestros invitados."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Valeria y Miguel</span>
                <span class="prod-quote__event">Boda en Jardín Villa del Lago, Xochimilco — 220 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Sistema audio</dt><dd>JBL/QSC completo</dd></div>
              <div class="ps-specs__row"><dt>DJ</dt><dd>Profesional certificado</dd></div>
              <div class="ps-specs__row"><dt>Consola</dt><dd>Pioneer DDJ</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>4 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Iluminación pista</dt><dd>2 cabezas + 4 par LED</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>Hasta 250 personas</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Todo el evento</dd></div>
              <div class="ps-specs__row"><dt>Brief musical</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas con pista de baile</span>
              <span class="ps-tag">100-250 invitados</span>
              <span class="ps-tag">Bodas en jardín</span>
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Un solo proveedor</span>
              <span class="ps-tag">DJ + iluminación</span>
              <span class="ps-tag">Novias organizadas</span>
              <span class="ps-tag">Bodas con playlist</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Solo Ceremonia" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Solo Ceremonia</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Boda Completa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda Completa</span>
                <span class="ps-pkg__price">$7,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Producción Boda" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Boda</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda de 300+ invitados o venue grande? El paquete Producción Boda incluye line array y director de audio para resultados de nivel producción.</p>
              <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" class="ps-upsell__link">Ver Producción Boda →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu boda</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
