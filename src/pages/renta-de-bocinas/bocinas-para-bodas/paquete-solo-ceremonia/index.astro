---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Solo Ceremonia?',
    respuesta: 'Incluye 2 bocinas JBL activas de 12 pulgadas, 2 micrófonos inalámbricos, mixer, cables y extensiones profesionales, transporte, instalación, técnico operador durante la ceremonia y desmontaje. Cubre ceremonia religiosa o civil para hasta 200 personas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Solo Ceremonia?',
    respuesta: 'El paquete tiene un precio desde $3,500 MXN + IVA. Incluye todo: transporte, instalación, 2 micrófonos inalámbricos, mixer, operación durante la ceremonia y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿El sistema sirve para ceremonias al aire libre y en capillas?',
    respuesta: 'Sí. Las bocinas JBL de 12 pulgadas proyectan el sonido con claridad tanto en espacios cerrados como capillas e iglesias, como en exteriores tipo jardines y haciendas. El técnico ajusta el sistema según la acústica del lugar antes de que inicie la ceremonia.'
  },
  {
    pregunta: '¿Cuántos invitados puede cubrir este sistema?',
    respuesta: 'El sistema de 2 bocinas JBL de 12 pulgadas cubre cómodamente ceremonias de hasta 200 personas en jardines, capillas, iglesias y salones. Para eventos más grandes o con recepción y baile, considera el paquete Boda Completa o Boda con DJ.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Solo Ceremonia — Bocinas para Bodas | REDEIL',
    description: 'Sistema de audio para ceremonia de boda: 2 bocinas JBL 12 pulgadas + 2 micrófonos inalámbricos + mixer. Cubre ceremonia religiosa o civil hasta 200 personas en CDMX.',
    image: SITE_URL + '/img/img-index/bocinas-para-bodas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '41',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Solo Ceremonia — Bocinas para Boda en CDMX | REDEIL"
  description="2 bocinas JBL + 2 micrófonos inalámbricos + mixer para tu ceremonia de boda. Audio claro para hasta 200 personas. Desde $3,500 MXN en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Bocinas', href: '/renta-de-bocinas/' }, { name: 'Bocinas para Bodas', href: '/renta-de-bocinas/bocinas-para-bodas/' }, { name: 'Solo Ceremonia', href: '/renta-de-bocinas/bocinas-para-bodas/paquete-solo-ceremonia/' }]} />

  <Hero
    badge="Solo Ceremonia"
    title="Solo Ceremonia — Bocinas para Boda"
    description="Audio profesional JBL para que los 45 minutos más importantes de tu boda suenen perfectos. 2 bocinas + 2 micrófonos inalámbricos + mixer. Desde $3,500 MXN."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-bocinas/bocinas-para-bodas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Solo Ceremonia está diseñado para que cada palabra de tus votos, cada oración y cada nota musical lleguen con claridad a todos tus invitados. <strong>2 bocinas JBL activas de 12 pulgadas</strong> distribuyen el audio de forma uniforme, mientras que los <strong>2 micrófonos inalámbricos</strong> permiten que el officiante y los lectores hablen con total libertad de movimiento.</p>
      <p>Nuestro técnico llega con anticipación, instala el sistema, hace la prueba de sonido y opera el equipo durante toda la ceremonia. Tú solo tienes que caminar hacia el altar. Nosotros cuidamos que cada momento se escuche perfectamente.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Bocinas para Bodas"
    items={[{ label: "Boda Completa", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" }, { label: "Boda con DJ", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" }, { label: "Producción Boda", href: "/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/bocinas-para-bodas.avif" alt="Sistema de audio JBL para ceremonia de boda en jardín" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="2 bocinas JBL de 12 pulgadas para ceremonia de boda" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Micrófonos inalámbricos para ceremonia religiosa" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Mixer de audio para ceremonia de boda" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Técnico de audio en ceremonia de boda al aire libre" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Solo Ceremonia — Enfocado en lo que importa</span>
            <h2 class="prod-info__title">2 Bocinas JBL de 12 pulgadas + 2 Micrófonos Inalámbricos + Mixer</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operación de la ceremonia y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Los 45 minutos más importantes de tu boda merecen un audio impecable</h2>
            <p class="prod-selling__intro">La ceremonia es el momento central de tu boda. Cada voz debe escucharse con claridad, cada palabra de tus votos debe llegar a todos. El paquete Solo Ceremonia concentra todo en ese momento: bocinas JBL de calidad profesional, micrófonos inalámbricos para libertad total de movimiento y un técnico que opera el sistema en tiempo real para que nada falle.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Bocinas JBL de 12 pulgadas — claridad en cualquier espacio</h3>
                  <p class="prod-hl__desc">Las bocinas JBL activas de 12 pulgadas proyectan el sonido con claridad uniforme tanto en capillas e iglesias como en jardines y haciendas al aire libre. El técnico posiciona el sistema estratégicamente para que no haya puntos muertos ni zonas con eco.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 micrófonos inalámbricos — el officiante y los lectores listos</h3>
                  <p class="prod-hl__desc">Con dos micrófonos inalámbricos simultáneos, el officiante y un lector o testigo pueden hablar al mismo tiempo sin pasar el micrófono. Libertad total de movimiento, sin cables que tropiecen, sin cortes de señal.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico operador en sitio — nada queda al azar</h3>
                  <p class="prod-hl__desc">El técnico llega con anticipación, realiza la prueba de sonido, ajusta el volumen según la acústica del espacio y opera el mixer durante toda la ceremonia. Sube la música de entrada, baja al encender el micrófono, reproduce la marcha nupcial en el momento exacto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Ideal para ceremonias religiosas y civiles hasta 200 personas</h3>
                  <p class="prod-hl__desc">El sistema cubre cómodamente misas, ceremonias civiles y ceremonias simbólicas en capillas, jardines, haciendas y salones. Para hasta 200 invitados sin perder ni un detalle del audio.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 bocinas JBL activas de 12 pulgadas</div>
              <div class="prod-feat">2 micrófonos inalámbricos</div>
              <div class="prod-feat">Mixer de audio</div>
              <div class="prod-feat">Cables y extensiones</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Prueba de sonido previa</div>
              <div class="prod-feat">Técnico operador en la ceremonia</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu ceremonia</h4>
                  <p class="prod-step__desc">Fecha, lugar, número de invitados y tipo de ceremonia (religiosa, civil o simbólica). Con esos datos determinamos la distribución óptima del sistema en tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final, distribución del sistema y plan de operación. Sin costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Nosotros llegamos, instalamos y operamos</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes, instalamos el sistema, hacemos prueba de sonido y operamos durante toda la ceremonia. Al terminar, desmontamos sin interrumpir el festejo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Solo Ceremonia o Boda Completa?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Solo Ceremonia — $3,500</span>
                <ul class="prod-compare__list">
                  <li>2 bocinas JBL de 12 pulgadas</li>
                  <li>2 micrófonos inalámbricos</li>
                  <li>Solo para la ceremonia</li>
                  <li>Hasta 200 personas</li>
                  <li>Técnico en la ceremonia</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Boda Completa — $7,500</span>
                <ul class="prod-compare__list">
                  <li>4 bocinas + subwoofer 18 pulgadas</li>
                  <li>4 micrófonos inalámbricos</li>
                  <li>Ceremonia + recepción + baile</li>
                  <li>Hasta 300 personas</li>
                  <li>Técnico todo el evento</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos Solo Ceremonia porque nuestra boda fue en un jardín y nos preocupaba que la voz del padre no se escuchara bien. El equipo llegó dos horas antes, puso todo perfecto y durante la ceremonia absolutamente todos escucharon cada palabra. Mis abuelos, que están un poco sordos, también. Vale cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Mariana y Rodrigo</span>
                <span class="prod-quote__event">Boda en Jardín Las Palmas, Coyoacán — 150 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Bocinas</dt><dd>2× JBL de 12 pulgadas activas</dd></div>
              <div class="ps-specs__row"><dt>Micrófonos</dt><dd>2 inalámbricos</dd></div>
              <div class="ps-specs__row"><dt>Mezcladora</dt><dd>Mixer incluido</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>Hasta 200 personas</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Ceremonia completa</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Durante la ceremonia</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Ceremonia de boda</span>
              <span class="ps-tag">Misa religiosa</span>
              <span class="ps-tag">Ceremonia civil</span>
              <span class="ps-tag">Capillas</span>
              <span class="ps-tag">Jardines</span>
              <span class="ps-tag">Hasta 200 invitados</span>
              <span class="ps-tag">Solo ceremonia</span>
              <span class="ps-tag">Espacios al aire libre</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Boda Completa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda Completa</span>
                <span class="ps-pkg__price">$7,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-con-dj/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Boda con DJ" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Boda con DJ</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-produccion-boda/" class="ps-pkg">
              <img src="/img/img-index/bocinas-para-bodas.avif" alt="Producción Boda" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Boda</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Necesitas audio también para la recepción y la pista de baile? El paquete Boda Completa cubre todo el evento.</p>
              <a href="/renta-de-bocinas/bocinas-para-bodas/paquete-boda-completa/" class="ps-upsell__link">Ver paquete Boda Completa →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu ceremonia</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/equipos-para-eventos/pantalla-inflable/" class="ps-link">Pantalla Inflable</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
