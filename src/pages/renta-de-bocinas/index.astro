---
import Base from '../../layouts/Base.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import FaqSection from '../../components/FaqSection.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppBubble from '../../components/WhatsAppBubble.astro';
import { organizationSchema, breadcrumbSchema, faqSchema } from '../../lib/seo';
import { AUDIO_SERVICES, WHATSAPP_URL_MSG } from '../../lib/config';

const faqItems = [
  { pregunta: '¿Qué marcas de bocinas profesionales rentan para eventos en CDMX?', respuesta: 'Rentamos exclusivamente marcas profesionales líderes: JBL (series PRX, SRX, EON), QSC (series K.2 y KW), y Electro-Voice. Para microfonía utilizamos Shure, y mixers Yamaha y Behringer. No trabajamos con equipos económicos de baja calidad para garantizar sonido cristalino en tu evento.' },
  { pregunta: '¿Qué potencia de bocinas necesito para mi evento?', respuesta: 'Para 50-100 personas interiores: 400-800W RMS (2 bocinas 12"-15"). Para 100-200 personas: 800-1,500W RMS (2-4 bocinas + subwoofer). Para 200-350 personas: 1,500-2,500W RMS (sistema profesional completo). Para eventos masivos 500+: Line arrays con 2,500W+ RMS. Nuestro equipo calcula el dimensionamiento exacto según tu venue.' },
  { pregunta: '¿Incluyen técnico operador durante todo el evento?', respuesta: 'Sí, todos nuestros paquetes profesionales incluyen técnico certificado en sitio durante todo el evento. El técnico se encarga de instalación, pruebas de sonido, ecualización según acústica del espacio, ajustes en tiempo real, operación de micrófonos, y resolución inmediata de cualquier problema técnico.' },
  { pregunta: '¿Puedo conectar mi playlist de Spotify o YouTube?', respuesta: 'Absolutamente. Todos nuestros mixers profesionales tienen conectividad Bluetooth integrada y entradas USB/auxiliares. Puedes reproducir música desde tu celular, laptop, tablet o cualquier dispositivo. También ofrecemos servicio de DJ profesional opcional.' },
  { pregunta: '¿El servicio de renta de audio incluye instalación?', respuesta: 'Sí, todos nuestros paquetes de renta de audio profesional incluyen transporte, montaje, desmontaje y un ingeniero de audio para operar el equipo durante tu evento, garantizando un sonido perfecto de principio a fin.' },
  { pregunta: '¿Ofrecen paquetes combinados de audio e iluminación?', respuesta: 'Sí, diseñamos paquetes a la medida que combinan audio profesional con iluminación LED. Al contratar ambos servicios obtienes mejor precio, coordinación perfecta y un solo equipo técnico encargado de todo.' },
];

const structuredData = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Renta de Bocinas', url: '/renta-de-bocinas/' },
  ]),
  faqSchema(faqItems),
];
---

<Base
  title="Bocinas y Audio Profesional para Eventos CDMX | REDEIL"
  description="Renta de bocinas JBL y QSC para bodas, XV años, fiestas y conferencias en CDMX. Sistemas de audio profesional con instalación y operador incluidos."
  structuredData={structuredData}
>
  <TopBar />
  <Header activePage="audio" />
  <Breadcrumb items={[{ name: 'Renta de Bocinas', href: '/renta-de-bocinas/' }]} />

  <!-- HERO 2-COL -->
  <Hero
    badge="Audio profesional JBL · QSC · Shure"
    title="Sonido que transforma. Eventos que resuenan."
    description="Renta de equipo de audio profesional JBL, QSC y Shure para bodas, XV años, fiestas y conferencias en CDMX y Estado de México."
    primaryCta={{ text: 'Cotizar Audio', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver equipos', href: '#servicios' }}
  >
    <Fragment slot="hero-seo">
      <p>El audio correcto puede transformar completamente un evento. En <strong>REDEIL</strong> rentamos <strong>equipos de audio profesional</strong> con marcas líderes como <strong>JBL, QSC y Shure</strong> que crean la experiencia sonora perfecta para bodas, eventos corporativos y celebraciones en <strong>CDMX y Estado de México</strong>.</p>
      <p>Desde <strong>bocinas para bodas</strong> con sonido cristalino hasta <strong>sistemas potentes para fiestas</strong> con DJ y subwoofers, tenemos todo tipo de audio. Nuestro equipo técnico se encarga de instalarlo, configurarlo y operarlo durante tu evento.</p>
    </Fragment>
  </Hero>

  <!-- SERVICIOS DE AUDIO — CategoryCards con paquetes -->
  <section class="section section--bg" id="servicios-detallados">
    <div class="container">
      <SectionHeader
        badge="4 servicios de audio"
        title="¿Qué incluye la renta de bocinas para eventos?"
        subtitle="Cada servicio incluye transporte, instalación profesional, operación durante el evento y desmontaje. Trabajamos con equipo JBL, QSC y Shure — las marcas líderes en audio profesional para eventos."
        subtitle2="Desde bocinas compactas para fiestas íntimas hasta line arrays para conciertos de 2,000+ personas, tenemos 4 categorías de audio con paquetes desde $3,500 MXN. Elige tu servicio y selecciona el paquete ideal."
        id="detallados-title"
      />
      <div class="grid-4">
        {AUDIO_SERVICES.map((s) => (
          <CategoryCard
            title={s.nombre}
            subtitle={s.descripcion}
            href={`/renta-de-bocinas/${s.slug}/`}
            image={s.imagen}
            subcategories={s.paquetes.map((p) => ({
              name: p.nombre,
              href: `/renta-de-bocinas/${s.slug}/${p.slug}/`,
            }))}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- TRUST SECTION -->
  <section class="section">
    <div class="container">
      <SectionHeader
        title="¿Por qué rentar audio profesional con REDEIL?"
        subtitle="Más de 10 años montando audio para eventos en CDMX y Estado de México."
        id="ventajas-title"
      />
      <div class="trust-grid">
        <div class="trust-item">
          <h3 class="trust-item__title">Equipo JBL y QSC Certificado</h3>
          <p class="trust-item__desc">Trabajamos exclusivamente con bocinas JBL PRX, SRX y QSC K.2 — las series profesionales que usan los mejores venues del mundo. Sonido cristalino sin distorsión a cualquier volumen.</p>
        </div>
        <div class="trust-item">
          <h3 class="trust-item__title">Dimensionamiento Técnico Preciso</h3>
          <p class="trust-item__desc">Calculamos la potencia exacta según tu espacio, número de invitados y tipo de evento. Ni más ni menos: el audio justo para que todo se escuche perfecto sin desperdiciar presupuesto.</p>
        </div>
        <div class="trust-item">
          <h3 class="trust-item__title">Técnico de Audio en Sitio</h3>
          <p class="trust-item__desc">Todos nuestros paquetes incluyen ingeniero de audio que opera el equipo durante tu evento. Ecualización en tiempo real, pruebas de sonido previas y resolución inmediata de cualquier imprevisto.</p>
        </div>
        <div class="trust-item">
          <h3 class="trust-item__title">Microfonía Shure Profesional</h3>
          <p class="trust-item__desc">Micrófonos inalámbricos Shure para discursos, brindis y ceremonias. Señal estable, sin interferencias y con alcance suficiente para moverte libremente por todo el espacio.</p>
        </div>
        <div class="trust-item">
          <h3 class="trust-item__title">DJ Profesional Opcional</h3>
          <p class="trust-item__desc">Agrega DJ certificado a tu paquete de audio. Nuestros DJs conocen la música para bodas, XV años y fiestas corporativas, y coordinan los momentos clave del evento con el equipo técnico.</p>
        </div>
        <div class="trust-item">
          <h3 class="trust-item__title">Cobertura CDMX + Estado de México</h3>
          <p class="trust-item__desc">Llegamos a salones, haciendas, jardines y centros de convenciones en toda la zona metropolitana. Traslado incluido dentro de 100 km desde CDMX, sin costos ocultos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas Frecuentes"
        subtitle="Resolvemos las dudas más comunes sobre renta de bocinas y audio profesional para eventos en CDMX y Estado de México. Marcas, potencia, instalación y precios."
        subtitle2="Si no encuentras tu respuesta, escríbenos por WhatsApp al 55 4937 5172 y te asesoramos sin compromiso. Cotización personalizada en menos de 24 horas."
        id="faq-title"
      />
    </div>
    <FaqSection items={faqItems} />
  </section>

  <Footer />
  <WhatsAppBubble />
</Base>
