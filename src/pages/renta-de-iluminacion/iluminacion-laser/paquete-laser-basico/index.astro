---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Láser Básico de Iluminación Láser?',
    respuesta: 'Incluye 1 láser RGB de 1W con patrones automáticos de barrido, estrellas y figuras geométricas, cable de alimentación, soporte de piso, transporte, instalación, técnico operador durante 4 horas de evento y desmontaje. Es el equipo ideal para fiesta en salón cerrado.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Láser Básico?',
    respuesta: 'El paquete Láser Básico tiene un precio desde $3,500 MXN + IVA. Incluye todo: transporte, instalación, operación de 4 horas y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿El láser puede usarse con humo para el efecto de rayos visibles?',
    respuesta: 'Sí, el efecto de rayos de láser visibles en el aire se potencia con humo o neblina. No incluimos máquina de humo en este paquete, pero podemos rentarla por separado. Contáctanos por WhatsApp para agregar ese efecto a tu cotización.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Láser Básico?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo de traslado adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 3 a 4 semanas de anticipación. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento y podemos confirmar en minutos.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Láser Básico — Iluminación Láser | REDEIL',
    description: 'Renta de 1 láser RGB profesional para fiestas, graduaciones y cumpleaños en CDMX. Efectos automáticos de barrido y figuras. Instalación y técnico incluidos.',
    image: SITE_URL + '/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/main.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/iluminacion-laser/paquete-laser-basico/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '34',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Láser Básico — Renta de Iluminación Láser en CDMX | REDEIL"
  description="Renta de 1 láser RGB con efectos automáticos para fiestas y graduaciones en CDMX. Instalación, técnico operador y desmontaje incluidos desde $3,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Iluminación Láser', href: '/renta-de-iluminacion/iluminacion-laser/' }, { name: 'Láser Básico', href: '/renta-de-iluminacion/iluminacion-laser/paquete-laser-basico/' }]} />

  <Hero
    badge="Láser Básico"
    title="Láser Básico — Iluminación Láser para Fiestas"
    description="El punto de entrada al mundo del láser profesional. 1 láser RGB con patrones automáticos que transforma cualquier salón oscuro en una pista de baile con ambiente de club. Instalación y técnico incluidos."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/iluminacion-laser/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>renta de iluminación láser</strong> no es solo para grandes producciones. Con el paquete Láser Básico llevamos un <strong>láser RGB de 1W</strong> a tu fiesta, graduación o cumpleaños en <strong>CDMX y Estado de México</strong> con efectos automáticos que no requieren programación: enciende y listo.</p>
      <p>En salones cerrados con poca luz ambiental, un solo láser bien posicionado proyecta haces de colores, barridos y figuras geométricas sobre paredes, techo y pista de baile. El efecto es inmediato: los invitados lo notan en cuanto entran. Incluye técnico que opera, ajusta y cuida el equipo durante las 4 horas de tu evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Iluminación Láser"
    items={[{ label: "Láser Estándar", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" }, { label: "Láser Premium", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-premium/" }, { label: "Producción Láser", href: "/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/main.avif" alt="Láser RGB proyectando efectos de luz en pista de baile de fiesta" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img1.avif" alt="Haces de luz láser verde y rojo en salón oscuro" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img2.avif" alt="Efecto láser con patrones geométricos en techo" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img3.avif" alt="Técnico configurando láser RGB en evento" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img4.avif" alt="Pista de baile iluminada con efectos láser de colores" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Láser Básico — Ideal para fiestas y graduaciones</span>
            <h2 class="prod-info__title">1 Láser RGB con Efectos Automáticos y Técnico Incluido</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operación 4 hrs y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El láser que convierte cualquier salón en una experiencia de club</h2>
            <p class="prod-selling__intro">La diferencia entre una fiesta con buen ambiente y una fiesta memorable muchas veces es la iluminación. Un láser RGB bien posicionado en el punto correcto del salón genera un impacto visual inmediato que las luces convencionales no pueden replicar. Con el Paquete Láser Básico no necesitas un gran presupuesto para tener ese efecto: es el láser correcto para espacios medianos con el soporte técnico que garantiza que funcione perfecto toda la noche.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Efectos automáticos — sin programación, sin complicaciones</h3>
                  <p class="prod-hl__desc">El láser tiene modos automáticos que cambian patrones, velocidad y colores según la música. No necesitas DJ ni consola especial. Enciendes y el equipo hace el trabajo. El técnico ajusta el modo más adecuado para cada momento del evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">RGB real — rojo, verde y azul en un solo equipo</h3>
                  <p class="prod-hl__desc">No es un puntero de color fijo. El láser RGB combina los tres canales de color para proyectar blanco, cian, amarillo y toda la gama de colores en tiempo real. El resultado es una variedad visual que mantiene el interés durante horas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico en sitio durante todo el evento</h3>
                  <p class="prod-hl__desc">No dejamos el equipo y nos vamos. Un técnico permanece durante las 4 horas de operación para cambiar efectos, ajustar la posición del láser según cómo evoluciona el evento y resolver cualquier imprevisto técnico sin interrupciones.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Seguro y certificado — cumple normativa de seguridad láser</h3>
                  <p class="prod-hl__desc">Nuestros láseres cuentan con protocolos de seguridad: zona de exclusión configurada, potencia calibrada para interior y posicionamiento correcto para que los haces no apunten directamente a los ojos de los asistentes. Seguro para todos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 láser RGB de 1W profesional</div>
              <div class="prod-feat">Patrones automáticos de barrido y figuras</div>
              <div class="prod-feat">Soporte de piso ajustable en altura</div>
              <div class="prod-feat">Cable de alimentación y extensiones</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y posicionamiento</div>
              <div class="prod-feat">Técnico operador 4 horas</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Verificación de seguridad láser</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, tipo de evento, salón o espacio aproximado y cuántos invitados. Con eso confirmamos que el Básico es el paquete correcto o te recomendamos uno más adecuado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final, horario de llegada del técnico y todo lo que necesitas saber. Sin letras pequeñas ni costos adicionales al día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con 50% de anticipo por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada de inmediato en nuestra agenda.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y operamos</h4>
                  <p class="prod-step__desc">El técnico llega 1 hora antes de tu evento, posiciona el láser, hace pruebas de seguridad y espera a que empiece la fiesta. Opera los 4 horas y desmonta cuando termina. Tú a disfrutar.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Básico o Estándar? Aquí la diferencia</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Láser Básico — 1 equipo</span>
                <ul class="prod-compare__list">
                  <li>1 láser RGB en un punto del salón</li>
                  <li>Efectos automáticos predefinidos</li>
                  <li>Ideal para salones hasta 200 m²</li>
                  <li>Un ángulo de proyección</li>
                  <li>Sin sincronización multi-láser</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Láser Estándar — 2 equipos</span>
                <ul class="prod-compare__list">
                  <li>2 lásers sincronizados en espejo</li>
                  <li>Efectos coordinados entre equipos</li>
                  <li>Cubre salones hasta 400 m²</li>
                  <li>Haces cruzados más impactantes</li>
                  <li>Perfecto para bodas y XV años</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Lo rentamos para la graduación de mi hijo y fue el hit de la noche. El salón era mediano, cerramos las cortinas y el láser se vio increíble. El técnico fue muy atento, cambiaba los efectos en los momentos buenos de la música. Vale cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Patricia V.</span>
                <span class="prod-quote__event">Graduación de preparatoria — Salón en Tlalpan, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Equipos</dt><dd>1 láser RGB</dd></div>
              <div class="ps-specs__row"><dt>Potencia</dt><dd>1W</dd></div>
              <div class="ps-specs__row"><dt>Colores</dt><dd>RGB completo</dd></div>
              <div class="ps-specs__row"><dt>Efectos</dt><dd>Automáticos</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Modo auto / DMX básico</dd></div>
              <div class="ps-specs__row"><dt>Espacio ideal</dt><dd>Hasta 200 m²</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>4 horas incluidas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas de cumpleaños</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Fiestas de XV años</span>
              <span class="ps-tag">Reuniones privadas</span>
              <span class="ps-tag">Salones medianos</span>
              <span class="ps-tag">Antros y bares</span>
              <span class="ps-tag">Fiestas temáticas</span>
              <span class="ps-tag">Eventos nocturnos</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-laser.avif" alt="Láser Estándar 2 equipos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Estándar</span>
                <span class="ps-pkg__price">$6,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-premium/" class="ps-pkg">
              <img src="/img/img-index/pro/iluminacion-laser.avif" alt="Láser Premium 4 equipos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Premium</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/" class="ps-pkg">
              <img src="/img/blog/laser-show-concierto.avif" alt="Producción Láser 8+ equipos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Láser</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda o evento de mediano impacto? El Estándar con 2 lásers sincronizados es el favorito para XV años y bodas.</p>
              <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" class="ps-upsell__link">Ver paquete Estándar →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting LED</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/renta-de-iluminacion/city-color/" class="ps-link">City Color LED</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
