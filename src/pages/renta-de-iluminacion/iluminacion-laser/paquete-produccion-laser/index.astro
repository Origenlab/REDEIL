---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción Láser?',
    respuesta: 'Incluye 8 o más lásers RGB de alta potencia, consola MA profesional de iluminación, director de show dedicado, crew técnico de instalación, show completamente programado según el rider, operación durante el evento, desmontaje y transporte. Es el estándar técnico para conciertos y festivales en CDMX.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción Láser?',
    respuesta: 'El paquete Producción Láser comienza desde $22,000 MXN + IVA. El precio final depende del número exacto de lásers, duración del evento, distancia del venue y si se requiere rider técnico específico. Solicita cotización detallada por WhatsApp.'
  },
  {
    pregunta: '¿Qué diferencia a la consola MA de otras consolas DMX?',
    respuesta: 'La consola grandMA es el estándar de la industria para conciertos y producciones de alto nivel. Permite programar miles de cues, crear paletas de colores, ejecutar efectos en tiempo real con precisión de milisegundos y manejar múltiples universos DMX simultáneamente. Es lo que usan los tours internacionales.'
  },
  {
    pregunta: '¿Pueden atender festivales y eventos en exteriores?',
    respuesta: 'Sí. Contamos con estructuras de rigging y soportes para instalación en escenarios al aire libre, torres de iluminación y estructuras de producción. Para eventos en exteriores cotizamos con detalle el rigging, estructuras y logística específica de tu venue.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo contratar Producción Láser?',
    respuesta: 'Para producciones de este nivel recomendamos mínimo 6 a 8 semanas de anticipación para producción y programación del show. Para festivales con múltiples artistas, idealmente 2 a 3 meses para coordinar el rider con cada acto.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción Láser — Iluminación Láser | REDEIL',
    description: '8+ lásers RGB con consola MA y director de show para conciertos y festivales en CDMX. El estándar técnico de la industria para iluminación láser profesional.',
    image: SITE_URL + '/img/blog/laser-show-concierto.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '22000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '18',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción Láser — Show para Conciertos y Festivales en CDMX | REDEIL"
  description="8+ lásers RGB con consola MA y director de show para conciertos y festivales en CDMX. Producción completa de iluminación láser desde $22,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Iluminación Láser', href: '/renta-de-iluminacion/iluminacion-laser/' }, { name: 'Producción Láser', href: '/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/' }]} />

  <Hero
    badge="Producción Láser — Estándar de conciertos"
    title="Producción Láser — 8+ Lásers con Consola MA para Conciertos y Festivales"
    description="El nivel máximo de iluminación láser. 8 o más lásers de alta potencia con consola grandMA, director de show dedicado y crew técnico. El estándar técnico que usan los conciertos internacionales, disponible en CDMX."
    primaryCta={{ text: 'Cotizar $22,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/iluminacion-laser/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>Producción Láser</strong> de REDEIL es el servicio para promotores, productoras y organizadores que necesitan el máximo nivel técnico en <strong>iluminación láser</strong> para sus eventos en <strong>CDMX y México</strong>. <strong>8 o más lásers RGB</strong> de alta potencia operados desde una <strong>consola grandMA</strong> con un director de show que ha trabajado en conciertos, festivales y tours de artistas nacionales e internacionales.</p>
      <p>No es solo cantidad de equipos — es la combinación de hardware profesional, programación experta y talento técnico que convierte el láser en un lenguaje visual que dialoga con la música, el escenario y el artista. Cada festival, concierto o evento corporativo de alto nivel merece una producción de láser a la altura.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Iluminación Láser"
    items={[{ label: "Láser Básico", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-basico/" }, { label: "Láser Estándar", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" }, { label: "Láser Premium", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-premium/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/laser-show-concierto.avif" alt="Show de producción láser con 8 equipos en concierto masivo CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/iluminacion-laser.avif" alt="Múltiples haces de láser RGB en festival nocturno" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/main.avif" alt="Producción completa de láser con consola MA en escenario" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img4.avif" alt="Director de show operando consola de iluminación láser" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img1.avif" alt="Show láser exterior en festival al aire libre CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Producción Láser — Conciertos, festivales y tours</span>
            <h2 class="prod-info__title">8+ Lásers de Alta Potencia con Consola MA y Director de Show</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$22,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Desde: precio final según número de lásers, duración y rider técnico. Cotización detallada en 24h.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La diferencia entre un show y una producción de clase mundial</h2>
            <p class="prod-selling__intro">En la producción de conciertos, el láser no es un extra que se agrega al final. Es parte del diseño de la experiencia desde el primer día. El director de show de REDEIL trabaja junto al director de arte, el DJ o el artista para diseñar un show láser que esté integrado con la música, la narrativa del evento y las emociones que quieres crear en el público. Eso es lo que distingue una producción real de simplemente prender lásers.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Consola grandMA — el estándar técnico de la industria</h3>
                  <p class="prod-hl__desc">La grandMA es la consola que usan los tours internacionales. Maneja múltiples universos DMX, miles de cues programadas, ejecución en tiempo real con precisión de milisegundos y capacidad de adaptarse en vivo sin perder la programación base. No hay limitación técnica en lo que puede ejecutar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">8+ lásers — cobertura de escenario completo y más allá</h3>
                  <p class="prod-hl__desc">Con 8 o más equipos posicionados estratégicamente, el láser cubre escenario, foso, pista completa y llega a los fondos de foros grandes. Los haces se cruzan, convergen, divergen y crean perspectivas visuales imposibles con menos equipos. El público en cualquier punto del venue vive el show.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de show — arte y técnica en una sola persona</h3>
                  <p class="prod-hl__desc">El director de show de REDEIL no solo opera la consola — diseña la experiencia. Conoce los tiempos del artista, los momentos de tensión y liberación de la música, y ejecuta el show láser como si fuera un instrumento más del concierto. Para el público, la diferencia es palpable.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Protocolos de seguridad láser de nivel producción</h3>
                  <p class="prod-hl__desc">En eventos masivos, la seguridad láser no es opcional. Implementamos zonas de exclusión calibradas, zonas de seguridad de audiencia según normativa, potencias ajustadas por sección del foro y protocolos de emergencia. El show es seguro para artistas, técnicos y los miles de asistentes.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">8+ lásers RGB de alta potencia</div>
              <div class="prod-feat">Consola grandMA profesional</div>
              <div class="prod-feat">Show completamente programado</div>
              <div class="prod-feat">Director de show dedicado</div>
              <div class="prod-feat">Crew técnico de instalación</div>
              <div class="prod-feat">Soportes, rigging y estructuras</div>
              <div class="prod-feat">Transporte de producción</div>
              <div class="prod-feat">Instalación en venue completa</div>
              <div class="prod-feat">Operación completa del evento</div>
              <div class="prod-feat">Protocolo de seguridad láser</div>
              <div class="prod-feat">Coordinación con rider artístico</div>
              <div class="prod-feat">Desmontaje y retiro de producción</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Proceso de producción láser profesional</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de producción y rider técnico</h4>
                  <p class="prod-step__desc">Revisamos el rider del artista o el guión técnico del evento, planos del venue, posiciones de escenario y expectativas visuales. Diseñamos el layout de láser y el concepto del show.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Programación y diseño de show</h4>
                  <p class="prod-step__desc">El director de show programa la coreografía completa en consola MA: cues por canción, cambios de color, efectos de transición, momentos especiales del artista. Todo antes del día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación y soundcheck de luz</h4>
                  <p class="prod-step__desc">El crew llega con suficiente anticipación para instalar todos los equipos, hacer rigging si aplica, calibrar posiciones y ejecutar un ensayo completo del show antes de que abra el venue.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Show en vivo y desmontaje</h4>
                  <p class="prod-step__desc">El director ejecuta el show en vivo, adaptando en tiempo real si el artista improvisa o cambia el setlist. Al terminar el evento, el crew desmonta toda la producción y retira el equipo del venue.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué Producción y no Premium?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Láser Premium — 4 equipos</span>
                <ul class="prod-compare__list">
                  <li>4 lásers para foros hasta 800 m²</li>
                  <li>Consola DMX estándar</li>
                  <li>Director técnico solo</li>
                  <li>Eventos privados y corporativos</li>
                  <li>Sin rigging aéreo</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción Láser — 8+ equipos</span>
                <ul class="prod-compare__list">
                  <li>8+ lásers para foros masivos</li>
                  <li>Consola grandMA industria</li>
                  <li>Director de show + crew técnico</li>
                  <li>Conciertos, festivales, tours</li>
                  <li>Rigging aéreo disponible</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Llevamos a REDEIL como proveedor de láser en tres fechas del tour. Lo que más nos sorprendió fue la comunicación antes del evento: el director de show revisó el setlist con nosotros, nos propuso momentos específicos para efectos clave y el resultado en vivo fue exactamente lo que habíamos imaginado. Repetimos en cada fecha."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Producción Artística NorteVivo</span>
                <span class="prod-quote__event">Tour 3 fechas — Foro Sol, Auditorio Telmex, Auditorio Civita</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Equipos</dt><dd>8+ lásers RGB</dd></div>
              <div class="ps-specs__row"><dt>Consola</dt><dd>grandMA profesional</dd></div>
              <div class="ps-specs__row"><dt>Show</dt><dd>Diseño personalizado</dd></div>
              <div class="ps-specs__row"><dt>Equipo</dt><dd>Director + crew</dd></div>
              <div class="ps-specs__row"><dt>Espacio</dt><dd>Foros masivos</dd></div>
              <div class="ps-specs__row"><dt>Rigging</dt><dd>Disponible</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX y México</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Conciertos masivos</span>
              <span class="ps-tag">Festivales de música</span>
              <span class="ps-tag">Tours nacionales</span>
              <span class="ps-tag">Foros y auditorios</span>
              <span class="ps-tag">Eventos corporativos VIP</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Shows de DJ headliner</span>
              <span class="ps-tag">Producciones de televisión</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-basico/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-laser.avif" alt="Láser Básico" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Básico</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-laser.avif" alt="Láser Estándar" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Estándar</span>
                <span class="ps-pkg__price">$6,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-premium/" class="ps-pkg">
              <img src="/img/img-index/pro/iluminacion-laser.avif" alt="Láser Premium 4 equipos DMX" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Premium</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento más íntimo? El Estándar con 2 lásers sincronizados es la opción perfecta para bodas y XV años.</p>
              <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" class="ps-upsell__link">Ver paquete Estándar →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización detallada según rider y venue en menos de 24 horas.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-iluminacion/sky-tracker/" class="ps-link">Sky Tracker</a>
              <a href="/renta-de-iluminacion/city-color/" class="ps-link">City Color LED</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Audio Profesional</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
