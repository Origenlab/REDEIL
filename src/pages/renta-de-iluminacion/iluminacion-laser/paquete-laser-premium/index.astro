---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Láser Premium de Iluminación Láser?',
    respuesta: 'Incluye 4 lásers RGB con show programado en DMX, coreografía de efectos sincronizada con la música, soportes profesionales, técnico operador durante el evento (hasta 6 horas), instalación y desmontaje. El show se programa con anticipación según el estilo musical de tu evento.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Láser Premium?',
    respuesta: 'El paquete Láser Premium tiene un precio desde $12,000 MXN + IVA. Incluye 4 lásers, programación DMX del show, técnico durante el evento hasta 6 horas, transporte, instalación y desmontaje en CDMX y Estado de México.'
  },
  {
    pregunta: '¿Cómo funciona el show programado en DMX?',
    respuesta: 'Antes del evento, nuestro programador crea una secuencia de efectos en consola DMX: barridos en tiempo con el BPM de la música, cambios de color según momentos clave, figuras y patrones que se activan en los drops o momentos de mayor energía. El resultado es un show coordinado, no efectos aleatorios.'
  },
  {
    pregunta: '¿Para qué tipo de eventos es el paquete Láser Premium?',
    respuesta: 'Es el paquete ideal para producciones medianas: foros de 400 a 800 m², lanzamientos de producto con show de iluminación, after-parties corporativas de alto nivel, y eventos privados donde la experiencia visual es protagonista. También para bodas de lujo con producción completa.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Láser Premium?',
    respuesta: 'Cubrimos CDMX y Estado de México sin cargo adicional de traslado. Para eventos fuera de este radio (Cuernavaca, Valle de Bravo, Puebla, etc.) cotizamos el traslado según la distancia.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Láser Premium — Iluminación Láser | REDEIL',
    description: '4 lásers RGB con show programado en DMX para producciones medianas y foros en CDMX. Coreografía de efectos personalizada. Director técnico incluido.',
    image: SITE_URL + '/img/img-index/pro/iluminacion-laser.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '12000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/iluminacion-laser/paquete-laser-premium/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Láser Premium — 4 Lásers con Show DMX para Producción en CDMX | REDEIL"
  description="4 lásers RGB con show programado en DMX para producciones medianas y foros en CDMX. Coreografía de efectos personalizada. Director técnico y todo incluido desde $12,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Iluminación Láser', href: '/renta-de-iluminacion/iluminacion-laser/' }, { name: 'Láser Premium', href: '/renta-de-iluminacion/iluminacion-laser/paquete-laser-premium/' }]} />

  <Hero
    badge="Láser Premium — Show con coreografía DMX"
    title="Láser Premium — 4 Lásers con Show Programado para Producción"
    description="Cuando el láser deja de ser decoración y se convierte en protagonista. 4 lásers RGB con show programado en DMX: efectos coreografiados al ritmo de la música, cobertura total de foro y director técnico en sitio."
    primaryCta={{ text: 'Cotizar $12,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/iluminacion-laser/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Láser Premium es para eventos donde la <strong>iluminación láser</strong> no es un extra sino parte central de la producción. <strong>4 lásers RGB</strong> posicionados estratégicamente en el foro o salón, con un show programado en <strong>consola DMX</strong> que sincroniza barridos, figuras y cambios de color con los momentos clave de tu evento.</p>
      <p>La diferencia con usar efectos automáticos es enorme: un show DMX programado sabe cuándo romper el silencio con un barrido de alta velocidad, cuándo enlentecer para crear ambiente, cuándo cambiar a blanco frío para dramatismo. Es diseño de experiencia, no solo iluminación. Disponible para foros y eventos en <strong>CDMX y Estado de México</strong>.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Iluminación Láser"
    items={[{ label: "Láser Básico", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-basico/" }, { label: "Láser Estándar", href: "/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" }, { label: "Producción Láser", href: "/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/iluminacion-laser.avif" alt="Show de 4 lásers RGB con efectos DMX en producción de foro" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img1.avif" alt="Haces de láser multicolor en foro de producción nocturna" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img2.avif" alt="Efectos láser DMX sincronizados con música en vivo" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-iluminacion-laser-para-eventos-cdmx/img3.avif" alt="Director técnico en consola DMX de show láser" width="300" height="200" loading="lazy" />
              <img src="/img/blog/laser-show-concierto.avif" alt="Show de laser profesional en concierto CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Láser Premium — Show DMX para producción media</span>
            <h2 class="prod-info__title">4 Lásers RGB con Show Programado en DMX y Director Técnico</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$12,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 4 lásers, programación DMX, director técnico hasta 6 hrs, transporte e instalación en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando el láser no es decoración — es el show</h2>
            <p class="prod-selling__intro">Un show de láser programado en DMX es cualitativamente diferente a poner un láser en modo automático. La programación define exactamente qué sucede en cada segundo del evento: el barrido que coincide con el drop de la canción, el cambio a rojo cuando sube la tensión, el patrón de estrellas en la balada. El Paquete Láser Premium convierte tu evento en una experiencia diseñada, no improvisada.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Show programado en DMX — coreografía de luz diseñada para tu evento</h3>
                  <p class="prod-hl__desc">Antes del evento, el director técnico programa la secuencia de efectos en consola DMX según tu setlist o momentos clave. No es random — cada efecto tiene un momento. El resultado es un show que se siente diseñado, no random.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4 puntos de proyección — cobertura total del foro</h3>
                  <p class="prod-hl__desc">Cuatro lásers posicionados en las cuatro esquinas del foro crean efectos que se cruzan en el centro, se abren hacia los lados, convergen en un punto. No hay rincón del foro sin cobertura. Los 400 m² de pista o escenario quedan completamente envueltos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director técnico en sitio — adapta el show en tiempo real</h3>
                  <p class="prod-hl__desc">La programación es el plan, pero el director técnico adapta en vivo. Si un artista improvisa un bis, si el DJ extiende una canción, si el MC cambia el orden del programa — el director técnico ajusta el show en tiempo real para que siempre esté alineado con lo que pasa en escena.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Integración con humo para máximo impacto visual</h3>
                  <p class="prod-hl__desc">Los haces de láser se vuelven visibles en el aire con neblina o humo. El paquete es compatible con máquinas de humo y hazer — podemos incluirlos en el paquete para crear el efecto de rayos cortando la oscuridad que caracteriza los grandes shows de producción.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 lásers RGB profesionales</div>
              <div class="prod-feat">Programación de show en consola DMX</div>
              <div class="prod-feat">Coreografía de efectos personalizada</div>
              <div class="prod-feat">Soportes de piso y aéreos según foro</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional de 4 puntos</div>
              <div class="prod-feat">Director técnico hasta 6 horas</div>
              <div class="prod-feat">Ajuste en tiempo real durante el evento</div>
              <div class="prod-feat">Verificación de seguridad láser completa</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio Premium</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Brief de producción</h4>
                  <p class="prod-step__desc">Compartes el rider técnico, plano del foro o salón, setlist o programa del evento y estilo musical. Con eso nuestro director técnico diseña el show.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta de show y cotización</h4>
                  <p class="prod-step__desc">Recibes descripción del show programado: qué efectos van en qué momentos, posicionamiento de los 4 equipos y precio final todo incluido.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Programación previa al evento</h4>
                  <p class="prod-step__desc">El director técnico programa la secuencia en consola DMX días antes del evento. Si hay ensayo de iluminación, hacemos coincidir la llegada para calibrar en el foro real.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación, show y desmontaje</h4>
                  <p class="prod-step__desc">Llegamos con 2 horas de anticipación, instalamos los 4 puntos, hacemos prueba de show completo y operamos durante el evento. Al terminar, desmontamos y dejamos el foro limpio.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">Premium vs Producción Láser: ¿cuándo necesitas 8+ equipos?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Láser Premium — 4 equipos</span>
                <ul class="prod-compare__list">
                  <li>4 lásers con show DMX programado</li>
                  <li>Cubre foros hasta 800 m²</li>
                  <li>Director técnico incluido</li>
                  <li>Producción media y eventos privados</li>
                  <li>Sin consola MA</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción Láser — 8+ equipos</span>
                <ul class="prod-compare__list">
                  <li>8+ lásers con consola MA profesional</li>
                  <li>Foros de más de 800 m², festivales</li>
                  <li>Director de show dedicado</li>
                  <li>Conciertos, festivales y tours</li>
                  <li>Producción completa de iluminación</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el Láser Premium para el after-party de nuestra conferencia anual. El director técnico coordinó el show con el DJ y fue exactamente lo que necesitábamos: impactante pero controlado. Los efectos en los drops de música fueron perfectos. Todos preguntaban quién había hecho la producción."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Grupo Empresarial Innovex</span>
                <span class="prod-quote__event">Conferencia Anual — Foro de 600 m², Santa Fe, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Equipos</dt><dd>4 lásers RGB</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Consola DMX</dd></div>
              <div class="ps-specs__row"><dt>Show</dt><dd>Programado personalizado</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Director de show</dd></div>
              <div class="ps-specs__row"><dt>Espacio ideal</dt><dd>400–800 m²</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Hasta 6 horas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Producciones medianas</span>
              <span class="ps-tag">Foros y teatros</span>
              <span class="ps-tag">After-parties corporativas</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Bodas de lujo</span>
              <span class="ps-tag">Shows de DJ</span>
              <span class="ps-tag">Eventos privados VIP</span>
              <span class="ps-tag">Presentaciones en vivo</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-basico/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-laser.avif" alt="Láser Básico" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Básico</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-laser-estandar/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-laser.avif" alt="Láser Estándar" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Láser Estándar</span>
                <span class="ps-pkg__price">$6,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/" class="ps-pkg">
              <img src="/img/blog/laser-show-concierto.avif" alt="Producción Láser conciertos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Láser</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Concierto, festival o tour? La Producción Láser con 8+ equipos y consola MA es el estándar de la industria.</p>
              <a href="/renta-de-iluminacion/iluminacion-laser/paquete-produccion-laser/" class="ps-upsell__link">Ver Producción Láser →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-iluminacion/sky-tracker/" class="ps-link">Sky Tracker</a>
              <a href="/equipos-para-eventos/maquina-de-humo/" class="ps-link">Máquina de Humo</a>
              <a href="/renta-de-iluminacion/city-color/" class="ps-link">City Color LED</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting LED</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
