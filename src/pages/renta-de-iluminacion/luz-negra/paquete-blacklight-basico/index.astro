---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Blacklight Básico de Luz Negra UV?',
    respuesta: 'Incluye 4 barras de luz negra UV de alta potencia, instalación profesional, posicionamiento estratégico para maximizar el efecto en espacios de hasta 40 m², técnico operador durante el evento, desmontaje y transporte dentro de CDMX y Edomex. Todo lo necesario para transformar un espacio pequeño en una experiencia neón.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Blacklight Básico?',
    respuesta: 'El paquete Blacklight Básico tiene un precio desde $2,500 MXN + IVA. Incluye transporte, instalación, operación y desmontaje en CDMX y Estado de México. Sin costos ocultos ni cargos extras por el técnico.'
  },
  {
    pregunta: '¿Funciona realmente la luz negra en fiestas en casa?',
    respuesta: 'Sí, y es donde más impacto tiene. En espacios cerrados de 20 a 40 m², 4 barras UV crean un efecto visual sorprendente. Todo lo blanco, neón o fluorescente brilla. Ropa blanca, dientes, ropa de colores neon y pintura UV se activan al instante. El secreto es apagar las luces blancas y dejar que la UV haga su magia.'
  },
  {
    pregunta: '¿Necesito ropa especial o pintura UV para la fiesta?',
    respuesta: 'No es obligatorio, pero amplifica mucho la experiencia. La ropa blanca y de colores neón ya brilla sola. Si quieres llevar la fiesta al siguiente nivel, consigue pintura UV — nosotros podemos orientarte sobre qué tipo usar. La luz hace el trabajo; la ropa y pintura solo lo potencian.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos reservar con 2 a 4 semanas de anticipación. Para fechas próximas, escríbenos por WhatsApp — verificamos disponibilidad en tiempo real. Un anticipo del 50% confirma tu fecha al instante.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Blacklight Básico — Luz Negra UV | REDEIL',
    description: 'Paquete de luz negra UV para fiestas en casa y espacios pequeños. 4 barras UV de alta potencia para transformar cualquier cuarto en una experiencia neón y glow en CDMX.',
    image: SITE_URL + '/img/paquetes/luz-negra/blacklight-basico.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-negra/paquete-blacklight-basico/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Blacklight Básico — Luz Negra UV para Fiestas en Casa CDMX | REDEIL"
  description="Transforma tu sala o patio en una fiesta neón con 4 barras de luz negra UV. Paquete básico desde $2,500 MXN. Todo brilla: ropa blanca, neón y pintura UV. CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Negra UV', href: '/renta-de-iluminacion/luz-negra/' }, { name: 'Blacklight Básico', href: '/renta-de-iluminacion/luz-negra/paquete-blacklight-basico/' }]} />

  <Hero
    badge="Blacklight Básico"
    title="Blacklight Básico — Luz Negra UV para Fiestas en Casa"
    description="Apaga las luces, enciende la UV y observa cómo todo lo blanco y neón explota en color. 4 barras de luz negra para espacios de hasta 40 m². El efecto que nadie espera y todos recuerdan."
    primaryCta={{ text: 'Cotizar $2,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-negra/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Blacklight Básico</strong> es la forma más accesible de convertir cualquier espacio en una experiencia de <strong>luz negra UV</strong> en <strong>CDMX y Estado de México</strong>. Cuatro barras de alta potencia colocadas estratégicamente son suficientes para que una sala, un patio pequeño o un cuarto de fiestas se transforme por completo cuando apagas la luz blanca.</p>
      <p>La luz ultravioleta activa todo lo que no ves a simple vista: la blancura de una camisa, los colores neón de una playera, la pintura fluorescente en la piel. No necesitas decoración especial ni una producción elaborada. Solo la oscuridad y las barras UV hacen el trabajo. Es el paquete ideal para cumpleaños en casa, pre-fiestas y reuniones temáticas donde el presupuesto es moderado pero el impacto tiene que ser total.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Negra UV"
    items={[{ label: "Blacklight Party — 8 barras", href: "/renta-de-iluminacion/luz-negra/paquete-blacklight-party/" }, { label: "UV Premium — 16 barras", href: "/renta-de-iluminacion/luz-negra/paquete-uv-premium/" }, { label: "Producción UV — DMX completo", href: "/renta-de-iluminacion/luz-negra/paquete-produccion-uv/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-negra/blacklight-basico.avif" alt="Fiesta en casa con luz negra UV, ropa blanca brillando en neón" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-negra.avif" alt="Ambiente luz negra UV sala transformada en glow party" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/ropa-neon.avif" alt="Invitados con ropa neón brillando bajo luz UV" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/barra-uv.avif" alt="Barra de luz negra UV instalada en techo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/efecto-uv.avif" alt="Efecto completo luz negra, todo brilla en colores neón" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Básico — El punto de entrada perfecto</span>
            <h2 class="prod-info__title">4 Barras de Luz Negra UV para Espacios de hasta 40 m²</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El momento en que apagas la luz y el cuarto explota en neón</h2>
            <p class="prod-selling__intro">Hay un instante en cada fiesta con luz negra que nadie olvida: cuando el anfitrión apaga las luces blancas y enciende la UV por primera vez. Las camisas blancas se iluminan como si tuvieran luz propia. Los colores neón detonan. Los dientes brillan. La gente voltea a verse entre sí y suelta una carcajada mezclada con asombro. Ese momento es lo que vende. Cuatro barras bien posicionadas lo crean perfectamente en espacios pequeños.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">La transformación ocurre en segundos — sin decoración extra</h3>
                  <p class="prod-hl__desc">No necesitas globos neón ni decoración especial. La luz UV convierte la ropa cotidiana de tus invitados en el centro del espectáculo. Ropa blanca, playeras de colores, calcetas — todo brilla. Tu sala de siempre se convierte en un ambiente que nadie reconoce.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura completa para espacios de hasta 40 m²</h3>
                  <p class="prod-hl__desc">Cuatro barras posicionadas en las esquinas o el techo de un espacio de 5×8 metros crean una cobertura UV sin zonas muertas. No hay rincón donde el efecto falle. Cada invitado brilla, sin importar dónde esté parado.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Las fotos y videos quedan espectaculares — sin filtros</h3>
                  <p class="prod-hl__desc">La luz ultravioleta crea contraste natural que los smartphones adoran. Los colores se ven saturados, los fondos oscuros, los sujetos iluminados con una precisión que ningún filtro de Instagram puede replicar. Tus invitados van a querer subir cada foto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Instalación en menos de 30 minutos — sin perforar paredes</h3>
                  <p class="prod-hl__desc">Nuestro técnico llega con todo lo necesario para instalar sin dañar tu casa. Usamos soportes y clamps que se adaptan a cualquier estructura. En media hora el espacio está listo. Al terminar, desmontamos sin dejar rastro.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 barras de luz negra UV alta potencia</div>
              <div class="prod-feat">Soportes y estructuras de montaje</div>
              <div class="prod-feat">Cable y conexiones profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Asesoría de posicionamiento</div>
              <div class="prod-feat">Pruebas previas al evento</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos el espacio y la fecha</h4>
                  <p class="prod-step__desc">Comparte el tamaño aproximado del espacio, la fecha y el tipo de fiesta. Con eso diseñamos la distribución exacta de las 4 barras para máximo efecto UV.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirma y aparta tu fecha</h4>
                  <p class="prod-step__desc">Con un anticipo del 50% por transferencia, efectivo o tarjeta, tu fecha queda confirmada. Te enviamos los detalles de llegada y preparación del espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos y montamos</h4>
                  <p class="prod-step__desc">El técnico llega 1 hora antes del evento, instala las barras, hace las pruebas de encendido y te muestra cómo se ve el espacio con las luces blancas apagadas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Tú disfrutas, nosotros cuidamos la luz</h4>
                  <p class="prod-step__desc">El técnico permanece durante el evento para cualquier ajuste. Al terminar la fiesta, desmontamos todo. Tu casa queda exactamente como la dejamos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Básico o Party? Elige según tu espacio</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Blacklight Básico — 4 barras</span>
                <ul class="prod-compare__list">
                  <li>Ideal para casas y departamentos</li>
                  <li>Cobertura hasta 40 m²</li>
                  <li>Hasta 30 invitados</li>
                  <li>Una zona UV principal</li>
                  <li>Fiesta casual o temática</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Blacklight Party — 8 barras</span>
                <ul class="prod-compare__list">
                  <li>Para salones medianos</li>
                  <li>Cobertura hasta 80 m²</li>
                  <li>Hasta 80 invitados</li>
                  <li>Cobertura en dos zonas</li>
                  <li>Glow party real sin zonas oscuras</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Para el cumple de mi hijo de 15 años en casa, renté el paquete básico sin saber muy bien qué esperar. Cuando apagamos las luces y encendieron la UV, mis sobrinos enloquecieron. Todos corrieron a ponerse ropa blanca que traían de reserva. Las fotos quedaron increíbles. Definitivamente el mejor dinero gastado de toda la fiesta."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Claudia R.</span>
                <span class="prod-quote__event">Cumpleaños en casa — Benito Juárez, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Barras UV</dt><dd>4 unidades</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 40 m²</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>Hasta 30 personas</dd></div>
              <div class="ps-specs__row"><dt>Tipo de luz</dt><dd>Ultravioleta UV-A</dd></div>
              <div class="ps-specs__row"><dt>Montaje</dt><dd>Sin perforar paredes</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas en casa</span>
              <span class="ps-tag">Cumpleaños temáticos</span>
              <span class="ps-tag">Pre-fiestas</span>
              <span class="ps-tag">Fiestas neón</span>
              <span class="ps-tag">Reuniones glow</span>
              <span class="ps-tag">Eventos universitarios</span>
              <span class="ps-tag">Salones pequeños</span>
              <span class="ps-tag">Patios techados</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-negra/paquete-blacklight-party/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/blacklight-party.avif" alt="Blacklight Party 8 barras" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Blacklight Party</span>
                <span class="ps-pkg__price">$4,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-negra/paquete-uv-premium/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/uv-premium.avif" alt="UV Premium 16 barras" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">UV Premium</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-negra/paquete-produccion-uv/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/produccion-uv.avif" alt="Producción UV DMX completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción UV</span>
                <span class="ps-pkg__price">$14,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Salón mediano o más de 30 personas? El Blacklight Party duplica la cobertura y garantiza que todos brillen por igual.</p>
              <a href="/renta-de-iluminacion/luz-negra/paquete-blacklight-party/" class="ps-upsell__link">Ver Blacklight Party →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/" class="ps-link">Bocinas para Fiestas</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
