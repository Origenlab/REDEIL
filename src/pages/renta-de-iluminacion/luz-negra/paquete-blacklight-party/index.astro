---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Blacklight Party de Luz Negra UV?',
    respuesta: 'Incluye 8 barras de luz negra UV de alta potencia, instalación profesional con posicionamiento estratégico para cobertura uniforme en salones de hasta 80 m², técnico operador durante todo el evento, desmontaje y transporte. Todo pensado para que no haya una sola zona oscura en tu glow party.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Blacklight Party?',
    respuesta: 'El paquete Blacklight Party tiene un precio desde $4,800 MXN + IVA. Incluye todo: transporte, instalación, operación y desmontaje en CDMX y Estado de México. Sin cargos extra por el técnico.'
  },
  {
    pregunta: '¿Para cuántas personas alcanza este paquete?',
    respuesta: 'Está diseñado para eventos de 40 a 80 personas en salones de hasta 80 m². Las 8 barras se distribuyen para que cada rincón del salón tenga cobertura UV sin puntos muertos. Si tu evento es más grande, el paquete UV Premium con 16 barras es la opción ideal.'
  },
  {
    pregunta: '¿Puedo combinar luz negra con otros efectos de luz?',
    respuesta: 'Sí, y queda espectacular. La combinación más popular es luz negra + humo bajo + confeti neón. También combinamos con nuestro servicio de luz neón LED para letreros y ambientación. Escríbenos por WhatsApp para diseñar el paquete combinado ideal para tu evento.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el Blacklight Party?',
    respuesta: 'Recomendamos reservar con 3 a 5 semanas de anticipación, especialmente para fines de semana. Un anticipo del 50% confirma tu fecha. Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad en tiempo real.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Blacklight Party — Luz Negra UV | REDEIL',
    description: 'Paquete de luz negra UV para glow parties en salones medianos. 8 barras UV de alta potencia para cobertura uniforme en espacios de hasta 80 m² en CDMX y Edomex.',
    image: SITE_URL + '/img/paquetes/luz-negra/blacklight-party.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4800',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-negra/paquete-blacklight-party/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '35',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Blacklight Party — Luz Negra UV para Glow Party en Salón CDMX | REDEIL"
  description="Glow party real sin zonas oscuras. 8 barras de luz negra UV para salones de hasta 80 m² y 80 personas. $4,800 MXN todo incluido. CDMX y Estado de México."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Negra UV', href: '/renta-de-iluminacion/luz-negra/' }, { name: 'Blacklight Party', href: '/renta-de-iluminacion/luz-negra/paquete-blacklight-party/' }]} />

  <Hero
    badge="Blacklight Party"
    title="Blacklight Party — Luz Negra UV para Glow Party en Salón"
    description="Ochenta personas, ochenta m², cero zonas oscuras. 8 barras UV distribuidas para que cada rincón del salón brille por igual. La diferencia entre 'había luz negra' y 'fue una glow party de verdad'."
    primaryCta={{ text: 'Cotizar $4,800 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-negra/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Blacklight Party</strong> está diseñado para quien quiere hacer una <strong>glow party real</strong> en un salón mediano de <strong>CDMX o Estado de México</strong>. La diferencia entre 4 y 8 barras no es solo el doble de luz — es la cobertura uniforme. Con 4 barras hay zonas brillantes y zonas opacas. Con 8, todo el salón queda saturado de UV y no hay un solo invitado que no brille.</p>
      <p>Las barras se posicionan estratégicamente — perimetrales, cruzadas o en el techo según la geometría del salón — para eliminar cualquier punto muerto. El técnico llega antes del evento, diseña la distribución exacta en sitio y hace pruebas de encendido. El resultado: cuando las luces blancas se apagan, el salón completo explota en neón de forma simultánea, sin transiciones ni rincones oscuros.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Negra UV"
    items={[{ label: "Blacklight Básico — 4 barras", href: "/renta-de-iluminacion/luz-negra/paquete-blacklight-basico/" }, { label: "UV Premium — 16 barras", href: "/renta-de-iluminacion/luz-negra/paquete-uv-premium/" }, { label: "Producción UV — DMX completo", href: "/renta-de-iluminacion/luz-negra/paquete-produccion-uv/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-negra/blacklight-party.avif" alt="Salón mediano con luz negra UV glow party, todos los invitados brillando" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-negra.avif" alt="Glow party con cobertura UV uniforme en todo el salón" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/ropa-neon.avif" alt="Invitados con ropa neón y pintura UV brillando" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/barra-uv.avif" alt="8 barras de luz UV instaladas en salón mediano" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/efecto-uv.avif" alt="Efecto blacklight completo sin zonas oscuras" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Blacklight Party — La glow party completa</span>
            <h2 class="prod-info__title">8 Barras UV para Glow Party sin Zonas Oscuras en Salones de hasta 80 m²</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,800</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, posicionamiento estratégico, operación y desmontaje</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La cobertura UV que hace que todos brillen — sin excepción</h2>
            <p class="prod-selling__intro">El secreto de una buena glow party no está en tener "luz negra" — está en no tener zonas donde la UV no llegue. Cuando el salón tiene puntos oscuros, los invitados se acumulan en las zonas brillantes y el resto del espacio muere. Ocho barras bien distribuidas eliminan ese problema: el salón completo se convierte en una cámara UV donde cada persona, sin importar dónde esté parada, brilla igual.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Posicionamiento estratégico — sin zonas muertas</h3>
                  <p class="prod-hl__desc">El técnico analiza la geometría del salón y distribuye las 8 barras para cobertura cruzada. No hay esquina sin UV. No hay mesa donde los invitados no brillen. Todo el espacio vive la fiesta por igual, desde la pista hasta el área de mesas.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">La pista de baile se convierte en otro mundo</h3>
                  <p class="prod-hl__desc">Cuando 60 personas bailan bajo luz UV, el movimiento crea un espectáculo visual que ninguna luz de colores puede replicar. Las telas neón se mueven como trazos de luz. Los brazos dejan rastros fluorescentes en el aire. La pista cobra vida propia.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Compatible con pintura UV, accesorios neón y decoración fluorescente</h3>
                  <p class="prod-hl__desc">Este paquete es el lienzo perfecto para llevar la fiesta más lejos. Agrega pintura UV en el entry, pulseras neón de bienvenida, globos fluorescentes. Con 8 barras de potencia, cada elemento de decoración UV alcanza su máxima saturación de color.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El contenido que genera solo — fotos y videos sin esfuerzo</h3>
                  <p class="prod-hl__desc">Una glow party con cobertura uniforme genera contenido visual potente de forma natural. Los smartphones capturan los colores con saturación automática. Tus invitados van a repostear. El evento vive más allá de la noche.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">8 barras de luz negra UV alta potencia</div>
              <div class="prod-feat">Análisis y diseño de posicionamiento</div>
              <div class="prod-feat">Soportes y estructuras de montaje</div>
              <div class="prod-feat">Cable y conexiones profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Pruebas previas al evento</div>
              <div class="prod-feat">Cobertura para dos zonas simultáneas</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte los datos del salón y la fecha</h4>
                  <p class="prod-step__desc">Medidas aproximadas, distribución del salón (pista, mesas, bar) y capacidad de invitados. Con eso diseñamos el mapa de posicionamiento de las 8 barras antes de llegar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirma con anticipo y recibe plan de instalación</h4>
                  <p class="prod-step__desc">Con el 50% de anticipo apartamos tu fecha. Te enviamos el plan de llegada, tiempos de instalación y recomendaciones de ropa y decoración UV para tus invitados.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación completa 90 minutos antes</h4>
                  <p class="prod-step__desc">El técnico llega con tiempo suficiente para instalar, distribuir y probar cada barra. Hacemos recorrido completo del salón para verificar que no hay zonas sin cobertura UV.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">La fiesta empieza, nosotros nos quedamos</h4>
                  <p class="prod-step__desc">El técnico permanece para cualquier ajuste durante el evento. Al terminar, desmontamos todo limpiamente. El salón queda libre antes de que la producción cierre.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Blacklight Party o UV Premium?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Blacklight Party — 8 barras</span>
                <ul class="prod-compare__list">
                  <li>Salones de hasta 80 m²</li>
                  <li>Hasta 80 invitados</li>
                  <li>Cobertura en 2 zonas</li>
                  <li>Sin control DMX</li>
                  <li>Encendido/apagado manual</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">UV Premium — 16 barras</span>
                <ul class="prod-compare__list">
                  <li>Salones de hasta 200 m²</li>
                  <li>Hasta 150 invitados</li>
                  <li>Cobertura total sin límites</li>
                  <li>Control de intensidad</li>
                  <li>Producción media completa</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos una glow party para los 18 años de mi hija en un salón en Tlalpan para 65 personas. El técnico llegó temprano, midió todo el salón y colocó las 8 barras de forma que cuando apagamos las luces, no había un solo lugar oscuro. Mis sobrinos se pusieron a bailar y se veían increíbles. Cada foto que tomábamos parecía de producción profesional."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Patricia G.</span>
                <span class="prod-quote__event">Fiesta de 18 años — Salón en Tlalpan, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Barras UV</dt><dd>8 unidades</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 80 m²</dd></div>
              <div class="ps-specs__row"><dt>Capacidad</dt><dd>Hasta 80 personas</dd></div>
              <div class="ps-specs__row"><dt>Tipo de luz</dt><dd>Ultravioleta UV-A</dd></div>
              <div class="ps-specs__row"><dt>Distribución</dt><dd>Estratégica sin zonas muertas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Glow parties</span>
              <span class="ps-tag">Fiestas neón temáticas</span>
              <span class="ps-tag">Cumpleaños 15 y 18</span>
              <span class="ps-tag">Fiestas universitarias</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Salones medianos</span>
              <span class="ps-tag">Fiestas de disfraces UV</span>
              <span class="ps-tag">Halloween neón</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-negra/paquete-blacklight-basico/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/blacklight-basico.avif" alt="Blacklight Básico 4 barras" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Blacklight Básico</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-negra/paquete-uv-premium/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/uv-premium.avif" alt="UV Premium 16 barras" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">UV Premium</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-negra/paquete-produccion-uv/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/produccion-uv.avif" alt="Producción UV DMX completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción UV</span>
                <span class="ps-pkg__price">$14,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Más de 80 personas o salón grande? UV Premium con 16 barras cubre hasta 200 m² con control de intensidad.</p>
              <a href="/renta-de-iluminacion/luz-negra/paquete-uv-premium/" class="ps-upsell__link">Ver UV Premium →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-fiestas/" class="ps-link">Bocinas para Fiestas</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
