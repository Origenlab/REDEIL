---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción UV de Luz Negra?',
    respuesta: 'Incluye 24 o más barras de luz negra UV de alta potencia, sistema DMX para control programado por escenas, diseño técnico completo del evento, técnico operador de iluminación dedicado, programación previa de cues según el timeline del evento, instalación profesional con estructuras certificadas, transporte y desmontaje. Es la producción UV más completa que ofrecemos.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción UV?',
    respuesta: 'El paquete Producción UV tiene un precio desde $14,000 MXN + IVA. El precio exacto depende del tamaño del espacio, el número de barras necesarias y la complejidad de la programación DMX. Cotización personalizada sin costo en menos de 24 horas.'
  },
  {
    pregunta: '¿Qué es el control DMX y para qué sirve en luz negra UV?',
    respuesta: 'DMX es el protocolo de control profesional para iluminación de espectáculos. Con DMX, las barras UV se programan por escenas: "entrada de novios", "primer baile", "apertura de pista". Cada escena tiene su nivel de intensidad y configuración de zonas predefinida. El técnico ejecuta los cambios con precisión al milisegundo, sincronizado con la música y el programa del evento.'
  },
  {
    pregunta: '¿El paquete Producción UV es solo para eventos grandes?',
    respuesta: 'No. El control DMX y la programación por escenas añade valor en cualquier evento donde el timing de la iluminación importa. Bodas, galas, lanzamientos de producto, presentaciones escénicas — cualquier evento con un programa definido donde la luz UV debe cambiar en momentos específicos se beneficia del control DMX, independientemente del tamaño del espacio.'
  },
  {
    pregunta: '¿Puedo combinar el paquete Producción UV con otros servicios?',
    respuesta: 'Absolutamente. La Producción UV está diseñada para integrarse con uplighting DMX, luces robotizadas, máquina de humo bajo y luz neón LED en una sola consola de control. Un solo técnico puede manejar toda la iluminación del evento de forma coordinada. Somos el proveedor de iluminación integral más completo para eventos en CDMX.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción UV — Luz Negra DMX Completa | REDEIL',
    description: 'Producción UV completa con 24+ barras de luz negra y control DMX para eventos de cualquier escala en CDMX. Programación por escenas, técnico de iluminación dedicado.',
    image: SITE_URL + '/img/paquetes/luz-negra/produccion-uv.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '14000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-negra/paquete-produccion-uv/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '15',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción UV — Luz Negra DMX 24+ Barras para Eventos CDMX | REDEIL"
  description="Producción UV profesional con 24+ barras de luz negra y control DMX. Programación por escenas para bodas, galas y eventos de producción completa. Desde $14,000 MXN. CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Negra UV', href: '/renta-de-iluminacion/luz-negra/' }, { name: 'Producción UV', href: '/renta-de-iluminacion/luz-negra/paquete-produccion-uv/' }]} />

  <Hero
    badge="Producción UV — DMX"
    title="Producción UV Completa — 24+ Barras de Luz Negra con Control DMX"
    description="El paquete para cuando la luz negra UV no es un ambiente — es el show. 24 o más barras controladas por DMX, programadas por escenas según tu timeline. La producción UV que los asistentes no olvidarán."
    primaryCta={{ text: 'Cotizar $14,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver todos los paquetes', href: '/renta-de-iluminacion/luz-negra/' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>Producción UV</strong> es el nivel máximo de luz negra que ofrecemos. No es solo más barras — es un sistema completo de <strong>iluminación UV con control DMX</strong> diseñado para eventos donde la experiencia visual es tan importante como el contenido del evento. 24 o más barras de alta potencia cubren cualquier espacio sin compromisos, y el sistema DMX permite programar cada momento del evento con precisión de milisegundos.</p>
      <p>En <strong>CDMX y Estado de México</strong>, este es el paquete que eligen los coordinadores de bodas de alta producción, los organizadores de eventos corporativos premium y los productores de espectáculos que quieren que la luz negra UV funcione como elemento narrativo del evento — no como decoración. Cada transición, cada cambio de intensidad, cada "reveal" está planificado, programado y ejecutado por un técnico de iluminación dedicado.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Negra UV"
    items={[{ label: "Blacklight Básico — 4 barras", href: "/renta-de-iluminacion/luz-negra/paquete-blacklight-basico/" }, { label: "Blacklight Party — 8 barras", href: "/renta-de-iluminacion/luz-negra/paquete-blacklight-party/" }, { label: "UV Premium — 16 barras", href: "/renta-de-iluminacion/luz-negra/paquete-uv-premium/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-negra/produccion-uv.avif" alt="Producción UV completa con 24 barras y control DMX en evento de gala" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-negra.avif" alt="Producción UV profesional con DMX en salón de eventos CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/ropa-neon.avif" alt="Evento de gala con luz negra UV en máxima saturación" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/barra-uv.avif" alt="Instalación profesional de 24 barras UV con estructuras" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-negra/sell/efecto-uv.avif" alt="Control DMX de luz negra UV en consola profesional" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Producción UV — El nivel profesional completo</span>
            <h2 class="prod-info__title">24+ Barras de Luz Negra UV con Control DMX y Programación por Escenas</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$14,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Precio desde. Incluye diseño técnico, DMX, técnico de iluminación dedicado, instalación y desmontaje</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando la luz negra UV narra el evento momento a momento</h2>
            <p class="prod-selling__intro">Hay eventos donde el ambiente UV no basta con encender las barras y dejarlas. Hay eventos donde la entrada de los novios merece una revelación de luz, donde el primer baile necesita que la UV suba gradualmente de cero, donde la apertura de la pista requiere que el espacio completo explote en colores simultáneamente. El control DMX hace todo eso posible. La Producción UV no es solo el paquete más grande — es el paquete donde la luz UV se convierte en un elemento activo del evento.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Control DMX programado por escenas — cada momento del evento tiene su luz</h3>
                  <p class="prod-hl__desc">Antes del evento, el técnico recibe el timeline completo y programa cada cue: entrada, cena, discursos, primer baile, apertura de pista. Durante el evento ejecuta cada cambio de forma precisa y coordinada. No hay improvisación — hay diseño de experiencia.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">24+ barras — el espacio completo sin excusas</h3>
                  <p class="prod-hl__desc">Con 24 o más barras, la saturación UV en cualquier espacio es total. No importa el tamaño del venue, los ángulos del techo o la distribución de las mesas — diseñamos la distribución para que no exista un centímetro cuadrado sin cobertura UV. El resultado visual es de nivel producción televisiva.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Integración total con el sistema de iluminación del evento</h3>
                  <p class="prod-hl__desc">El sistema DMX de la Producción UV se conecta con el resto de la iluminación del evento — uplighting, luces robotizadas, chasers. Un solo operador controla toda la iluminación desde una consola, creando cambios de ambiente sincronizados entre diferentes tipos de luz. La UV no es un elemento aislado: es parte del diseño completo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico de iluminación dedicado — no un asistente, un profesional</h3>
                  <p class="prod-hl__desc">La Producción UV incluye un técnico de iluminación con experiencia en producción de eventos. No solo opera el equipo — coordina con el DJ, el coordinador de bodas y el equipo de producción para que cada cambio de luz ocurra en el momento exacto. Es el diferencial entre una producción amateur y una profesional.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">24+ barras de luz negra UV alta potencia</div>
              <div class="prod-feat">Sistema de control DMX profesional</div>
              <div class="prod-feat">Programación previa por escenas</div>
              <div class="prod-feat">Diseño técnico del evento</div>
              <div class="prod-feat">Estructuras certificadas de soporte</div>
              <div class="prod-feat">Cable y conexiones profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional completa</div>
              <div class="prod-feat">Técnico de iluminación dedicado</div>
              <div class="prod-feat">Coordinación con producción del evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Soporte técnico en sitio durante el evento</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Consulta técnica y diseño del evento</h4>
                  <p class="prod-step__desc">Reunión virtual o en sitio con el técnico de iluminación. Revisamos planos del venue, el programa del evento y los momentos clave. Diseñamos la distribución de barras y el mapa de escenas DMX.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Programación previa de cues DMX</h4>
                  <p class="prod-step__desc">Con el timeline del evento, el técnico programa cada escena en la consola DMX antes del día. No hay improvisación en sitio. Cada cambio de luz está listo para ejecutarse al segundo preciso.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación con acceso anticipado al venue</h4>
                  <p class="prod-step__desc">Coordinamos con el salón acceso de 4 a 6 horas antes del evento para instalación completa, pruebas por zonas y verificación del sistema DMX. El venue está listo y probado antes de que llegue el primer invitado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Operación profesional coordinada durante el evento</h4>
                  <p class="prod-step__desc">El técnico opera desde la consola DMX durante todo el evento, coordinado con el DJ y el coordinador general. Cada escena se ejecuta en el momento preciso. Al cierre, desmontaje completo sin afectar la limpieza del venue.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿UV Premium o Producción UV con DMX?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">UV Premium — 16 barras</span>
                <ul class="prod-compare__list">
                  <li>Control manual de intensidad</li>
                  <li>Sin programación por escenas</li>
                  <li>Ajustes manuales en tiempo real</li>
                  <li>Ideal para eventos de producción media</li>
                  <li>Sin integración con otros sistemas</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción UV — 24+ barras DMX</span>
                <ul class="prod-compare__list">
                  <li>Control DMX programado por escenas</li>
                  <li>Cada momento del evento tiene su cue</li>
                  <li>Cambios de luz precisos al milisegundo</li>
                  <li>Para producciones de alto nivel</li>
                  <li>Integración con iluminación completa</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos la Producción UV para una boda de 200 personas en una hacienda en el Estado de México. El técnico coordinó con nuestro DJ para que cada cambio de luz UV ocurriera exactamente en el momento indicado. La entrada de los novios fue con UV al 0% y subiendo gradualmente — la reacción del salón fue increíble. Varios invitados nos preguntaron después quién había hecho la producción de iluminación. Fue el elemento más comentado de toda la boda."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Alejandra y Marcos</span>
                <span class="prod-quote__event">Boda de 200 personas — Hacienda en Tepotzotlán, Edomex</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Barras UV</dt><dd>24+ unidades</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Sin límite de espacio</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>DMX programado</dd></div>
              <div class="ps-specs__row"><dt>Escenas</dt><dd>Personalizadas por evento</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Iluminación dedicado</dd></div>
              <div class="ps-specs__row"><dt>Diseño previo</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas de alto nivel</span>
              <span class="ps-tag">Galas corporativas</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Producciones escénicas</span>
              <span class="ps-tag">Fiestas temáticas UV</span>
              <span class="ps-tag">Eventos con más de 150 personas</span>
              <span class="ps-tag">Venues con producción completa</span>
              <span class="ps-tag">Conciertos y espectáculos</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-negra/paquete-blacklight-basico/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/blacklight-basico.avif" alt="Blacklight Básico" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Blacklight Básico</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-negra/paquete-blacklight-party/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/blacklight-party.avif" alt="Blacklight Party" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Blacklight Party</span>
                <span class="ps-pkg__price">$4,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-negra/paquete-uv-premium/" class="ps-pkg">
              <img src="/img/paquetes/luz-negra/uv-premium.avif" alt="UV Premium" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">UV Premium</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Producción completa con uplighting y neón? Cotizamos el paquete integral con todos los servicios combinados.</p>
              <a href="/cotizar/" class="ps-upsell__link">Cotizar producción completa →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Diseño técnico personalizado. Respuesta en menos de 24 horas.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting DMX</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
