---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción de Cascadas LED?',
    respuesta: 'Incluye 8 o más cortinas LED de 3×3 metros según el venue, sistema DMX profesional con consola de iluminación, diseño personalizado de la producción de luz, director de iluminación el día del evento, equipo de técnicos para instalación, transporte de equipo completo, programación de show de luz, operación durante todo el evento y desmontaje. Es una producción de iluminación completa, no solo un equipo de renta.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción de Cascadas LED?',
    respuesta: 'El paquete Producción tiene un precio desde $12,000 MXN + IVA. El precio final depende del tamaño del venue, número exacto de cortinas necesarias y complejidad del diseño. Incluye todo: equipo, DMX, personal, dirección y desmontaje. Solicita tu cotización personalizada por WhatsApp.'
  },
  {
    pregunta: '¿Qué es el sistema DMX y por qué lo necesito?',
    respuesta: 'DMX es el protocolo profesional de control de iluminación que usan las producciones de conciertos y grandes eventos. Con DMX, cada cortina se controla de forma individual y las secuencias de luz se programan con precisión milimétrica. Puedes sincronizar los efectos con la música, crear coreografías de luz y tener un show de iluminación completamente personalizado.'
  },
  {
    pregunta: '¿Qué hace el director de iluminación el día del evento?',
    respuesta: 'El director de iluminación es el responsable artístico y técnico de toda la producción. Opera la consola DMX, coordina al equipo de técnicos, sincroniza los cambios de luz con los momentos del evento y toma decisiones en tiempo real para que la iluminación sea perfecta. Es la diferencia entre un servicio de renta y una producción profesional.'
  },
  {
    pregunta: '¿En qué tipos de eventos se usa el paquete Producción?',
    respuesta: 'Bodas de lujo con más de 200 invitados, eventos corporativos de gala, lanzamientos de productos, convenciones, shows en vivo y cualquier evento donde la iluminación sea un elemento central de la experiencia. También es el paquete elegido por wedding planners y coordinadores de eventos que buscan diferenciarse con producción de alto nivel.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Paquete Producción — Cascadas LED | REDEIL',
    description: 'Producción profesional de cascadas LED con 8+ cortinas, sistema DMX, diseño personalizado y director de iluminación para bodas y eventos de alto nivel en CDMX.',
    image: SITE_URL + '/img/paquetes/cascadas-led/produccion.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '12000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cascadas-led/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '14',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Paquete Producción — Cascadas LED en CDMX | REDEIL"
  description="Producción completa de cascadas LED con 8+ cortinas, sistema DMX profesional y director de iluminación para bodas de lujo y eventos corporativos en CDMX desde $12,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cascadas LED', href: '/renta-de-iluminacion/cascadas-led/' }, { name: 'Paquete Producción', href: '/renta-de-iluminacion/cascadas-led/paquete-produccion/' }]} />

  <Hero
    badge="Paquete Producción"
    title="Paquete Producción — Cascadas LED con DMX y Director de Iluminación"
    description="8 o más cortinas LED, consola DMX profesional, diseño personalizado y director de iluminación. La producción completa para bodas de lujo y eventos corporativos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $12,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cascadas-led/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete Producción de Cascadas LED</strong> es para eventos donde la iluminación no es un adorno — es parte del espectáculo. Con <strong>8 o más cortinas LED</strong>, sistema DMX profesional y un director de iluminación dedicado, transformamos cualquier venue en una producción de nivel internacional.</p>
      <p>No es un servicio de renta. Es una producción completa con diseño previo, programación de show de luz, dirección artística el día del evento y un equipo de técnicos que ejecuta cada detalle con precisión. Para bodas de lujo en <strong>CDMX, Edomex, Morelos y Puebla</strong> donde la iluminación tiene que estar a la altura de todo lo demás.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cascadas LED"
    items={[{ label: "1 Cortina", href: "/renta-de-iluminacion/cascadas-led/paquete-1-cortina/" }, { label: "2 Cortinas", href: "/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/" }, { label: "4 Cortinas", href: "/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/cascadas-led/produccion.avif" alt="Producción cascadas LED 8 cortinas boda de lujo CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cascadas-led.avif" alt="Cascadas LED producción profesional evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/efecto-lluvia.avif" alt="Show de cascadas LED DMX boda de lujo" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/exterior.avif" alt="Producción cascadas LED instalación exterior venue" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/backdrop.avif" alt="Fondo cascadas LED producción profesional" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Producción — El nivel más alto</span>
            <h2 class="prod-info__title">8+ Cortinas LED con Sistema DMX, Diseño Personalizado y Director de Iluminación</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$12,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Desde: precio final según venue, número de cortinas y complejidad del diseño. Todo incluido: equipo, DMX, personal y dirección.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Una producción de luz, no solo equipo rentado</h2>
            <p class="prod-selling__intro">La diferencia entre rentar cortinas LED y contratar una producción de iluminación es la misma que hay entre poner música de Spotify y tener un DJ profesional. Con el paquete Producción, cada momento de tu evento tiene su propia secuencia de luz diseñada, programada y ejecutada por profesionales. El sistema DMX controla cada cortina de forma individual con precisión que los controladores básicos no pueden alcanzar.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sistema DMX profesional — control individual de cada cortina</h3>
                  <p class="prod-hl__desc">Con DMX, cada una de las 8 o más cortinas tiene su propio canal de control. Las cortinas pueden tener efectos distintos simultáneamente, sincronizarse en secuencias complejas o crear patrones de luz en movimiento a través del salón. Es el mismo sistema que usan los conciertos y las producciones de Broadway.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Diseño personalizado previo al evento</h3>
                  <p class="prod-hl__desc">Antes del evento, nuestro director de iluminación diseña el show de luz completo: qué efecto en cada cortina, en qué momento del evento, con qué transiciones. Recibes un mapa de luz antes del día para que sepas exactamente qué va a pasar en cada momento de tu celebración.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de iluminación dedicado — arte y técnica en uno</h3>
                  <p class="prod-hl__desc">El director de iluminación es el responsable de toda la producción. Opera la consola DMX, toma decisiones artísticas en tiempo real y coordina al equipo de técnicos. No improvisamos: cada cambio está programado, pero el director reacciona a los imprevistos del evento sin que nada se note.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura total de venues grandes y venues complejos</h3>
                  <p class="prod-hl__desc">Salones de más de 500 m², haciendas con múltiples espacios, venues con geometría irregular: el paquete Producción se diseña a medida. Número de cortinas, posición, ángulo y programación se calculan específicamente para tu espacio. No hay un venue que no podamos cubrir.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">8 o más cortinas LED 3×3m (según venue)</div>
              <div class="prod-feat">Consola DMX profesional</div>
              <div class="prod-feat">Diseño personalizado de producción de luz</div>
              <div class="prod-feat">Director de iluminación el día del evento</div>
              <div class="prod-feat">Equipo de técnicos instaladores</div>
              <div class="prod-feat">Programación de show de luz pre-evento</div>
              <div class="prod-feat">Cable y conectores profesionales de alta carga</div>
              <div class="prod-feat">Soportes y estructuras de montaje</div>
              <div class="prod-feat">Transporte de equipo completo</div>
              <div class="prod-feat">Coordinación técnica con el venue</div>
              <div class="prod-feat">Prueba general el día del evento</div>
              <div class="prod-feat">Desmontaje completo al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Visita técnica al venue (incluida)</h4>
                  <p class="prod-step__desc">Para producciones de este nivel, realizamos una visita técnica al venue para medir espacios, verificar capacidad eléctrica y diseñar la distribución exacta de las cortinas. Sin costo adicional.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Diseño de producción personalizado</h4>
                  <p class="prod-step__desc">El director de iluminación diseña el show completo: layout de cortinas, secuencias DMX por momento del evento y mapa de transiciones. Recibes el diseño para revisarlo y aprobarlo antes de confirmar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Programación y ensayo virtual</h4>
                  <p class="prod-step__desc">Una vez aprobado el diseño, se programa la consola DMX con las secuencias del evento. Si es posible, hacemos un ensayo en el venue días antes para que todo esté afinado al detalle.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Producción completa el día del evento</h4>
                  <p class="prod-step__desc">Llegamos 4 horas antes con el equipo completo. Instalación, prueba técnica general y briefing con coordinadores del evento. El director opera la consola DMX durante toda la celebración y el equipo está en comunicación constante para ejecutar cada momento de manera perfecta.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué elegir Producción y no 4 Cortinas?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 4 Cortinas</span>
                <ul class="prod-compare__list">
                  <li>4 cortinas en posición fija</li>
                  <li>Controlador con efectos básicos</li>
                  <li>Sin diseño previo de producción</li>
                  <li>2 técnicos operadores</li>
                  <li>Para salones hasta 400 m²</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Paquete Producción</span>
                <ul class="prod-compare__list">
                  <li>8+ cortinas, diseño a medida</li>
                  <li>Sistema DMX con control total</li>
                  <li>Show de luz diseñado y programado</li>
                  <li>Director de iluminación profesional</li>
                  <li>Sin límite de tamaño de venue</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete Producción para una boda de 240 invitados en una hacienda en Cuernavaca. El director de iluminación se reunió con nosotros tres veces antes del evento para afinar cada detalle. El día de la boda, cuando hicieron la entrada de los novios, las 10 cortinas encendieron en cascada sincronizadas con la música. Fue el momento más impactante que yo haya presenciado en una boda. Valió cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Valentina y Andrés</span>
                <span class="prod-quote__event">Boda en Hacienda de Cortés Cuernavaca — 240 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cortinas incluidas</dt><dd>8 o más</dd></div>
              <div class="ps-specs__row"><dt>Dimensiones c/u</dt><dd>3×3 metros</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Sistema DMX profesional</dd></div>
              <div class="ps-specs__row"><dt>Diseño</dt><dd>Personalizado por evento</dd></div>
              <div class="ps-specs__row"><dt>Director</dt><dd>1 director de iluminación</dd></div>
              <div class="ps-specs__row"><dt>Equipo técnico</dt><dd>3+ técnicos</dd></div>
              <div class="ps-specs__row"><dt>Visita técnica</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX, Edomex, Morelos, Puebla</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas de lujo 200+</span>
              <span class="ps-tag">Eventos corporativos gala</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Haciendas grandes</span>
              <span class="ps-tag">Venues complejos</span>
              <span class="ps-tag">Shows en vivo</span>
              <span class="ps-tag">Wedding planners</span>
              <span class="ps-tag">Producciones premium</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-1-cortina/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-1-cortina.avif" alt="Paquete 1 Cortina" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">1 Cortina</span>
                <span class="ps-pkg__price">$2,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-2-cortinas.avif" alt="Paquete 2 Cortinas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Cortinas</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-4-cortinas.avif" alt="Paquete 4 Cortinas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cortinas</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento mediano o presupuesto más acotado? El paquete de 4 cortinas cubre la mayoría de salones con controlador profesional.</p>
              <a href="/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" class="ps-upsell__link">Ver paquete 4 Cortinas →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización personalizada para tu venue en menos de 24 horas.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Luces Arquitectónicas</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
