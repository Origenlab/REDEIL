---
import Base from '../../../layouts/Base.astro';
import TopBar from '../../../components/TopBar.astro';
import Header from '../../../components/Header.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import CategoryCard from '../../../components/CategoryCard.astro';
import FaqSection from '../../../components/FaqSection.astro';
import Footer from '../../../components/Footer.astro';
import WhatsAppBubble from '../../../components/WhatsAppBubble.astro';
import { faqSchema, breadcrumbSchema } from '../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../lib/config';

const paquetes = [
  {
    "nombre": "1 Cortina",
    "slug": "paquete-1-cortina",
    "precio": 2000,
    "imagen": "/img/paquetes/cascadas-led/paquete-1-cortina.avif",
    "badge": "",
    "features": [
      "1 cortina LED 3x3m",
      "Luz blanca cálida",
      "Instalación y desmontaje",
      "Estructura de montaje"
    ]
  },
  {
    "nombre": "2 Cortinas",
    "slug": "paquete-2-cortinas",
    "precio": 3500,
    "imagen": "/img/paquetes/cascadas-led/paquete-2-cortinas.avif",
    "badge": "Más popular",
    "features": [
      "2 cortinas LED 3x3m",
      "Luz blanca cálida",
      "Instalación y desmontaje",
      "Estructura de montaje",
      "Controlador de efectos"
    ]
  },
  {
    "nombre": "4 Cortinas",
    "slug": "paquete-4-cortinas",
    "precio": 6000,
    "imagen": "/img/paquetes/cascadas-led/paquete-4-cortinas.avif",
    "badge": "",
    "features": [
      "4 cortinas LED 3x3m",
      "Luz blanca cálida o colores",
      "Instalación y desmontaje",
      "Estructura de montaje",
      "Controlador de efectos",
      "Colores adicionales"
    ]
  },
  {
    "nombre": "Producción",
    "slug": "paquete-produccion",
    "precio": 12000,
    "imagen": "/img/paquetes/cascadas-led/produccion.avif",
    "badge": "",
    "features": [
      "8+ cortinas LED 3x3m",
      "Luz multicolor RGBW",
      "Instalación profesional",
      "Estructura de montaje",
      "Controlador DMX",
      "Diseño personalizado",
      "Técnico operador"
    ]
  }
];

const faqItems = [
  {
    "pregunta": "¿Cuánto cuesta la renta de cascadas led en CDMX?",
    "respuesta": "Los precios de cascadas led van desde $2,000 MXN hasta $12,000 MXN + IVA, dependiendo del paquete. Todos incluyen instalación profesional y desmontaje."
  },
  {
    "pregunta": "¿Qué paquetes de cascadas led ofrecen?",
    "respuesta": "Ofrecemos 4 paquetes: 1 Cortina, 2 Cortinas, 4 Cortinas, Producción. Cada uno está diseñado para diferentes tamaños de evento y presupuesto."
  },
  {
    "pregunta": "¿La instalación de cascadas led está incluida?",
    "respuesta": "Sí, todos nuestros paquetes de cascadas led incluyen transporte, instalación profesional, operación durante el evento y desmontaje. No hay costos ocultos."
  },
  {
    "pregunta": "¿En qué tipo de eventos se usa cascadas led?",
    "respuesta": "Cascadas LED es popular en bodas, XV años, fiestas de cumpleaños, eventos corporativos, conferencias y celebraciones privadas. Adaptamos cada paquete al tipo de evento."
  },
  {
    "pregunta": "¿Cubren servicio de cascadas led en Estado de México?",
    "respuesta": "Sí, cubrimos CDMX y todo el Estado de México. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km sin costo adicional."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar cascadas led?",
    "respuesta": "Recomendamos reservar con 4-6 semanas de anticipación, especialmente en temporada alta. Para fechas próximas, escríbenos por WhatsApp al 55 4937 5172."
  },
  {
    "pregunta": "¿Puedo combinar cascadas led con otros servicios?",
    "respuesta": "Por supuesto. Ofrecemos descuentos especiales al combinar servicios de iluminación, audio y equipos. Diseñamos paquetes integrales a la medida de tu evento."
  },
  {
    "pregunta": "¿Qué marcas de equipo usan para cascadas led?",
    "respuesta": "Trabajamos con marcas líderes como JBL, QSC, Martin Professional, Chauvet y Elation. Nuestro inventario se actualiza constantemente para ofrecer la mejor tecnología disponible."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Renta de Cascadas LED — REDEIL',
    description: 'Cortinas de luces LED tipo cascada para decoración de salones y jardines.',
    provider: {
      '@type': 'LocalBusiness',
      name: 'REDEIL',
      url: SITE_URL,
    },
    areaServed: { '@type': 'City', name: 'Ciudad de México' },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Paquetes de Cascadas LED',
      itemListElement: paquetes.map(p => ({
        '@type': 'Offer',
        name: p.nombre,
        price: p.precio,
        priceCurrency: 'MXN',
        url: SITE_URL + '/renta-de-iluminacion/cascadas-led/' + p.slug + '/',
      })),
    },
  },
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Renta de Iluminación', url: '/renta-de-iluminacion/' },
    { name: 'Cascadas LED', url: '/renta-de-iluminacion/cascadas-led/' },
  ]),
  faqSchema(faqItems),
];
---

<Base
  title="Renta de Cascadas LED para Eventos en CDMX | REDEIL"
  description="Cortinas de luces LED tipo cascada para decoración de salones y jardines. 4 paquetes desde $2,000 MXN. Instalación profesional incluida en CDMX y EdoMex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cascadas LED', href: '/renta-de-iluminacion/cascadas-led/' }]} />

  <Hero
    badge="Renta de Cascadas LED"
    title="Renta de Cascadas LED para Eventos en CDMX"
    description="Cortinas de luces LED tipo cascada para decoración de salones y jardines. Ofrecemos 4 paquetes profesionales con instalación incluida para bodas, XV año..."
    primaryCta={{ text: 'Cotizar Cascadas LED', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver Paquetes', href: '#paquetes' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>renta de cascadas led</strong> es uno de los servicios más solicitados en <strong>REDEIL</strong>. Cortinas de luces LED tipo cascada para decoración de salones y jardines. Cada paquete incluye transporte, instalación profesional, operación durante el evento y desmontaje en <strong>CDMX y Estado de México</strong>.</p>
      <p>Con más de 10 años de experiencia, hemos llevado cascadas led a cientos de <strong>bodas, XV años, fiestas privadas y eventos corporativos</strong>. Trabajamos con equipo de marcas líderes y un equipo técnico capacitado que garantiza resultados impecables en cada evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Elige tu paquete de Cascadas LED"
    items={paquetes.map(p => ({
      label: p.nombre,
      href: '/renta-de-iluminacion/cascadas-led/' + p.slug + '/',
    }))}
  />

  

  <!-- PAQUETES -->
  <section class="section" id="paquetes">
    <div class="container">
      <SectionHeader
        badge="4 paquetes de cascadas"
        title="¿Cuánto cuesta rentar cascadas LED?"
        subtitle="Desde una sola cortina para un rincón fotográfico hasta una producción completa que envuelve todo el espacio en luz. Cada cortina mide entre 6 y 20 metros de largo y cae creando un efecto de lluvia de luz que transforma cualquier pared o estructura."
        subtitle2="Todos los paquetes incluyen transporte, instalación profesional con estructura, operación durante el evento y desmontaje. Sin costos ocultos — lo que cotizamos es lo que pagas."
        id="paquetes-title"
      />
      <div class="pkg-grid">
        {paquetes.map((p: any) => (
          <article class={`pkg ${p.badge ? 'pkg--featured' : ''}`}>
            <div class="pkg__img-wrap">
              <img src={p.imagen} alt={p.nombre} width="600" height="400" loading="lazy" class="pkg__img" />
              {p.badge && <span class="pkg__badge">{p.badge}</span>}
            </div>
            <div class="pkg__body">
              <h3 class="pkg__name">{p.nombre}</h3>
              <div class="pkg__pricing">
                <span class="pkg__amount">${p.precio.toLocaleString()}</span>
                <span class="pkg__tax">MXN + IVA</span>
              </div>
              <ul class="pkg__features">
                {p.features.map((f: string) => (
                  <li>{f}</li>
                ))}
              </ul>
              <a href={'/renta-de-iluminacion/cascadas-led/' + p.slug + '/'} class="pkg__cta">
                Cotizar este paquete
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- LA DIFERENCIA -->
  <section class="section section--bg">
    <div class="container">
      <SectionHeader
        badge="El efecto wow"
        title="¿Por qué las cascadas LED son el fondo fotográfico más solicitado?"
        subtitle="Hay un momento en cada boda donde los invitados sacan el celular y empiezan a tomarse fotos. Las cascadas LED crean ese momento. Una pared de cientos de luces LED cayendo como lluvia genera un fondo que no necesita filtros ni edición — cada foto sale espectacular."
        subtitle2="No es decoración genérica. Es el elemento que define cómo se van a ver TODAS las fotos de tu evento. Por eso las cascadas LED son lo segundo más solicitado después de las guirnaldas. Y a diferencia de un photobooth, funcionan toda la noche sin necesitar operador."
        id="diferencia-title"
      />
      <div class="sell__grid">
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cascadas-led/sell/backdrop.avif" alt="Cascada LED como fondo fotográfico en boda" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Fondo fotográfico perfecto</h3>
            <p class="sell__card-desc">Las cascadas crean el backdrop que todas las novias buscan. Cientos de LEDs cayendo como lluvia detrás de la mesa principal generan fotos que parecen sacadas de revista. Sin filtros, sin edición.</p>
          </div>
        </div>
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cascadas-led/sell/efecto-lluvia.avif" alt="Efecto lluvia de luz LED cascada" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Efecto lluvia de luz</h3>
            <p class="sell__card-desc">Cada cortina tiene cientos de LEDs programados para encenderse en secuencia, simulando gotas de agua cayendo. El efecto es hipnótico — tus invitados no van a dejar de mirarlo. Velocidad ajustable con dimmer.</p>
          </div>
        </div>
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cascadas-led/sell/exterior.avif" alt="Cascada LED para exteriores certificación IP65" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">IP65 para exteriores</h3>
            <p class="sell__card-desc">¿Tu evento es en jardín? No hay problema. Nuestras cascadas LED tienen certificación IP65 — funcionan con humedad, rocío y hasta lluvia ligera. Hemos montado cascadas en jardines de Cuernavaca, terrazas en Polanco y patios en Valle de Bravo.</p>
          </div>
        </div>
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cascadas-led/sell/control.avif" alt="Control DMX dimmer para cascadas LED" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Control total de efectos</h3>
            <p class="sell__card-desc">Nuestro técnico controla velocidad, brillo y patrón de la cascada en tiempo real. Ceremonia con efecto suave y lento, cena con brillo estable, fiesta con cascada rápida y dinámica. Cada momento tiene su propio efecto.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ZONAS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Cobertura"
        title="¿Dónde instalamos cascadas LED en CDMX?"
        subtitle="Cubrimos las 16 alcaldías de la Ciudad de México y los principales municipios del Estado de México. Las cascadas LED son especialmente populares en haciendas y jardines donde las paredes naturales de árboles o estructuras de madera sirven como soporte."
        subtitle2="Nuestro equipo hace visita técnica previa para verificar puntos de anclaje, tomas de corriente y la distribución óptima de las cortinas en tu espacio."
        id="zonas-title"
      />
      <div class="zonas-grid">
        <a href="/zonas/polanco/" class="zona-card"><span class="zona-card__name">Polanco</span><span class="zona-card__desc">Terrazas y hoteles</span></a>
        <a href="/zonas/condesa/" class="zona-card"><span class="zona-card__name">Condesa</span><span class="zona-card__desc">Foros y jardines</span></a>
        <a href="/zonas/santa-fe/" class="zona-card"><span class="zona-card__name">Santa Fe</span><span class="zona-card__desc">Salones corporativos</span></a>
        <a href="/zonas/coyoacan/" class="zona-card"><span class="zona-card__name">Coyoacán</span><span class="zona-card__desc">Jardines y haciendas</span></a>
        <a href="/zonas/san-angel/" class="zona-card"><span class="zona-card__name">San Ángel</span><span class="zona-card__desc">Casas privadas</span></a>
        <a href="/zonas/interlomas/" class="zona-card"><span class="zona-card__name">Interlomas</span><span class="zona-card__desc">Residenciales</span></a>
        <a href="/zonas/naucalpan/" class="zona-card"><span class="zona-card__name">Naucalpan</span><span class="zona-card__desc">Salones y jardines</span></a>
        <a href="/zonas/tlalnepantla/" class="zona-card"><span class="zona-card__name">Tlalnepantla</span><span class="zona-card__desc">Eventos y haciendas</span></a>
      </div>
      <div class="zonas-cta"><a href="/zonas/" class="zonas-cta__link">Ver las 30 zonas de cobertura →</a></div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas Frecuentes"
        subtitle="Las dudas más comunes sobre renta de cascadas LED para eventos en CDMX. Precios, instalación, exteriores y tiempos de montaje."
        subtitle2="Si no encuentras tu respuesta, escríbenos por WhatsApp al 55 4937 5172 y te asesoramos sin compromiso."
        id="faq-title"
      />
    </div>
    <FaqSection items={faqItems} />
  </section>


  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .pkg-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
  }
  .pkg-card__header {
    padding: 1.5rem;
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
  }
  .pkg-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .pkg-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
  }
  .pkg-card__amount {
    font-size: var(--font-size-2xl);
    font-weight: 800;
  }
  .pkg-card__currency {
    font-size: var(--font-size-sm);
    opacity: 0.8;
  }
  .pkg-card__features {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
  }
  .pkg-card__feature {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--color-bg);
  }
  .pkg-card__feature:last-child {
    border-bottom: none;
  }
  .pkg-card__btn {
    display: block;
    margin: 0 1.5rem 1.5rem;
    padding: 0.875rem;
    text-align: center;
    font-size: var(--font-size-sm);
    font-weight: 600;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: background 0.2s;
  }
  .pkg-card__btn:hover {
    background: var(--color-accent-dark);
  }
  .content-prose {
    max-width: 800px;
    margin: 0 auto;
  }
  .content-prose h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .content-prose h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }
  .content-prose p {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .zonas-servicio {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-sm);
  }
  .zonas-servicio .zona-link,
  .zona-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 600;
    font-size: var(--font-size-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .zona-link:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }
</style>
