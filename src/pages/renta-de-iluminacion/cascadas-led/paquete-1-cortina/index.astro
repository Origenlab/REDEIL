---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 1 Cortina de Cascadas LED?',
    respuesta: 'Incluye 1 cortina LED de 3×3 metros, controlador con efectos de lluvia y estático, cable y conectores profesionales, transporte, instalación, técnico operador durante el evento y desmontaje al finalizar. Todo listo para crear un fondo impactante en tu evento.'
  },
  {
    pregunta: '¿Cuánto cuesta la renta de 1 cortina de cascadas LED?',
    respuesta: 'El paquete tiene un precio desde $2,000 MXN + IVA. Incluye todo: traslado, instalación, operación y desmontaje dentro de CDMX y Estado de México. Sin cargos ocultos ni sorpresas de último momento.'
  },
  {
    pregunta: '¿Para qué espacios es ideal 1 cortina de cascadas LED?',
    respuesta: 'Es perfecta para fondos de mesa principal, photobooth, arco de ceremonia o zona de fotos. Una cortina de 3×3m crea un telón de luz impresionante que transforma cualquier esquina en el punto focal del evento.'
  },
  {
    pregunta: '¿Puedo cambiar los efectos durante el evento?',
    respuesta: 'Sí. El controlador incluido permite cambiar entre efecto lluvia (luz que cae), estático (brillo fijo) y pulso (fade suave). Nuestro técnico ajusta el efecto según el momento del evento: ceremonia, cena o baile.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar la cortina de cascadas LED?',
    respuesta: 'Recomendamos reservar con 2 a 4 semanas de anticipación. En temporada alta (noviembre a febrero) y fines de semana de gran demanda, te conviene apartar con más tiempo. Contáctanos por WhatsApp para verificar disponibilidad.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Paquete 1 Cortina — Cascadas LED | REDEIL',
    description: 'Renta de 1 cortina de cascadas LED 3×3m para bodas y eventos en CDMX. Efecto lluvia de luz perfecto para fondos de mesa principal y photobooth. Instalación profesional incluida.',
    image: SITE_URL + '/img/paquetes/cascadas-led/paquete-1-cortina.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cascadas-led/paquete-1-cortina/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Paquete 1 Cortina — Cascadas LED en CDMX | REDEIL"
  description="Renta de 1 cortina de cascadas LED 3×3m para bodas y eventos. Fondo de mesa principal o photobooth con efecto lluvia de luz. Instalación profesional en CDMX y Edomex desde $2,000."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cascadas LED', href: '/renta-de-iluminacion/cascadas-led/' }, { name: 'Paquete 1 Cortina', href: '/renta-de-iluminacion/cascadas-led/paquete-1-cortina/' }]} />

  <Hero
    badge="Paquete 1 Cortina"
    title="Paquete 1 Cortina — Cascadas LED para Eventos"
    description="Una cortina LED de 3×3m que transforma tu mesa principal o photobooth en el punto focal de tu evento. Efecto lluvia de luz con controlador de efectos incluido. CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $2,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cascadas-led/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete 1 Cortina de Cascadas LED</strong> es la entrada perfecta al mundo de la iluminación de cortinas para bodas y eventos en <strong>CDMX y Estado de México</strong>. Una sola cortina de 3×3 metros basta para crear un telón de luz que convierte tu mesa principal o zona de fotos en algo verdaderamente memorable.</p>
      <p>Con el controlador incluido, alternarás entre efecto lluvia de luz, brillo estático y pulso suave según el momento del evento. Nuestro técnico opera todo durante la celebración para que tú solo disfrutes. Instalación, operación y desmontaje incluidos en el precio.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cascadas LED"
    items={[{ label: "2 Cortinas", href: "/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/" }, { label: "4 Cortinas", href: "/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" }, { label: "Producción", href: "/renta-de-iluminacion/cascadas-led/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/cascadas-led/paquete-1-cortina.avif" alt="Paquete 1 cortina cascadas LED fondo mesa principal boda" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cascadas-led.avif" alt="Cascadas LED efecto lluvia de luz en evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/backdrop.avif" alt="Cortina LED como fondo de photobooth" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/efecto-lluvia.avif" alt="Efecto lluvia cascadas LED en boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/control.avif" alt="Controlador de efectos cascadas LED" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Entrada — El más accesible</span>
            <h2 class="prod-info__title">1 Cortina LED 3×3m con Controlador de Efectos</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, controlador, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Un solo telón de luz que transforma tu evento entero</h2>
            <p class="prod-selling__intro">Una cortina LED de 3×3 metros es todo lo que necesitas para crear el elemento visual más impactante de tu boda o evento. Colgada detrás de la mesa principal o en la zona de fotos, convierte cualquier espacio en un escenario de película. El efecto lluvia de luz hace que cada foto sea cinematográfica sin importar la cámara que use el fotógrafo.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Fondo de mesa principal o photobooth instantáneo</h3>
                  <p class="prod-hl__desc">3×3 metros de cortina LED crean un fondo perfecto para la mesa de los novios, el área de brindis o la zona de fotos. Todas las fotos y videos desde esa posición quedan con un telón luminoso espectacular.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">3 efectos en un controlador — lluvia, estático y pulso</h3>
                  <p class="prod-hl__desc">El controlador incluido te da tres modos: efecto cascada donde la luz cae como lluvia, modo estático para brillo continuo elegante, y pulso suave para transiciones de ambiente. Un técnico los opera en tiempo real.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Instalación limpia sin dañar el venue</h3>
                  <p class="prod-hl__desc">Nuestra instalación no requiere perforar paredes ni estructuras fijas. Usamos soportes y tensores profesionales que se montan sin daño alguno. Al finalizar, desmontamos sin rastro. Cualquier salón nos autoriza al instante.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Fotogénico por diseño — luz que las cámaras aman</h3>
                  <p class="prod-hl__desc">Los LEDs de la cortina tienen temperatura de color optimizada para fotografía. A diferencia de otras luces que saturan o planchan las fotos, la cascada LED crea un bokeh de luz que hace que los retratos contra el fondo sean excepcionales.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 cortina LED cascada 3×3 metros</div>
              <div class="prod-feat">Controlador de efectos (lluvia/estático/pulso)</div>
              <div class="prod-feat">Cable y conectores profesionales</div>
              <div class="prod-feat">Soporte y estructura de montaje</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Prueba de encendido previa al evento</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos dónde va la cortina</h4>
                  <p class="prod-step__desc">Fecha, salón o venue, y dónde quieres instalar la cortina: mesa principal, arco, photobooth. Si tienes fotos del lugar, mándalas para diseñar la instalación exacta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización en menos de 24 horas</h4>
                  <p class="prod-step__desc">Te enviamos propuesta con precio final, layout de instalación y opciones de combinación con otros equipos. Sin compromiso ni letras pequeñas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada con el anticipo. Aceptamos transferencia, efectivo o tarjeta. Confirmación inmediata por escrito en WhatsApp.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y operamos</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes para instalar y hacer pruebas. Durante el evento, el técnico opera los efectos según la agenda. Al terminar, desmontamos todo sin que tengas que preocuparte por nada.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿1 cortina o 2 cortinas?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sin cascadas LED</span>
                <ul class="prod-compare__list">
                  <li>Fondo de mesa sin impacto visual</li>
                  <li>Fotos planas sin elemento focal</li>
                  <li>Solo luces del salón</li>
                  <li>Un ambiente durante todo el evento</li>
                  <li>Photobooth sin backdrop luminoso</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Paquete 1 Cortina</span>
                <ul class="prod-compare__list">
                  <li>Telón de luz impactante para fotos</li>
                  <li>Punto focal del evento creado</li>
                  <li>3 efectos según el momento</li>
                  <li>Ambiente dinámico con 1 elemento</li>
                  <li>Backdrop luminoso espectacular</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Pusimos la cortina cascada LED detrás de la mesa de los novios y fue lo más comentado de la boda. Todos querían tomarse fotos ahí. Nuestro fotógrafo decía que nunca había visto un fondo tan impactante. Con un presupuesto ajustado, fue la mejor inversión visual del evento."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Paola y Roberto</span>
                <span class="prod-quote__event">Boda en salón del Valle de México — 70 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cortinas incluidas</dt><dd>1 cortina</dd></div>
              <div class="ps-specs__row"><dt>Dimensiones</dt><dd>3×3 metros</dd></div>
              <div class="ps-specs__row"><dt>Efectos</dt><dd>Lluvia / Estático / Pulso</dd></div>
              <div class="ps-specs__row"><dt>Controlador</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Uso ideal</dt><dd>Interior y exterior cubierto</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Fondo mesa principal</span>
              <span class="ps-tag">Photobooth</span>
              <span class="ps-tag">Arco de ceremonia</span>
              <span class="ps-tag">Zona de fotos</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Fiestas temáticas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-2-cortinas.avif" alt="Paquete 2 Cortinas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Cortinas</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-4-cortinas.avif" alt="Paquete 4 Cortinas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cortinas</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/produccion.avif" alt="Paquete Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres cubrir mesa principal y pista de baile? El paquete de 2 cortinas lo hace posible.</p>
              <a href="/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/" class="ps-upsell__link">Ver paquete 2 Cortinas →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Luces Arquitectónicas</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
