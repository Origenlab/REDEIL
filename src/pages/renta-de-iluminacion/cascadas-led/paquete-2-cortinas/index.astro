---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 2 Cortinas de Cascadas LED?',
    respuesta: 'Incluye 2 cortinas LED de 3×3 metros cada una, controlador con 3 efectos (cascada, estático y pulso), cables y conectores profesionales, soporte de montaje, transporte, instalación, técnico operador durante el evento y desmontaje. Puedes ubicar cada cortina en zonas distintas del mismo salón.'
  },
  {
    pregunta: '¿Cuánto cuesta la renta de 2 cortinas de cascadas LED?',
    respuesta: 'El paquete tiene un precio desde $3,500 MXN + IVA. Incluye traslado, instalación en dos puntos del venue, operación por técnico y desmontaje dentro de CDMX y Estado de México. Precio cerrado sin sorpresas.'
  },
  {
    pregunta: '¿Puedo poner las 2 cortinas en zonas diferentes del salón?',
    respuesta: 'Sí. La configuración más popular es una cortina detrás de la mesa principal y otra sobre la pista de baile. También puedes colocarlas en el arco de ceremonia y el photobooth, o en dos extremos del salón para crear profundidad visual completa.'
  },
  {
    pregunta: '¿Se pueden programar efectos distintos en cada cortina?',
    respuesta: 'Con el controlador incluido, ambas cortinas operan en sincronía o de forma independiente según el momento. Nuestro técnico coordina los efectos para que la transición entre zonas del evento sea fluida y con impacto visual máximo.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete 2 cortinas?',
    respuesta: 'Recomendamos reservar con 3 a 5 semanas de anticipación para garantizar disponibilidad en tu fecha. Los fines de semana de mayo a octubre son temporada alta de bodas en CDMX. Escríbenos por WhatsApp y revisamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Paquete 2 Cortinas — Cascadas LED | REDEIL',
    description: 'Renta de 2 cortinas de cascadas LED 3×3m para bodas y eventos en CDMX. Cubre mesa principal y pista de baile con efectos cascada, estático y pulso. Instalación profesional incluida.',
    image: SITE_URL + '/img/paquetes/cascadas-led/paquete-2-cortinas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '35',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Paquete 2 Cortinas — Cascadas LED en CDMX | REDEIL"
  description="Renta de 2 cortinas de cascadas LED 3×3m para bodas en CDMX. Mesa principal y pista de baile con efectos lluvia, estático y pulso. Instalación profesional desde $3,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cascadas LED', href: '/renta-de-iluminacion/cascadas-led/' }, { name: 'Paquete 2 Cortinas', href: '/renta-de-iluminacion/cascadas-led/paquete-2-cortinas/' }]} />

  <Hero
    badge="Paquete 2 Cortinas"
    title="Paquete 2 Cortinas — Cascadas LED para Bodas"
    description="Dos cortinas LED de 3×3m para cubrir mesa principal y pista de baile. Efectos de cascada, estático y pulso controlados en tiempo real. El paquete favorito para bodas en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cascadas-led/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Paquete 2 Cortinas de Cascadas LED</strong> es el más solicitado para <strong>bodas en CDMX y Estado de México</strong>. Dos cortinas de 3×3 metros te permiten tener presencia visual en los dos momentos más fotografiados: la mesa de los novios y la pista de baile. Cuando comienza el baile y las cascadas entran en modo lluvia, el salón completo reacciona.</p>
      <p>Los tres efectos disponibles — cascada de luz que cae, brillo estático y pulso suave — los opera nuestro técnico en tiempo real para que la iluminación acompañe cada momento del evento. Instalación, operación y desmontaje incluidos sin costo adicional.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cascadas LED"
    items={[{ label: "1 Cortina", href: "/renta-de-iluminacion/cascadas-led/paquete-1-cortina/" }, { label: "4 Cortinas", href: "/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" }, { label: "Producción", href: "/renta-de-iluminacion/cascadas-led/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/cascadas-led/paquete-2-cortinas.avif" alt="Paquete 2 cortinas cascadas LED mesa principal y pista de baile boda" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cascadas-led.avif" alt="Cascadas LED efecto lluvia de luz en boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/efecto-lluvia.avif" alt="Efecto lluvia cascadas LED pista de baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/backdrop.avif" alt="Cortina LED detrás de mesa principal" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/cascadas-led/sell/control.avif" alt="Control de efectos cascadas LED en evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Estándar — El favorito para bodas</span>
            <h2 class="prod-info__title">2 Cortinas LED 3×3m con 3 Efectos — Mesa + Pista de Baile</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación en 2 puntos, controlador, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Dos momentos únicos del evento, dos fondos espectaculares</h2>
            <p class="prod-selling__intro">En una boda hay dos momentos que todos fotografían: la mesa de los novios y la pista de baile. Con dos cortinas LED, ambos puntos tienen un telón de luz impresionante. Las fotos de la cena tienen un fondo de cascada brillante; las fotos del baile tienen luz que fluye y cae como lluvia. Dos experiencias visuales completamente distintas con un solo paquete.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mesa principal + pista de baile — los dos puntos más fotografiados</h3>
                  <p class="prod-hl__desc">Una cortina detrás de la mesa de los novios crea el fondo de las fotos formales. La segunda sobre la pista de baile transforma ese espacio cuando empieza la música. Dos zonas del evento transformadas con dos elementos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">3 efectos para cada momento del evento</h3>
                  <p class="prod-hl__desc">Efecto cascada para el baile y la fiesta. Brillo estático para la cena y los discursos. Pulso suave para las entradas y momentos especiales. El técnico cambia entre efectos según la agenda sin que tengas que pedir nada.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Instalación coordinada en dos puntos del venue</h3>
                  <p class="prod-hl__desc">Nuestro equipo instala ambas cortinas de forma coordinada, verificando que la distribución de carga eléctrica sea correcta y que el tendido de cables sea invisible. Los dos puntos quedan listos antes de que lleguen los invitados.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El momento del primer baile se vuelve cinematográfico</h3>
                  <p class="prod-hl__desc">Cuando los novios entran a la pista y la cortina cambia a efecto lluvia, cada hilo de luz cae suavemente alrededor de ellos. Es uno de esos momentos que los invitados no olvidan y que el fotógrafo y el videógrafo agradecen.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 cortinas LED cascada 3×3 metros c/u</div>
              <div class="prod-feat">Controlador con 3 efectos: cascada/estático/pulso</div>
              <div class="prod-feat">Cable y conectores profesionales</div>
              <div class="prod-feat">Soportes y estructura de montaje</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación en 2 puntos del venue</div>
              <div class="prod-feat">Técnico operador durante todo el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Prueba de encendido previa al evento</div>
              <div class="prod-feat">Coordinación con el venue incluida</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte los detalles y el layout del venue</h4>
                  <p class="prod-step__desc">Fecha, nombre del salón o venue, y en qué puntos quieres instalar las cortinas. Si tienes el plano del espacio o fotos, úsalos para diseñar la distribución óptima.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta detallada en menos de 24 horas</h4>
                  <p class="prod-step__desc">Recibirás layout de instalación, precio final y opciones para combinar con otros servicios como uplighting o guirnaldas. Sin costos ocultos ni letra pequeña.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con anticipo del 50%</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada de inmediato. Puedes pagar por transferencia, efectivo o tarjeta. Confirmación escrita por WhatsApp al momento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y manejamos los efectos</h4>
                  <p class="prod-step__desc">Llegamos 2.5 horas antes para instalar ambas cortinas, configurar el controlador y hacer pruebas. El técnico opera los efectos durante toda la celebración y desmonta todo al terminar.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 2 cortinas y no solo 1?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 1 Cortina</span>
                <ul class="prod-compare__list">
                  <li>Un solo punto visual cubierto</li>
                  <li>Mesa principal o pista, no ambas</li>
                  <li>Fotógrafo limitado a una zona</li>
                  <li>Impacto concentrado en un área</li>
                  <li>Ideal para eventos pequeños</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Paquete 2 Cortinas</span>
                <ul class="prod-compare__list">
                  <li>Mesa principal y pista cubiertos</li>
                  <li>Los dos momentos más fotografiados</li>
                  <li>Fotos espectaculares en todo el evento</li>
                  <li>Impacto visual en todo el salón</li>
                  <li>Perfecto para bodas de 60-150 personas</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Pusimos una cortina en la mesa principal y otra en la pista. Durante la cena, la de la mesa estaba en modo estático y se veía elegantísimo. Cuando empezó el baile, las dos encendieron en cascada y el salón se transformó por completo. Nuestra videógrafa dijo que fue la boda mejor iluminada que había filmado en el año."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Claudia y Marcos</span>
                <span class="prod-quote__event">Boda en Salón Versalles CDMX — 110 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cortinas incluidas</dt><dd>2 cortinas</dd></div>
              <div class="ps-specs__row"><dt>Dimensiones c/u</dt><dd>3×3 metros</dd></div>
              <div class="ps-specs__row"><dt>Efectos</dt><dd>Cascada / Estático / Pulso</dd></div>
              <div class="ps-specs__row"><dt>Controlador</dt><dd>1 (sincronizado)</dd></div>
              <div class="ps-specs__row"><dt>Puntos instalación</dt><dd>2 zonas del venue</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas 60-150 personas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Mesa + pista de baile</span>
              <span class="ps-tag">Ceremonias + recepción</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Salones medianos</span>
              <span class="ps-tag">Haciendas</span>
              <span class="ps-tag">Eventos gala</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-1-cortina/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-1-cortina.avif" alt="Paquete 1 Cortina" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">1 Cortina</span>
                <span class="ps-pkg__price">$2,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/paquete-4-cortinas.avif" alt="Paquete 4 Cortinas" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cortinas</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cascadas-led/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/cascadas-led/produccion.avif" alt="Paquete Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$12,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres cubrir el salón completo? El paquete de 4 cortinas con controlador profesional lo hace a otro nivel.</p>
              <a href="/renta-de-iluminacion/cascadas-led/paquete-4-cortinas/" class="ps-upsell__link">Ver paquete 4 Cortinas →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Luces Arquitectónicas</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
