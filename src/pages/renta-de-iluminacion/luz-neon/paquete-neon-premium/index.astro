---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Neón Premium de Luz Neón LED?',
    respuesta: 'Incluye letreros neón custom con texto o diseño personalizado, barras neón LED completas para ambientación del salón, luz UV full para cobertura total, instalación profesional, técnico durante el evento y desmontaje. Es la producción neón media: diseño personalizado sin llegar a la producción completa con DMX.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Neón Premium?',
    respuesta: 'El paquete Neón Premium tiene un precio desde $9,200 MXN + IVA. Incluye transporte, instalación, letreros custom, barras neón completas, UV full y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Cómo funciona la personalización de letreros en el paquete Neón Premium?',
    respuesta: 'En el paquete Neón Premium los letreros son 100% personalizados: texto, fuente, color y tamaño. El proceso requiere 10-15 días para fabricación. Enviamos render de aprobación antes de fabricar. El diseño queda listo para tu evento con garantía de que se verá exactamente como aprobaste.'
  },
  {
    pregunta: '¿Para cuántos invitados está diseñado el paquete Neón Premium?',
    respuesta: 'El paquete Neón Premium está diseñado para eventos de 150 a 300 invitados en salón grande. El equipo cubre área de baile, zona de mesas y pasillo de entrada. Para eventos mayores a 300 invitados o festivales, recomendamos el paquete Producción Neón con control DMX.'
  },
  {
    pregunta: '¿El paquete Neón Premium funciona para eventos corporativos?',
    respuesta: 'Sí. El Neón Premium es ideal para lanzamientos de producto, eventos corporativos y galas donde necesitas identidad visual fuerte. Los letreros con el nombre de la empresa o producto, más la ambientación neón completa, crean una experiencia de marca memorable. Trabajamos con brief de branding si lo tienes.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Neón Premium — Luz Neón LED Custom para Bodas y Eventos | REDEIL',
    description: 'Letreros neón LED custom + barras neón completas + UV full para bodas, eventos corporativos y galas en CDMX. Paquete Neón Premium desde $9,200 MXN con instalación incluida.',
    image: SITE_URL + '/img/paquetes/luz-neon/neon-premium.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '9200',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-neon/paquete-neon-premium/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '27',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Neón Premium — Letreros Custom + Barras Neón LED CDMX | REDEIL"
  description="Letreros neón custom + barras neón completas + UV full para bodas modernas, eventos corporativos y galas en CDMX. Paquete Neón Premium desde $9,200 MXN con instalación."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Neón LED', href: '/renta-de-iluminacion/luz-neon/' }, { name: 'Neón Premium', href: '/renta-de-iluminacion/luz-neon/paquete-neon-premium/' }]} />

  <Hero
    badge="Neón Premium — Producción media"
    title="Neón Premium — Letreros Custom + Barras Neón Completas + UV Full para Salones Grandes"
    description="Producción neón de nivel intermedio para eventos de 150-300 invitados. Letreros 100% custom con tu texto, barras neón para ambientación completa del salón y UV full. Bodas modernas, corporativos y galas en CDMX."
    primaryCta={{ text: 'Cotizar $9,200 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-neon/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Neón Premium</strong> es la producción neón de nivel intermedio para eventos grandes en <strong>CDMX y Estado de México</strong>. No es solo un letrero en una pared — es ambientación neón completa: barras LED que crean líneas de luz en columnas, esquinas y techos, UV full que activa todos los elementos blancos y fluorescentes del salón, y letreros 100% personalizados con el texto exacto que quieres.</p>
      <p>Para bodas modernas donde los novios quieren un letrero con su apellido unido, para lanzamientos corporativos donde el nombre del producto brilla en neón, para galas donde la estética neón define la identidad visual del evento. 150-300 invitados, salón grande, producción completa sin llegar al nivel DMX.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Neón LED"
    items={[{ label: "UV Básico — Letreros neón", href: "/renta-de-iluminacion/luz-neon/paquete-uv-basico/" }, { label: "Glow Party — Neón + UV + pintura", href: "/renta-de-iluminacion/luz-neon/paquete-glow-party/" }, { label: "Producción Neón — DMX total", href: "/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-neon/neon-premium.avif" alt="Paquete Neón Premium con letreros custom y barras neón en boda moderna CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-neon.avif" alt="Letreros neón custom en evento corporativo CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/barras-neon.avif" alt="Barras de luz neón LED en columnas de salón de bodas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/letrero-amor.avif" alt="Letrero neón custom con nombre de pareja en boda moderna" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/neon-detalle.avif" alt="Detalle producción neón premium en gala corporativa" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Neón Premium — Producción media, impacto total</span>
            <h2 class="prod-info__title">Letreros Neón 100% Custom + Barras LED + UV Full para Eventos de 150-300 Personas</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$9,200</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, letreros custom, barras neón, UV full, instalación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">El salón que se transforma — de espacio a experiencia neón</h2>
            <p class="prod-selling__intro">Hay una diferencia enorme entre poner un letrero neón en un rincón y producir un ambiente neón completo. El Neón Premium hace lo segundo: barras LED que corren por columnas y bordes del techo, UV que activa los elementos blancos del salón, y letreros personalizados que crean los puntos de referencia visual del evento. El resultado es que los invitados no solo "ven" la decoración — están dentro de ella.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Letreros 100% custom — tu texto, tu fuente, tu color</h3>
                  <p class="prod-hl__desc">No hay opciones de catálogo que se adapten a lo que necesitas — fabricamos el letrero exacto. Texto libre, tipografía a elegir, color que combine con la paleta del evento. Enviamos render de aprobación digital antes de fabricar para que veas exactamente cómo se va a ver antes del día del evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Barras neón completas — ambientación arquitectónica del espacio</h3>
                  <p class="prod-hl__desc">Las barras de tubo neón LED se instalan en columnas, bordes de techo, detrás de la mesa principal y en pasillos. Crean líneas de luz continuas que redefinen la geometría del espacio. No es decoración puntual — es rediseño visual completo del salón usando neón como material arquitectónico.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">UV full — el salón completo bajo efecto fluorescente</h3>
                  <p class="prod-hl__desc">La cobertura UV full significa que el efecto fluorescente llega a todo el salón, no solo al área de baile. Manteles blancos, vestidos de novia, camisas blancas de los invitados, flores blancas en las mesas — todo brilla bajo la luz negra. El ambiente es inmersivo y uniforme desde cualquier punto del salón.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura para 150-300 invitados — salón grande sin zonas muertas</h3>
                  <p class="prod-hl__desc">El equipo y la cantidad de barras están calibrados para salones grandes de CDMX. El técnico hace scouting del espacio antes del evento y diseña la distribución para que no haya zonas donde el efecto no llegue. 300 invitados, todos dentro del ambiente neón.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Letreros neón custom (texto libre)</div>
              <div class="prod-feat">Barras neón LED completas</div>
              <div class="prod-feat">Luz UV full cobertura salón</div>
              <div class="prod-feat">Render digital de aprobación</div>
              <div class="prod-feat">Soportes y sistema de montaje</div>
              <div class="prod-feat">Cable y conexiones profesionales</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Brief de diseño — texto, fuente y color</h4>
                  <p class="prod-step__desc">Nos compartes el texto exacto, el estilo tipográfico y el color que quieres para los letreros. También el tipo de evento y las dimensiones del salón para dimensionar las barras neón y la cobertura UV.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Render y aprobación</h4>
                  <p class="prod-step__desc">En 48 horas enviamos render digital del letrero para aprobación. Una vez aprobado, arranca fabricación. El tiempo de producción es de 10-15 días antes del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Scouting y planeación de distribución</h4>
                  <p class="prod-step__desc">El técnico visita el salón con anticipación para planear la ubicación exacta de barras neón, posicionamiento de letreros y puntos de conexión UV. Llegamos el día del evento con el plan ejecutado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación, operación y desmontaje</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes del evento, instalamos todo el equipo según el plan, hacemos prueba completa del efecto y permanecemos durante el evento para ajustes. Al terminar, desmontamos sin dejar rastro.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Glow Party o Neón Premium?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Glow Party — Fiesta temática</span>
                <ul class="prod-compare__list">
                  <li>80-150 invitados</li>
                  <li>Neón + UV + pintura glow</li>
                  <li>Letreros de catálogo o básicos</li>
                  <li>Experiencia glow interactiva</li>
                  <li>Para XV años y cumpleaños</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Neón Premium — Producción media</span>
                <ul class="prod-compare__list">
                  <li>150-300 invitados</li>
                  <li>Letreros 100% custom con render</li>
                  <li>Barras neón arquitectónicas</li>
                  <li>Producción visual de alto impacto</li>
                  <li>Para bodas, corporativos, galas</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Para nuestro lanzamiento de producto elegimos el Neón Premium porque necesitábamos el nombre de la marca en neón. El proceso fue muy profesional: nos mandaron el render antes de fabricar, llegaron al venue con tiempo, instalaron las barras en toda la perimetría del salón y el letrero quedó perfecto. Nuestro fotógrafo dijo que fue el mejor backdrop que ha tenido en un evento corporativo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Eduardo V.</span>
                <span class="prod-quote__event">Lanzamiento de producto — Salón corporativo Polanco, CDMX — 200 asistentes</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Letreros neón</dt><dd>100% custom</dd></div>
              <div class="ps-specs__row"><dt>Barras neón</dt><dd>Completas, arquitectónicas</dd></div>
              <div class="ps-specs__row"><dt>UV</dt><dd>Full cobertura salón</dd></div>
              <div class="ps-specs__row"><dt>Personalización</dt><dd>Texto + fuente + color</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>150-300 invitados</dd></div>
              <div class="ps-specs__row"><dt>Espacio</dt><dd>Salón grande</dd></div>
              <div class="ps-specs__row"><dt>Anticipación</dt><dd>15 días mínimo</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas modernas</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Lanzamientos</span>
              <span class="ps-tag">Galas</span>
              <span class="ps-tag">Convenciones</span>
              <span class="ps-tag">XV años premium</span>
              <span class="ps-tag">Aniversarios de empresa</span>
              <span class="ps-tag">Eventos de marca</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-neon/paquete-uv-basico/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/basico.avif" alt="UV Básico letreros neón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">UV Básico</span>
                <span class="ps-pkg__price">$2,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-glow-party/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/glow-party.avif" alt="Glow Party neón completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Glow Party</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/produccion-neon.avif" alt="Producción Neón DMX profesional" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Neón</span>
                <span class="ps-pkg__price">$16,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Producción a escala completa con control DMX y director técnico? El paquete Producción Neón es para festivales y bodas de lujo.</p>
              <a href="/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" class="ps-upsell__link">Ver Producción Neón →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra UV</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
