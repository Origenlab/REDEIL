---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción Neón de Luz Neón LED?',
    respuesta: 'Incluye producción neón completa con diseño personalizado a medida, control DMX para programación de secuencias y cambios de color, director técnico de producción en sitio, instalación profesional a gran escala, operación completa durante el evento y desmontaje. Es el nivel máximo de producción neón para festivales, bodas de lujo y producciones de alto presupuesto.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción Neón?',
    respuesta: 'El paquete Producción Neón tiene un precio desde $16,500 MXN + IVA. El precio final depende del tamaño del venue, la complejidad del diseño y la duración del evento. Incluye director técnico, control DMX, instalación completa y desmontaje. Solicita cotización personalizada para tu producción específica.'
  },
  {
    pregunta: '¿Qué es el control DMX y para qué sirve en una producción neón?',
    respuesta: 'El control DMX es el protocolo estándar de la industria para control de iluminación profesional. Permite programar secuencias de color, sincronizar cambios de luz con la música, crear transiciones graduales y controlar en tiempo real toda la instalación neón desde una consola. El resultado es una producción de iluminación coordinada como en festivales de música o producciones televisivas.'
  },
  {
    pregunta: '¿El paquete Producción Neón funciona en exteriores?',
    respuesta: 'Sí. El equipo de producción neón está certificado para uso en exteriores bajo condiciones controladas. Festivales al aire libre, bodas en jardín grande, eventos en terraza o explanada. El director técnico evalúa las condiciones del venue y adapta la instalación para garantizar el rendimiento óptimo del equipo.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete Producción Neón?',
    respuesta: 'Para producciones de esta escala recomendamos mínimo 30 días de anticipación. El diseño personalizado, la planificación técnica del venue, la fabricación de elementos a medida y la coordinación del equipo de producción requieren tiempo. Para festivales o producciones televisivas, contáctanos con 60-90 días de anticipación.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción Neón — Luz Neón LED con DMX para Festivales y Bodas de Lujo | REDEIL',
    description: 'Producción neón completa con diseño personalizado, control DMX y director técnico para festivales, bodas de lujo y producciones en CDMX. Desde $16,500 MXN.',
    image: SITE_URL + '/img/paquetes/luz-neon/produccion-neon.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '16500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-neon/paquete-produccion-neon/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '19',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción Neón — DMX + Director Técnico para Festivales CDMX | REDEIL"
  description="Producción neón completa con diseño personalizado, control DMX y director técnico. Para festivales, bodas de lujo y producciones TV en CDMX. Desde $16,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Neón LED', href: '/renta-de-iluminacion/luz-neon/' }, { name: 'Producción Neón', href: '/renta-de-iluminacion/luz-neon/paquete-produccion-neon/' }]} />

  <Hero
    badge="Producción Neón — Nivel máximo"
    title="Producción Neón Completa — DMX, Diseño Personalizado y Director Técnico para Festivales y Bodas de Lujo"
    description="El nivel más alto de producción neón. Diseño a medida, control DMX para secuencias programadas, director técnico en sitio. Para festivales, bodas de lujo, producciones TV y lanzamientos premium en CDMX."
    primaryCta={{ text: 'Cotizar $16,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-neon/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Producción Neón</strong> es la producción de iluminación neón de máximo nivel para eventos que exigen el mismo estándar que un festival internacional o una producción televisiva. Control <strong>DMX</strong> para programar cada cambio de luz, director técnico que opera la consola en tiempo real, diseño personalizado a la escala exacta del venue y cobertura para 300+ invitados en cualquier tipo de espacio.</p>
      <p>Para festivales de música en <strong>CDMX</strong> que quieren que el escenario sea visualmente memorable, bodas de lujo donde la iluminación es parte integral del diseño del evento, lanzamientos premium de marca donde el neón define la identidad visual, y producciones de TV o foto donde la luz neón es el set. Este no es un servicio de renta — es una producción completa.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Neón LED"
    items={[{ label: "UV Básico — Letreros neón", href: "/renta-de-iluminacion/luz-neon/paquete-uv-basico/" }, { label: "Glow Party — Neón + UV + pintura", href: "/renta-de-iluminacion/luz-neon/paquete-glow-party/" }, { label: "Neón Premium — Custom completo", href: "/renta-de-iluminacion/luz-neon/paquete-neon-premium/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-neon/produccion-neon.avif" alt="Producción Neón completa con DMX en festival de música CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-neon.avif" alt="Control DMX para producción neón profesional en evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/barras-neon.avif" alt="Instalación neón a gran escala en boda de lujo CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/photobooth.avif" alt="Set de producción neón para fotografía y video profesional" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/neon-detalle.avif" alt="Detalle instalación neón LED en festival con control DMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Producción Neón — La producción más completa del catálogo</span>
            <h2 class="prod-info__title">Producción Neón Completa con DMX, Diseño Personalizado y Director Técnico</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$16,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Precio base. Cotización final según dimensiones del venue y complejidad del diseño. Incluye director técnico, DMX, instalación y desmontaje.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando el neón no es decoración sino el lenguaje visual del evento</h2>
            <p class="prod-selling__intro">Hay una diferencia entre "tener neón en el evento" y "producir un evento con neón". El Producción Neón hace lo segundo. El control DMX permite que los cambios de luz estén sincronizados con los momentos del evento: la entrada de los novios, el cambio de ambiente de cena a baile, el clímax musical del festival. No es iluminación estática que se prende y se queda igual — es iluminación que cuenta la historia del evento en tiempo real.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Control DMX — la iluminación que responde al evento en tiempo real</h3>
                  <p class="prod-hl__desc">El protocolo DMX es el estándar de la industria para iluminación profesional. La consola controla cada canal de luz individualmente: intensidad, color, velocidad de transición. El director técnico programa las secuencias antes del evento y las ejecuta en tiempo real siguiendo el guión. El resultado es iluminación cinematográfica, no decoración de salón.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Diseño personalizado a la escala del venue</h3>
                  <p class="prod-hl__desc">No hay paquetes predefinidos a los que tienes que adaptarte. El diseñador trabaja el proyecto desde cero: planos del venue, alturas, distancias, puntos de anclaje, distribución óptima de equipo. El resultado es una instalación diseñada específicamente para tu espacio, no una solución genérica sobredimensionada o insuficiente.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director técnico en sitio — producción sin improvisación</h3>
                  <p class="prod-hl__desc">El director técnico no es un técnico de montaje — es el responsable de toda la producción visual del evento. Coordina al equipo de instalación, opera la consola DMX, sincroniza con DJ o director de escena, y toma decisiones en tiempo real cuando algo cambia. Es la diferencia entre un evento que se ve profesional y uno que parece amateur.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Escala para 300+ invitados — festivales, salones de gala, exteriores</h3>
                  <p class="prod-hl__desc">El equipo y el headcount del servicio están dimensionados para producciones de gran escala. Festivales de 500-1000 personas, salones de convenciones, jardines de hacienda de varios miles de metros cuadrados, sets de TV. La misma calidad de producción sin importar el tamaño del evento.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Diseño personalizado a medida</div>
              <div class="prod-feat">Control DMX profesional</div>
              <div class="prod-feat">Consola de iluminación</div>
              <div class="prod-feat">Director técnico de producción</div>
              <div class="prod-feat">Letreros neón custom</div>
              <div class="prod-feat">Barras neón a gran escala</div>
              <div class="prod-feat">Programación de secuencias</div>
              <div class="prod-feat">Equipo completo de instalación</div>
              <div class="prod-feat">Transporte y logística</div>
              <div class="prod-feat">Operación completa del evento</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Brief de producción y visita al venue</h4>
                  <p class="prod-step__desc">Reunión de brief con el cliente para entender el tipo de evento, la identidad visual, los momentos clave del programa y las expectativas estéticas. Visita técnica al venue para levantar planos y dimensionar el proyecto con precisión.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Diseño, render y aprobación</h4>
                  <p class="prod-step__desc">El equipo de diseño desarrolla la propuesta completa: distribución de equipo, letreros, programación DMX tentativa y render visual del resultado. Presentamos para aprobación con 2 rondas de ajustes incluidas antes de confirmar fabricación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Fabricación y pruebas técnicas</h4>
                  <p class="prod-step__desc">Fabricación de todos los elementos a medida, programación de secuencias DMX y prueba de todo el equipo en taller antes de llevarlo al venue. Llegamos el día del evento con producción 100% verificada.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación, ensayo y operación</h4>
                  <p class="prod-step__desc">Instalación completa con 4-6 horas de anticipación, ensayo técnico con el equipo del evento (DJ, MC, coordinador), ajustes finales y operación completa durante el evento con el director técnico en consola. Al terminar, desmontaje limpio y rápido.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Neón Premium o Producción Neón?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Neón Premium — Producción media</span>
                <ul class="prod-compare__list">
                  <li>150-300 invitados</li>
                  <li>Letreros custom + barras neón</li>
                  <li>Sin control DMX</li>
                  <li>Técnico de soporte</li>
                  <li>Para bodas y corporativos</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción Neón — Nivel máximo</span>
                <ul class="prod-compare__list">
                  <li>300+ invitados, cualquier escala</li>
                  <li>Diseño completo desde cero</li>
                  <li>Control DMX con secuencias</li>
                  <li>Director técnico en consola</li>
                  <li>Festivales, TV, bodas de lujo</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos Producción Neón para el lanzamiento de temporada de nuestra marca. El director técnico fue invaluable — coordinó todo con nuestro fotógrafo, el DJ y el coordinador del evento. Las secuencias DMX estaban perfectamente sincronizadas con los momentos del programa. El setup neón fue exactamente lo que habíamos aprobado en el render. Nuestro equipo de marketing quedó impresionado y ya estamos planeando el siguiente evento con REDEIL."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Alejandra M.</span>
                <span class="prod-quote__event">Lanzamiento de temporada — Producción premium — CDMX — 400 asistentes</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Control</dt><dd>DMX profesional</dd></div>
              <div class="ps-specs__row"><dt>Director técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Diseño</dt><dd>100% personalizado</dd></div>
              <div class="ps-specs__row"><dt>Secuencias</dt><dd>Programadas + tiempo real</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>300+ invitados</dd></div>
              <div class="ps-specs__row"><dt>Espacio</dt><dd>Cualquier escala</dd></div>
              <div class="ps-specs__row"><dt>Anticipación</dt><dd>30 días mínimo</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + nacional</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Festivales</span>
              <span class="ps-tag">Bodas de lujo</span>
              <span class="ps-tag">Producciones TV</span>
              <span class="ps-tag">Lanzamientos premium</span>
              <span class="ps-tag">Sets fotográficos</span>
              <span class="ps-tag">Galas de alto nivel</span>
              <span class="ps-tag">Conciertos</span>
              <span class="ps-tag">Producciones de marca</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-neon/paquete-uv-basico/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/basico.avif" alt="UV Básico letreros neón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">UV Básico</span>
                <span class="ps-pkg__price">$2,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-glow-party/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/glow-party.avif" alt="Glow Party neón completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Glow Party</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-neon-premium/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/neon-premium.avif" alt="Neón Premium custom completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Neón Premium</span>
                <span class="ps-pkg__price">$9,200 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento más íntimo o presupuesto ajustado? El Neón Premium cubre 150-300 invitados con letreros custom a menor inversión.</p>
              <a href="/renta-de-iluminacion/luz-neon/paquete-neon-premium/" class="ps-upsell__link">Ver Neón Premium →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización personalizada para tu venue y tipo de evento en menos de 24 horas.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra UV</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
