---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Glow Party de Luz Neón LED?',
    respuesta: 'Incluye letreros neón LED temáticos, barras de luz UV para cubrir el salón, pintura fluorescente para los invitados, instalación y posicionamiento estratégico, técnico de montaje, desmontaje y transporte dentro de CDMX y Edomex. Todo lo necesario para que la fiesta glow sea completa de principio a fin.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Glow Party?',
    respuesta: 'El paquete Glow Party de Luz Neón LED tiene un precio desde $5,500 MXN + IVA. Incluye transporte, instalación, letreros neón, barras UV, pintura fluorescente y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿La pintura fluorescente es segura para la piel?',
    respuesta: 'Sí. Utilizamos pintura fluorescente a base de agua, no tóxica, certificada para uso en piel. Se aplica con facilidad, brilla intensamente bajo luz UV y se retira con agua y jabón. Ideal para niños, jóvenes y adultos en fiestas glow.'
  },
  {
    pregunta: '¿Para cuántos invitados está diseñado el paquete Glow Party?',
    respuesta: 'El paquete Glow Party está diseñado para eventos de 80 a 150 invitados en salón mediano. Las barras UV cubren el área de baile y las zonas principales. Para eventos más grandes o al aire libre, el paquete Neón Premium o Producción Neón tiene mejor cobertura.'
  },
  {
    pregunta: '¿Puedo personalizar los letreros neón del paquete Glow Party?',
    respuesta: 'Sí. Podemos adaptar letreros con el nombre del festejado, frases temáticas o palabras clave del evento. Los letreros de catálogo están disponibles de inmediato; los 100% personalizados requieren 10 días de fabricación. Consultamos contigo el diseño antes de confirmar.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Glow Party — Luz Neón LED para Fiestas Temáticas | REDEIL',
    description: 'Kit completo glow: letreros neón LED + barras UV + pintura fluorescente para fiestas temáticas en CDMX. Paquete Glow Party desde $5,500 MXN con instalación incluida.',
    image: SITE_URL + '/img/paquetes/luz-neon/glow-party.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '5500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-neon/paquete-glow-party/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Glow Party — Kit Neón LED + UV + Pintura Fluorescente CDMX | REDEIL"
  description="Kit completo para fiesta glow: letreros neón LED + barras UV + pintura fluorescente. Paquete Glow Party desde $5,500 MXN con instalación. XV años, cumpleaños y graduaciones en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Neón LED', href: '/renta-de-iluminacion/luz-neon/' }, { name: 'Glow Party', href: '/renta-de-iluminacion/luz-neon/paquete-glow-party/' }]} />

  <Hero
    badge="Glow Party — Kit Completo"
    title="Glow Party — Neón LED + Luz UV + Pintura Fluorescente para Fiestas Temáticas"
    description="El paquete que convierte cualquier salón en una fiesta glow completa. Letreros neón LED + barras UV + pintura fluorescente para invitados. La experiencia glow de principio a fin en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $5,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-neon/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Glow Party de Luz Neón LED</strong> es la solución completa para fiestas temáticas en <strong>CDMX y Estado de México</strong>. No es solo poner letreros en la pared — es transformar el ambiente completo del salón con luz UV que hace brillar todo lo blanco y fluorescente, pintura que convierte a los invitados en parte de la decoración, y letreros neón que crean los puntos focales fotográficos del evento.</p>
      <p>Una fiesta glow exitosa necesita tres elementos trabajando juntos: la luz UV que da el ambiente base, el neón que crea contraste y puntos de atención, y la pintura fluorescente que activa a los invitados. Este paquete tiene los tres. Para XV años temáticos, cumpleaños de impacto y graduaciones que nadie va a olvidar.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Neón LED"
    items={[{ label: "UV Básico — Letreros neón", href: "/renta-de-iluminacion/luz-neon/paquete-uv-basico/" }, { label: "Neón Premium — Custom completo", href: "/renta-de-iluminacion/luz-neon/paquete-neon-premium/" }, { label: "Producción Neón — DMX total", href: "/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-neon/glow-party.avif" alt="Fiesta glow con luz UV, neón y pintura fluorescente en salón CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-neon.avif" alt="Kit Glow Party con barras UV y letreros neón en evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/barras-uv.avif" alt="Barras de luz UV iluminando zona de baile en fiesta glow" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/pintura-fluorescente.avif" alt="Invitados con pintura fluorescente brillando bajo luz UV" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/neon-detalle.avif" alt="Letrero neón LED en fiesta glow temática CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Glow Party — Kit completo para fiesta temática</span>
            <h2 class="prod-info__title">Letreros Neón + Barras UV + Pintura Fluorescente — Todo en un Paquete</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$5,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, letreros neón, barras UV, pintura y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La fiesta que brilla sola — sin que tú tengas que organizar nada extra</h2>
            <p class="prod-selling__intro">Una fiesta glow sin los tres elementos correctos es solo una fiesta oscura con luces de colores. El paquete Glow Party está diseñado para que el ambiente sea inmersivo desde que apagan la luz blanca: las barras UV activan todo lo fluorescente del salón, los letreros neón crean los fondos perfectos para fotos, y la pintura pone a los invitados en modo fiesta en segundos. 80-150 invitados, salón mediano, ambiente completo.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Barras UV que cubren el salón completo — no solo un rincón</h3>
                  <p class="prod-hl__desc">Las barras de luz UV de alta potencia se distribuyen estratégicamente para que el efecto fluorescente llegue a toda la pista y las zonas de mesas. Nada arruina una fiesta glow como una zona donde la pintura no brilla. Con cobertura completa, el efecto es uniforme y cinematográfico.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Pintura fluorescente no tóxica incluida — la activación del ambiente</h3>
                  <p class="prod-hl__desc">La pintura es lo que convierte a los invitados de espectadores a participantes. A base de agua, sin tóxicos, certificada para uso en piel. Se entrega en colores neón: verde, amarillo, rosa, naranja. Una aplicación en el brazo o la cara y la persona se convierte en parte de la decoración luminosa.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Letreros neón LED — el punto focal fotográfico</h3>
                  <p class="prod-hl__desc">Los letreros neón complementan el ambiente UV creando zonas de contraste donde el color del neón rompe el azul morado de la luz negra. Frases temáticas, nombres del festejado, emojis luminosos — cada letrero se convierte en el fondo perfecto para las fotos que van a compartir en redes.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Diseñado para 80-150 invitados — ni corto ni excesivo</h3>
                  <p class="prod-hl__desc">La potencia y cantidad del equipo está calibrada para salones medianos de CDMX. No pagas por exceso de equipo que no necesitas ni te quedas corto con coverage insuficiente. El técnico evalúa las dimensiones del salón antes del evento y ajusta la distribución para cobertura óptima.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">Letreros neón LED temáticos</div>
              <div class="prod-feat">Barras de luz UV de alta potencia</div>
              <div class="prod-feat">Pintura fluorescente no tóxica</div>
              <div class="prod-feat">Soportes y sistema de montaje</div>
              <div class="prod-feat">Cable y conexiones incluidas</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Posicionamiento estratégico UV</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos el tema y el espacio</h4>
                  <p class="prod-step__desc">Fecha, tipo de evento, número de invitados y dimensiones aproximadas del salón. Con eso diseñamos la distribución de barras UV y el posicionamiento de letreros para cobertura completa.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Elige el estilo neón y confirma</h4>
                  <p class="prod-step__desc">Te mostramos el catálogo de letreros disponibles y las opciones de personalización. 50% de anticipo confirma tu fecha. Para letreros con texto custom, necesitamos 10 días para fabricación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalamos antes de que lleguen los invitados</h4>
                  <p class="prod-step__desc">El equipo llega 1 hora antes, instala barras UV, posiciona letreros neón y hace prueba completa del efecto glow. La pintura se entrega lista para aplicar. Todo montado antes del primer invitado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">La fiesta brilla, tú disfrutas</h4>
                  <p class="prod-step__desc">El técnico permanece para ajustes durante el evento. Al terminar desmontamos todo sin dejar rastro. Los únicos recuerdos que quedan son las fotos y la pintura en la ropa — esa es la firma de una buena glow party.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿UV Básico o Glow Party?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">UV Básico — Solo neón</span>
                <ul class="prod-compare__list">
                  <li>Solo letreros neón LED</li>
                  <li>Zona de fotos puntual</li>
                  <li>Sin barras UV ni pintura</li>
                  <li>Photobooth específico</li>
                  <li>Para complementar decoración</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Glow Party — Kit completo</span>
                <ul class="prod-compare__list">
                  <li>Neón + UV + pintura fluorescente</li>
                  <li>Ambiente glow en todo el salón</li>
                  <li>Los invitados brillan con la pintura</li>
                  <li>Experiencia inmersiva completa</li>
                  <li>Fiesta temática de principio a fin</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el Glow Party para los XV años de mi hija con temática neón. Cuando apagaron las luces normales y encendieron todo el equipo, el salón se transformó completamente. Los invitados con la pintura brillaban, los letreros eran el fondo perfecto para todas las fotos y las barras UV hacían que hasta la decoración blanca brillara. Fue exactamente lo que necesitábamos."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Patricia R.</span>
                <span class="prod-quote__event">XV años temáticos — Salón en Naucalpan, Edomex — 120 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Letreros neón</dt><dd>Temáticos o custom</dd></div>
              <div class="ps-specs__row"><dt>Barras UV</dt><dd>Alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Pintura fluorescente</dt><dd>Incluida, no tóxica</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>80-150 invitados</dd></div>
              <div class="ps-specs__row"><dt>Espacio</dt><dd>Salón mediano</dd></div>
              <div class="ps-specs__row"><dt>Montaje</dt><dd>Sin perforar paredes</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años temáticos</span>
              <span class="ps-tag">Fiestas glow</span>
              <span class="ps-tag">Cumpleaños</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Fiestas neón</span>
              <span class="ps-tag">Eventos UV</span>
              <span class="ps-tag">Fiestas universitarias</span>
              <span class="ps-tag">Eventos temáticos</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-neon/paquete-uv-basico/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/basico.avif" alt="UV Básico letreros neón" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">UV Básico</span>
                <span class="ps-pkg__price">$2,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-neon-premium/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/neon-premium.avif" alt="Neón Premium custom completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Neón Premium</span>
                <span class="ps-pkg__price">$9,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/produccion-neon.avif" alt="Producción Neón DMX profesional" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Neón</span>
                <span class="ps-pkg__price">$16,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento más grande o con letreros totalmente custom? El paquete Neón Premium cubre hasta 300 invitados con diseño personalizado.</p>
              <a href="/renta-de-iluminacion/luz-neon/paquete-neon-premium/" class="ps-upsell__link">Ver Neón Premium →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra UV</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
