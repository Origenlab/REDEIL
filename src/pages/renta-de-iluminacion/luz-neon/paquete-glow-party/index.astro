---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    "pregunta": "¿Qué incluye el paquete Glow Party de Luz Neón LED?",
    "respuesta": "El paquete Glow Party incluye 6 barras uv led, montaje en truss, instalación y desmontaje. Todo con instalación profesional y desmontaje incluido. Nuestro equipo técnico llega con anticipación para montar y hacer pruebas."
  },
  {
    "pregunta": "¿Cuánto cuesta el paquete Glow Party?",
    "respuesta": "El paquete Glow Party de Luz Neón LED tiene un precio desde $5,500 MXN + IVA. Este precio incluye transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México."
  },
  {
    "pregunta": "¿Puedo personalizar el paquete Glow Party?",
    "respuesta": "Sí, todos nuestros paquetes son personalizables. Podemos agregar o quitar elementos según tus necesidades y presupuesto. Contáctanos por WhatsApp al 55 4937 5172 para una cotización a la medida."
  },
  {
    "pregunta": "¿En qué zonas entregan el paquete Glow Party?",
    "respuesta": "Cubrimos toda la Ciudad de México y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km de CDMX."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar el paquete Glow Party?",
    "respuesta": "Recomendamos reservar con 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp para verificar disponibilidad del equipo."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Glow Party — Luz Neón LED | REDEIL',
    description: 'La fiesta neón completa. 6 barras UV LED para 80m², pintura neón corporal incluida y todo lo necesario para una Glow Party inolvidable en CDMX.',
    image: SITE_URL + '/img/img-index/luz-neon.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '5500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-neon/paquete-glow-party/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '42',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Glow Party — Luz Neón LED en CDMX | REDEIL"
  description="La fiesta neón completa. 6 barras UV LED para 80m², pintura neón corporal incluida y todo lo necesario para una Glow Party inolvidable en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Neón LED', href: '/renta-de-iluminacion/luz-neon/' }, { name: 'Glow Party', href: '/renta-de-iluminacion/luz-neon/paquete-glow-party/' }]} />

  <Hero
    badge="Glow Party"
    title="Glow Party — Luz Neón LED"
    description="La fiesta neón completa. 6 barras UV LED para 80m², pintura neón corporal incluida y todo lo necesario para una Glow Party inolvidable en CDMX."
    primaryCta={{ text: 'Cotizar $5,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-neon/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Glow Party transforma cualquier salón en una experiencia neón inmersiva. Con 6 barras UV LED cubrimos hasta 80m², creando el escenario perfecto para fiestas temáticas donde la luz ultravioleta hace brillar cada detalle fluorescente.</p>
      <p>Incluye pintura neón corporal para que tus invitados se conviertan en parte del espectáculo. Este paquete es el favorito para fiestas de graduación, despedidas de soltera y eventos temáticos en clubes y salones de CDMX y Estado de México.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Neón LED"
    items={[{ label: "UV Básico", href: "/renta-de-iluminacion/luz-neon/paquete-uv-basico/" }, { label: "Neón Premium", href: "/renta-de-iluminacion/luz-neon/paquete-neon-premium/" }, { label: "Producción Neón", href: "/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" }]}
  />

  <!-- QUÉ INCLUYE -->
  <section class="section" id="features">
    <div class="container">
      <h2 class="section__title">¿Qué incluye el paquete Glow Party?</h2>
      <p class="section__subtitle">Todo lo que necesitas para tu evento, sin sorpresas ni costos ocultos.</p>
      <div class="features-grid">
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>6 barras UV LED</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Montaje en truss</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Instalación y desmontaje</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Cobertura 80m²</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Pintura neón corporal</span></div>
        <div class="feature-item feature-item--no"><span class="feature-icon">&mdash;</span><span>Accesorios fluorescentes</span></div>
      </div>
      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">$5,500 MXN</span>
        <span class="price-highlight__note">+ IVA · Instalación incluida</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <!-- CONTENIDO SEO -->
  <section class="section section--bg">
    <div class="container content-prose">
      <h2>¿Por qué elegir el paquete Glow Party de luz neón LED?</h2>
      <p>El paquete Glow Party transforma cualquier salón en una experiencia neón inmersiva. Con 6 barras UV LED cubrimos hasta 80m², creando el escenario perfecto para fiestas temáticas donde la luz ultravioleta hace brillar cada detalle fluorescente.</p>
      <p>Incluye pintura neón corporal para que tus invitados se conviertan en parte del espectáculo. Este paquete es el favorito para fiestas de graduación, despedidas de soltera y eventos temáticos en clubes y salones de CDMX y Estado de México.</p>
      <h3>¿Para quién es este paquete?</h3>
      <p>El paquete Glow Party de luz neón led está diseñado para eventos medianos que buscan calidad profesional. Con equipo profesional de marcas líderes y servicio técnico especializado, garantizamos resultados impecables.</p>
      <h3>Servicio profesional de luz neón led</h3>
      <p>En REDEIL llevamos más de 10 años ofreciendo renta de luz neón led en CDMX y Estado de México. Nuestro equipo técnico se encarga de todo: logística, transporte, instalación, configuración, operación durante el evento y desmontaje. Trabajamos con equipo profesional para garantizar que cada evento sea perfecto.</p>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <!-- CTA FINAL -->

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .section__subtitle {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: var(--border-radius);
    font-size: var(--font-size-sm);
  }
  .feature-item--yes {
    background: #f0fdf4;
    color: #166534;
  }
  .feature-item--no {
    background: var(--color-bg);
    color: var(--color-text-light);
  }
  .feature-icon {
    font-weight: 700;
    font-size: 1.125rem;
    flex-shrink: 0;
  }
  .price-highlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    background: var(--color-bg);
    border-radius: var(--border-radius-lg);
    text-align: center;
  }
  .price-highlight__label {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .price-highlight__amount {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
  }
  .price-highlight__note {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }
  .content-prose {
    max-width: 800px;
    margin: 0 auto;
  }
  .content-prose h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .content-prose h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }
  .content-prose p {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
</style>
