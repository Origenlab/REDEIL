---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Básico de Luz Neón LED?',
    respuesta: 'Incluye 2 a 3 letreros de neón LED personalizados o de diseño fijo, instalación y posicionamiento estratégico para photobooth o zona de fotos, técnico de montaje, desmontaje y transporte dentro de CDMX y Edomex. Perfecta para crear una zona de fotos que todos quieran capturar.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Básico de Luz Neón?',
    respuesta: 'El paquete Básico de Luz Neón LED tiene un precio desde $2,800 MXN + IVA. Incluye transporte, instalación, 2-3 letreros neón LED y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Puedo elegir el texto o diseño de los letreros neón?',
    respuesta: 'Sí. Podemos adaptar letreros con frases populares para photobooth, nombres de los festejados o palabras temáticas de la fiesta. Para letreros 100% personalizados con texto específico, cotiza con tiempo de fabricación. Los letreros de diseño fijo están disponibles de inmediato.'
  },
  {
    pregunta: '¿Para qué tamaño de espacio funciona el paquete Básico?',
    respuesta: 'El paquete Básico está diseñado para crear una zona específica de fotos o photobooth. No es para iluminar un salón completo — es para crear el punto focal fotográfico del evento. Funciona en esquinas, pasillos de entrada o cualquier zona destinada a fotos y selfies.'
  },
  {
    pregunta: '¿Los letreros neón LED son seguros para interiores y exteriores?',
    respuesta: 'Los letreros neón LED que utilizamos son seguros para interiores. Para exteriores bajo techo también funcionan bien. No recomendamos exposición directa a lluvia. El técnico evalúa el espacio en la instalación para garantizar la seguridad del montaje.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Básico — Kit Neón LED para Photobooth | REDEIL',
    description: 'Kit básico de luz neón LED con 2-3 letreros para crear la zona de fotos perfecta en fiestas y eventos en CDMX. Desde $2,800 MXN con instalación incluida.',
    image: SITE_URL + '/img/paquetes/luz-neon/basico.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2800',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-neon/paquete-uv-basico/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '31',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Básico — Kit Neón LED para Photobooth en Fiestas CDMX | REDEIL"
  description="2-3 letreros de luz neón LED para crear la zona de fotos que todos quieren capturar. Kit básico desde $2,800 MXN con instalación. Photobooth neón en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Neón LED', href: '/renta-de-iluminacion/luz-neon/' }, { name: 'Básico — Kit Neón', href: '/renta-de-iluminacion/luz-neon/paquete-uv-basico/' }]} />

  <Hero
    badge="Kit Básico Neón"
    title="Kit Básico — Letreros Neón LED para la Zona de Fotos Perfecta"
    description="El letrero neón que nadie se puede resistir a fotografiar. 2 a 3 piezas de luz neón LED que convierten cualquier rincón del evento en el punto focal de todas las fotos. Photobooth sin photobooth."
    primaryCta={{ text: 'Cotizar $2,800 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-neon/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>Kit Básico de Luz Neón LED</strong> es la forma más accesible de agregar un elemento visual memorable a tu evento en <strong>CDMX y Estado de México</strong>. Dos o tres letreros neón bien colocados crean una zona de fotos que no necesita estructura elaborada ni cabina profesional — solo la luz neón haciendo lo que mejor sabe hacer: brillar en la oscuridad y hacerse el centro de atención.</p>
      <p>Las frases neón se han convertido en el accesorio fotográfico más solicitado en eventos sociales. No es solo decoración — es el fondo que todos buscan para su foto de perfil, el detalle que aparece en cada Instagram del evento, el elemento que identifica visualmente la fiesta días después de que terminó. Con 2-3 letreros estratégicamente posicionados, creas ese efecto sin necesidad de una producción completa.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Neón LED"
    items={[{ label: "Glow Party — Neón + UV + pintura", href: "/renta-de-iluminacion/luz-neon/paquete-glow-party/" }, { label: "Neón Premium — Custom completo", href: "/renta-de-iluminacion/luz-neon/paquete-neon-premium/" }, { label: "Producción Neón — DMX total", href: "/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/luz-neon/basico.avif" alt="Letrero neón LED en photobooth de fiesta, pareja posando" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/luz-neon.avif" alt="Kit básico neón LED en zona de fotos evento CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/letrero-amor.avif" alt="Letrero neón Love brillando en fondo oscuro" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/photobooth.avif" alt="Zona de fotos con letreros neón para invitados" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/luz-neon/sell/neon-detalle.avif" alt="Detalle de letrero neón LED colores vibrantes" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Kit Básico — El punto de entrada ideal</span>
            <h2 class="prod-info__title">2-3 Letreros Neón LED para Photobooth y Zona de Fotos</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$2,800</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">El fondo de foto que todos van a querer — sin cabina, sin estructura elaborada</h2>
            <p class="prod-selling__intro">Los letreros neón tienen algo que ningún otro elemento decorativo logra: hacen que la gente busque activamente tomarse una foto con ellos. No es una tendencia pasajera — es física. La luz neón en una habitación oscura o semioscura crea el contraste perfecto para fotografía con smartphone. Los sujetos se ven bien, el fondo es interesante, los colores son vibrantes. Dos o tres letreros bien colocados crean ese efecto en cualquier evento.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El rincón del evento donde todos hacen fila para la foto</h3>
                  <p class="prod-hl__desc">Un letrero con la frase correcta crea un punto de atracción natural en la fiesta. Los invitados se acercan, posan, toman la foto y la suben. Es publicidad orgánica para el evento y recuerdos que duran más que cualquier detalle de mesa.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Instalación en cualquier superficie — sin perforar ni dañar</h3>
                  <p class="prod-hl__desc">Los letreros se montan en soportes o se cuelgan con sistemas que no dañan paredes ni techos. Funcionan en cortinas de tela, paneles de madera, estructuras de tubo y prácticamente cualquier superficie vertical. El técnico evalúa el espacio en sitio y determina el mejor método.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Colores que no se ven en ningún otro tipo de luz</h3>
                  <p class="prod-hl__desc">El neón LED emite un glow suave y uniforme que crea halos de color en los bordes. A diferencia de los LEDs planos, el neón tiene profundidad visual — se ve igual de bien de cerca que a distancia. Rojo intenso, rosa fucsia, azul eléctrico, verde lima: el color que elijas se ve exactamente como debe verse.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Base perfecta para escalar — crece con el evento</h3>
                  <p class="prod-hl__desc">El Kit Básico es el punto de partida. Si quieres agregar más letreros, sumar luz UV o integrar barras neón de ambientación, el paquete Glow Party tiene todo eso. Empezar básico y escalar es la estrategia inteligente para eventos con presupuesto incremental.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2-3 letreros de luz neón LED</div>
              <div class="prod-feat">Soportes o sistema de colgado</div>
              <div class="prod-feat">Cable y conexiones incluidas</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Posicionamiento para photobooth</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Asesoría de diseño visual</div>
              <div class="prod-feat">Pruebas previas al evento</div>
              <div class="prod-feat">Soporte técnico en sitio</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Elige los letreros y la fecha</h4>
                  <p class="prod-step__desc">Cuéntanos el tipo de evento, el tema y la zona donde quieres instalar los letreros. Te mostramos el catálogo de diseños disponibles y las opciones de personalización dentro del paquete.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirma con anticipo</h4>
                  <p class="prod-step__desc">50% de anticipo confirma tu fecha. Para letreros con texto personalizado que requieren fabricación, necesitamos al menos 10 días de anticipación. Letreros de catálogo están disponibles con 3-5 días.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos y montamos tu zona de fotos</h4>
                  <p class="prod-step__desc">El técnico llega 45 minutos antes, instala los letreros, ajusta el ángulo y la altura para que las fotos queden perfectas y hace prueba final de encendido. El photobooth está listo antes de que llegue el primer invitado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Los letreros brillan, tú disfrutas</h4>
                  <p class="prod-step__desc">Los letreros operan sin supervisión constante durante el evento. Al terminar, el técnico desmonta todo sin dejar rastro. Los letreros se van con nosotros — tú solo llevas las fotos.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Kit Básico o Glow Party?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Kit Básico — 2-3 letreros</span>
                <ul class="prod-compare__list">
                  <li>Zona de fotos puntual</li>
                  <li>Solo letreros neón</li>
                  <li>Para complementar la decoración</li>
                  <li>Sin luz UV ni pintura</li>
                  <li>Photobooth sencillo y efectivo</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Glow Party — Kit completo</span>
                <ul class="prod-compare__list">
                  <li>Ambiente neón en todo el evento</li>
                  <li>Neón + UV + pintura fluorescente</li>
                  <li>Para que la fiesta sea UV entera</li>
                  <li>Experiencia glow completa</li>
                  <li>Múltiples zonas y efectos</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Renté el kit básico de neón para la boda de mi hermana — dos letreros, uno que decía 'Just Married' y otro con un corazón. Los pusimos en la zona de entrada al salón y literalmente todos los invitados se tomaron foto ahí. Al final del evento mi hermana tenía más de 80 fotos distintas de invitados con esos letreros. El efecto fue increíble para el costo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sofía M.</span>
                <span class="prod-quote__event">Boda en salón — Coyoacán, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Letreros neón</dt><dd>2 a 3 piezas</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Neón LED flexible</dd></div>
              <div class="ps-specs__row"><dt>Uso</dt><dd>Photobooth y zona de fotos</dd></div>
              <div class="ps-specs__row"><dt>Personalización</dt><dd>Catálogo o texto custom</dd></div>
              <div class="ps-specs__row"><dt>Montaje</dt><dd>Sin perforar paredes</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Cumpleaños adultos</span>
              <span class="ps-tag">Baby showers</span>
              <span class="ps-tag">Photobooth sencillo</span>
              <span class="ps-tag">Fiestas de compromiso</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Inauguraciones</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luz-neon/paquete-glow-party/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/glow-party.avif" alt="Glow Party neón completo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Glow Party</span>
                <span class="ps-pkg__price">$5,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-neon-premium/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/neon-premium.avif" alt="Neón Premium custom" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Neón Premium</span>
                <span class="ps-pkg__price">$9,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" class="ps-pkg">
              <img src="/img/paquetes/luz-neon/produccion-neon.avif" alt="Producción Neón DMX" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción Neón</span>
                <span class="ps-pkg__price">$16,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres que toda la fiesta sea glow? El paquete Glow Party suma UV y pintura fluorescente al kit neón.</p>
              <a href="/renta-de-iluminacion/luz-neon/paquete-glow-party/" class="ps-upsell__link">Ver Glow Party →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luz-negra/" class="ps-link">Luz Negra UV</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />
  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
