---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    "pregunta": "¿Qué incluye el paquete UV Básico de Luz Neón LED?",
    "respuesta": "El paquete UV Básico incluye 2 barras uv led, montaje en truss, instalación y desmontaje. Todo con instalación profesional y desmontaje incluido. Nuestro equipo técnico llega con anticipación para montar y hacer pruebas."
  },
  {
    "pregunta": "¿Cuánto cuesta el paquete UV Básico?",
    "respuesta": "El paquete UV Básico de Luz Neón LED tiene un precio desde $2,800 MXN + IVA. Este precio incluye transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México."
  },
  {
    "pregunta": "¿Puedo personalizar el paquete UV Básico?",
    "respuesta": "Sí, todos nuestros paquetes son personalizables. Podemos agregar o quitar elementos según tus necesidades y presupuesto. Contáctanos por WhatsApp al 55 4937 5172 para una cotización a la medida."
  },
  {
    "pregunta": "¿En qué zonas entregan el paquete UV Básico?",
    "respuesta": "Cubrimos toda la Ciudad de México y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km de CDMX."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar el paquete UV Básico?",
    "respuesta": "Recomendamos reservar con 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp para verificar disponibilidad del equipo."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'UV Básico — Luz Neón LED | REDEIL',
    description: 'Introducción al mundo neón. 2 barras UV LED que transforman un espacio de 30m² en una experiencia visual llamativa ideal para fiestas casuales y decoraciones modernas.',
    image: SITE_URL + '/img/img-index/luz-neon.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '2800',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luz-neon/paquete-uv-basico/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '30',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="UV Básico — Luz Neón LED en CDMX | REDEIL"
  description="Introducción al mundo neón. 2 barras UV LED que transforman un espacio de 30m² en una experiencia visual llamativa ideal para fiestas casuales y decorac..."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luz Neón LED', href: '/renta-de-iluminacion/luz-neon/' }, { name: 'UV Básico', href: '/renta-de-iluminacion/luz-neon/paquete-uv-basico/' }]} />

  <Hero
    badge="UV Básico"
    title="UV Básico — Luz Neón LED"
    description="Introducción al mundo neón. 2 barras UV LED que transforman un espacio de 30m² en una experiencia visual llamativa ideal para fiestas casuales y decorac..."
    primaryCta={{ text: 'Cotizar $2,800 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luz-neon/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete UV Básico es perfecto para quienes quieren experimentar la magia de la iluminación neón sin una gran inversión. Con 2 barras UV LED montadas en truss, cubrimos hasta 30 metros cuadrados con luz ultravioleta que hace brillar colores fluorescentes.</p>
      <p>Incluye instalación y desmontaje profesional. Ideal para fiestas de cumpleaños, reuniones temáticas y espacios donde quieres agregar un elemento visual diferente. El montaje en truss garantiza una distribución uniforme de la luz UV.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luz Neón LED"
    items={[{ label: "Glow Party", href: "/renta-de-iluminacion/luz-neon/paquete-glow-party/" }, { label: "Neón Premium", href: "/renta-de-iluminacion/luz-neon/paquete-neon-premium/" }, { label: "Producción Neón", href: "/renta-de-iluminacion/luz-neon/paquete-produccion-neon/" }]}
  />

  <!-- QUÉ INCLUYE -->
  <section class="section" id="features">
    <div class="container">
      <h2 class="section__title">¿Qué incluye el paquete UV Básico?</h2>
      <p class="section__subtitle">Todo lo que necesitas para tu evento, sin sorpresas ni costos ocultos.</p>
      <div class="features-grid">
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>2 barras UV LED</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Montaje en truss</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Instalación y desmontaje</span></div>
        <div class="feature-item feature-item--yes"><span class="feature-icon">&#10003;</span><span>Cobertura 30m²</span></div>
        <div class="feature-item feature-item--no"><span class="feature-icon">&mdash;</span><span>Pintura neón</span></div>
        <div class="feature-item feature-item--no"><span class="feature-icon">&mdash;</span><span>Accesorios fluorescentes</span></div>
      </div>
      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">$2,800 MXN</span>
        <span class="price-highlight__note">+ IVA · Instalación incluida</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <!-- CONTENIDO SEO -->
  <section class="section section--bg">
    <div class="container content-prose">
      <h2>¿Por qué elegir el paquete UV Básico de luz neón LED?</h2>
      <p>El paquete UV Básico es perfecto para quienes quieren experimentar la magia de la iluminación neón sin una gran inversión. Con 2 barras UV LED montadas en truss, cubrimos hasta 30 metros cuadrados con luz ultravioleta que hace brillar colores fluorescentes.</p>
      <p>Incluye instalación y desmontaje profesional. Ideal para fiestas de cumpleaños, reuniones temáticas y espacios donde quieres agregar un elemento visual diferente. El montaje en truss garantiza una distribución uniforme de la luz UV.</p>
      <h3>¿Para quién es este paquete?</h3>
      <p>El paquete UV Básico de luz neón led está diseñado para eventos íntimos y presupuestos ajustados. Con equipo profesional de marcas líderes y servicio técnico especializado, garantizamos resultados impecables.</p>
      <h3>Servicio profesional de luz neón led</h3>
      <p>En REDEIL llevamos más de 10 años ofreciendo renta de luz neón led en CDMX y Estado de México. Nuestro equipo técnico se encarga de todo: logística, transporte, instalación, configuración, operación durante el evento y desmontaje. Trabajamos con equipo profesional para garantizar que cada evento sea perfecto.</p>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <!-- CTA FINAL -->

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .section__subtitle {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: var(--border-radius);
    font-size: var(--font-size-sm);
  }
  .feature-item--yes {
    background: #f0fdf4;
    color: #166534;
  }
  .feature-item--no {
    background: var(--color-bg);
    color: var(--color-text-light);
  }
  .feature-icon {
    font-weight: 700;
    font-size: 1.125rem;
    flex-shrink: 0;
  }
  .price-highlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    background: var(--color-bg);
    border-radius: var(--border-radius-lg);
    text-align: center;
  }
  .price-highlight__label {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .price-highlight__amount {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
  }
  .price-highlight__note {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }
  .content-prose {
    max-width: 800px;
    margin: 0 auto;
  }
  .content-prose h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .content-prose h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }
  .content-prose p {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
</style>
