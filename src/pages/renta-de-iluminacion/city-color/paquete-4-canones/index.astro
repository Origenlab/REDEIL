---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 4 Cañones City Color LED?',
    respuesta: 'Incluye 4 cañones LED RGBW de alto impacto, controlador de color, cable profesional, transporte, instalación, técnico operador durante el evento y desmontaje. El equipo llega 2 horas antes para instalar, calibrar y hacer pruebas de encendido.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 4 Cañones City Color LED?',
    respuesta: 'El paquete tiene un precio desde $4,500 MXN + IVA. Incluye todo: transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos ni cargos extra por cable o soportes.'
  },
  {
    pregunta: '¿Para qué tamaño de espacio son suficientes 4 cañones?',
    respuesta: '4 cañones cubren perfectamente una fachada de hasta 8 metros de ancho, una entrada o recepción, o el backdrop principal de un salón chico. Son ideales para crear un punto focal de color sin saturar todo el espacio.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 4 Cañones?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con un cargo de traslado mínimo.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, escríbenos por WhatsApp — verificamos disponibilidad al momento y confirmamos en menos de una hora.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '4 Cañones — City Color LED | REDEIL',
    description: 'Paquete 4 Cañones City Color LED para bañar fachadas y entradas en color. Ideal para eventos íntimos, backdoors y recepciones en CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/city-color.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/city-color/paquete-4-canones/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '34',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="4 Cañones — City Color LED en CDMX | REDEIL"
  description="Paquete 4 Cañones City Color LED para eventos en CDMX. Baña tu fachada o entrada en el color de tu evento. Instalación profesional, técnico incluido. Desde $4,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'City Color LED', href: '/renta-de-iluminacion/city-color/' }, { name: '4 Cañones', href: '/renta-de-iluminacion/city-color/paquete-4-canones/' }]} />

  <Hero
    badge="4 Cañones — City Color LED"
    title="4 Cañones City Color LED — Fachada o Entrada en Color"
    description="Cuatro cañones LED RGBW de alto impacto para transformar la entrada, el backdrop o la fachada de tu evento. Color sólido, vibrante y profesional desde $4,500 MXN."
    primaryCta={{ text: 'Cotizar $4,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/city-color/' }}
  >
    <Fragment slot="hero-seo">
      <p>Con <strong>4 cañones City Color LED</strong> transformas una entrada, un telón de fondo o una fachada pequeña en un punto focal de color puro. Son los cañones que hacen que los invitados digan "wow" al llegar — antes de que empiece el evento. Cubren hasta 8 metros de ancho con luz uniforme y saturada en cualquier color RGBW.</p>
      <p>Este paquete es perfecto para eventos de hasta 80 invitados donde quieres un impacto visual concentrado: la zona de fotos, el altar, la entrada principal o el escenario del DJ. Incluye técnico operador que cambia los colores en tiempo real según el momento del evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de City Color LED"
    items={[{ label: "8 Cañones", href: "/renta-de-iluminacion/city-color/paquete-8-canones/" }, { label: "16 Cañones", href: "/renta-de-iluminacion/city-color/paquete-16-canones/" }, { label: "Producción", href: "/renta-de-iluminacion/city-color/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/city-color.avif" alt="4 cañones City Color LED bañando fachada en color azul evento CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/city-color.avif" alt="Cañón LED RGBW iluminando entrada de salón en rojo" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Backdrop de boda bañado en color amber con cañones LED" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Técnico configurando cañón city color en evento" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="4 cañones city color instalados en piso apuntando a pared" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Inicial — Impacto concentrado</span>
            <h2 class="prod-info__title">4 Cañones City Color LED — Color saturado en tu punto focal</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Un punto focal de color que nadie olvida</h2>
            <p class="prod-selling__intro">4 cañones no llenan un salón — lo definen. En lugar de iluminar todo con un color suave, este paquete crea un impacto concentrado: la fachada de tu hacienda bañada en azul rey, el backdrop de tu boda en blush, la entrada de tu evento en el color corporativo de tu empresa. Cuando algo está completamente bañado en un color sólido, las fotos cambian, el ambiente cambia, la experiencia cambia.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Color RGBW puro — 16 millones de combinaciones, sin mezcla mediocre</h3>
                  <p class="prod-hl__desc">Los cañones City Color son RGBW: rojo, verde, azul y blanco en un solo foco. Eso significa que puedes obtener colores puros y brillantes que los cañones RGB convencionales no logran — especialmente pasteles suaves y blancos cálidos o fríos. Tu color de boda se ve exactamente como en el moodboard.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Fachada completa en un solo encendido — llegada que impresiona</h3>
                  <p class="prod-hl__desc">4 cañones posicionados estratégicamente bañan los primeros 8 metros de tu fachada en color uniforme sin zonas oscuras ni transiciones visibles. Tus invitados llegan y la primera imagen que ven ya es el evento. No hay decoración que compita con una pared de color real.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cambios de color en vivo — el evento tiene actos distintos</h3>
                  <p class="prod-hl__desc">El técnico opera los cañones en tiempo real. Llegada con blanco cálido, cena con azul rey, primer baile con rojo pasión, festejo con multicolor. Sin programación previa, sin controles complicados — tú avisas y el técnico ejecuta en segundos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Fotos que no necesitan edición — el color ya está ahí</h3>
                  <p class="prod-hl__desc">Un fondo bañado en color sólido hace que cualquier foto se vea producida. Sin importar la cámara del invitado, el color está en el ambiente: no en un filtro. Los fotógrafos profesionales saben esto — es por eso que los piden en todos sus eventos de alto perfil.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 cañones City Color LED RGBW</div>
              <div class="prod-feat">Controlador de color incluido</div>
              <div class="prod-feat">Cable profesional calibre correcto</div>
              <div class="prod-feat">Soportes y trípodes de piso</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y alineación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Cambios de color en tiempo real</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Extensiones y multicontactos incluidos</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Dinos qué quieres iluminar</h4>
                  <p class="prod-step__desc">Fachada, entrada, backdrop o escenario — con esa información y las dimensiones del espacio diseñamos la distribución exacta de los 4 cañones para cobertura uniforme.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización confirmada en 24 horas</h4>
                  <p class="prod-step__desc">Recibes propuesta con precio final, colores disponibles y plan de instalación. Si tu venue está fuera de CDMX, incluimos el costo de traslado sin sorpresas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada al confirmar. Aceptamos transferencia, efectivo o tarjeta. El 50% restante se liquida el día del evento o antes.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 2 horas antes y nos quedamos hasta el final</h4>
                  <p class="prod-step__desc">El equipo instala, alinea y hace pruebas de color. Durante el evento el técnico opera en vivo. Al terminar desmontamos sin que tú tengas que hacer nada.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿4 cañones o necesitas más?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sin cañones City Color</span>
                <ul class="prod-compare__list">
                  <li>Pared o fachada sin carácter</li>
                  <li>Fotos con fondo plano</li>
                  <li>Un solo ambiente todo el evento</li>
                  <li>Decoración cargando todo el trabajo visual</li>
                  <li>Entrada sin impacto</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">4 Cañones City Color LED</span>
                <ul class="prod-compare__list">
                  <li>Punto focal de color sólido y vibrante</li>
                  <li>Fotos con contexto cromático profesional</li>
                  <li>Colores diferentes por momento del evento</li>
                  <li>El color hace el trabajo, la decoración descansa</li>
                  <li>Llegada que sorprende desde la calle</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Renté los 4 cañones para iluminar la fachada de mi hacienda en color dorado para la entrada de la quinceañera. Mis invitados llegaron y se quedaron parados tomando fotos antes de entrar. El técnico estuvo todo el tiempo y cambió a azul cuando empezó el vals. Lo que costó no tiene comparación con cómo quedó."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Adriana Fuentes</span>
                <span class="prod-quote__event">XV años en Hacienda Los Morales — CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones incluidos</dt><dd>4 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>City Color RGBW</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 8 m de ancho</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Controlador incluido</dd></div>
              <div class="ps-specs__row"><dt>Colores</dt><dd>16M combinaciones</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Bodas íntimas</span>
              <span class="ps-tag">Fachadas pequeñas</span>
              <span class="ps-tag">Zona de fotos</span>
              <span class="ps-tag">Entradas de eventos</span>
              <span class="ps-tag">Backdrops corporativos</span>
              <span class="ps-tag">Cenas privadas</span>
              <span class="ps-tag">Eventos hasta 80 personas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/city-color/paquete-8-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="8 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">8 Cañones</span>
                <span class="ps-pkg__price">$7,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-color/paquete-16-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="16 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">16 Cañones</span>
                <span class="ps-pkg__price">$13,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-color/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="Producción City Color 24+ cañones" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 24+</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Quieres iluminar fachada completa y salón? El paquete de 8 cañones cubre ambos espacios sin comprometer intensidad.</p>
              <a href="/renta-de-iluminacion/city-color/paquete-8-canones/" class="ps-upsell__link">Ver paquete 8 Cañones →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light — Par LED</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting arquitectónico</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas móviles</a>
              <a href="/renta-de-iluminacion/iluminacion-laser/" class="ps-link">Iluminación Láser</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas LED Edison</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
