---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción City Color LED?',
    respuesta: 'Incluye 24 o más cañones City Color LED RGBW según el venue, consola DMX profesional de espectáculo, director de iluminación, diseño personalizado de secuencias y escenas, visita de inspección previa, instalación completa, operación durante el evento y desmontaje. Es el servicio más completo que ofrecemos.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción City Color LED?',
    respuesta: 'El paquete Producción tiene un precio desde $22,000 MXN + IVA. El precio final depende del número de cañones necesarios, tamaño del venue y complejidad del diseño. Incluye visita previa, diseño de iluminación, todo el equipo, director e instalación completa.'
  },
  {
    pregunta: '¿En qué se diferencia el director de iluminación del técnico operador?',
    respuesta: 'El técnico operador ejecuta los cambios de color según indicaciones básicas. El director de iluminación diseña el show completo: coreografía de colores sincronizada con música, momentos dramáticos calculados, transiciones artísticas y uso del color como herramienta narrativa del evento. Es la diferencia entre operar y dirigir.'
  },
  {
    pregunta: '¿El paquete Producción incluye diseño previo del show de iluminación?',
    respuesta: 'Sí. Incluye visita de inspección al venue, reunión de diseño con el cliente, plano de iluminación con posición de cada cañón, storyboard de colores por momento del evento, y prueba de color previa si el venue lo permite. Todo documentado y aprobado antes del evento.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete Producción?',
    respuesta: 'Mínimo 8 semanas de anticipación para poder hacer la visita, diseñar el show y coordinar logística. Para eventos de alta producción recomendamos 3 a 4 meses. El director de iluminación solo puede tomar un evento por fecha, así que la reserva anticipada es crítica.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — City Color LED | REDEIL',
    description: 'Producción completa City Color LED con 24+ cañones, director de iluminación y diseño personalizado. Para bodas y eventos de alto perfil en CDMX.',
    image: SITE_URL + '/img/img-index/city-color.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '22000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/city-color/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '22',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción — City Color LED en CDMX | REDEIL"
  description="Producción completa City Color LED: 24+ cañones, director de iluminación y show de color personalizado. Para bodas y eventos de alto perfil en CDMX. Desde $22,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'City Color LED', href: '/renta-de-iluminacion/city-color/' }, { name: 'Producción', href: '/renta-de-iluminacion/city-color/paquete-produccion/' }]} />

  <Hero
    badge="Producción — City Color LED"
    title="Producción City Color LED — Show de Color con Director de Iluminación"
    description="El nivel más alto de iluminación cromática para eventos. 24+ cañones RGBW, consola de espectáculo y director de iluminación que diseña el show completo. Desde $22,000 MXN."
    primaryCta={{ text: 'Cotizar $22,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/city-color/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete Producción de <strong>City Color LED</strong> no es renta de equipo — es un servicio de dirección artística de iluminación. Con 24 o más cañones RGBW, una consola de espectáculo profesional y un director de iluminación dedicado, transformamos cualquier venue en un escenario de alto impacto visual donde cada momento del evento tiene su propio show de color.</p>
      <p>Bodas con entrada de novios en cascada de luz blanca que transiciona a rojo, cenas corporativas donde el color de marca baña el espacio entero, XV años con shows de color sincronizados con la música en vivo. No es tecnología — es experiencia diseñada con luz.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de City Color LED"
    items={[{ label: "4 Cañones", href: "/renta-de-iluminacion/city-color/paquete-4-canones/" }, { label: "8 Cañones", href: "/renta-de-iluminacion/city-color/paquete-8-canones/" }, { label: "16 Cañones", href: "/renta-de-iluminacion/city-color/paquete-16-canones/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/city-color.avif" alt="Producción City Color LED con 24 cañones en boda de alto perfil CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/city-color.avif" alt="Show de color con transición de azul a rojo en entrada de novios" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Director de iluminación operando consola de espectáculo DMX" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Hacienda entera en producción de color con 24 cañones LED" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Show de iluminación city color sincronizado con orquesta en vivo" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Producción — Nivel espectáculo</span>
            <h2 class="prod-info__title">Producción City Color LED — El color como experiencia narrativa</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$22,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Incluye: visita previa, diseño de show, 24+ cañones, consola de espectáculo, director de iluminación e instalación completa</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando la luz cuenta la historia de tu evento</h2>
            <p class="prod-selling__intro">En una producción, el color no decora — narra. El director de iluminación trabaja contigo antes del evento para diseñar un storyboard de luz: qué color en qué momento, qué transición para cada acto, qué efecto para la entrada de los novios. El resultado es un evento donde la luz tiene dirección artística, no solo temperatura y cantidad.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de iluminación — el único que puede diseñar el show, no solo operarlo</h3>
                  <p class="prod-hl__desc">No es un técnico que cambia colores según instrucciones. Es un director artístico que sabe cuándo hacer una transición lenta de 30 segundos para crear tensión dramática antes del vals, cuándo un flash de blanco intenso hace que el momento se grabe en la memoria, y cuándo el silencio de color es más poderoso que cualquier efecto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">24+ cañones — cero zonas sin color en cualquier venue</h3>
                  <p class="prod-hl__desc">Con 24 o más cañones posicionados según el diseño específico del venue, eliminamos cualquier zona sin iluminación. Columnas, arcos, jardines laterales, escaleras, techos abovedados. Cada centímetro del espacio forma parte del diseño de color. No hay rincón que la cámara capture sin intención.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Consola de espectáculo — sincronización precisa con música y protocolo del evento</h3>
                  <p class="prod-hl__desc">La consola que usamos es la misma que utilizan los conciertos y producciones de TV. Permite sincronización musical automática, programación de hasta 500 escenas, transiciones en fracciones de segundo y efectos imposibles con controladores convencionales. El show de luz respira con la música.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Diseño previo documentado — sin improvisaciones el día del evento</h3>
                  <p class="prod-hl__desc">Antes del evento recibes un storyboard completo: diagrama de posiciones, paleta de colores por zona, secuencia de cambios por momento, tiempos de transición y plan de contingencia. El día del evento, el director ejecuta un diseño aprobado. No hay sorpresas — solo precisión.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">24+ cañones City Color LED RGBW</div>
              <div class="prod-feat">Consola de espectáculo profesional</div>
              <div class="prod-feat">Director de iluminación dedicado</div>
              <div class="prod-feat">Visita de inspección al venue</div>
              <div class="prod-feat">Diseño de show con storyboard</div>
              <div class="prod-feat">Programación de 500+ escenas</div>
              <div class="prod-feat">Sincronización musical automática</div>
              <div class="prod-feat">Coordinación con otros proveedores</div>
              <div class="prod-feat">Instalación 4 horas antes del evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio de producción</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de briefing y visita al venue</h4>
                  <p class="prod-step__desc">El director de iluminación se reúne contigo para entender la identidad visual del evento, recorre el venue y documenta todo lo necesario para diseñar el show. Esta visita es incluida en el paquete.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Diseño del show con storyboard</h4>
                  <p class="prod-step__desc">Recibes un documento completo con diagrama de posiciones, paleta por zona, secuencia de colores por momento del evento y efectos programados. Revisamos y aprobamos juntos antes de confirmar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirmación y coordinación logística</h4>
                  <p class="prod-step__desc">Con 50% de anticipo bloqueamos la fecha y el equipo. El director coordina con el venue, el DJ o banda y otros proveedores para garantizar sincronía perfecta el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Producción completa el día del evento</h4>
                  <p class="prod-step__desc">El equipo llega 4 horas antes para instalación, programación de la consola y prueba general de color. El director opera durante todo el evento ejecutando el show diseñado. Al terminar, desmontamos sin dejar rastro.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué producción y no 16 cañones?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">16 Cañones — Premium</span>
                <ul class="prod-compare__list">
                  <li>Técnico operador en tiempo real</li>
                  <li>4 zonas independientes</li>
                  <li>Consola DMX avanzada</li>
                  <li>Cambios según indicaciones del cliente</li>
                  <li>Sin diseño previo de show</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción — 24+ cañones</span>
                <ul class="prod-compare__list">
                  <li>Director artístico de iluminación</li>
                  <li>Zonas ilimitadas según venue</li>
                  <li>Consola de espectáculo profesional</li>
                  <li>Show diseñado y aprobado antes del evento</li>
                  <li>Storyboard de color con cada momento</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos la producción completa para la boda de nuestros hijos en el Museo Soumaya. El director de iluminación se reunió con nosotros tres veces antes del evento para diseñar el show. El resultado fue algo que no sé describir con palabras — cada momento tenía su color, su transición, su intención. Cuando los novios entraron y el espacio pasó de azul profundo a blanco puro, toda la sala se quedó en silencio. Nuestro videógrafo dijo que fue el mejor evento que había filmado en 15 años."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Eduardo y Cristina Villanueva</span>
                <span class="prod-quote__event">Boda en Museo Soumaya — Miguel Hidalgo, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones</dt><dd>24+ según venue</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>City Color RGBW pro</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Consola de espectáculo</dd></div>
              <div class="ps-specs__row"><dt>Director</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Diseño previo</dt><dd>Storyboard completo</dd></div>
              <div class="ps-specs__row"><dt>Escenas</dt><dd>500+ programables</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>4 h antes</dd></div>
              <div class="ps-specs__row"><dt>Visita previa</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex + foráneo</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas de alto perfil</span>
              <span class="ps-tag">Eventos +500 personas</span>
              <span class="ps-tag">Venues históricos</span>
              <span class="ps-tag">Galas corporativas</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Conciertos y festivales</span>
              <span class="ps-tag">Producciones con orquesta</span>
              <span class="ps-tag">Eventos con transmisión en vivo</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/city-color/paquete-4-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="4 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cañones</span>
                <span class="ps-pkg__price">$4,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-color/paquete-8-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="8 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">8 Cañones</span>
                <span class="ps-pkg__price">$7,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-color/paquete-16-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="16 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">16 Cañones</span>
                <span class="ps-pkg__price">$13,500 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Presupuesto más ajustado? El paquete de 16 cañones ofrece 4 zonas independientes con consola DMX avanzada.</p>
              <a href="/renta-de-iluminacion/city-color/paquete-16-canones/" class="ps-upsell__link">Ver paquete 16 Cañones →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización personalizada con diseño de iluminación incluido. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas móviles</a>
              <a href="/renta-de-iluminacion/seguidor-de-luz/" class="ps-link">Seguidor de Luz</a>
              <a href="/renta-de-iluminacion/iluminacion-laser/" class="ps-link">Iluminación Láser</a>
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light — Par LED</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting arquitectónico</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
