---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 16 Cañones City Color LED?',
    respuesta: 'Incluye 16 cañones LED RGBW profesionales, consola DMX avanzada, distribución en múltiples zonas independientes, cable profesional, soportes, transporte, instalación, técnico operador dedicado durante el evento y desmontaje completo. Permite crear hasta 4 zonas de color simultáneas.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 16 Cañones City Color LED?',
    respuesta: 'El paquete tiene un precio desde $13,500 MXN + IVA. Incluye transporte, instalación multi-zona, consola DMX, técnico operador y desmontaje dentro de CDMX y Estado de México. Costo de traslado adicional fuera de esa zona.'
  },
  {
    pregunta: '¿Para qué tamaño de evento son necesarios 16 cañones?',
    respuesta: 'El paquete de 16 cañones está diseñado para haciendas, jardines grandes (más de 1,500 m²) o producciones con múltiples escenarios simultáneos. Cubre eventos de 200 a 500 invitados donde se necesita iluminación completa sin zonas sin color.'
  },
  {
    pregunta: '¿Cuántas zonas independientes de color puedo tener con 16 cañones?',
    respuesta: 'Con la consola DMX incluida puedes tener hasta 4 zonas de color completamente independientes: fachada, jardín, salón interior y escenario, cada uno con su propio color y programa. Todas operadas por el técnico en tiempo real.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete de 16 cañones?',
    respuesta: 'Recomendamos 6 a 8 semanas de anticipación para este paquete, ya que requiere coordinación adicional de equipo y logística. En temporada alta (noviembre-febrero) el equipo se reserva con hasta 3 meses de anticipación.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '16 Cañones — City Color LED | REDEIL',
    description: 'Paquete 16 Cañones City Color LED para haciendas y jardines grandes. 4 zonas de color independientes con consola DMX. Para eventos 200-500 invitados en CDMX.',
    image: SITE_URL + '/img/img-index/city-color.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '13500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/city-color/paquete-16-canones/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="16 Cañones — City Color LED en CDMX | REDEIL"
  description="Paquete 16 Cañones City Color LED para haciendas y eventos grandes. 4 zonas independientes de color con consola DMX. Ideal para 200-500 invitados. Desde $13,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'City Color LED', href: '/renta-de-iluminacion/city-color/' }, { name: '16 Cañones', href: '/renta-de-iluminacion/city-color/paquete-16-canones/' }]} />

  <Hero
    badge="16 Cañones — City Color LED"
    title="16 Cañones City Color LED — Hacienda Entera en Color"
    description="Producción media de iluminación en color para haciendas, jardines y eventos de 200 a 500 invitados. Cuatro zonas de color independientes con consola DMX. Desde $13,500 MXN."
    primaryCta={{ text: 'Cotizar $13,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/city-color/' }}
  >
    <Fragment slot="hero-seo">
      <p>Con <strong>16 cañones City Color LED</strong> el evento entero vive en color. No hay entrada, jardín, salón ni escenario sin iluminación cromática profesional. Cada zona tiene su propio color, su propia identidad visual, y su propio programa de escenas controlado desde consola DMX.</p>
      <p>Es el paquete que eligen los planners para bodas en haciendas históricas de CDMX y Valle de Bravo donde la arquitectura merece ser tratada como escenario. Las columnas bañadas en dorado, el jardín en verde esmeralda, el salón en azul profundo y el escenario en rojo cereza — todo al mismo tiempo, todo controlado por un técnico dedicado.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de City Color LED"
    items={[{ label: "4 Cañones", href: "/renta-de-iluminacion/city-color/paquete-4-canones/" }, { label: "8 Cañones", href: "/renta-de-iluminacion/city-color/paquete-8-canones/" }, { label: "Producción", href: "/renta-de-iluminacion/city-color/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/city-color.avif" alt="16 cañones City Color LED iluminando hacienda entera en producción media" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/city-color.avif" alt="Jardín de hacienda bañado en colores múltiples con 16 cañones LED" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Columnas de hacienda iluminadas en dorado con cañones RGBW" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Consola DMX operada por técnico REDEIL en evento" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-color.avif" alt="Vista panorámica de hacienda con iluminación city color completa" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Premium — Producción media completa</span>
            <h2 class="prod-info__title">16 Cañones City Color LED — Cuatro zonas, cuatro colores, una producción</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$13,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación multi-zona, consola DMX, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando el color no es decoración — es arquitectura</h2>
            <p class="prod-selling__intro">16 cañones convierte cada elemento arquitectónico de tu venue en parte del diseño de tu evento. Las columnas de cantera ya no son beige — son doradas. El jardín colonial ya no es negro en la noche — es esmeralda. La escalera principal ya no desaparece después del sol — es el centro visual del evento. El color no embellece el espacio, lo rediseña.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cuatro zonas independientes — el evento que nunca se ve igual</h3>
                  <p class="prod-hl__desc">Fachada, jardín, salón y escenario con colores completamente distintos y programas independientes. La consola DMX permite cambiar las cuatro zonas de manera coordinada o individual. Cada zona tiene su propio universo cromático.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Haciendas históricas transformadas — la arquitectura como lienzo</h3>
                  <p class="prod-hl__desc">Las haciendas y salones coloniales de CDMX tienen elementos que cobran vida con color: arcos, columnas, techos abovedados. 16 cañones posicionados estratégicamente convierten la arquitectura en el elemento de diseño más impactante de tu evento. Sin florería que compita.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Consola DMX avanzada — sincronización con música y momentos</h3>
                  <p class="prod-hl__desc">La consola DMX de este paquete permite programar transiciones automáticas, sincronizar cambios de color con la música en vivo, y ejecutar secuencias pre-programadas para momentos específicos: entrada de novios, vals, brindis. El técnico las ejecuta en el momento exacto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura total sin zonas muertas — 1,500 m² en color uniforme</h3>
                  <p class="prod-hl__desc">16 cañones distribuidos profesionalmente eliminan las zonas sin color que arruinan fotos y videos. No hay esquina oscura, no hay columna sin iluminar, no hay rincón donde el color se pierda. El evento entero vive en la paleta que elegiste.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">16 cañones City Color LED RGBW</div>
              <div class="prod-feat">Consola DMX avanzada con programación</div>
              <div class="prod-feat">Hasta 4 zonas de color independientes</div>
              <div class="prod-feat">Transiciones y secuencias pre-programadas</div>
              <div class="prod-feat">Cable profesional de alta capacidad</div>
              <div class="prod-feat">Soportes, trípodes y clamps de techo</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y diseño de posiciones</div>
              <div class="prod-feat">Técnico operador dedicado durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Visita de inspección o planos del venue</h4>
                  <p class="prod-step__desc">Para eventos de este tamaño hacemos una visita previa o analizamos los planos del venue para diseñar la distribución exacta de 16 cañones y anticipar necesidades eléctricas y logísticas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Diseño de iluminación con zonas y paleta</h4>
                  <p class="prod-step__desc">Recibes un diagrama de iluminación con posición de cada cañón, zonas definidas, paleta de colores por zona y secuencias de cambio durante el evento. Todo aprobado antes de la fecha.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirmación con 50% de anticipo</h4>
                  <p class="prod-step__desc">La fecha queda bloqueada y el equipo reservado. Incluimos coordinación con el venue y otros proveedores para garantizar acceso eléctrico suficiente y tiempos de montaje.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación 3 horas antes — producción completa</h4>
                  <p class="prod-step__desc">El equipo llega con 3 horas de anticipación, instala, programa la consola DMX con todas las secuencias acordadas y hace prueba general de color. El técnico opera durante todo el evento.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 16 y no 8 cañones?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">8 Cañones — Estándar</span>
                <ul class="prod-compare__list">
                  <li>2 zonas máximo simultáneas</li>
                  <li>Cobertura hasta 16 m de fachada</li>
                  <li>Control DMX básico</li>
                  <li>Ideal para salones medianos</li>
                  <li>80-200 invitados</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">16 Cañones — Premium</span>
                <ul class="prod-compare__list">
                  <li>4 zonas completamente independientes</li>
                  <li>Hacienda o jardín entero cubierto</li>
                  <li>Consola DMX con programación</li>
                  <li>Para haciendas y producciones grandes</li>
                  <li>200-500 invitados sin zonas sin color</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Para la boda de mi hija en Hacienda de los Morales contratamos el paquete de 16 cañones. Dividimos los colores en cuatro zonas: la fachada en champagne, el jardín en verde suave, el salón en rosa palo y el escenario de la orquesta en dorado. Nuestro fotógrafo dijo que era la primera vez que veía un evento donde cada foto de cada zona se veía como producción editorial."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Lucía Montoya</span>
                <span class="prod-quote__event">Boda en Hacienda de los Morales — Miguel Hidalgo, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cañones incluidos</dt><dd>16 unidades</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>City Color RGBW</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 1,500 m²</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Consola DMX avanzada</dd></div>
              <div class="ps-specs__row"><dt>Zonas</dt><dd>Hasta 4 independientes</dd></div>
              <div class="ps-specs__row"><dt>Programación</dt><dd>Secuencias incluidas</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Dedicado al evento</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>3 h antes</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Jardines grandes</span>
              <span class="ps-tag">200-500 invitados</span>
              <span class="ps-tag">Producciones con orquesta</span>
              <span class="ps-tag">Galas corporativas</span>
              <span class="ps-tag">Eventos con múltiples salones</span>
              <span class="ps-tag">XV años de producción</span>
              <span class="ps-tag">Lanzamientos de marca</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/city-color/paquete-4-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="4 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Cañones</span>
                <span class="ps-pkg__price">$4,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-color/paquete-8-canones/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="8 Cañones City Color" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">8 Cañones</span>
                <span class="ps-pkg__price">$7,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-color/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/city-color.avif" alt="Producción City Color 24+" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 24+</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Necesitas director de iluminación y diseño personalizado de escenas? El paquete Producción incluye 24+ cañones y dirección artística completa.</p>
              <a href="/renta-de-iluminacion/city-color/paquete-produccion/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light — Par LED</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas móviles</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting arquitectónico</a>
              <a href="/renta-de-iluminacion/iluminacion-laser/" class="ps-link">Iluminación Láser</a>
              <a href="/renta-de-iluminacion/seguidor-de-luz/" class="ps-link">Seguidor de Luz</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
