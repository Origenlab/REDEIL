---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de Producción de Cabezas Móviles?',
    respuesta: 'Incluye 12 o más cabezas móviles (beam, wash, spot y hybrid según el diseño), consola MA de producción, director de luces a cargo del show, equipo técnico completo, truss y estructura de colgado, transporte, montaje completo, producción del show y desmontaje. Para conciertos, festivales, shows de artistas y televisión.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de Producción de Cabezas Móviles?',
    respuesta: 'El precio base es desde $24,000 MXN + IVA. El costo final varía según el número exacto de cabezas, dimensiones del espacio, necesidades de estructura (truss) y días de producción. Contáctanos con los detalles de tu evento para una cotización a la medida.'
  },
  {
    pregunta: '¿Cuál es la diferencia entre el paquete de Producción y el Show Premium?',
    respuesta: 'El paquete de Producción está diseñado para escala de concierto y televisión: 12+ cabezas (vs 8 del Premium), consola MA de nivel tour (vs DMX estándar), director de luces con experiencia en producción profesional, y posibilidad de incluir estructura de truss para colgado en espacios sin infraestructura. Es la solución para cuando el evento necesita nivel de producción real.'
  },
  {
    pregunta: '¿El paquete de Producción incluye la estructura de truss?',
    respuesta: 'Sí, en la mayoría de los casos incluimos truss o estructura de colgado según el espacio. Para conciertos y festivales al aire libre esto es fundamental. El director de diseño evalúa el espacio y define la configuración de estructura óptima para el show.'
  },
  {
    pregunta: '¿Tienen experiencia en producción para televisión o transmisiones en vivo?',
    respuesta: 'Sí. Nuestro equipo de producción tiene experiencia en eventos transmitidos en vivo, programas de televisión, conferencias con cobertura mediática y festivales. El diseño de iluminación considera las necesidades técnicas de cámaras: temperatura de color, niveles de exposición y control de sombras. Contáctanos con los detalles de tu proyecto.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — Cabezas Móviles | REDEIL',
    description: '12+ cabezas móviles nivel tour con consola MA y director de luces. Para conciertos, festivales, shows de artistas y televisión en CDMX.',
    image: SITE_URL + '/img/img-index/pro/cabezas-moviles.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '24000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cabezas-moviles/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '17',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción — Cabezas Móviles en CDMX | REDEIL"
  description="12+ cabezas móviles nivel tour con consola MA y director de luces. Para conciertos, festivales y shows de artistas en CDMX. Producción profesional de iluminación."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cabezas Móviles', href: '/renta-de-iluminacion/cabezas-moviles/' }, { name: 'Producción', href: '/renta-de-iluminacion/cabezas-moviles/paquete-produccion/' }]} />

  <Hero
    badge="Producción — Cabezas Móviles"
    title="Producción — Cabezas Móviles"
    description="Producción de iluminación nivel tour — 12+ cabezas robotizadas con director de luces. Consola MA, equipo completo y estructura para conciertos y festivales en CDMX."
    primaryCta={{ text: 'Cotizar $24,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cabezas-moviles/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de <strong>Producción de Cabezas Móviles</strong> de REDEIL es la solución para eventos que requieren <strong>iluminación de nivel concierto o televisión</strong> en <strong>CDMX y Edomex</strong>. Con 12 o más cabezas entre beam, wash, spot y hybrid, consola MA de producción y un director de luces con experiencia en tours, el resultado es un show visual de nivel profesional.</p>
      <p>Para <strong>conciertos, festivales, shows de artistas, eventos corporativos masivos y producciones de televisión</strong> con 300 o más asistentes. El equipo de producción REDEIL diseña, monta y opera todo — tú te enfocas en el evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cabezas Móviles"
    items={[{ label: "Show Básico", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/" }, { label: "Show Estándar", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" }, { label: "Show Premium", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Producción cabezas móviles 12+ en concierto festival CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="12 cabezas móviles en truss concierto nivel tour" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Director de luces operando consola MA producción" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show de producción iluminación festival México" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Equipo técnico REDEIL montando producción de luces" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Producción — Nivel concierto y televisión</span>
            <h2 class="prod-info__title">12+ Cabezas Móviles con Consola MA y Director de Luces</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$24,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Precio base. Cotización final según número de cabezas, espacio y días de producción. Sin costos ocultos.</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Producción de iluminación nivel tour — 12+ cabezas robotizadas con director de luces</h2>
            <p class="prod-selling__intro">Hay eventos donde la iluminación no puede ser "suficientemente buena" — tiene que ser impecable. Conciertos, festivales, shows de artistas, lanzamientos de producto con producción visual, televisión en vivo. Para eso existe el paquete de Producción. No es una versión más grande del Show Premium — es una categoría diferente, con consola de nivel tour, director de luces con experiencia en producción real y capacidad de escalar a cualquier tamaño de espacio.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Consola MA de producción — la misma que usan los tours</h3>
                  <p class="prod-hl__desc">La consola grandMA es el estándar de la industria en producción de gira. Permite controlar docenas de cabezas con precisión, programar shows complejos con múltiples universos DMX y ejecutar cues con timing de milisegundos. Es lo que usan los espectáculos que salen en televisión.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de luces con experiencia en producción real</h3>
                  <p class="prod-hl__desc">No es un técnico que opera un show — es un director de luces que diseña el show. Con experiencia en conciertos, festivales y producción televisiva, nuestro director diseña el look de cada canción o momento, coordina con el equipo creativo del artista o cliente y ejecuta en vivo con precisión profesional.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">12+ cabezas de cuatro tipos — capacidad de cualquier escala</h3>
                  <p class="prod-hl__desc">Beam para efectos de rayo y columnas de luz, wash para banear el escenario en color, spot para enfocar intérpretes y momentos, hybrid para combinar efectos en una sola unidad. La combinación y cantidad se define según el diseño de producción de tu evento — no es un template fijo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">REDEIL vs rentadora genérica — la diferencia que se nota en pantalla</h3>
                  <p class="prod-hl__desc">Una rentadora genérica entrega el equipo y te manda a un técnico. REDEIL entrega producción: diseño previo, rider técnico, coordinación con producción general, prueba de sonido con luces, ensayo de show y operación de concierto en vivo. La diferencia no es el equipo — es el equipo humano.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">12+ cabezas móviles (beam/wash/spot/hybrid)</div>
              <div class="prod-feat">Consola MA de producción</div>
              <div class="prod-feat">Director de luces dedicado</div>
              <div class="prod-feat">Equipo técnico completo</div>
              <div class="prod-feat">Truss y estructura de colgado</div>
              <div class="prod-feat">Diseño de show previo al evento</div>
              <div class="prod-feat">Rider técnico y coordinación</div>
              <div class="prod-feat">Transporte y logística</div>
              <div class="prod-feat">Montaje y prueba de show</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Brief de producción y diseño del show</h4>
                  <p class="prod-step__desc">Recibimos el brief del evento: programa, artistas o momentos clave, dimensiones del espacio, presupuesto de producción. El director de luces diseña el concepto visual y genera el rider técnico de iluminación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y confirmación de producción</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con número de cabezas, configuración de truss, rider completo y precio final. Ajustamos según el presupuesto de producción del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Montaje de producción y ensayo técnico</h4>
                  <p class="prod-step__desc">Llegamos el día anterior o el mismo día con suficiente anticipación para montaje completo, programación de consola y ensayo técnico con todas las posiciones y efectos. Para eventos de TV, coordinamos con el director de fotografía.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Show en vivo con el equipo completo operando</h4>
                  <p class="prod-step__desc">El director de luces opera la consola MA en vivo con el equipo completo de soporte. Coordinación total con producción de audio, video y escenografía. Resultado: un show de producción profesional donde la luz es protagonista.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Rentadora genérica vs Producción profesional REDEIL</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Rentadora genérica</span>
                <ul class="prod-compare__list">
                  <li>Entrega equipo, sin diseño</li>
                  <li>Técnico básico de operación</li>
                  <li>Sin consola MA ni producción</li>
                  <li>Sin coordinación con producción</li>
                  <li>Sin rider ni diseño de show</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción REDEIL</span>
                <ul class="prod-compare__list">
                  <li>Diseño de show + rider técnico</li>
                  <li>Director de luces profesional</li>
                  <li>Consola MA nivel tour</li>
                  <li>Coordinación total de producción</li>
                  <li>Show completo de principio a fin</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos a REDEIL para el evento corporativo anual de nuestra empresa en el Pepsi Center con 1,200 asistentes. Lo que nos sorprendió fue el nivel de profesionalismo desde el día de producción: llegaron con el diseño listo, coordinaron con nuestro equipo de AV, hicieron el ensayo técnico completo y cuando arrancó el evento, cada momento tuvo su escena de luz perfecta. Varios invitados preguntaron si los artistas habían traído su propio equipo de producción."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Roberto Díaz, Director de Eventos</span>
                <span class="prod-quote__event">Evento corporativo anual — Pepsi Center WTC, CDMX — 1,200 asistentes</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cabezas móviles</dt><dd>12+ (beam/wash/spot/hybrid)</dd></div>
              <div class="ps-specs__row"><dt>Consola</dt><dd>MA de producción</dd></div>
              <div class="ps-specs__row"><dt>Director</dt><dd>Luces incluido</dd></div>
              <div class="ps-specs__row"><dt>Estructura</dt><dd>Truss incluido</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>300+ personas</dd></div>
              <div class="ps-specs__row"><dt>Diseño</dt><dd>Show personalizado</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Equipo completo</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Conciertos</span>
              <span class="ps-tag">Festivales</span>
              <span class="ps-tag">Shows de artistas</span>
              <span class="ps-tag">Televisión en vivo</span>
              <span class="ps-tag">300+ personas</span>
              <span class="ps-tag">Eventos corporativos masivos</span>
              <span class="ps-tag">Lanzamientos de producto</span>
              <span class="ps-tag">Producción audiovisual</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Básico 2 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Básico</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Estándar 4 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Estándar</span>
                <span class="ps-pkg__price">$7,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Premium 8 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Premium</span>
                <span class="ps-pkg__price">$13,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Necesitas iluminación para un evento más íntimo? El Show Premium incluye 8 cabezas y show coreografiado para 150-400 personas.</p>
              <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" class="ps-upsell__link">Ver Show Premium →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización a la medida para tu evento en menos de 24 horas.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
