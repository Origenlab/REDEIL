---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Show Premium de Cabezas Móviles?',
    respuesta: 'Incluye 8 cabezas móviles (4 beam + 2 wash + 2 spot), consola DMX profesional, 2 técnicos de iluminación dedicados, show coreografiado diseñado para tu evento, transporte, instalación completa y desmontaje. Todo en CDMX y Estado de México.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Show Premium de Cabezas Móviles?',
    respuesta: 'El precio es desde $13,000 MXN + IVA. Incluye 8 cabezas de tres tipos (beam, wash, spot), 2 técnicos, consola DMX, coreografía de luz personalizada y todo el servicio completo. Para producciones más grandes, consulta el paquete de Producción.'
  },
  {
    pregunta: '¿Qué hace diferente al Show Premium del Show Estándar?',
    respuesta: 'El Premium añade 4 cabezas más (total 8), suma cabezas spot para efectos de haz enfocado de largo alcance, incluye 2 técnicos operando simultáneamente y el show está coreografiado — no solo operado en vivo. Cada momento tiene su secuencia de luz diseñada específicamente para tu evento.'
  },
  {
    pregunta: '¿El Show Premium incluye diseño de show coreografiado?',
    respuesta: 'Sí. Antes del evento, nuestro equipo diseña una coreografía de luz específica para los momentos más importantes: entrada, vals, primera pieza de XV, sorpresa, hora loca. No es improvisación — es un show con guión visual preparado con anticipación.'
  },
  {
    pregunta: '¿Para qué tamaño de salón está diseñado el Show Premium?',
    respuesta: 'Está diseñado para espacios de 150 a 400 invitados. Funciona en salones de eventos grandes, haciendas con salón techado, jardines con estructura, terrazas amplias y recintos de eventos. Para eventos más grandes o exteriores sin estructura, recomendamos el paquete de Producción.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Show Premium — Cabezas Móviles | REDEIL',
    description: '8 cabezas móviles (4 beam + 2 wash + 2 spot) con consola DMX, 2 técnicos y show coreografiado. Para XV años de producción, bodas de lujo y galas en CDMX.',
    image: SITE_URL + '/img/img-index/pro/cabezas-moviles.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '13000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '29',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Show Premium — Cabezas Móviles en CDMX | REDEIL"
  description="8 cabezas móviles beam, wash y spot con consola DMX y show coreografiado. Para XV años de producción y bodas de lujo de 150-400 invitados en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cabezas Móviles', href: '/renta-de-iluminacion/cabezas-moviles/' }, { name: 'Show Premium', href: '/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/' }]} />

  <Hero
    badge="Show Premium — Cabezas Móviles"
    title="Show Premium — Cabezas Móviles"
    description="8 cabezas robotizadas con show coreografiado — el efecto que nadie olvida. Beam + wash + spot, consola DMX y 2 técnicos para XV años y bodas de lujo en CDMX."
    primaryCta={{ text: 'Cotizar $13,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cabezas-moviles/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Show Premium de Cabezas Móviles</strong> es el estándar de producción para <strong>XV años, bodas de lujo y galas</strong> en <strong>CDMX y Estado de México</strong>. Con 8 cabezas de tres tipos distintos operadas por 2 técnicos con un show coreografiado, el resultado es una experiencia visual que tus invitados van a recordar y comentar.</p>
      <p>No es solo iluminación dinámica — es un show con narrativa. Cada momento del evento tiene su propia secuencia diseñada: la entrada, el vals, la sorpresa, la hora loca. Diseñado para <strong>150 a 400 invitados</strong> en salones grandes y recintos de eventos de CDMX.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cabezas Móviles"
    items={[{ label: "Show Básico", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/" }, { label: "Show Estándar", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" }, { label: "Producción", href: "/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Paquete Show Premium 8 cabezas móviles en XV años salón grande" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="8 cabezas móviles beam wash spot en salón de eventos CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show coreografiado cabezas móviles XV años" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Consola DMX operada por técnico profesional" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show de luces premium en boda de lujo CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Show Premium — Producción para eventos de lujo</span>
            <h2 class="prod-info__title">8 Cabezas Móviles (Beam + Wash + Spot) con Consola DMX y 2 Técnicos</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$13,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 8 cabezas, consola DMX, 2 técnicos, show coreografiado, transporte, instalación y desmontaje</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">8 cabezas robotizadas con show coreografiado — el efecto que nadie olvida</h2>
            <p class="prod-selling__intro">Hay eventos que se recuerdan por años. Los XV años donde la quinceañera entró con un show de luces que nadie esperaba. La boda donde cuando sonó el vals, el salón entero se transformó en algo cinematográfico. El Show Premium existe para crear ese momento. 8 cabezas, 3 tipos de efecto, 2 técnicos y una coreografía de luz diseñada para tu evento — no un template genérico.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Show coreografiado — diseñado para tu evento, no un template</h3>
                  <p class="prod-hl__desc">Antes del evento diseñamos la coreografía de luz completa: qué cabezas se mueven en qué momento, qué colores, a qué velocidad. La entrada, el vals, la sorpresa, la hora loca — todo tiene su secuencia. Es un show con guión, no improvisación.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Tres tipos de cabeza — beam, wash y spot en uno</h3>
                  <p class="prod-hl__desc">Las 4 beam crean efectos de haz concentrado y dinámico. Las 2 wash envuelven el espacio en color. Las 2 spot enfocan la luz en puntos específicos — la quinceañera al entrar, los novios al vals. Tres tipos de efecto combinados crean profundidad visual que un solo tipo nunca logra.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 técnicos en vivo — uno en consola, uno supervisando</h3>
                  <p class="prod-hl__desc">Con 8 cabezas, la operación requiere dos personas. Un técnico opera la consola DMX ejecutando las secuencias. El segundo supervisa el equipo, ajusta posiciones y coordina con el equipo de sonido y el animador. Precisión profesional en cada momento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura total para salones de hasta 400 invitados</h3>
                  <p class="prod-hl__desc">8 cabezas posicionadas en puntos estratégicos garantizan que cada rincón del salón reciba el show completo. No hay zona muerta, no hay invitados que "no vieron nada". El efecto llega a todos y desde todos los ángulos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 cabezas móviles beam profesionales</div>
              <div class="prod-feat">2 cabezas móviles wash RGB</div>
              <div class="prod-feat">2 cabezas móviles spot</div>
              <div class="prod-feat">Consola DMX profesional</div>
              <div class="prod-feat">2 técnicos de iluminación</div>
              <div class="prod-feat">Show coreografiado personalizado</div>
              <div class="prod-feat">Soportes y herraje completo</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de producción previa al evento</h4>
                  <p class="prod-step__desc">Hablamos contigo sobre el programa del evento: tiempos, momentos especiales, música de cada secuencia. Con esa información diseñamos la coreografía de luz específica para tu celebración.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización y confirmación de fecha</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con distribución de las 8 cabezas, secuencias propuestas y precio final. Reservas con el 50% de anticipo para confirmar.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 3 horas antes para instalación completa</h4>
                  <p class="prod-step__desc">Con 8 cabezas, el montaje requiere más tiempo. Llegamos 3 horas antes para instalar, posicionar, programar la consola con las secuencias de tu evento y hacer ensayo completo de todas las escenas.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Show en vivo de principio a fin</h4>
                  <p class="prod-step__desc">Los 2 técnicos operan durante todo el evento ejecutando cada secuencia en el momento exacto. Coordinamos con sonido y animación para que luz, música y programa vayan perfectamente sincronizados.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Show Estándar (4 cabezas) vs Show Premium (8 cabezas con coreografía)</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Show Estándar — 4 cabezas</span>
                <ul class="prod-compare__list">
                  <li>4 cabezas (beam + wash)</li>
                  <li>1 técnico operando</li>
                  <li>Operación en vivo, sin guión</li>
                  <li>80-200 invitados</li>
                  <li>Sin cabezas spot</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Show Premium — 8 cabezas + coreografía</span>
                <ul class="prod-compare__list">
                  <li>8 cabezas (beam + wash + spot)</li>
                  <li>2 técnicos en simultáneo</li>
                  <li>Show coreografiado con guión</li>
                  <li>150-400 invitados</li>
                  <li>Spot para enfocar momentos clave</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contraté el Show Premium para los XV de mi hija en un salón en Pedregal. Cuando entró al salón con 8 cabezas moviendose sincronizadas con su canción favorita, todo el salón gritó. Fue el momento del evento. El técnico que diseñó la coreografía nos pidió los tiempos con anticipación y ejecutó todo perfecto — entrada, vals, sorpresa. Mis invitadas preguntaron durante semanas dónde contratamos la producción de luces."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Mónica Castillo</span>
                <span class="prod-quote__event">XV años — Salón de eventos en Pedregal, CDMX — 280 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cabezas móviles</dt><dd>8 (4 beam + 2 wash + 2 spot)</dd></div>
              <div class="ps-specs__row"><dt>Consola</dt><dd>DMX profesional</dd></div>
              <div class="ps-specs__row"><dt>Técnicos</dt><dd>2 dedicados</dd></div>
              <div class="ps-specs__row"><dt>Show</dt><dd>Coreografiado</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>150-400 invitados</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">XV años de producción</span>
              <span class="ps-tag">Bodas de lujo</span>
              <span class="ps-tag">Galas</span>
              <span class="ps-tag">Salones grandes</span>
              <span class="ps-tag">150-400 invitados</span>
              <span class="ps-tag">Recintos de eventos</span>
              <span class="ps-tag">Haciendas con salón</span>
              <span class="ps-tag">Eventos con producción</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Básico 2 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Básico</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Estándar 4 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Estándar</span>
                <span class="ps-pkg__price">$7,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Producción 12+ cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$24,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Concierto, festival o evento masivo? El paquete de Producción incluye 12+ cabezas, consola MA y director de luces.</p>
              <a href="/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" class="ps-upsell__link">Ver Producción →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
