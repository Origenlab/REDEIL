---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Show Estándar de Cabezas Móviles?',
    respuesta: 'Incluye 4 cabezas móviles (2 beam + 2 wash), controlador DMX profesional, técnico de iluminación dedicado para tu evento, transporte, instalación, programación de escenas personalizadas y desmontaje. Todo en CDMX y Estado de México sin costo adicional.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Show Estándar de Cabezas Móviles?',
    respuesta: 'El precio es desde $7,500 MXN + IVA. Incluye equipo completo (4 cabezas beam + wash), técnico DMX dedicado, transporte, instalación y operación durante todo el evento. Sin cobros ocultos ni extras por distancia dentro de CDMX y Edomex.'
  },
  {
    pregunta: '¿Cuál es la diferencia entre las cabezas beam y las wash?',
    respuesta: 'Las cabezas beam proyectan haces de luz concentrada y enfocada, perfectas para cortes de luz, columnas y efectos de movimiento. Las wash iluminan superficies amplias con colores suaves, ideales para ambientar el salón, iluminar a los invitados y crear fondos coloridos. La combinación beam + wash crea un show completo con efectos y ambiente.'
  },
  {
    pregunta: '¿El Show Estándar sirve para bodas al aire libre?',
    respuesta: 'Sí, siempre que la zona tenga una estructura donde montar las cabezas (pergolado, truss, tarima o poste). Para jardines completamente abiertos podemos incluir soportes de pie. Cuéntanos tu espacio y te asesoramos sobre el montaje más adecuado.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el Show Estándar?',
    respuesta: 'Para bodas y XV años recomendamos reservar con 4 a 8 semanas de anticipación, especialmente en temporada alta (octubre-febrero). Contáctanos por WhatsApp al 55 4937 5172 para verificar disponibilidad de tu fecha.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Show Estándar — Cabezas Móviles | REDEIL',
    description: '4 cabezas móviles (2 beam + 2 wash) con controlador DMX y técnico dedicado. Ideal para bodas, XV años y corporativos de 80-200 invitados en CDMX.',
    image: SITE_URL + '/img/img-index/pro/cabezas-moviles.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '7500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '54',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Show Estándar — Cabezas Móviles en CDMX | REDEIL"
  description="4 cabezas móviles beam y wash con controlador DMX y técnico dedicado. Para bodas, XV años y corporativos de 80-200 invitados. Instalación profesional en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cabezas Móviles', href: '/renta-de-iluminacion/cabezas-moviles/' }, { name: 'Show Estándar', href: '/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/' }]} />

  <Hero
    badge="Show Estándar — Cabezas Móviles"
    title="Show Estándar — Cabezas Móviles"
    description="4 cabezas robotizadas que hacen que tus invitados sientan que están en un concierto. Beam + wash, controlador DMX y técnico dedicado para bodas y XV años en CDMX."
    primaryCta={{ text: 'Cotizar $7,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cabezas-moviles/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Show Estándar de Cabezas Móviles</strong> combina 2 cabezas beam para efectos de luz dinámica y 2 cabezas wash para ambientar el salón con color. El resultado: un show visual completo que hace que cualquier <strong>boda, XV años o evento corporativo</strong> en <strong>CDMX o Edomex</strong> se sienta como producción profesional.</p>
      <p>Con técnico DMX dedicado que opera el equipo en vivo, cada momento del evento tiene su propia escena de luz: entrada, vals, brindis, hora loca. Diseñado para <strong>80 a 200 invitados</strong> en salones, jardines y recintos de eventos.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cabezas Móviles"
    items={[{ label: "Show Básico", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/" }, { label: "Show Premium", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" }, { label: "Producción", href: "/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Paquete Show Estándar 4 cabezas móviles beam y wash en boda" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="4 cabezas móviles beam en salón de bodas CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Cabezas wash iluminando salón XV años" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Controlador DMX profesional técnico operando" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show de luces beam y wash en pista de baile boda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Show Estándar — El favorito de bodas y XV años</span>
            <h2 class="prod-info__title">4 Cabezas Móviles (Beam + Wash) con Controlador DMX y Técnico</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$7,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 4 cabezas, técnico DMX dedicado, transporte, instalación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">4 cabezas robotizadas que hacen que tus invitados sientan que están en un concierto</h2>
            <p class="prod-selling__intro">La combinación de beam y wash es lo que separa un show de luces de una iluminación genérica. Las cabezas beam crean efectos de haz que se mueven, cruzan y barren el espacio. Las cabezas wash envuelven el salón en color, transforman paredes y techos, y crean el ambiente que complementa cada momento. 4 cabezas controladas por un técnico dedicado: es un show real, no solo luz.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Combinación beam + wash — efectos y ambiente en uno</h3>
                  <p class="prod-hl__desc">Las 2 cabezas beam generan efectos visuales dinámicos: columnas de luz, barridos, movimientos sincronizados. Las 2 wash iluminan el espacio con colores suaves que se adaptan al momento. Juntas crean un show con profundidad visual que ningún sistema de un solo tipo logra.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico DMX dedicado — opera en vivo todo el evento</h3>
                  <p class="prod-hl__desc">No programamos escenas fijas y nos vamos. Un técnico DMX opera las 4 cabezas en tiempo real durante todo el evento. Coordina con el DJ, anticipa cada momento especial y ajusta los efectos sobre la marcha. Tú disfrutas, él cuida el show.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Escenas únicas para cada momento del evento</h3>
                  <p class="prod-hl__desc">Entrada de los novios, vals, primera pieza de los quince, brindis, hora loca — cada momento tiene su propia escena de luz programada. Tu evento no tiene un solo estado visual: tiene una narrativa lumínica completa de principio a fin.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura total para salones de 80-200 personas</h3>
                  <p class="prod-hl__desc">4 cabezas posicionadas estratégicamente cubren todos los ángulos del salón. No hay zona sin iluminación dinámica. Los invitados en cualquier mesa sienten el show, no solo los que están junto a la pista.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 cabezas móviles beam profesionales</div>
              <div class="prod-feat">2 cabezas móviles wash RGB</div>
              <div class="prod-feat">Controlador DMX profesional</div>
              <div class="prod-feat">Técnico operador dedicado</div>
              <div class="prod-feat">Soportes y herraje de montaje</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Programación de escenas</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cableado y conexiones incluidos</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte los detalles de tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento, número de invitados y momentos especiales que quieres destacar. Con esa información diseñamos el plan de iluminación y programamos las escenas a medida.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu propuesta en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos cotización detallada con distribución del equipo, escenas propuestas para tu evento y precio final sin costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con el 50% por transferencia, efectivo o tarjeta. Tu fecha queda confirmada y el técnico asignado a tu evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Show completo desde la primera canción</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes, instalamos las 4 cabezas, configuramos la consola y hacemos prueba general. Cuando empiezan tus invitados a llegar, el show ya está encendido. El técnico opera en vivo todo el evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Show Básico (2 cabezas) vs Show Estándar (4 cabezas beam + wash)</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Show Básico — 2 cabezas beam</span>
                <ul class="prod-compare__list">
                  <li>Solo efectos beam</li>
                  <li>Sin iluminación de ambiente</li>
                  <li>Cobertura parcial del salón</li>
                  <li>Ideal hasta 80 invitados</li>
                  <li>Sin técnico dedicado</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Show Estándar — 4 cabezas beam + wash</span>
                <ul class="prod-compare__list">
                  <li>Efectos beam + ambiente wash</li>
                  <li>Salón completo en color</li>
                  <li>Cobertura total 360°</li>
                  <li>80-200 invitados</li>
                  <li>Técnico DMX dedicado en vivo</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Usamos el Show Estándar para nuestra boda en un jardín en Coyoacán. Lo que más nos impresionó fue que el técnico coordinó con el DJ en tiempo real — cuando empezó el vals, las luces cambiaron automáticamente a un blanco suave y romántico, y cuando llegó la hora loca, todo se transformó en un club. Varios invitados nos preguntaron cuánto costó la producción de luces pensando que era algo enorme."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Andrea y Carlos Mendoza</span>
                <span class="prod-quote__event">Boda en jardín Coyoacán, CDMX — 140 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cabezas móviles</dt><dd>4 (2 beam + 2 wash)</dd></div>
              <div class="ps-specs__row"><dt>Controlador</dt><dd>DMX profesional</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Dedicado incluido</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>80-200 invitados</dd></div>
              <div class="ps-specs__row"><dt>Escenas</dt><dd>Personalizadas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Salones de eventos</span>
              <span class="ps-tag">80-200 invitados</span>
              <span class="ps-tag">Jardines con estructura</span>
              <span class="ps-tag">Haciendas</span>
              <span class="ps-tag">Recintos CDMX</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Básico 2 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Básico</span>
                <span class="ps-pkg__price">$4,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Premium 8 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Premium</span>
                <span class="ps-pkg__price">$13,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Producción 12+ cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$24,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿XV años de producción o boda de lujo? El Show Premium incluye 8 cabezas y show coreografiado.</p>
              <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" class="ps-upsell__link">Ver Show Premium →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
