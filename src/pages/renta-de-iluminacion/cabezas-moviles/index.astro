---
import Base from '../../../layouts/Base.astro';
import TopBar from '../../../components/TopBar.astro';
import Header from '../../../components/Header.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import CategoryCard from '../../../components/CategoryCard.astro';
import FaqSection from '../../../components/FaqSection.astro';
import Footer from '../../../components/Footer.astro';
import WhatsAppBubble from '../../../components/WhatsAppBubble.astro';
import { faqSchema, breadcrumbSchema } from '../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../lib/config';

const paquetes = [
  {
    "nombre": "Show Básico",
    "slug": "paquete-show-basico",
    "precio": 4000,
    "imagen": "/img/paquetes/cabezas-moviles/show-basico.avif",
    "badge": "",
    "features": [
      "4 cabezas móviles LED",
      "Controlador DMX",
      "Instalación y desmontaje",
      "Operación durante evento"
    ]
  },
  {
    "nombre": "Show Estándar",
    "slug": "paquete-show-estandar",
    "precio": 7500,
    "imagen": "/img/paquetes/cabezas-moviles/show-estandar.avif",
    "badge": "Más popular",
    "features": [
      "8 cabezas móviles LED",
      "Controlador DMX avanzado",
      "Instalación y desmontaje",
      "Programación personalizada",
      "Operación durante evento"
    ]
  },
  {
    "nombre": "Show Premium",
    "slug": "paquete-show-premium",
    "precio": 13000,
    "imagen": "/img/paquetes/cabezas-moviles/show-premium.avif",
    "badge": "",
    "features": [
      "12 cabezas móviles LED",
      "Controlador DMX profesional",
      "Instalación y desmontaje",
      "Programación personalizada",
      "Humo para efecto",
      "Técnico operador"
    ]
  },
  {
    "nombre": "Producción",
    "slug": "paquete-produccion",
    "precio": 24000,
    "imagen": "/img/paquetes/cabezas-moviles/produccion.avif",
    "badge": "",
    "features": [
      "20+ cabezas móviles LED",
      "Controlador DMX profesional",
      "Instalación y desmontaje",
      "Programación personalizada",
      "Humo para efecto",
      "Diseño de show",
      "2 técnicos operadores"
    ]
  }
];

const faqItems = [
  {
    "pregunta": "¿Cuánto cuesta la renta de cabezas móviles en CDMX?",
    "respuesta": "Los precios de cabezas móviles van desde $4,000 MXN hasta $24,000 MXN + IVA, dependiendo del paquete. Todos incluyen instalación profesional y desmontaje."
  },
  {
    "pregunta": "¿Qué paquetes de cabezas móviles ofrecen?",
    "respuesta": "Ofrecemos 4 paquetes: Show Básico, Show Estándar, Show Premium, Producción. Cada uno está diseñado para diferentes tamaños de evento y presupuesto."
  },
  {
    "pregunta": "¿La instalación de cabezas móviles está incluida?",
    "respuesta": "Sí, todos nuestros paquetes de cabezas móviles incluyen transporte, instalación profesional, operación durante el evento y desmontaje. No hay costos ocultos."
  },
  {
    "pregunta": "¿En qué tipo de eventos se usa cabezas móviles?",
    "respuesta": "Cabezas Móviles es popular en bodas, XV años, fiestas de cumpleaños, eventos corporativos, conferencias y celebraciones privadas. Adaptamos cada paquete al tipo de evento."
  },
  {
    "pregunta": "¿Cubren servicio de cabezas móviles en Estado de México?",
    "respuesta": "Sí, cubrimos CDMX y todo el Estado de México. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km sin costo adicional."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar cabezas móviles?",
    "respuesta": "Recomendamos reservar con 4-6 semanas de anticipación, especialmente en temporada alta. Para fechas próximas, escríbenos por WhatsApp al 55 4937 5172."
  },
  {
    "pregunta": "¿Puedo combinar cabezas móviles con otros servicios?",
    "respuesta": "Por supuesto. Ofrecemos descuentos especiales al combinar servicios de iluminación, audio y equipos. Diseñamos paquetes integrales a la medida de tu evento."
  },
  {
    "pregunta": "¿Qué marcas de equipo usan para cabezas móviles?",
    "respuesta": "Trabajamos con marcas líderes como JBL, QSC, Martin Professional, Chauvet y Elation. Nuestro inventario se actualiza constantemente para ofrecer la mejor tecnología disponible."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Renta de Cabezas Móviles — REDEIL',
    description: 'Luces robóticas inteligentes con movimiento y cambio de color para pistas de baile.',
    provider: {
      '@type': 'LocalBusiness',
      name: 'REDEIL',
      url: SITE_URL,
    },
    areaServed: { '@type': 'City', name: 'Ciudad de México' },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Paquetes de Cabezas Móviles',
      itemListElement: paquetes.map(p => ({
        '@type': 'Offer',
        name: p.nombre,
        price: p.precio,
        priceCurrency: 'MXN',
        url: SITE_URL + '/renta-de-iluminacion/cabezas-moviles/' + p.slug + '/',
      })),
    },
  },
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Renta de Iluminación', url: '/renta-de-iluminacion/' },
    { name: 'Cabezas Móviles', url: '/renta-de-iluminacion/cabezas-moviles/' },
  ]),
  faqSchema(faqItems),
];
---

<Base
  title="Renta de Cabezas Móviles para Eventos en CDMX | REDEIL"
  description="Luces robóticas inteligentes con movimiento y cambio de color para pistas de baile. 4 paquetes desde $4,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cabezas Móviles', href: '/renta-de-iluminacion/cabezas-moviles/' }]} />

  <Hero
    badge="Renta de Cabezas Móviles"
    title="Renta de Cabezas Móviles para Eventos en CDMX"
    description="Luces robóticas inteligentes con movimiento y cambio de color para pistas de baile. Ofrecemos 4 paquetes profesionales con instalación incluida para bod..."
    primaryCta={{ text: 'Cotizar Cabezas Móviles', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver Paquetes', href: '#paquetes' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>renta de cabezas móviles</strong> es uno de los servicios más solicitados en <strong>REDEIL</strong>. Luces robóticas inteligentes con movimiento y cambio de color para pistas de baile. Cada paquete incluye transporte, instalación profesional, operación durante el evento y desmontaje en <strong>CDMX y Estado de México</strong>.</p>
      <p>Con más de 10 años de experiencia, hemos llevado cabezas móviles a cientos de <strong>bodas, XV años, fiestas privadas y eventos corporativos</strong>. Trabajamos con equipo de marcas líderes y un equipo técnico capacitado que garantiza resultados impecables en cada evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Elige tu paquete de Cabezas Móviles"
    items={paquetes.map(p => ({
      label: p.nombre,
      href: '/renta-de-iluminacion/cabezas-moviles/' + p.slug + '/',
    }))}
  />

  <!-- GRID DE PAQUETES -->
    <!-- PAQUETES -->
  <section class="section" id="paquetes">
    <div class="container">
      <SectionHeader
        badge="4 niveles de show"
        title="¿Cuánto cuesta un show de cabezas móviles?"
        subtitle="De 4 fixtures para una pista de baile íntima hasta 20+ para una producción tipo concierto. Las cabezas móviles no son decoración — son un show de luces programado que transforma completamente la atmósfera de tu evento."
        subtitle2="Cada paquete incluye truss de aluminio, cabezas móviles Martin/Chauvet, controlador DMX, máquina de humo atmosférico (para que los haces se vean), instalación, programación, operación durante todo el evento y desmontaje."
        id="paquetes-title"
      />
      <div class="pkg-grid">
        {paquetes.map((p: any) => (
          <article class={`pkg ${p.badge ? 'pkg--featured' : ''}`}>
            <div class="pkg__img-wrap">
              <img src={p.imagen} alt={p.nombre} width="600" height="400" loading="lazy" class="pkg__img" />
              {p.badge && <span class="pkg__badge">{p.badge}</span>}
            </div>
            <div class="pkg__body">
              <h3 class="pkg__name">{p.nombre}</h3>
              <div class="pkg__pricing">
                <span class="pkg__amount">${p.precio.toLocaleString()}</span>
                <span class="pkg__tax">MXN + IVA</span>
              </div>
              <ul class="pkg__features">
                {p.features.map((f: string) => (
                  <li>{f}</li>
                ))}
              </ul>
              <a href={'/renta-de-iluminacion/cabezas-moviles/' + p.slug + '/'} class="pkg__cta">Cotizar este show</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ CABEZAS MÓVILES -->
  <section class="section section--bg">
    <div class="container">
      <SectionHeader
        badge="No es decoración — es un show"
        title="¿Qué hace diferente a las cabezas móviles de cualquier otra iluminación?"
        subtitle="La diferencia es movimiento. Las guirnaldas decoran. Las cascadas ambientan. Las cabezas móviles crean un espectáculo. Son luces robóticas que se programan para cada momento de tu evento: vals suave con movimientos lentos, fiesta con barridos rápidos multicolor, momento sorpresa con blackout y explosión de haces."
        subtitle2="Cada fixture Martin o Chauvet tiene motor interno que gira 360° y proyecta haces de luz concentrados. Con humo atmosférico, esos haces se convierten en rayos sólidos de color que cortan el aire — el efecto visual que ves en conciertos y festivales, ahora en tu boda o evento."
        id="diferencia-title"
      />
      <div class="sell__grid">
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cabezas-moviles/sell/movimiento.avif" alt="Cabeza móvil en pleno giro sobre truss" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Show programado por momentos</h3>
            <p class="sell__card-desc">Nuestro técnico programa escenas para cada momento: ceremonia con wash suave, cena con colores cálidos estáticos, vals con movimientos lentos románticos, fiesta con barridos rápidos multicolor. Cada transición es automática — el show se adapta al ritmo de tu evento sin que nadie lo note.</p>
          </div>
        </div>
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cabezas-moviles/sell/haces-aire.avif" alt="Haces de luz de cabezas móviles cortando humo atmosférico" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Haces que se ven en el aire</h3>
            <p class="sell__card-desc">¿Sabes por qué en los conciertos los haces de luz se ven como rayos sólidos? Humo atmosférico. Cada paquete incluye máquina de haze profesional que llena el ambiente con una neblina imperceptible — pero que hace que cada haz de luz se convierta en una línea de color sólida que corta el aire. El resultado es cinematográfico.</p>
          </div>
        </div>
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cabezas-moviles/sell/control-dmx.avif" alt="Consola DMX controlando cabezas móviles" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Control DMX profesional</h3>
            <p class="sell__card-desc">El cerebro del show. Una consola DMX controla cada fixture individualmente: posición, color, intensidad, velocidad de movimiento, patrones de gobos internos. Nuestro técnico opera la consola en tiempo real, sincronizando los movimientos con la música y la energía del momento.</p>
          </div>
        </div>
        <div class="sell__card">
          <div class="sell__card-img">
            <img src="/img/paquetes/cabezas-moviles/sell/transformacion.avif" alt="Pista de baile transformada con show de cabezas móviles" width="600" height="400" loading="lazy" />
          </div>
          <div class="sell__card-body">
            <h3 class="sell__card-title">Escalable a cualquier evento</h3>
            <p class="sell__card-desc">4 cabezas para una fiesta de 50 personas. 8 para una boda de 150. 12 para una producción de XV años. 20+ para un evento corporativo o concierto. El mismo tipo de show a diferente escala — siempre con equipo profesional Martin y Chauvet, siempre con técnico operador dedicado.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ZONAS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Cobertura"
        title="¿Dónde montamos shows de cabezas móviles?"
        subtitle="Llevamos producción de cabezas móviles a toda la CDMX y Estado de México. El montaje requiere espacio vertical (mínimo 3 metros de altura para el truss), así que es ideal para salones con techo alto, carpas de eventos, jardines con estructura y foros."
        subtitle2="Nuestro equipo hace visita técnica previa para medir alturas, verificar carga eléctrica y diseñar la distribución del truss. El traslado está incluido dentro de 100 km de CDMX."
        id="zonas-title"
      />
      <div class="zonas-grid">
        <a href="/zonas/polanco/" class="zona-card"><span class="zona-card__name">Polanco</span><span class="zona-card__desc">Hoteles y salones</span></a>
        <a href="/zonas/condesa/" class="zona-card"><span class="zona-card__name">Condesa</span><span class="zona-card__desc">Foros y terrazas</span></a>
        <a href="/zonas/santa-fe/" class="zona-card"><span class="zona-card__name">Santa Fe</span><span class="zona-card__desc">Corporativos</span></a>
        <a href="/zonas/coyoacan/" class="zona-card"><span class="zona-card__name">Coyoacán</span><span class="zona-card__desc">Jardines y haciendas</span></a>
        <a href="/zonas/san-angel/" class="zona-card"><span class="zona-card__name">San Ángel</span><span class="zona-card__desc">Salones privados</span></a>
        <a href="/zonas/interlomas/" class="zona-card"><span class="zona-card__name">Interlomas</span><span class="zona-card__desc">Carpas y foros</span></a>
        <a href="/zonas/naucalpan/" class="zona-card"><span class="zona-card__name">Naucalpan</span><span class="zona-card__desc">Salones grandes</span></a>
        <a href="/zonas/tlalnepantla/" class="zona-card"><span class="zona-card__name">Tlalnepantla</span><span class="zona-card__desc">Eventos masivos</span></a>
      </div>
      <div class="zonas-cta"><a href="/zonas/" class="zonas-cta__link">Ver las 30 zonas de cobertura →</a></div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas Frecuentes"
        subtitle="Las dudas más comunes sobre renta de cabezas móviles para eventos en CDMX. Precios, montaje, humo atmosférico y programación."
        subtitle2="Si no encuentras tu respuesta, escríbenos por WhatsApp al 55 4937 5172. Asesoría sin compromiso."
        id="faq-title"
      />
    </div>
    <FaqSection items={faqItems} />
  </section>

  <Footer />
  <WhatsAppBubble />
</Base>

<style>

  .pkg-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
  }
  .pkg-card__header {
    padding: 1.5rem;
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
  }
  .pkg-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .pkg-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
  }
  .pkg-card__amount {
    font-size: var(--font-size-2xl);
    font-weight: 800;
  }
  .pkg-card__currency {
    font-size: var(--font-size-sm);
    opacity: 0.8;
  }
  .pkg-card__features {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
  }
  .pkg-card__feature {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--color-bg);
  }
  .pkg-card__feature:last-child {
    border-bottom: none;
  }
  .pkg-card__btn {
    display: block;
    margin: 0 1.5rem 1.5rem;
    padding: 0.875rem;
    text-align: center;
    font-size: var(--font-size-sm);
    font-weight: 600;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: background 0.2s;
  }
  .pkg-card__btn:hover {
    background: var(--color-accent-dark);
  }
  .content-prose {
    max-width: 800px;
    margin: 0 auto;
  }
  .content-prose h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .content-prose h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }
  .content-prose p {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .zonas-servicio {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-sm);
  }
  .zonas-servicio .zona-link,
  .zona-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 600;
    font-size: var(--font-size-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .zona-link:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }


  /* Package cards - redesigned */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .pkg {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 8px 24px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .pkg:hover { border-color: #D4A04A; }
  .pkg--featured { border-color: #D4A04A; }
  .pkg__img-wrap {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .pkg__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pkg__badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #D4A04A;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .pkg__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .pkg__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }
  .pkg__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #E8E8E8;
  }
  .pkg__amount {
    font-size: 1.75rem;
    font-weight: 800;
    color: #D4A04A;
    line-height: 1;
  }
  .pkg__tax {
    font-size: 0.75rem;
    color: #94A3B8;
    font-weight: 500;
  }
  .pkg__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .pkg__features li {
    font-size: 0.875rem;
    color: #475569;
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .pkg__features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #D4A04A;
  }
  .pkg__cta {
    display: block;
    text-align: center;
    padding: 0.875rem;
    background: #1A1A2E;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s;
    margin-top: auto;
  }
  .pkg__cta:hover { background: #D4A04A; }
  .pkg--featured .pkg__cta { background: #D4A04A; }
  .pkg--featured .pkg__cta:hover { background: #B8862D; }


  .sell__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 640px) { .sell__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .sell__grid { grid-template-columns: repeat(4, 1fr); } }
  .sell__card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .sell__card-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .sell__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sell__card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }
  .sell__card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.5rem;
