---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Show Básico de Cabezas Móviles?',
    respuesta: 'Incluye 2 cabezas móviles beam robotizadas, controlador DMX programado, transporte, instalación y configuración de escenas de luz, operación durante el evento y desmontaje al finalizar. Todo dentro de CDMX y Estado de México sin cargo extra.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Show Básico de Cabezas Móviles?',
    respuesta: 'El precio es desde $4,000 MXN + IVA. Este precio incluye equipo, transporte, instalación, programación de escenas y operación durante el evento. Sin costos ocultos ni cobros por distancia dentro de CDMX y Edomex.'
  },
  {
    pregunta: '¿Para cuántas personas es suficiente el Show Básico?',
    respuesta: 'Está diseñado para eventos de 30 a 80 invitados con pista de baile chica o mediana. Para eventos más grandes, recomendamos el paquete Show Estándar con 4 cabezas. Contáctanos por WhatsApp al 55 4937 5172 y te asesoramos sin compromiso.'
  },
  {
    pregunta: '¿Las cabezas móviles beam sirven para fiestas en salón?',
    respuesta: 'Sí, especialmente en salones con techos de 3 a 5 metros. Las cabezas beam proyectan haces de luz concentrada que crean columnas y movimientos espectaculares. En espacios cerrados el efecto es más intenso que en exteriores.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el Show Básico?',
    respuesta: 'Recomendamos mínimo 2 a 3 semanas de anticipación. Para fechas en fin de semana o temporada alta (diciembre, febrero, mayo) conviene reservar con 4 a 6 semanas. Escríbenos por WhatsApp para verificar disponibilidad al instante.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Show Básico — Cabezas Móviles | REDEIL',
    description: '2 cabezas móviles beam robotizadas con controlador DMX. Ideal para fiestas y graduaciones de 30-80 invitados en CDMX. Instalación y operación profesional incluidas.',
    image: SITE_URL + '/img/img-index/pro/cabezas-moviles.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Show Básico — Cabezas Móviles en CDMX | REDEIL"
  description="2 cabezas móviles beam robotizadas con controlador DMX para fiestas y graduaciones. Ideal para 30-80 invitados. Instalación profesional en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Cabezas Móviles', href: '/renta-de-iluminacion/cabezas-moviles/' }, { name: 'Show Básico', href: '/renta-de-iluminacion/cabezas-moviles/paquete-show-basico/' }]} />

  <Hero
    badge="Show Básico — Cabezas Móviles"
    title="Show Básico — Cabezas Móviles"
    description="2 haces de luz robotizados que transforman una fiesta normal en un show. Controlador DMX, instalación profesional y operación incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $4,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/cabezas-moviles/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Show Básico de Cabezas Móviles</strong> es la forma más accesible de llevar <strong>iluminación robotizada profesional</strong> a tu fiesta en <strong>CDMX o Estado de México</strong>. Con 2 cabezas beam sincronizadas, cada canción tiene su propio movimiento de luces — algo que ningún DJ con luces básicas puede replicar.</p>
      <p>Ideal para <strong>graduaciones, fiestas de cumpleaños y eventos privados</strong> con 30 a 80 invitados. Nuestro técnico programa escenas de luz antes del evento y las opera en vivo para que la iluminación acompañe cada momento: entrada, brindis, baile.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Cabezas Móviles"
    items={[{ label: "Show Estándar", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" }, { label: "Show Premium", href: "/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" }, { label: "Producción", href: "/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Paquete Show Básico 2 cabezas móviles beam en fiesta" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Cabezas móviles beam robotizadas en salón" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Haces de luz beam en pista de baile" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Controlador DMX para cabezas móviles" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show de luces robotizadas en graduación CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Show Básico — Entrada al show robotizado</span>
            <h2 class="prod-info__title">2 Cabezas Móviles Beam con Controlador DMX</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, programación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">2 haces de luz robotizados que transforman una fiesta normal en un show</h2>
            <p class="prod-selling__intro">La diferencia entre una fiesta con luces normales y un show real no es el tamaño del salón — es el movimiento. Las cabezas móviles beam se mueven en sincronía con la música, crean efectos que siguen el ritmo y hacen que hasta una pista chica se sienta como un club profesional. Con 2 cabezas y el controlador DMX programado, tienes escenas distintas para cada momento del evento.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Movimiento robotizado sincronizado — no son luces estáticas</h3>
                  <p class="prod-hl__desc">Las cabezas beam giran, se inclinan y barren el espacio en tiempo real. El controlador DMX permite programar coreografías de luz que cambian con cada canción. El resultado es un show visual completo, no solo iluminación de ambiente.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Escenas programadas para cada momento del evento</h3>
                  <p class="prod-hl__desc">Nuestro técnico programa la consola antes del evento con escenas específicas: entrada de los festejados, brindis, canción favorita, hora loca. Cuando llega el momento, el show está listo. Sin improvisar, sin esperar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico operador en sitio durante todo el evento</h3>
                  <p class="prod-hl__desc">No dejamos el equipo solo. Un técnico opera las cabezas en vivo para que los efectos de luz coincidan con los momentos clave. Coordinamos con el DJ o animador para que el show visual y el sonido estén perfectamente sincronizados.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Equipo profesional en un paquete accesible</h3>
                  <p class="prod-hl__desc">Las cabezas beam que usamos son las mismas que se usan en conciertos y festivales — no son juguetes de ferretería. A $4,000 MXN obtienes equipo de producción real con operación profesional incluida.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 cabezas móviles beam profesionales</div>
              <div class="prod-feat">Controlador DMX programado</div>
              <div class="prod-feat">Escenas de luz personalizadas</div>
              <div class="prod-feat">Soportes y herraje de montaje</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cableado y conexiones incluidos</div>
              <div class="prod-feat">Repuestos en sitio por si acaso</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento y cuántos invitados esperas. Con esos datos definimos posicionamiento de las cabezas y programamos las escenas que más impacto tienen en tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, distribución del equipo y opciones de personalización. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, montamos y hacemos el show</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes para instalar, posicionar y hacer pruebas de encendido. Cuando empieza tu evento, el equipo está listo y el técnico opera cada efecto en sincronía con la música.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">DJ con luces básicas vs Cabezas Móviles profesionales</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">DJ con luces básicas</span>
                <ul class="prod-compare__list">
                  <li>Luces fijas de colores</li>
                  <li>Sin movimiento robotizado</li>
                  <li>Sin programación de escenas</li>
                  <li>El mismo efecto toda la noche</li>
                  <li>Equipo de consumidor, no profesional</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Show Básico — 2 Cabezas Móviles</span>
                <ul class="prod-compare__list">
                  <li>Haces beam robotizados en movimiento</li>
                  <li>Coreografía de luz sincronizada</li>
                  <li>Escenas programadas por momento</li>
                  <li>Show diferente para cada canción</li>
                  <li>Equipo de producción profesional</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contraté el Show Básico para la graduación de mi hija en un salón en Iztapalapa. Pensé que 2 cabezas era poco, pero quedé impresionada. En cuanto empezó la música y los haces se empezaron a mover, todo el salón se transformó. Los chamacos no podían creer que en un salón normal hubiera ese show de luces. Valió cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Patricia Ramírez</span>
                <span class="prod-quote__event">Fiesta de graduación — Salón en Iztapalapa, CDMX — 65 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Cabezas móviles</dt><dd>2 beam</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Beam robotizado</dd></div>
              <div class="ps-specs__row"><dt>Controlador</dt><dd>DMX incluido</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>30-80 invitados</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Fiestas de cumpleaños</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Pista chica</span>
              <span class="ps-tag">Salones medianos</span>
              <span class="ps-tag">30-80 invitados</span>
              <span class="ps-tag">Eventos privados</span>
              <span class="ps-tag">Quince años sencillos</span>
              <span class="ps-tag">Fiestas en terraza</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Estándar 4 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Estándar</span>
                <span class="ps-pkg__price">$7,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-premium/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Show Premium 8 cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Show Premium</span>
                <span class="ps-pkg__price">$13,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/cabezas-moviles/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/pro/cabezas-moviles.avif" alt="Producción 12+ cabezas móviles" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$24,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda o XV años con más invitados? El Show Estándar incluye 4 cabezas (beam + wash) y técnico DMX dedicado.</p>
              <a href="/renta-de-iluminacion/cabezas-moviles/paquete-show-estandar/" class="ps-upsell__link">Ver Show Estándar →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/sky-tracker/" class="ps-link">Sky Tracker</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
