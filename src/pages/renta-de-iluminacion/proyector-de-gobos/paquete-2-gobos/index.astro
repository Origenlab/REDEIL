---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de 2 Proyectores de Gobos?',
    respuesta: 'Incluye 2 proyectores de gobos profesionales, 2 discos gobo personalizados (pueden ser el mismo diseño o 2 diseños diferentes), instalación y alineación de ambos proyectores, técnico operador durante el evento y desmontaje. Puedes cubrir 2 zonas distintas o duplicar el impacto en una sola zona.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de 2 Proyectores de Gobos?',
    respuesta: 'El paquete tiene un precio desde $4,200 MXN + IVA. Incluye todo: 2 discos gobo personalizados, 2 proyectores, instalación, operación y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Puedo usar 2 diseños diferentes en cada proyector?',
    respuesta: 'Sí. Puedes proyectar 2 diseños distintos — por ejemplo, el logo del evento en la entrada y las iniciales de los novios en la pista de baile. También puedes usar el mismo diseño en 2 ubicaciones para reforzar la identidad visual del evento.'
  },
  {
    pregunta: '¿Se puede instalar en 2 zonas del mismo evento?',
    respuesta: 'Exactamente. Con 2 proyectores puedes cubrir la zona de ceremonia y la zona de recepción de forma simultánea, o la entrada del salón y la pista de baile. Los dos proyectores operan de forma independiente.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Mínimo 1 semana para fabricar los 2 discos gobo personalizados. Para fechas próximas contáctanos por WhatsApp — si tienes flexibilidad en los diseños podemos resolver antes.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Doble — 2 Proyectores de Gobos | REDEIL',
    description: 'Cubre 2 zonas de tu evento con 2 proyectores de gobos y 2 diseños personalizados. El paquete para bodas y XV años que quieren personalización total en CDMX.',
    image: SITE_URL + '/img/paquetes/gobos/dos-gobos.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4200',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/proyector-de-gobos/paquete-2-gobos/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '31',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Doble — 2 Proyectores de Gobos en CDMX | REDEIL"
  description="2 proyectores de gobos con 2 diseños personalizados. Cubre la ceremonia y la recepción, o proyecta 2 diseños distintos en 2 zonas del evento. Instalación en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Proyector de Gobos', href: '/renta-de-iluminacion/proyector-de-gobos/' }, { name: 'Doble — 2 Gobos', href: '/renta-de-iluminacion/proyector-de-gobos/paquete-2-gobos/' }]} />

  <Hero
    badge="Doble — 2 Proyectores"
    title="Doble — 2 Proyectores de Gobos con Diseños Personalizados"
    description="Cubre 2 zonas de tu evento con diseños distintos o duplica el impacto visual en una misma área. Personalización completa: 2 discos gobo fabricados con tu arte. CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $4,200 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/proyector-de-gobos/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete doble de 2 proyectores de gobos</strong> es la opción para quienes quieren llevar la personalización a otro nivel. Con dos proyectores puedes tener tu <strong>logo en la entrada del salón</strong> y tus <strong>iniciales en la pista de baile</strong> de forma simultánea, o proyectar el mismo diseño desde 2 ángulos para un efecto de total inmersión.</p>
      <p>Ideal para <strong>bodas, XV años y eventos corporativos</strong> en CDMX y Estado de México donde la identidad visual del evento importa tanto como la decoración. Dos gobos, dos historias contadas en luz.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Proyector de Gobos"
    items={[{ label: "1 Gobo", href: "/renta-de-iluminacion/proyector-de-gobos/paquete-1-gobo/" }, { label: "4 Gobos", href: "/renta-de-iluminacion/proyector-de-gobos/paquete-4-gobos/" }, { label: "Producción", href: "/renta-de-iluminacion/proyector-de-gobos/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/gobos/dos-gobos.avif" alt="2 proyectores de gobos en salón de eventos con diseños distintos" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/gobos.avif" alt="Proyección dual de gobos en boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/gobos/sell/disco-gobo.avif" alt="2 discos gobo personalizados con diseños distintos" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/gobos/sell/proyeccion-piso.avif" alt="Dos proyecciones de gobos en pistas de baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/gobos/sell/instalacion.avif" alt="Técnico configurando 2 proyectores de gobos" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Doble — 2 zonas cubiertas</span>
            <h2 class="prod-info__title">2 Proyectores de Gobos — 2 Diseños Personalizados, 2 Zonas</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,200</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 2 discos gobo, 2 proyectores, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Una historia contada en dos momentos, dos espacios</h2>
            <p class="prod-selling__intro">Con 2 gobos tienes la flexibilidad que un solo proyector no puede darte. La entrada del salón puede mostrar el logo del evento mientras la pista de baile exhibe las iniciales de los festejados. O proyectar el mismo diseño desde dos ángulos para que no haya un solo punto del salón donde no se vea. Este paquete es la elección de los eventos que quieren coherencia visual total.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 diseños exclusivos — cada uno fabricado para tu evento</h3>
                  <p class="prod-hl__desc">Cada disco gobo se fabrica específicamente para tu evento. Puedes elegir 2 diseños completamente distintos: logo para la entrada, iniciales para la pista, fecha para la zona de fotos. Total libertad creativa.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Ceremonia + recepción cubiertos simultáneamente</h3>
                  <p class="prod-hl__desc">Los 2 proyectores operan de forma independiente. Uno puede estar encendido durante la ceremonia y el otro durante la recepción, o ambos al mismo tiempo en zonas distintas. El técnico coordina los encendidos según el programa del evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Mayor impacto visual sin multiplicar la complejidad</h3>
                  <p class="prod-hl__desc">Dos proyectores estratégicamente ubicados crean la sensación de un evento completamente brandificado. Los invitados lo ven desde que llegan hasta que se van. La diferencia entre un evento bonito y un evento memorable.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Un técnico coordina ambos proyectores durante el evento</h3>
                  <p class="prod-hl__desc">Nuestro técnico gestiona los 2 equipos: ajusta posición, enfoque y momentos de encendido según el desarrollo del evento. Tú solo disfrutas — nosotros cuidamos que todo esté perfecto en cada momento.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 proyectores de gobos profesionales</div>
              <div class="prod-feat">2 discos gobo personalizados</div>
              <div class="prod-feat">Diseño de ambos gobos incluido</div>
              <div class="prod-feat">Instalación y alineación de 2 equipos</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Coordinación de encendidos</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables y soportes incluidos</div>
              <div class="prod-feat">Prueba de encendido previa</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Define tus 2 diseños y las zonas de proyección</h4>
                  <p class="prod-step__desc">Cuéntanos qué quieres proyectar en cada zona: iniciales, logo, fecha, o diseño libre. También indícanos las dimensiones aproximadas del espacio para calcular posicionamiento y tamaño de proyección.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Fabricamos tus 2 discos gobo</h4>
                  <p class="prod-step__desc">Con los diseños aprobados fabricamos ambos discos. Te enviamos vistas previas digitales de los 2 resultados esperados para confirmar antes de producirlos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">50% de anticipo para confirmar. El saldo restante se paga el día del evento. Aceptamos transferencia, efectivo o tarjeta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos 2 equipos y coordinamos todo</h4>
                  <p class="prod-step__desc">Llegamos 2-3 horas antes, instalamos ambos proyectores en las posiciones acordadas, enfocamos y hacemos pruebas. Durante el evento coordinamos los encendidos según el programa. Al terminar, desmontamos todo.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 2 gobos y no uno solo?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Básico — 1 Gobo</span>
                <ul class="prod-compare__list">
                  <li>Solo 1 zona cubierta</li>
                  <li>Un solo diseño</li>
                  <li>Sin cobertura en entrada</li>
                  <li>Impacto limitado a un área</li>
                  <li>Ceremonia O recepción</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Doble REDEIL — 2 Gobos</span>
                <ul class="prod-compare__list">
                  <li>2 zonas cubiertas simultáneamente</li>
                  <li>Hasta 2 diseños distintos</li>
                  <li>Entrada + pista de baile</li>
                  <li>Coherencia visual en todo el evento</li>
                  <li>Ceremonia Y recepción</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Pedimos los 2 gobos para nuestra boda: uno con el monograma en la pista y otro con el logo de nuestra boda en la entrada. Cuando los invitados entraron y vieron su nombre proyectado, todos se detuvieron a fotografiarlo. El detalle que más gustó de toda la decoración."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Gabriela y Mauricio</span>
                <span class="prod-quote__event">Boda en Terraza Bellavista — 180 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Proyectores</dt><dd>2 unidades</dd></div>
              <div class="ps-specs__row"><dt>Discos gobo</dt><dd>2 personalizados</dd></div>
              <div class="ps-specs__row"><dt>Diseños</dt><dd>Iguales o distintos</dd></div>
              <div class="ps-specs__row"><dt>Zonas</dt><dd>Hasta 2 simultáneas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico en sitio</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas con jardín y salón</span>
              <span class="ps-tag">XV años con 2 áreas</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Aniversarios de empresa</span>
              <span class="ps-tag">Graduaciones grandes</span>
              <span class="ps-tag">Cenas de gala</span>
              <span class="ps-tag">Congresos y convenciones</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-1-gobo/" class="ps-pkg">
              <img src="/img/paquetes/gobos/basico.avif" alt="Básico 1 Gobo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Básico — 1 Gobo</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-4-gobos/" class="ps-pkg">
              <img src="/img/paquetes/gobos/cuatro-gobos.avif" alt="4 Gobos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Gobos</span>
                <span class="ps-pkg__price">$7,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/gobos/produccion.avif" alt="Producción 8+ Gobos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 8+ Gobos</span>
                <span class="ps-pkg__price">$14,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Múltiples zonas o show de patrones? El paquete de 4 gobos cubre todo el venue con diseños distintos en cada área.</p>
              <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-4-gobos/" class="ps-upsell__link">Ver paquete 4 Gobos →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
