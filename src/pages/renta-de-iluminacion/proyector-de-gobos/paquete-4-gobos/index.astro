---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de 4 Proyectores de Gobos?',
    respuesta: 'Incluye 4 proyectores de gobos profesionales, hasta 4 discos gobo personalizados (pueden ser diseños distintos o combinaciones), instalación y alineación de todos los equipos, show de rotación de patrones entre proyectores, técnico operador durante el evento y desmontaje.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de 4 Proyectores de Gobos?',
    respuesta: 'El paquete tiene un precio desde $7,000 MXN + IVA. Incluye todo: hasta 4 discos gobo personalizados, 4 proyectores, instalación completa, show de rotación de patrones, técnico operador y desmontaje en CDMX y Edomex.'
  },
  {
    pregunta: '¿Qué es el show de patrones?',
    respuesta: 'Con 4 proyectores podemos crear un show donde los patrones se alternan y combinan en secuencias programadas. Por ejemplo: tus iniciales en 2 proyectores y un patrón floral en los otros 2, rotando durante el baile. El técnico programa las secuencias según el programa del evento.'
  },
  {
    pregunta: '¿Se pueden cubrir múltiples zonas del venue?',
    respuesta: 'Sí. Con 4 proyectores cubrimos entrada, zona de ceremonia, zona de cena y pista de baile de forma simultánea, o concentramos los 4 en una sola zona para un efecto envolvente máximo. La distribución se diseña según tu espacio.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 2 semanas de anticipación para diseñar y fabricar los 4 discos gobo y planificar la distribución del show. Para fechas próximas contáctanos — evaluamos disponibilidad y opciones.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Show — 4 Proyectores de Gobos | REDEIL',
    description: 'Show de gobos con 4 proyectores y hasta 4 diseños personalizados. Cubre múltiples zonas del venue o crea un show de rotación de patrones. Bodas y eventos grandes en CDMX.',
    image: SITE_URL + '/img/paquetes/gobos/cuatro-gobos.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '7000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/proyector-de-gobos/paquete-4-gobos/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '22',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Show — 4 Proyectores de Gobos en CDMX | REDEIL"
  description="4 proyectores de gobos con show de rotación de patrones. Cubre múltiples zonas del venue con diseños personalizados. El paquete para eventos grandes y producciones en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Proyector de Gobos', href: '/renta-de-iluminacion/proyector-de-gobos/' }, { name: 'Show — 4 Gobos', href: '/renta-de-iluminacion/proyector-de-gobos/paquete-4-gobos/' }]} />

  <Hero
    badge="Show — 4 Proyectores"
    title="Show de Gobos — 4 Proyectores con Rotación de Patrones"
    description="Cubre todo el venue con diseños personalizados en múltiples ubicaciones. Show de rotación de patrones programado para cada momento del evento. El paquete para bodas y eventos grandes en CDMX."
    primaryCta={{ text: 'Cotizar $7,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/proyector-de-gobos/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete de 4 proyectores de gobos</strong> es para eventos donde la personalización visual no es un detalle — es parte de la experiencia. Con 4 proyectores puedes cubrir todas las zonas del venue simultáneamente, crear un <strong>show de rotación de patrones</strong> sincronizado con el programa del evento, o combinar diferentes diseños en diferentes momentos de la noche.</p>
      <p>Para <strong>bodas grandes, eventos corporativos de alta producción y XV años de gran formato</strong> en CDMX y Estado de México, este paquete convierte la identidad visual del evento en un elemento omnipresente que los invitados experimentan desde que llegan hasta que se van.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Proyector de Gobos"
    items={[{ label: "1 Gobo", href: "/renta-de-iluminacion/proyector-de-gobos/paquete-1-gobo/" }, { label: "2 Gobos", href: "/renta-de-iluminacion/proyector-de-gobos/paquete-2-gobos/" }, { label: "Producción", href: "/renta-de-iluminacion/proyector-de-gobos/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/gobos/cuatro-gobos.avif" alt="Show de 4 proyectores de gobos cubriendo salón completo" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/gobos.avif" alt="Múltiples proyecciones de gobos en evento grande" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/gobos/sell/disco-gobo.avif" alt="Set de 4 discos gobo personalizados" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/gobos/sell/proyeccion-piso.avif" alt="Show de patrones de gobos en pista de baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/gobos/sell/instalacion.avif" alt="Instalación de 4 proyectores de gobos en evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Show — Cobertura total del venue</span>
            <h2 class="prod-info__title">4 Proyectores de Gobos — Show de Rotación de Patrones Personalizados</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$7,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: hasta 4 discos gobo, 4 proyectores, show de patrones, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando la identidad del evento cubre cada centímetro del venue</h2>
            <p class="prod-selling__intro">Cuatro proyectores bien posicionados transforman un salón en un entorno completamente brandificado. No hay un solo rincón donde el ojo no encuentre algo diseñado para ese evento específico. El show de rotación de patrones agrega una dimensión temporal: la luz cambia con el programa, marca cada momento y crea recuerdos visuales que las fotos capturan perfectamente.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura total del venue — 4 zonas simultáneas</h3>
                  <p class="prod-hl__desc">Con 4 proyectores cubres entrada, ceremonia, cena y baile al mismo tiempo. Cada zona tiene su propia proyección, su propio momento. Los invitados transitan por un espacio donde todo comunica la misma identidad visual.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Show de rotación de patrones — la luz narra el evento</h3>
                  <p class="prod-hl__desc">Programamos secuencias de patrones que se alternan durante el evento. Iniciales durante la entrada, logo durante la cena, patrón floral durante el vals, confeti de luz durante el baile. La luz cuenta la historia del evento en tiempo real.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Hasta 4 discos gobo distintos — máxima variedad visual</h3>
                  <p class="prod-hl__desc">Cada proyector puede tener su propio disco con un diseño diferente, o combinar diseños iguales en los 4 para efecto envolvente. La decisión es tuya — nosotros fabricamos lo que necesites y te asesoramos sobre qué funciona mejor para tu espacio.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico de producción coordina todo el show</h3>
                  <p class="prod-hl__desc">El técnico opera los 4 equipos con visión de producción: sabe en qué momento encender cada proyector, cómo ajustar la intensidad según la iluminación ambiente y cuándo cambiar patrones. No improvisa — tiene el programa del evento y lo ejecuta con precisión.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 proyectores de gobos profesionales</div>
              <div class="prod-feat">Hasta 4 discos gobo personalizados</div>
              <div class="prod-feat">Diseño y fabricación de todos los gobos</div>
              <div class="prod-feat">Show de rotación de patrones</div>
              <div class="prod-feat">Instalación en múltiples zonas</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Técnico operador de producción</div>
              <div class="prod-feat">Programación de secuencias</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables, soportes y adaptadores</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Planificamos juntos el show y la distribución</h4>
                  <p class="prod-step__desc">Revisamos plano del venue, definimos zonas de proyección, elegimos diseños para cada gobo y construimos el programa del show según el timeline del evento: entrada, cena, baile, cierre.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Fabricamos hasta 4 discos gobo personalizados</h4>
                  <p class="prod-step__desc">Con los diseños aprobados fabricamos todos los discos. Vistas previas digitales de cada gobo para tu aprobación antes de producir. Tiempo de fabricación: 5-7 días hábiles.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">50% de anticipo para confirmar. Saldo el día del evento. Aceptamos transferencia, efectivo o tarjeta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Producción completa el día del evento</h4>
                  <p class="prod-step__desc">Llegamos 3 horas antes para instalación completa de 4 equipos. Prueba de encendido y ajuste de posición en cada zona. El técnico ejecuta el show según el programa acordado. Desmontaje limpio al terminar.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué el Show de 4 vs solo 2 gobos?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Doble — 2 Gobos</span>
                <ul class="prod-compare__list">
                  <li>2 zonas cubiertas</li>
                  <li>Sin show de rotación</li>
                  <li>Entrada o pista, no ambas</li>
                  <li>Estático durante el evento</li>
                  <li>Impacto visual parcial</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Show REDEIL — 4 Gobos</span>
                <ul class="prod-compare__list">
                  <li>Todo el venue cubierto</li>
                  <li>Show de rotación programado</li>
                  <li>Entrada + cena + baile</li>
                  <li>La luz narra el evento</li>
                  <li>Cobertura visual total</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete de 4 gobos para el XV años de mi hija. Lo que más me impresionó fue cómo el técnico cambió los patrones exactamente en cada momento: durante el vals pusieron un patrón de mariposas, durante el baile las iniciales de ella. Cada zona del salón tenía algo diseñado para el evento. Mis invitados no podían creer lo personalizado que se veía todo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Patricia Hernández</span>
                <span class="prod-quote__event">XV años en Salón Versalles — 250 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Proyectores</dt><dd>4 unidades</dd></div>
              <div class="ps-specs__row"><dt>Discos gobo</dt><dd>Hasta 4 personalizados</dd></div>
              <div class="ps-specs__row"><dt>Show de patrones</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zonas</dt><dd>Hasta 4 simultáneas</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico de producción</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas grandes</span>
              <span class="ps-tag">XV años de gran formato</span>
              <span class="ps-tag">Eventos corporativos premium</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Cenas de gala</span>
              <span class="ps-tag">Congresos y convenciones</span>
              <span class="ps-tag">Galas benéficas</span>
              <span class="ps-tag">Festivales privados</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-1-gobo/" class="ps-pkg">
              <img src="/img/paquetes/gobos/basico.avif" alt="Básico 1 Gobo" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Básico — 1 Gobo</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-2-gobos/" class="ps-pkg">
              <img src="/img/paquetes/gobos/dos-gobos.avif" alt="Doble 2 Gobos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Doble — 2 Gobos</span>
                <span class="ps-pkg__price">$4,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/gobos/produccion.avif" alt="Producción 8+ Gobos" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 8+ Gobos</span>
                <span class="ps-pkg__price">$14,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Producción completa con DMX? El paquete Producción con 8+ gobos y control profesional es el nivel siguiente.</p>
              <a href="/renta-de-iluminacion/proyector-de-gobos/paquete-produccion/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; }
