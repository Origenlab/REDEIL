---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 16 Par LED City Light?',
    respuesta: 'Incluye 16 luminarias par LED RGBW profesionales, controlador DMX, soportes y trípodes, cable profesional calibrado, transporte, instalación en distribución estratégica, técnico operador durante el evento y desmontaje. Cubre salones medianos con iluminación base perfectamente uniforme.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 16 Par LED City Light?',
    respuesta: 'El paquete tiene un precio desde $4,200 MXN + IVA. Incluye transporte, instalación, control DMX, técnico operador y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Qué superficie cubre el paquete de 16 par LED?',
    respuesta: '16 par LED cubren salones de hasta 180 m², carpas de hasta 10×12 metros, o jardines medianos con estructuras. Con esta cantidad se logra iluminación uniforme sin puntos de luz visibles ni zonas de sombra en eventos de 80 a 150 invitados.'
  },
  {
    pregunta: '¿Se puede combinar el City Light con otras luces del venue o con guirnaldas?',
    respuesta: 'Sí, el City Light funciona perfectamente como capa base junto con otras fuentes de luz. Se combina muy bien con guirnaldas Edison (que aportan calidez puntual), City Color (que agregan color en zonas específicas) y la iluminación arquitectónica del venue. El técnico coordina las intensidades para que todo funcione junto.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete de 16 par LED?',
    respuesta: 'Recomendamos 4 a 6 semanas. En temporada alta (noviembre-febrero) el equipo se agenda con más rapidez. Para fechas próximas, escríbenos por WhatsApp para verificar disponibilidad inmediata.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '16 Par LED — City Light | REDEIL',
    description: 'Paquete 16 Par LED City Light para salones medianos y bodas. Iluminación base uniforme de hasta 180 m², control DMX y técnico incluido. Desde $4,200 MXN.',
    image: SITE_URL + '/img/img-index/city-light.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '4200',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/city-light/paquete-16-par-led/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '51',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="16 Par LED — City Light en CDMX | REDEIL"
  description="Paquete 16 Par LED City Light para salones medianos y bodas en CDMX. El más solicitado. Iluminación uniforme hasta 180 m² con control DMX. Desde $4,200 MXN + IVA."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'City Light', href: '/renta-de-iluminacion/city-light/' }, { name: '16 Par LED', href: '/renta-de-iluminacion/city-light/paquete-16-par-led/' }]} />

  <Hero
    badge="16 Par LED — City Light"
    title="16 Par LED City Light — Iluminación Completa para Salón Mediano"
    description="El paquete más solicitado para bodas y XV años en salones medianos. 16 luminarias par LED para cubrir hasta 180 m² con luz perfectamente uniforme y sin zonas oscuras. Desde $4,200 MXN."
    primaryCta={{ text: 'Cotizar $4,200 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/city-light/' }}
  >
    <Fragment slot="hero-seo">
      <p>Con <strong>16 par LED City Light</strong> cubres un salón de boda mediano con iluminación base que funciona como el lienzo sobre el que todo lo demás se ve bien. La decoración, las flores, la vestimenta — todo cobra vida diferente cuando la base de luz es uniforme, calibrada y controlada por un técnico.</p>
      <p>Es el paquete favorito de los planners de bodas en CDMX para salones entre 80 y 150 invitados porque resuelve la iluminación base completa sin requerir inversión de producción. El control DMX incluido permite ajustar el ambiente en cada momento del evento con precisión profesional.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de City Light"
    items={[{ label: "8 Par LED", href: "/renta-de-iluminacion/city-light/paquete-8-par-led/" }, { label: "24 Par LED", href: "/renta-de-iluminacion/city-light/paquete-24-par-led/" }, { label: "Producción", href: "/renta-de-iluminacion/city-light/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/img-index/city-light.avif" alt="16 par LED City Light iluminando salón mediano de boda en CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/city-light.avif" alt="Salón de XV años con iluminación base uniforme 16 par LED" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-light.avif" alt="Mesas de boda bajo iluminación par LED cálida y uniforme" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-light.avif" alt="Técnico ajustando consola DMX para iluminación de salón mediano" width="300" height="200" loading="lazy" />
              <img src="/img/img-index/city-light.avif" alt="Vista panorámica de salón con 16 par LED instalados" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Estándar — El más solicitado</span>
            <h2 class="prod-info__title">16 Par LED City Light — La base que hace que todo lo demás se vea mejor</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$4,200</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, control DMX, técnico operador y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando la iluminación base está bien, todo lo demás se multiplica</h2>
            <p class="prod-selling__intro">16 par LED son el punto donde la iluminación base deja de ser un servicio de apoyo y se convierte en la base de todo el diseño visual del evento. Con 16 luminarias bien distribuidas, la decoración florece, la ropa se ve del color exacto, las fotos capturan profundidad real y el espacio tiene una coherencia visual que ninguna otra fuente de luz logra por sí sola. Es el paquete que planners y fotógrafos recomiendan primero.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">180 m² cubiertos sin un solo punto de luz visible — uniformidad real</h3>
                  <p class="prod-hl__desc">Con 16 luminarias distribuidas correctamente, la luz llega al techo y rebota uniformemente por todo el salón. No hay puntos brillantes ni zonas grises. El resultado es una luz envolvente que hace que el espacio entero se vea del mismo nivel en cualquier foto desde cualquier ángulo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Control DMX incluido — tres momentos distintos con un solo paquete</h3>
                  <p class="prod-hl__desc">La consola DMX de este paquete permite programar escenas independientes: luz funcional alta para la cena, blanco cálido suave para los brindis, y un color de acento para el baile. El técnico ejecuta cada transición en el momento exacto sin interrumpir el evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">La base que multiplica cualquier otra iluminación — el efecto synergy</h3>
                  <p class="prod-hl__desc">Guirnaldas sobre 16 par LED se ven 3 veces mejor que sin ellos. City Color sobre 16 par LED crea profundidad cromática imposible de lograr sin base. El City Light no compite con otras fuentes — las potencia. Es la razón por la que los planners lo recomiendan como primera inversión.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Fotógrafos trabajan diferente — imágenes sin corrección de color necesaria</h3>
                  <p class="prod-hl__desc">Los fotógrafos profesionales calibran su cámara a la temperatura de color dominante. Con 16 par LED calibrados al mismo nivel, la temperatura es consistente en todo el salón. Las fotos salen con balance de blancos perfecto desde la cámara, sin necesitar correcciones extensas en edición.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">16 luminarias par LED RGBW</div>
              <div class="prod-feat">Consola DMX con programación de escenas</div>
              <div class="prod-feat">Soportes, trípodes y clamps</div>
              <div class="prod-feat">Cable profesional de alta capacidad</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y distribución estratégica</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Programación de hasta 3 escenas</div>
              <div class="prod-feat">Ajustes en tiempo real</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte medidas y fotos del salón</h4>
                  <p class="prod-step__desc">Con la superficie y altura del techo diseñamos la distribución óptima de las 16 luminarias. Si el salón tiene columnas, vigas o formas irregulares, las contemplamos para garantizar cobertura uniforme.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta con distribución y escenas de color</h4>
                  <p class="prod-step__desc">Recibes precio final, distribución de luminarias y propuesta de escenas DMX (temperatura por momento del evento). Si combinas con guirnaldas o City Color, coordinamos los niveles.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirmación con 50% de anticipo</h4>
                  <p class="prod-step__desc">Fecha bloqueada al confirmar. Cambios de escenas o distribución pueden ajustarse hasta 48 horas antes sin costo adicional.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalación 2 horas antes, operación completa</h4>
                  <p class="prod-step__desc">Llegamos 2 horas antes, instalamos, programamos la consola DMX y hacemos prueba de todas las escenas. El técnico opera durante el evento y ejecuta los cambios en cada momento acordado.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 16 par LED y no 8?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">8 Par LED — Inicial</span>
                <ul class="prod-compare__list">
                  <li>Cubre hasta 80 m²</li>
                  <li>Controlador básico de color</li>
                  <li>Ideal para eventos hasta 60 personas</li>
                  <li>Sin programación de escenas</li>
                  <li>Para salones y carpas chicas</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">16 Par LED — Estándar</span>
                <ul class="prod-compare__list">
                  <li>Cubre hasta 180 m²</li>
                  <li>Consola DMX con programación</li>
                  <li>Ideal para eventos 80-150 personas</li>
                  <li>3 escenas independientes programadas</li>
                  <li>Para salones medianos y bodas</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete de 16 par LED para nuestra boda en el Salón de Fiestas Las Palomas en Tlalpan. Combinamos con guirnaldas Edison y el resultado fue increíble — las guirnaldas se veían perfectas porque la base de luz estaba bien calibrada. Nuestro fotógrafo dijo que fue la primera boda donde no tuvo que hacer corrección de color en las fotos. Todo salió tal cual se veía en el salón."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Valeria y Miguel</span>
                <span class="prod-quote__event">Boda en Las Palomas — Tlalpan, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Luminarias</dt><dd>16 par LED RGBW</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>Par LED profesional</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Hasta 180 m²</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Consola DMX</dd></div>
              <div class="ps-specs__row"><dt>Escenas</dt><dd>Hasta 3 programadas</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>2 h antes</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en salón mediano</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">80-150 invitados</span>
              <span class="ps-tag">Salones 100-180 m²</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Cenas de gala</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Carpas medianas</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/city-light/paquete-8-par-led/" class="ps-pkg">
              <img src="/img/img-index/city-light.avif" alt="8 Par LED City Light" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">8 Par LED</span>
                <span class="ps-pkg__price">$2,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-light/paquete-24-par-led/" class="ps-pkg">
              <img src="/img/img-index/city-light.avif" alt="24 Par LED City Light" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">24 Par LED</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/city-light/paquete-produccion/" class="ps-pkg">
              <img src="/img/img-index/city-light.avif" alt="Producción 40+ Par LED" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 40+</span>
                <span class="ps-pkg__price">$11,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Salón grande o jardín abierto? El paquete 24 par LED cubre hasta 300 m² con la misma uniformidad sin comprometer calidad.</p>
              <a href="/renta-de-iluminacion/city-light/paquete-24-par-led/" class="ps-upsell__link">Ver paquete 24 Par LED →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/city-color/" class="ps-link">City Color LED — Cañones</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas LED Edison</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting arquitectónico</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
