---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de 4 Sky Trackers?',
    respuesta: 'Incluye 4 sky trackers de 7,000W cada uno, instalación y configuración de los 4 equipos, técnicos operadores durante el evento, combustible completo, transporte y desmontaje. Los 4 rayos de luz se distribuyen estratégicamente para crear un efecto de señalización visible a 7 kilómetros.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de 4 Sky Trackers?',
    respuesta: 'El paquete tiene un precio desde $15,000 MXN + IVA. Incluye todo: 4 sky trackers de 7,000W, instalación y posicionamiento estratégico, operación profesional, combustible y desmontaje en CDMX y Estado de México.'
  },
  {
    pregunta: '¿A qué distancia se ven los 4 sky trackers?',
    respuesta: 'Cuatro sky trackers de 7,000W operando en simultáneo son visibles a 7 kilómetros de distancia en condiciones normales. En zonas de alta visibilidad el efecto puede alcanzar hasta 10 km. Para eventos de 500 personas o más, el impacto visual es prácticamente imposible de ignorar desde cualquier punto de la ciudad.'
  },
  {
    pregunta: '¿Para qué tipo de eventos se recomienda el paquete de 4 sky trackers?',
    respuesta: 'Es el paquete ideal para festivales, inauguraciones de gran escala, XV años de lujo, lanzamientos de marca, convenciones y cualquier evento con 500 o más invitados que necesite dominar el skyline de la ciudad. Cuatro columnas de luz crean un perímetro visual que convierte el evento en el punto de referencia de toda la ciudad.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete de 4 sky trackers?',
    respuesta: 'Recomendamos 2-3 semanas de anticipación para eventos grandes. Para festivales y producciones de escala mayor, 4-6 semanas garantiza disponibilidad de los 4 equipos en la misma fecha. Contáctanos por WhatsApp para verificar disponibilidad inmediata.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '4 Sky Trackers — Sky Tracker 7,000W | REDEIL',
    description: 'Cuatro columnas de luz de 7,000W que marcan el cielo de la ciudad. Paquete de 4 sky trackers para festivales, inauguraciones grandes y eventos de 500+ personas en CDMX.',
    image: SITE_URL + '/img/paquetes/sky-tracker/cuatro.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '15000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/sky-tracker/paquete-4-sky-trackers/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '17',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="4 Sky Trackers 7,000W para Festivales e Inauguraciones en CDMX | REDEIL"
  description="Cuatro columnas de luz visibles a 7 km. Paquete de 4 sky trackers para festivales, inauguraciones grandes y eventos de 500+ personas en CDMX. Todo incluido desde $15,000."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Sky Tracker', href: '/renta-de-iluminacion/sky-tracker/' }, { name: '4 Sky Trackers', href: '/renta-de-iluminacion/sky-tracker/paquete-4-sky-trackers/' }]} />

  <Hero
    badge="4 Sky Trackers — Producción Media"
    title="4 Sky Trackers 7,000W — Cuatro Columnas de Luz que Marcan el Cielo de la Ciudad"
    description="Cuatro rayos de luz de 7,000W posicionados estratégicamente que convierten tu evento en el punto de referencia de toda la ciudad. Visible a 7 kilómetros. Para festivales, inauguraciones y eventos de 500+ personas en CDMX."
    primaryCta={{ text: 'Cotizar $15,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/sky-tracker/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de <strong>4 sky trackers de 7,000W</strong> es el nivel donde un evento deja de ser un punto en el mapa y se convierte en el horizonte. Cuatro columnas de luz distribuidas estratégicamente crean un perímetro luminoso <strong>visible a 7 kilómetros de distancia</strong> que no admite confusión: tu evento es el que domina el skyline esa noche.</p>
      <p>Para <strong>festivales en CDMX</strong>, inauguraciones de gran escala, XV años de lujo y lanzamientos de marca con 500 o más invitados. Cuando un sky tracker señaliza, cuatro sky trackers declaran. Incluye posicionamiento estratégico de los 4 equipos, operación profesional y todo el equipo técnico necesario para una producción media de alto impacto.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Sky Tracker"
    items={[{ label: "1 Sky Tracker", href: "/renta-de-iluminacion/sky-tracker/paquete-1-sky-tracker/" }, { label: "2 Sky Trackers", href: "/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" }, { label: "Producción", href: "/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/sky-tracker/cuatro.avif" alt="4 sky trackers de 7,000W proyectando rayos de luz al cielo nocturno" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/sky-tracker.avif" alt="Sky tracker 7,000W en festival nocturno CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/rayo-cielo.avif" alt="Cuatro rayos de luz visibles desde kilómetros" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/instalacion.avif" alt="Instalación de 4 sky trackers para festival" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/vista-lejana.avif" alt="4 sky trackers visibles a 7km en ciudad" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete 4 Sky Trackers — Producción media, impacto máximo</span>
            <h2 class="prod-info__title">4 Sky Trackers de 7,000W — El Perímetro de Luz que Define tu Evento</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$15,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 4 sky trackers 7,000W, posicionamiento estratégico, combustible, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuatro columnas de luz que marcan el cielo de la ciudad desde 7 kilómetros</h2>
            <p class="prod-selling__intro">Un solo sky tracker señaliza. Cuatro sky trackers dominan. Con cuatro equipos de 7,000W posicionados en los puntos estratégicos de tu venue, el efecto en el skyline nocturno no es lineal — es exponencial. Cada rayo refuerza a los demás y crea un perímetro luminoso que convierte tu evento en el referente visual de toda la ciudad durante esa noche. Nadie pregunta "¿dónde es?" cuando pueden verlo desde 7 kilómetros.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">28,000 watts totales — visibilidad a 7 kilómetros garantizada</h3>
                  <p class="prod-hl__desc">Cuatro sky trackers de 7,000W operando en simultáneo generan 28,000 watts de potencia luminosa. A esa escala, el efecto es visible desde cualquier punto de la zona metropolitana en un radio de 7 km. Para un festival o una inauguración grande, eso significa que todo el público potencial puede orientarse hacia tu evento desde antes de llegar.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Posicionamiento estratégico de los 4 equipos</h3>
                  <p class="prod-hl__desc">No es colocar cuatro sky trackers al azar. Nuestro equipo analiza el layout del venue y distribuye los equipos en los puntos que maximizan la cobertura visual desde los accesos principales y las rutas de llegada del público. El resultado es un perímetro de luz que envuelve el evento y no deja ángulo muerto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Para eventos de 500+ personas — la escala correcta</h3>
                  <p class="prod-hl__desc">Festivales, inauguraciones gubernamentales o corporativas, XV años de escala premium, lanzamientos de marca con prensa e invitados VIP. Este paquete está calibrado para eventos donde la señalización tiene que estar a la altura de la convocatoria. Cuatro sky trackers es el estándar mínimo para que el efecto sea proporcional al evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Equipo técnico completo — operación sin interrupciones</h3>
                  <p class="prod-hl__desc">Con 4 sky trackers en operación simultánea, el servicio incluye el equipo técnico completo: técnicos dedicados a la operación durante todo el evento, verificación de combustible, mantenimiento preventivo en sitio y coordinación entre equipos. Tú organizas el evento; nosotros garantizamos que los 4 rayos estén encendidos desde el inicio hasta el cierre.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4 Sky trackers de 7,000W c/u</div>
              <div class="prod-feat">Posicionamiento estratégico</div>
              <div class="prod-feat">Combustible completo para el evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y configuración profesional</div>
              <div class="prod-feat">Equipo técnico en sitio</div>
              <div class="prod-feat">Operación durante todo el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables y conexiones incluidos</div>
              <div class="prod-feat">Coordinación entre los 4 equipos</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Compártenos el layout del venue y detalles del evento</h4>
                  <p class="prod-step__desc">Fecha, dirección, plano o descripción del espacio, tipo de evento y aforo esperado. Con esa información diseñamos el posicionamiento óptimo de los 4 sky trackers para máximo impacto visual.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización y propuesta de posicionamiento</h4>
                  <p class="prod-step__desc">Propuesta detallada con precio final, distribución de los 4 equipos y consideraciones técnicas del venue. Sin compromisos ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">50% de anticipo para bloquear los 4 equipos en tu fecha. El saldo se liquida el día del evento antes de la instalación. Transferencia, efectivo o tarjeta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, instalamos y operamos los 4 equipos</h4>
                  <p class="prod-step__desc">El equipo técnico llega 2 horas antes del inicio, instala y posiciona los 4 sky trackers según el plan acordado, verifica el funcionamiento simultáneo y opera durante toda la duración del evento. Al terminar, desmontamos.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 4 sky trackers y no 2?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 2 Sky Trackers</span>
                <ul class="prod-compare__list">
                  <li>Visible a 5-6 km</li>
                  <li>Cubre una fachada del venue</li>
                  <li>Ideal para eventos 150-300 personas</li>
                  <li>Efecto de señalización lineal</li>
                  <li>Impacto medio en el skyline</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">4 Sky Trackers — Producción Media</span>
                <ul class="prod-compare__list">
                  <li>Visible a 7 km garantizados</li>
                  <li>Perímetro completo del venue</li>
                  <li>Escala para 500+ personas</li>
                  <li>Efecto de señalización envolvente</li>
                  <li>Domina el skyline nocturno</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos una inauguración corporativa con 600 asistentes en un venue en Tlalpan. Contratamos los 4 sky trackers y la diferencia fue brutal — teníamos invitados que nos decían que lo vieron desde Coyoacán, desde Xochimilco. El rayo de luz no solo señalizó el lugar, le dio escala a todo el evento. Cuando llegas y ves 4 columnas de luz, ya sabes que algo importante está pasando ahí."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Rodrigo Mendoza</span>
                <span class="prod-quote__event">Inauguración Corporativa — Tlalpan, CDMX — 600 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Sky trackers</dt><dd>4 unidades</dd></div>
              <div class="ps-specs__row"><dt>Potencia c/u</dt><dd>7,000W</dd></div>
              <div class="ps-specs__row"><dt>Potencia total</dt><dd>28,000W</dd></div>
              <div class="ps-specs__row"><dt>Visibilidad</dt><dd>7 km</dd></div>
              <div class="ps-specs__row"><dt>Aforo ideal</dt><dd>500+ personas</dd></div>
              <div class="ps-specs__row"><dt>Efecto</dt><dd>Perímetro luminoso</dd></div>
              <div class="ps-specs__row"><dt>Combustible</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnicos en sitio</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Festivales</span>
              <span class="ps-tag">Inauguraciones grandes</span>
              <span class="ps-tag">XV años de lujo</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Convenciones</span>
              <span class="ps-tag">Eventos 500+ personas</span>
              <span class="ps-tag">Bodas de gala</span>
              <span class="ps-tag">Expos y ferias</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-1-sky-tracker/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/uno.avif" alt="1 Sky Tracker" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">1 Sky Tracker</span>
                <span class="ps-pkg__price">$5,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/dos.avif" alt="2 Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Sky Trackers</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/produccion.avif" alt="Producción 8+ Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 8+ Sky Trackers</span>
                <span class="ps-pkg__price">$28,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Festival o producción de escala mayor? El paquete Producción incluye 8+ sky trackers con coreografía y director técnico.</p>
              <a href="/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/proyector-de-gobos/" class="ps-link">Proyector de Gobos</a>
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
