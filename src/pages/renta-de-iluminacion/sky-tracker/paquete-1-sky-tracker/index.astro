---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete de 1 Sky Tracker?',
    respuesta: 'Incluye 1 sky tracker de 7,000W, instalación y configuración del equipo, técnico operador durante el evento, combustible, transporte y desmontaje. El rayo de luz es visible a kilómetros de distancia y opera durante toda la duración del evento.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete de 1 Sky Tracker?',
    respuesta: 'El paquete tiene un precio desde $5,000 MXN + IVA. Incluye todo: sky tracker de 7,000W, instalación, operación, combustible y desmontaje en CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿A qué distancia es visible el sky tracker?',
    respuesta: 'Con condiciones de cielo despejado, el rayo de luz de 7,000W es visible a 5-10 kilómetros de distancia. En zonas urbanas con buena visibilidad horizontal, funciona como señalización del evento que guía a los invitados desde lejos.'
  },
  {
    pregunta: '¿Se puede usar en cualquier tipo de evento?',
    respuesta: 'Sí. Es ideal para inauguraciones de locales comerciales, showrooms, bodas, XV años, eventos corporativos y cualquier evento donde quieras generar expectativa y señalizar la ubicación. El rayo vertical es inconfundible en el cielo nocturno.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 1-2 semanas de anticipación. Para fechas próximas contáctanos por WhatsApp — verificamos disponibilidad al momento y confirmamos en el día.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Señalización — 1 Sky Tracker 7,000W | REDEIL',
    description: 'Un rayo de luz de 7,000W visible a kilómetros. El sky tracker más espectacular para inauguraciones, bodas y eventos en CDMX. Señaliza tu evento en el cielo nocturno.',
    image: SITE_URL + '/img/paquetes/sky-tracker/uno.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '5000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/sky-tracker/paquete-1-sky-tracker/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '29',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Señalización — 1 Sky Tracker 7,000W en CDMX | REDEIL"
  description="Un rayo de luz de 7,000W visible a kilómetros. Sky tracker para inauguraciones, bodas y eventos en CDMX. La señalización más espectacular del cielo nocturno."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Sky Tracker', href: '/renta-de-iluminacion/sky-tracker/' }, { name: 'Señalización — 1 Sky Tracker', href: '/renta-de-iluminacion/sky-tracker/paquete-1-sky-tracker/' }]} />

  <Hero
    badge="Señalización — 1 Sky Tracker"
    title="1 Sky Tracker 7,000W — Rayo de Luz Visible a Kilómetros"
    description="Un solo rayo de luz de 7,000W que atraviesa el cielo nocturno y señaliza tu evento desde kilómetros de distancia. El efecto visual más poderoso para inauguraciones, bodas y eventos en CDMX."
    primaryCta={{ text: 'Cotizar $5,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/sky-tracker/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>sky tracker de 7,000W</strong> es el efecto de iluminación de exterior más impactante disponible para eventos en México. Un rayo de luz vertical que sube desde el suelo hasta el cielo, visible a <strong>5-10 kilómetros de distancia</strong> en condiciones normales. No hay señalización más espectacular para una inauguración, una boda o un evento que quiera ser visto desde lejos.</p>
      <p>Para <strong>inauguraciones de locales en CDMX</strong>, openings de showrooms, bodas en venues con acceso exterior y cualquier evento nocturno que necesite marcar su presencia en el skyline de la ciudad. Un solo sky tracker basta para crear el efecto que hace que la gente pregunte "¿qué está pasando allá?"</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Sky Tracker"
    items={[{ label: "2 Sky Trackers", href: "/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" }, { label: "4 Sky Trackers", href: "/renta-de-iluminacion/sky-tracker/paquete-4-sky-trackers/" }, { label: "Producción", href: "/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/sky-tracker/uno.avif" alt="Sky tracker de 7,000W proyectando rayo de luz al cielo" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/sky-tracker.avif" alt="Rayo de luz de sky tracker visible desde kilómetros" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/rayo-cielo.avif" alt="Sky tracker 7000W en inauguración nocturna" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/instalacion.avif" alt="Instalación de sky tracker para evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/vista-lejana.avif" alt="Rayo de sky tracker visible desde lejos en ciudad" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Señalización — El rayo que se ve desde kilómetros</span>
            <h2 class="prod-info__title">1 Sky Tracker de 7,000W — Señalización Espectacular del Cielo Nocturno</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$5,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: sky tracker 7,000W, instalación, combustible, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">7,000 watts que atraviesan el cielo y marcan dónde está tu evento</h2>
            <p class="prod-selling__intro">No existe ningún otro elemento de iluminación exterior que tenga el poder de convocatoria de un sky tracker. El rayo vertical de 7,000W opera en una escala completamente diferente a cualquier otra iluminación: lo ves desde el automóvil antes de llegar, lo ves desde bloques de distancia, lo ves y sabes exactamente dónde tienes que ir. Eso es señalización al nivel más espectacular posible.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">7,000W — la potencia que convierte un evento en un hito del skyline</h3>
                  <p class="prod-hl__desc">Un sky tracker de 7,000W no es una lámpara grande — es un haz de luz concentrado que perfora la oscuridad nocturna y sube kilómetros hacia el cielo. A esa potencia, el efecto no es sutil: es espectacular, inconfundible y fotografiable desde cualquier distancia.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Señalización que guía a tus invitados desde kilómetros</h3>
                  <p class="prod-hl__desc">Para inauguraciones y eventos con invitados que necesitan encontrar la ubicación, el sky tracker es la señalización más efectiva posible. "El lugar con el rayo de luz" es una dirección que todos entienden. No hay mapa que iguale la claridad de un haz de 7,000W en el cielo.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El efecto que genera expectativa antes de que lleguen</h3>
                  <p class="prod-hl__desc">El sky tracker crea expectativa en quienes aún no llegan. Lo ven desde la calle, desde el carro, desde la ventana de su casa — y eso genera conversación, curiosidad y ganas de llegar. Es marketing de evento en tiempo real, gratuito, que funciona en un radio de kilómetros.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Operación profesional — sin preocupaciones técnicas</h3>
                  <p class="prod-hl__desc">El técnico llega antes del evento, instala y configura el sky tracker, verifica el funcionamiento y permanece durante toda la duración para garantizar operación continua. Tú no te preocupas por nada técnico — solo disfrutas el efecto.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 Sky tracker de 7,000W</div>
              <div class="prod-feat">Combustible para todo el evento</div>
              <div class="prod-feat">Instalación y configuración</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables y conexiones incluidos</div>
              <div class="prod-feat">Verificación de funcionamiento</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento y ubicación</h4>
                  <p class="prod-step__desc">Fecha, dirección del venue, tipo de evento y duración aproximada. Verificamos que el espacio tenga acceso exterior para instalar el sky tracker y confirmamos disponibilidad.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Propuesta detallada con precio final, hora de instalación y consideraciones técnicas. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">50% de anticipo para confirmar. El saldo se paga el día del evento antes de la instalación. Aceptamos transferencia, efectivo o tarjeta.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalamos, encendemos y operamos durante el evento</h4>
                  <p class="prod-step__desc">Llegamos 1-2 horas antes del inicio, instalamos el sky tracker en la posición exterior acordada y lo mantenemos operando durante toda la duración del evento. Al terminar, desmontamos.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué sky tracker y no iluminación exterior convencional?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Iluminación exterior convencional</span>
                <ul class="prod-compare__list">
                  <li>Visible solo en el perímetro</li>
                  <li>No crea expectativa</li>
                  <li>Se pierde entre otras luces</li>
                  <li>No señaliza desde distancia</li>
                  <li>Sin impacto visual en el skyline</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Sky Tracker REDEIL — 7,000W</span>
                <ul class="prod-compare__list">
                  <li>Visible a 5-10 km de distancia</li>
                  <li>Genera expectativa desde lejos</li>
                  <li>Inconfundible en cualquier skyline</li>
                  <li>Señaliza el venue desde kilómetros</li>
                  <li>Efecto espectacular en el cielo</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el sky tracker para la inauguración de nuestro showroom en Polanco. Dos horas antes de abrir ya había gente preguntando en redes qué estaba pasando en esa dirección porque veían el rayo desde sus casas. Llegaron invitados que no habían confirmado solo porque lo vieron desde la calle. Nunca esperé ese nivel de convocatoria de un solo equipo."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Alejandro Torres</span>
                <span class="prod-quote__event">Inauguración Showroom — Polanco, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Sky trackers</dt><dd>1 unidad</dd></div>
              <div class="ps-specs__row"><dt>Potencia</dt><dd>7,000W</dd></div>
              <div class="ps-specs__row"><dt>Visibilidad</dt><dd>5-10 km</dd></div>
              <div class="ps-specs__row"><dt>Efecto</dt><dd>Rayo vertical</dd></div>
              <div class="ps-specs__row"><dt>Combustible</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Técnico en sitio</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Inauguraciones</span>
              <span class="ps-tag">Openings de locales</span>
              <span class="ps-tag">Bodas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Lanzamientos de marca</span>
              <span class="ps-tag">Showrooms</span>
              <span class="ps-tag">Fiestas privadas</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/dos.avif" alt="2 Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Sky Trackers</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-4-sky-trackers/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/cuatro.avif" alt="4 Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Sky Trackers</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/produccion.avif" alt="Producción 8+ Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 8+ Sky Trackers</span>
                <span class="ps-pkg__price">$28,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda grande o XV años? 2 sky trackers crean un efecto visual que duplica el impacto en el cielo nocturno.</p>
              <a href="/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" class="ps-upsell__link">Ver paquete 2 Sky Trackers →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/proyector-de-gobos/" class="ps-link">Proyector de Gobos</a>
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; }
  .prod-includes__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
  .prod-includes__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
