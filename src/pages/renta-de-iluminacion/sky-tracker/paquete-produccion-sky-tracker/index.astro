---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción de Sky Trackers?',
    respuesta: 'Incluye 8 o más sky trackers de 7,000W, director técnico de producción, coreografía personalizada de los rayos de luz, técnicos operadores para cada equipo, combustible completo, transporte, instalación profesional y desmontaje. Es un servicio de producción completo diseñado para eventos de escala festival o concierto.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción de Sky Trackers?',
    respuesta: 'El paquete tiene un precio desde $28,000 MXN + IVA. Incluye 8+ sky trackers de 7,000W, director de producción, coreografía de luces, equipo técnico completo, combustible y logística. Para producciones especiales o mayor número de equipos, cotizamos a medida.'
  },
  {
    pregunta: '¿A qué distancia es visible la producción de sky trackers?',
    respuesta: 'Con 8 o más sky trackers operando en simultáneo, el efecto es visible a más de 10 kilómetros de distancia. A esa escala, el evento deja de ser un punto de referencia local y se convierte en un hito visual de la ciudad. Es el nivel de producción de conciertos masivos y festivales nacionales.'
  },
  {
    pregunta: '¿Qué es la coreografía de sky trackers?',
    respuesta: 'La coreografía es la programación sincronizada del movimiento y operación de los sky trackers para crear patrones visuales en el cielo. El director técnico coordina los 8+ equipos para que se muevan en secuencias coordinadas, convergiendo y divergiendo los rayos de luz al ritmo del evento. Es el estándar de producción de conciertos y festivales internacionales.'
  },
  {
    pregunta: '¿Para qué tipo de eventos es el paquete Producción?',
    respuesta: 'Conciertos masivos, festivales de música, inauguraciones gubernamentales o corporativas de gran escala, producciones de televisión, eventos con transmisión en vivo, ferias nacionales y cualquier producción donde el impacto visual del cielo nocturno sea parte de la producción. Es el paquete para cuando el evento se ve desde toda la ciudad.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — Sky Tracker 8+ Unidades 7,000W | REDEIL',
    description: 'Producción nivel festival visible desde toda la ciudad. 8+ sky trackers de 7,000W con coreografía sincronizada y director técnico para conciertos, festivales e inauguraciones gubernamentales en CDMX.',
    image: SITE_URL + '/img/paquetes/sky-tracker/produccion.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '28000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '11',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción Sky Trackers — 8+ Unidades para Conciertos y Festivales en CDMX | REDEIL"
  description="Producción nivel festival que se ve desde toda la ciudad. 8+ sky trackers 7,000W con coreografía y director técnico. Para conciertos, festivales e inauguraciones masivas en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Sky Tracker', href: '/renta-de-iluminacion/sky-tracker/' }, { name: 'Producción — Sky Tracker', href: '/renta-de-iluminacion/sky-tracker/paquete-produccion-sky-tracker/' }]} />

  <Hero
    badge="Producción — Sky Tracker"
    title="Producción Sky Trackers — Nivel Festival que se Ve desde Toda la Ciudad"
    description="8 o más sky trackers de 7,000W con coreografía sincronizada y director técnico de producción. Visible a más de 10 kilómetros. El estándar de producción para conciertos masivos, festivales y grandes inauguraciones en CDMX."
    primaryCta={{ text: 'Cotizar $28,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/sky-tracker/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de <strong>Producción de Sky Trackers</strong> es el servicio de iluminación exterior de mayor escala disponible en México para eventos privados y corporativos. Con <strong>8 o más sky trackers de 7,000W</strong> operando en coreografía sincronizada bajo la dirección de un director técnico de producción, el evento se convierte en el hito visual de la ciudad — visible a <strong>más de 10 kilómetros de distancia</strong> desde cualquier punto de la zona metropolitana.</p>
      <p>Para <strong>conciertos masivos en CDMX</strong>, festivales de música, inauguraciones gubernamentales o corporativas de primera plana, producciones televisivas y cualquier evento donde el cielo nocturno sea parte del espectáculo. Esto no es señalización — es producción. El mismo nivel técnico de los festivales internacionales más importantes, disponible para tu evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Sky Tracker"
    items={[{ label: "1 Sky Tracker", href: "/renta-de-iluminacion/sky-tracker/paquete-1-sky-tracker/" }, { label: "2 Sky Trackers", href: "/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" }, { label: "4 Sky Trackers", href: "/renta-de-iluminacion/sky-tracker/paquete-4-sky-trackers/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/sky-tracker/produccion.avif" alt="Producción de 8 sky trackers con coreografía sincronizada en festival nocturno" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/sky-tracker.avif" alt="Sky trackers en producción de festival CDMX" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/rayo-cielo.avif" alt="8 rayos de luz sincronizados visibles a 10km" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/instalacion.avif" alt="Instalación de producción sky tracker festival" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/sky-tracker/sell/vista-lejana.avif" alt="Producción sky trackers visible desde toda la ciudad" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete Producción — Nivel festival, escala ciudad</span>
            <h2 class="prod-info__title">Producción Completa de Sky Trackers — 8+ Equipos con Coreografía y Director Técnico</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$28,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 8+ sky trackers 7,000W, director técnico, coreografía, equipo completo, combustible y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La producción de sky trackers que convierte cualquier noche de la ciudad en la noche de tu evento</h2>
            <p class="prod-selling__intro">Hay eventos que se señalizan. Y hay eventos que se ven desde toda la ciudad. El paquete Producción pertenece a la segunda categoría. Con 8 o más sky trackers de 7,000W operando en coreografía sincronizada bajo la dirección de un director técnico especializado, el cielo nocturno de la ciudad se convierte en el lienzo de tu evento. Cada rayo se mueve, converge y diverge en patrones diseñados para el momento. Visible a más de 10 kilómetros. Imposible de ignorar. Imposible de olvidar.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">56,000+ watts — visible a más de 10 km desde cualquier punto de la ciudad</h3>
                  <p class="prod-hl__desc">8 sky trackers de 7,000W generan una potencia luminosa total de 56,000 watts o más. A esa escala, el efecto ya no es local — es metropolitano. Desde Satélite, desde Coyoacán, desde Tlalnepantla, cualquier persona con vista al cielo nocturno puede ver que algo está pasando. Es el nivel de producción de los festivales más grandes del país.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Coreografía personalizada — los rayos de luz danzan con tu evento</h3>
                  <p class="prod-hl__desc">Los 8 sky trackers no simplemente apuntan al cielo: se mueven en secuencias diseñadas específicamente para tu evento. Convergencia en el momento cumbre, abanico para la presentación principal, ondas sincronizadas para crear tensión visual. La coreografía es diseñada por nuestro director técnico en coordinación con tu producción para que el cielo sea parte del show.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director técnico de producción — el experto que coordina todo</h3>
                  <p class="prod-hl__desc">El paquete Producción incluye un director técnico dedicado que lidera el equipo completo, coordina la coreografía en tiempo real, sincroniza con el programa del evento y toma decisiones técnicas durante la operación. Es la diferencia entre colocar equipos y hacer una producción. Para conciertos y festivales, ese nivel de coordinación no es opcional.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">El estándar de conciertos masivos, disponible para tu evento</h3>
                  <p class="prod-hl__desc">Inauguraciones gubernamentales de alto perfil, lanzamientos con cobertura mediática, festivales con aforos de miles de personas, producciones televisivas con transmisión en vivo. Para estos eventos, el impacto visual exterior no es decoración — es parte de la producción. El paquete Producción está diseñado exactamente para eso.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">8+ sky trackers de 7,000W c/u</div>
              <div class="prod-feat">Director técnico de producción</div>
              <div class="prod-feat">Coreografía personalizada de luces</div>
              <div class="prod-feat">Técnico operador por equipo</div>
              <div class="prod-feat">Combustible completo para el evento</div>
              <div class="prod-feat">Transporte y logística completa</div>
              <div class="prod-feat">Instalación y posicionamiento profesional</div>
              <div class="prod-feat">Coordinación con producción del evento</div>
              <div class="prod-feat">Operación durante todo el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Cables y conexiones completas</div>
              <div class="prod-feat">Soporte técnico en tiempo real</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reunión de producción previa al evento</h4>
                  <p class="prod-step__desc">Para producciones de esta escala, coordinamos una reunión con tu equipo de producción. Revisamos el venue, el programa del evento, los momentos clave y diseñamos la coreografía de los sky trackers en función de ello.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe propuesta técnica y cotización detallada</h4>
                  <p class="prod-step__desc">Propuesta completa con número de equipos recomendado según el venue, diseño de posicionamiento, descripción de la coreografía y precio final. Sin sorpresas el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Confirma con anticipo — bloqueamos el equipo completo</h4>
                  <p class="prod-step__desc">50% de anticipo para reservar los 8+ equipos y el director técnico en tu fecha. Para producciones con fecha específica e inamovible, recomendamos confirmar con 4-6 semanas de anticipación.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos con tiempo — producción y ensayo previo al evento</h4>
                  <p class="prod-step__desc">El equipo completo llega con suficiente anticipación para instalación, posicionamiento, prueba de coreografía y coordinación con tu equipo de producción. El director técnico verifica que todo esté operando en sincronía antes del inicio del evento.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué Producción y no 4 sky trackers?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete 4 Sky Trackers</span>
                <ul class="prod-compare__list">
                  <li>Visible a 7 km</li>
                  <li>Señalización de alto impacto</li>
                  <li>Posicionamiento estático</li>
                  <li>Ideal para 500+ personas</li>
                  <li>Sin coreografía ni director</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Producción — 8+ Sky Trackers</span>
                <ul class="prod-compare__list">
                  <li>Visible a 10+ km</li>
                  <li>Producción nivel festival/concierto</li>
                  <li>Coreografía sincronizada en tiempo real</li>
                  <li>Para miles de personas</li>
                  <li>Director técnico de producción incluido</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos una inauguración gubernamental con transmisión en vivo y cobertura de medios. Los 8 sky trackers con coreografía sincronizada fueron lo que hizo que las tomas aéreas del evento tuvieran ese nivel de producción. Los comentaristas en la transmisión mencionaron la iluminación varias veces. El director técnico de REDEIL coordinó todo con nuestro productor de TV sin ningún problema. Fue producción de primer nivel."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Coordinación de Eventos</span>
                <span class="prod-quote__event">Inauguración Gubernamental — CDMX — Transmisión en vivo</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Sky trackers</dt><dd>8+ unidades</dd></div>
              <div class="ps-specs__row"><dt>Potencia c/u</dt><dd>7,000W</dd></div>
              <div class="ps-specs__row"><dt>Potencia total</dt><dd>56,000W+</dd></div>
              <div class="ps-specs__row"><dt>Visibilidad</dt><dd>10+ km</dd></div>
              <div class="ps-specs__row"><dt>Coreografía</dt><dd>Personalizada</dd></div>
              <div class="ps-specs__row"><dt>Director técnico</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Combustible</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Operación</dt><dd>Equipo completo</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Conciertos masivos</span>
              <span class="ps-tag">Festivales de música</span>
              <span class="ps-tag">Inauguraciones gubernamentales</span>
              <span class="ps-tag">Producciones de TV</span>
              <span class="ps-tag">Ferias nacionales</span>
              <span class="ps-tag">Eventos con transmisión en vivo</span>
              <span class="ps-tag">Lanzamientos de alto perfil</span>
              <span class="ps-tag">Convenciones masivas</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-1-sky-tracker/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/uno.avif" alt="1 Sky Tracker" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">1 Sky Tracker</span>
                <span class="ps-pkg__price">$5,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-2-sky-trackers/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/dos.avif" alt="2 Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Sky Trackers</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/sky-tracker/paquete-4-sky-trackers/" class="ps-pkg">
              <img src="/img/paquetes/sky-tracker/cuatro.avif" alt="4 Sky Trackers" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">4 Sky Trackers</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">Para eventos de alta producción, el paquete completo incluye 8+ equipos con coreografía y director técnico. Es el nivel festival.</p>
              <a href={WHATSAPP_URL_MSG} class="ps-upsell__link" target="_blank" rel="noopener">Cotizar producción personalizada →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/proyector-de-gobos/" class="ps-link">Proyector de Gobos</a>
              <a href="/renta-de-iluminacion/city-light/" class="ps-link">City Light</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
