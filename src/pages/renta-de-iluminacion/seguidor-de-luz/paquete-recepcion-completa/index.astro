---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Recepción Completa de Seguidor de Luz?',
    respuesta: 'Incluye 3 seguidores de luz profesionales 575W, 3 operadores especializados, cobertura durante toda la recepción (entrada, cena, vals, brindis, baile), transporte, instalación, calibración previa y desmontaje. Los 3 equipos trabajan en coordinación para que ningún momento de la noche quede sin cobertura profesional.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Recepción Completa?',
    respuesta: 'El paquete Recepción Completa tiene un precio desde $9,000 MXN + IVA. Incluye todo: transporte, instalación de los 3 equipos, 3 operadores profesionales coordinados y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Cuánto tiempo cubre el paquete Recepción Completa?',
    respuesta: 'Cubre toda la duración de la recepción — desde la entrada triunfal hasta el último baile. Nuestro equipo llega con 2 horas de anticipación para instalar y calibrar, y permanece hasta que termina el evento. El precio incluye la duración estándar del evento; para eventos de más de 6 horas consultar disponibilidad.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Recepción Completa?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con cargo por traslado extra.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 6 a 8 semanas de anticipación para este paquete, ya que requiere coordinar 3 operadores. Para fechas próximas, escríbenos por WhatsApp — verificamos disponibilidad del equipo completo al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Recepción Completa — Seguidor de Luz | REDEIL',
    description: 'Paquete de 3 seguidores de luz profesionales para cobertura de toda la recepción. Entrada, vals, brindis y baile con spotlight profesional. Operadores incluidos. CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/seguidor-de-luz.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '9000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '29',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Recepción Completa — Seguidor de Luz para Bodas en CDMX | REDEIL"
  description="3 seguidores de luz para cobertura de toda la recepción. Entrada, vals, brindis y baile con spotlight profesional desde el primer hasta el último momento. Operadores incluidos en CDMX."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Seguidor de Luz', href: '/renta-de-iluminacion/seguidor-de-luz/' }, { name: 'Recepción Completa', href: '/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/' }]} />

  <Hero
    badge="Recepción Completa"
    title="Recepción Completa — Toda la Noche con Spotlight"
    description="3 seguidores de luz profesionales que cubren cada momento de tu recepción. Entrada, vals, brindis, baile — toda la noche eres la estrella. 3 operadores coordinados incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $9,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/seguidor-de-luz/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Recepción Completa de seguidor de luz</strong> es la elección de quien no quiere que ningún momento de su boda o XV años quede sin producción profesional. Con 3 spotlights 575W y 3 operadores coordinados, cada instante de la noche — la entrada triunfal, el vals, el brindis, los bailables, el pastel — está cubierto por luz profesional que te convierte en el centro absoluto de cada escena.</p>
      <p>No es solo iluminación. Es dirección de escena. Nuestros operadores se coordinan para que cuando un seguidor entrega al festejado al DJ, el otro ya está posicionado para la siguiente secuencia. La recepción fluye como si hubiera un director de cine invisible cuidando cada toma — porque lo hay.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Seguidor de Luz"
    items={[{ label: "Momento Estelar", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/" }, { label: "2 Seguidores", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" }, { label: "Producción", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/seguidor-de-luz/recepcion-completa.avif" alt="Tres seguidores de luz cubriendo toda la recepción de boda en salón CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/seguidor-de-luz.avif" alt="Cobertura completa de spotlight en recepción de boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/operador.avif" alt="Tres operadores coordinados de seguidores de luz en evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/spotlight-vals.avif" alt="Recepción completa iluminada con spotlight profesional desde entrada hasta baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/equipo-575w.avif" alt="Setup completo de 3 seguidores de luz 575W profesionales" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Recepción Completa — 3 Spotlights · Toda la Noche</span>
            <h2 class="prod-info__title">3 Seguidores de Luz — Cobertura Profesional de Principio a Fin</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$9,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación de 3 equipos, 3 operadores coordinados y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">De la entrada al último baile — ningún momento sin luz profesional</h2>
            <p class="prod-selling__intro">Una boda o XV años tiene decenas de momentos importantes. El problema con 1 o 2 seguidores es que tienes que elegir cuáles cubrir — y eso significa que los demás quedan en la oscuridad de la iluminación del salón. El paquete Recepción Completa elimina esa decisión: 3 spotlights, 3 operadores, cobertura total. Desde que la festejada pone un pie en el salón hasta que se apaga la música, cada instante tiene la luz que merece.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Toda la recepción cubierta — ningún momento importante a oscuras</h3>
                  <p class="prod-hl__desc">Entrada triunfal, primer baile, vals con papá, brindis, corte del pastel, bailables — cada momento tiene un operador asignado con un seguidor profesional. Los 3 equipos rotan según el momento del programa, sin pausas ni reposicionamientos visibles para los invitados.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">3 operadores coordinados — dirección de escena, no solo operación de equipo</h3>
                  <p class="prod-hl__desc">Nuestros operadores se comunican por radio durante todo el evento. Saben el programa de la noche, anticipan los movimientos, se coordinan con el DJ o la orquesta y se aseguran de que cada transición sea fluida. El fotógrafo y el videógrafo trabajan con luz profesional durante toda la noche.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Fotos y video de toda la noche con calidad cinematográfica</h3>
                  <p class="prod-hl__desc">El mayor beneficio de la cobertura completa es en el material visual: el fotógrafo y videógrafo tienen luz profesional durante toda la recepción, no solo en 1 o 2 momentos. El álbum completo tiene una cohesión visual que solo se logra con producción de spotlight consistente.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Los invitados sienten que asistieron a algo especial</h3>
                  <p class="prod-hl__desc">La diferencia entre un evento con cobertura completa de spotlight y uno sin ella no es sutil — es dramática. Los invitados lo sienten aunque no sepan nombrarlo: hay algo que hace que este evento se sienta como producción profesional, como si la festejada fuera alguien importante. Porque lo es.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">3 seguidores de luz 575W profesionales</div>
              <div class="prod-feat">3 operadores especializados y coordinados</div>
              <div class="prod-feat">Cobertura de toda la recepción</div>
              <div class="prod-feat">Comunicación por radio entre operadores</div>
              <div class="prod-feat">Revisión de programa con organizador</div>
              <div class="prod-feat">Calibración previa al evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación de los 3 equipos</div>
              <div class="prod-feat">Coordinación con DJ u orquesta</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Comparte el programa de tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, programa de la noche y momentos clave. Con esa información diseñamos la estrategia de cobertura: posición de cada equipo, secuencia de operación y coordinación con tu equipo de entretenimiento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, descripción del setup, secuencia de cobertura y todo lo necesario. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha y los 3 operadores quedan asignados y confirmados al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos 2 horas antes y nos quedamos hasta el final</h4>
                  <p class="prod-step__desc">Instalamos los 3 equipos en sus posiciones óptimas, revisamos el programa con el coordinador del evento, hacemos pruebas y operamos durante toda la recepción. Al terminar, desmontamos sin interrumpir el cierre del evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Cobertura parcial vs Recepción Completa</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">1-2 Seguidores</span>
                <ul class="prod-compare__list">
                  <li>Solo 1-2 momentos con spotlight</li>
                  <li>El resto de la noche sin luz profesional</li>
                  <li>El fotógrafo usa flash en otros momentos</li>
                  <li>El álbum tiene inconsistencia visual</li>
                  <li>Los invitados sienten el evento a medias</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Recepción Completa</span>
                <ul class="prod-compare__list">
                  <li>Toda la noche con cobertura de spotlight</li>
                  <li>Cada momento tratado como producción</li>
                  <li>Fotógrafo con luz perfecta toda la noche</li>
                  <li>Álbum con cohesión visual impecable</li>
                  <li>Los invitados sienten que fue algo especial</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contraté la Recepción Completa para la boda de mi hija y fue la mejor inversión de todo el evento. Cada momento de la noche — la entrada, el vals con su papá, el brindis, el primer baile — tenía esa luz perfecta que hace que todo se vea increíble. El videógrafo me dijo que nunca había trabajado con tanta luz profesional durante toda una recepción. El video quedó como película. No me imagino cómo hubiera quedado sin los seguidores."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Carmen Villanueva</span>
                <span class="prod-quote__event">Boda de su hija — Club de Golf Bellavista, 220 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Seguidores</dt><dd>3 unidades</dd></div>
              <div class="ps-specs__row"><dt>Potencia</dt><dd>575W c/u</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Toda la recepción</dd></div>
              <div class="ps-specs__row"><dt>Operadores</dt><dd>3 incluidos</dd></div>
              <div class="ps-specs__row"><dt>Coordinación</dt><dd>Por radio</dd></div>
              <div class="ps-specs__row"><dt>Llegada previa</dt><dd>2 horas antes</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas medianas y grandes</span>
              <span class="ps-tag">XV años completos</span>
              <span class="ps-tag">Recepciones largas</span>
              <span class="ps-tag">Múltiples bailables</span>
              <span class="ps-tag">Evento con orquesta</span>
              <span class="ps-tag">Haciendas y clubes</span>
              <span class="ps-tag">100-250 invitados</span>
              <span class="ps-tag">Producciones intermedias</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/momento-estelar.avif" alt="Momento Estelar" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Momento Estelar</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/2-seguidores.avif" alt="2 Seguidores" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Seguidores</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/produccion.avif" alt="Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$16,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento de gran formato o producción profesional con director? El paquete Producción incluye 4+ seguidores y dirección creativa.</p>
              <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
