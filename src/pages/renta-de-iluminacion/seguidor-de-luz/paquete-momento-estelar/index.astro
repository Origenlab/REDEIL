---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Momento Estelar de Seguidor de Luz?',
    respuesta: 'Incluye 1 seguidor de luz profesional 575W, operador especializado durante el evento, 1 momento de cobertura dedicado (vals, entrada triunfal o brindis), transporte, instalación y desmontaje. Nuestro equipo llega con anticipación para montar, calibrar y hacer pruebas de posicionamiento antes de que lleguen los invitados.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Momento Estelar?',
    respuesta: 'El paquete Momento Estelar tiene un precio desde $3,500 MXN + IVA. Incluye todo: transporte, instalación, operador profesional y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos ni cargos extra por distancia en zona metro.'
  },
  {
    pregunta: '¿Para qué momento puedo usar el seguidor de luz?',
    respuesta: 'El paquete cubre 1 momento especial: puede ser el vals de la quinceañera o los novios, la entrada triunfal al salón, el brindis principal o el momento de la corona. Tú decides cuál es el instante más importante de tu evento y nosotros lo iluminamos de forma profesional.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Momento Estelar?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con cargo por traslado extra.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, escríbenos por WhatsApp — verificamos disponibilidad del equipo al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Momento Estelar — Seguidor de Luz | REDEIL',
    description: 'Paquete de 1 seguidor de luz profesional para 1 momento especial: vals, entrada triunfal o brindis. Operador incluido. Para bodas y XV años en CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/seguidor-de-luz.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Momento Estelar — Seguidor de Luz en CDMX | REDEIL"
  description="1 seguidor de luz profesional para el momento más importante de tu evento. Vals, entrada triunfal o brindis con cobertura de spotlight dedicado. Operador incluido en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Seguidor de Luz', href: '/renta-de-iluminacion/seguidor-de-luz/' }, { name: 'Momento Estelar', href: '/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/' }]} />

  <Hero
    badge="Momento Estelar"
    title="Momento Estelar — Seguidor de Luz"
    description="Un spotlight profesional. Un momento que nadie olvidará. Vals, entrada triunfal o brindis con toda la luz puesta en ti. Operador especializado incluido en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/seguidor-de-luz/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Momento Estelar de seguidor de luz</strong> está diseñado para ese instante que define toda la celebración: el vals de los novios, la entrada triunfal de la quinceañera o el brindis que para el tiempo. Un spotlight profesional 575W sigue cada movimiento del festejado mientras todos los demás desaparecen en la penumbra — porque en ese momento, solo tú importas.</p>
      <p>Nuestro operador especializado calibra la posición exacta antes del evento y sigue al festejado con precisión cinematográfica durante todo el momento. Tú bailas, entras, brindes. Nosotros nos aseguramos de que cada cámara, cada teléfono y cada ojo en el salón esté exactamente donde debe estar: apuntando hacia ti.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Seguidor de Luz"
    items={[{ label: "2 Seguidores", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" }, { label: "Recepción Completa", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" }, { label: "Producción", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/seguidor-de-luz/momento-estelar.avif" alt="Seguidor de luz profesional iluminando vals de quinceañera en salón de fiestas CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/seguidor-de-luz.avif" alt="Spotlight siguiendo a la festejada durante su entrada triunfal" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/operador.avif" alt="Operador profesional de seguidor de luz en posición durante evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/spotlight-vals.avif" alt="Haz de luz blanca siguiendo pareja de novios durante primer baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/equipo-575w.avif" alt="Equipo seguidor de luz 575W profesional listo para evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Momento Estelar — 1 Spotlight · 1 Momento</span>
            <h2 class="prod-info__title">1 Seguidor de Luz Profesional para tu Momento Más Importante</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operador especializado y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El momento que para el tiempo — con toda la luz puesta en ti</h2>
            <p class="prod-selling__intro">Hay un instante en cada celebración donde el tiempo se detiene: el vals que soñaste durante meses, la entrada triunfal que marca el inicio de una nueva etapa, el brindis que todos recordarán. El paquete Momento Estelar garantiza que ese instante sea exactamente como lo imaginaste — con un spotlight profesional que te sigue cada paso, te envuelve en luz y le dice a todos en el salón: aquí está la estrella.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Todos los ojos y todas las cámaras apuntan hacia ti</h3>
                  <p class="prod-hl__desc">Cuando el spotlight te sigue, no hay confusión sobre quién es el protagonista. Los fotógrafos tienen la luz perfecta, los videos quedan impecables y cada invitado sabe exactamente dónde mirar. No hay fotos borrosas, no hay momentos perdidos en la oscuridad.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Operador especializado — no es solo encender una luz</h3>
                  <p class="prod-hl__desc">Nuestro operador sabe anticipar movimientos, mantener el haz exacto aunque el festejado se mueva y ajustar intensidad según el momento. Es la diferencia entre una luz que ilumina y un seguidor que cuenta la historia. Años de experiencia en bodas y XV años.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Equipo 575W profesional — no de espectáculos de bar</h3>
                  <p class="prod-hl__desc">El seguidor de luz 575W está diseñado para salones y jardines de eventos. Rango de cobertura hasta 30 metros, iris ajustable para controlar el diámetro del haz, filtros de color opcionales y cabezal de movimiento suave. La diferencia se nota en las fotos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Tú eliges el momento — vals, entrada o brindis</h3>
                  <p class="prod-hl__desc">Cuéntanos cuál es el instante cumbre de tu evento y organizamos todo para ese momento específico: posición del equipo, ensayo de posicionamiento, coordinación con el DJ o la orquesta. Tu momento, con producción profesional.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">1 seguidor de luz 575W profesional</div>
              <div class="prod-feat">Operador especializado durante el evento</div>
              <div class="prod-feat">1 momento de cobertura dedicado</div>
              <div class="prod-feat">Calibración previa al evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación y acomodo en posición</div>
              <div class="prod-feat">Coordinación con DJ u orquesta</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Repuestos en sitio por si acaso</div>
              <div class="prod-feat">Prueba de luz antes del evento</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos cuál es tu momento especial</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento y qué momento necesitas iluminar. Vals, entrada triunfal, brindis — con esos datos definimos la posición exacta del equipo y el ángulo de cobertura.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, descripción del setup y todo lo que necesitas saber. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, calibramos y hacemos el momento perfecto</h4>
                  <p class="prod-step__desc">Llegamos con anticipación, instalamos el equipo en la posición óptima, hacemos pruebas de alcance e intensidad, coordinamos con tu equipo de entretenimiento y ejecutamos el momento con precisión profesional.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Tu evento sin spotlight vs con el Momento Estelar</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sin seguidor de luz</span>
                <ul class="prod-compare__list">
                  <li>La festejada se pierde entre las sombras</li>
                  <li>Nadie sabe exactamente dónde mirar</li>
                  <li>Fotos del vals oscuras o con flash frío</li>
                  <li>El momento pasa — nadie lo captura bien</li>
                  <li>La magia se diluye en la iluminación general</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Con Momento Estelar</span>
                <ul class="prod-compare__list">
                  <li>Todo el salón sabe que eres la estrella</li>
                  <li>Todos los ojos y cámaras apuntan hacia ti</li>
                  <li>Fotos y videos con luz cinematográfica</li>
                  <li>Cada segundo del momento, perfectamente iluminado</li>
                  <li>El instante se vuelve unforgettable</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contraté el Momento Estelar para el vals de mi boda y fue lo mejor que pude haber hecho. Cuando entré al salón y el spotlight me siguió, sentí que era la protagonista de una película. Mi fotógrafo me dijo que las fotos del vals quedaron perfectas gracias a la luz — sin flash, con luz cálida y natural. Mis papás lloraron. Nosotros lloramos. Fue el momento que imaginé durante años."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Gabriela Montoya</span>
                <span class="prod-quote__event">Boda en Salón Versalles — 130 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Seguidores</dt><dd>1 unidad</dd></div>
              <div class="ps-specs__row"><dt>Potencia</dt><dd>575W profesional</dd></div>
              <div class="ps-specs__row"><dt>Momentos cubiertos</dt><dd>1 momento</dd></div>
              <div class="ps-specs__row"><dt>Operador</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Alcance</dt><dd>Hasta 30 metros</dd></div>
              <div class="ps-specs__row"><dt>Calibración previa</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Vals de quinceañera</span>
              <span class="ps-tag">Primer baile de novios</span>
              <span class="ps-tag">Entrada triunfal</span>
              <span class="ps-tag">Brindis principal</span>
              <span class="ps-tag">Momento de la corona</span>
              <span class="ps-tag">Bodas íntimas</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Eventos en salón</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Más cobertura</h3>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/2-seguidores.avif" alt="2 Seguidores" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Seguidores</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/recepcion-completa.avif" alt="Recepción Completa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Recepción Completa</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/produccion.avif" alt="Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$16,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Tienes más de un momento importante? El paquete 2 Seguidores cubre la entrada Y el vals con cobertura simultánea.</p>
              <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" class="ps-upsell__link">Ver paquete 2 Seguidores →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
