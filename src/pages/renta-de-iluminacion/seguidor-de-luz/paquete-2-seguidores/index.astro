---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 2 Seguidores de Luz?',
    respuesta: 'Incluye 2 seguidores de luz profesionales 575W, 2 operadores especializados, cobertura para 2 momentos simultáneos o doble cobertura de un mismo momento, transporte, instalación, calibración previa y desmontaje. Ideal para cubrir entrada triunfal Y vals, o para iluminar a dos protagonistas al mismo tiempo.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 2 Seguidores?',
    respuesta: 'El paquete 2 Seguidores tiene un precio desde $6,000 MXN + IVA. Incluye todo: transporte, instalación de ambos equipos, 2 operadores profesionales y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Para qué sirven 2 seguidores en lugar de 1?',
    respuesta: '2 seguidores permiten cubrir dos momentos en simultáneo — por ejemplo, la entrada de la quinceañera con un seguidor y el vals con el otro, sin tener que mover el equipo entre momentos. También permiten cobertura doble del mismo momento desde dos ángulos, lo que resulta en fotos y videos mucho más ricos. En bodas, uno puede seguir a la novia y otro al novio durante el vals.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 2 Seguidores?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX con cargo por traslado extra.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, escríbenos por WhatsApp — verificamos disponibilidad del equipo al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '2 Seguidores de Luz — Seguidor de Luz | REDEIL',
    description: 'Paquete de 2 seguidores de luz profesionales para cobertura doble o 2 momentos simultáneos. Operadores incluidos. Para bodas y XV años en CDMX y Edomex.',
    image: SITE_URL + '/img/img-index/seguidor-de-luz.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '6000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '44',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="2 Seguidores de Luz para Bodas y XV Años en CDMX | REDEIL"
  description="2 spotlights profesionales para cobertura doble o 2 momentos simultáneos. Entrada triunfal y vals al mismo tiempo, dos protagonistas iluminados. Operadores incluidos en CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Seguidor de Luz', href: '/renta-de-iluminacion/seguidor-de-luz/' }, { name: '2 Seguidores', href: '/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/' }]} />

  <Hero
    badge="2 Seguidores"
    title="2 Seguidores de Luz — Cobertura Doble"
    description="Dos spotlights profesionales para que nada se pierda. Entrada triunfal y vals cubiertos en simultáneo, o dos protagonistas iluminados al mismo tiempo. Operadores incluidos en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $6,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/seguidor-de-luz/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete 2 Seguidores de Luz</strong> es la elección de los eventos donde hay más de un momento estrella — o donde un solo momento merece ser capturado desde dos ángulos. Con dos spotlights profesionales 575W y dos operadores especializados trabajando en coordinación, puedes iluminar la entrada triunfal con un seguidor mientras el otro ya está listo para el vals, sin mover equipo, sin pausas, sin momentos sin luz.</p>
      <p>En bodas, el paquete 2 Seguidores hace algo mágico: mientras uno sigue a la novia, el otro sigue al novio durante el primer baile. El fotógrafo tiene dos fuentes de luz perfectas, el video captura a ambos protagonistas y la sala completa entiende que este es el momento más importante del evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Seguidor de Luz"
    items={[{ label: "Momento Estelar", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/" }, { label: "Recepción Completa", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" }, { label: "Producción", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/seguidor-de-luz/2-seguidores.avif" alt="Dos seguidores de luz iluminando a novios durante el vals en boda CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/seguidor-de-luz.avif" alt="Cobertura doble de spotlight en quinceañera" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/operador.avif" alt="Dos operadores profesionales coordinando seguidores de luz" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/spotlight-vals.avif" alt="Dos hazes de luz siguiendo a novios en primer baile" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/equipo-575w.avif" alt="Par de equipos seguidores de luz 575W profesionales" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete 2 Seguidores — Cobertura Doble · 2 Momentos</span>
            <h2 class="prod-info__title">2 Seguidores de Luz Profesionales — Ningún Momento sin Luz</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$6,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación de ambos equipos, 2 operadores y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Dos spotlights, dos protagonistas — todo capturado a la perfección</h2>
            <p class="prod-selling__intro">En los eventos donde hay dos momentos clave — o dos personas que merecen ser el centro — un solo seguidor no alcanza. El paquete 2 Seguidores fue diseñado para que la entrada triunfal y el vals ocurran con la misma intensidad de producción, sin que uno opaque al otro. Dos operadores coordinados, dos equipos profesionales, una experiencia sin costuras donde cada instante tiene su propia luz y su propia historia.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Dos momentos cubiertos sin mover equipo entre uno y otro</h3>
                  <p class="prod-hl__desc">Con 2 seguidores, la entrada triunfal y el vals pueden ocurrir de forma continua: uno cubre la entrada mientras el otro ya está posicionado para el vals. Sin pausa, sin transición torpe, sin segundos a oscuras entre el momento más esperado y el segundo más importante.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Novio y novia iluminados al mismo tiempo durante el vals</h3>
                  <p class="prod-hl__desc">El vals con un solo seguidor ilumina a uno y deja al otro en sombra. Con 2 seguidores, ambos protagonistas están perfectamente iluminados desde ángulos distintos. El fotógrafo no necesita flash, el video tiene luz natural y cada invitado ve a los dos protagonistas con claridad.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Doble cobertura del mismo momento — dos ángulos, el doble de impacto</h3>
                  <p class="prod-hl__desc">Si prefieres concentrar ambos spotlights en un solo momento — el vals, la corona, el brindis — la cobertura doble crea una diferencia visual enorme: más intensidad de luz, sombras eliminadas desde múltiples ángulos, un efecto cinematográfico que solo se logra con producción profesional.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 operadores coordinados — no es lo mismo que 1 persona manejando 2 luces</h3>
                  <p class="prod-hl__desc">Cada seguidor requiere un operador dedicado para moverse con fluidez y anticipación. Con dos operadores coordinados por radio, los movimientos son sincronizados — si el festejado gira, ambos giran. Si se mueve, ambos se mueven. La coordinación es lo que hace que se vea como producción de TV, no como renta de equipo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">2 seguidores de luz 575W profesionales</div>
              <div class="prod-feat">2 operadores especializados</div>
              <div class="prod-feat">Cobertura doble o 2 momentos</div>
              <div class="prod-feat">Coordinación entre operadores</div>
              <div class="prod-feat">Calibración previa al evento</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación de ambos equipos</div>
              <div class="prod-feat">Coordinación con DJ u orquesta</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Repuestos en sitio por si acaso</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos cuáles son tus momentos clave</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento y qué momentos necesitas iluminar. Con esos datos diseñamos el posicionamiento de ambos equipos y la secuencia de cobertura.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, descripción del setup y secuencia de operación. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Llegamos, montamos y coordinamos todo</h4>
                  <p class="prod-step__desc">Llegamos con anticipación, instalamos ambos equipos en sus posiciones óptimas, hacemos pruebas, coordinamos con tu equipo de entretenimiento y ejecutamos cada momento con precisión de producción profesional.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">1 seguidor vs 2 seguidores — la diferencia en fotos y en la sala</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Solo 1 seguidor</span>
                <ul class="prod-compare__list">
                  <li>Un protagonista iluminado, el otro en sombra</li>
                  <li>Solo 1 momento cubierto por evento</li>
                  <li>Hay que mover el equipo entre momentos</li>
                  <li>Fotógrafo necesita flash para el segundo sujeto</li>
                  <li>La cobertura se siente parcial</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">2 Seguidores</span>
                <ul class="prod-compare__list">
                  <li>Ambos protagonistas perfectamente iluminados</li>
                  <li>2 momentos cubiertos sin mover equipo</li>
                  <li>Transición fluida entre momentos</li>
                  <li>Fotos y video con luz profesional en todo</li>
                  <li>Producción completa que se nota</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Para la boda de mi hija contratamos los 2 seguidores y fue una decisión perfecta. Uno los siguió durante la entrada y el otro ya estaba listo para el vals. Las fotos con los dos iluminados al mismo tiempo quedaron increíbles — como portada de revista. El fotógrafo nos dijo que fue el mejor regalo que le pudimos hacer porque no tuvo que usar flash en ningún momento del baile."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Roberto Anaya</span>
                <span class="prod-quote__event">Boda de su hija — Hacienda La Llave, 180 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Seguidores</dt><dd>2 unidades</dd></div>
              <div class="ps-specs__row"><dt>Potencia</dt><dd>575W c/u</dd></div>
              <div class="ps-specs__row"><dt>Momentos cubiertos</dt><dd>2 momentos</dd></div>
              <div class="ps-specs__row"><dt>Operadores</dt><dd>2 incluidos</dd></div>
              <div class="ps-specs__row"><dt>Alcance</dt><dd>Hasta 30 metros c/u</dd></div>
              <div class="ps-specs__row"><dt>Coordinación</dt><dd>Por radio</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Vals de novios</span>
              <span class="ps-tag">Entrada + Vals</span>
              <span class="ps-tag">XV años completos</span>
              <span class="ps-tag">Bodas medianas</span>
              <span class="ps-tag">Dos protagonistas</span>
              <span class="ps-tag">Cobertura 360°</span>
              <span class="ps-tag">Salones grandes</span>
              <span class="ps-tag">Haciendas</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/momento-estelar.avif" alt="Momento Estelar" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Momento Estelar</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/recepcion-completa.avif" alt="Recepción Completa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Recepción Completa</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/produccion.avif" alt="Producción" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción</span>
                <span class="ps-pkg__price">$16,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Tienes 3+ momentos importantes o recepción larga? El paquete Recepción Completa cubre todo el evento con 3 seguidores.</p>
              <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" class="ps-upsell__link">Ver Recepción Completa →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
