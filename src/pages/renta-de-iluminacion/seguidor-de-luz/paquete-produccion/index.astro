---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Producción de Seguidor de Luz?',
    respuesta: 'Incluye 4 o más seguidores de luz profesionales, operadores especializados por equipo, director de iluminación en sitio, diseño personalizado de cobertura, coordinación con fotógrafo y videógrafo, transporte, instalación, calibración y desmontaje. Es la solución de producción completa para eventos de gran formato donde cada detalle importa.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Producción?',
    respuesta: 'El paquete Producción tiene un precio desde $16,000 MXN + IVA, dependiendo del número de seguidores, duración del evento y requerimientos específicos. Incluye todo: transporte, instalación de todos los equipos, operadores, director de iluminación y desmontaje dentro de CDMX y Estado de México.'
  },
  {
    pregunta: '¿Qué hace diferente al paquete Producción de los demás?',
    respuesta: 'La diferencia principal es el director de iluminación: un profesional que diseña la estrategia completa de luz para tu evento, coordina a todos los operadores, trabaja en comunicación constante con fotógrafo, videógrafo, DJ y coordinador del evento. No es solo rentar equipos — es tener a alguien cuyo trabajo es que tu evento se vea como producción televisiva de primer nivel.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Producción?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México. También llegamos a cualquier destino en México — Guadalajara, Monterrey, Cancún, Mérida, Los Cabos — con coordinación previa y cargo por traslado. Consulta disponibilidad y condiciones para eventos fuera de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Para el paquete Producción recomendamos 8 a 12 semanas de anticipación. Esto permite diseñar la estrategia de iluminación, hacer un recorrido previo al venue, coordinar con todos los proveedores y garantizar disponibilidad del director de iluminación y todo el equipo técnico.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Producción — Seguidor de Luz | REDEIL',
    description: 'Paquete de producción completa con 4+ seguidores de luz, director de iluminación en sitio y coordinación total del evento. Para bodas y XV años de gran formato en CDMX.',
    image: SITE_URL + '/img/img-index/seguidor-de-luz.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '16000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5.0',
      reviewCount: '18',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Producción — Seguidor de Luz Profesional para Eventos de Gran Formato | REDEIL"
  description="4+ seguidores de luz con director de iluminación en sitio. Producción cinematográfica para bodas y XV años de gran formato en CDMX. Coordinación completa con fotógrafo y videógrafo."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Seguidor de Luz', href: '/renta-de-iluminacion/seguidor-de-luz/' }, { name: 'Producción', href: '/renta-de-iluminacion/seguidor-de-luz/paquete-produccion/' }]} />

  <Hero
    badge="Producción"
    title="Producción — Seguidor de Luz de Gran Formato"
    description="4+ spotlights profesionales y director de iluminación en sitio. Para eventos donde todo debe verse como producción televisiva de primer nivel. El estándar más alto disponible en CDMX."
    primaryCta={{ text: 'Cotizar desde $16,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/seguidor-de-luz/' }}
  >
    <Fragment slot="hero-seo">
      <p>El <strong>paquete Producción de seguidor de luz</strong> existe para los eventos donde la diferencia entre "muy bonito" y "absolutamente cinematográfico" la hace quien está detrás de la luz. Con 4 o más spotlights profesionales y un director de iluminación en sitio, tu evento no solo tiene cobertura técnica — tiene dirección creativa. Cada escena está diseñada de antemano, cada transición es intencional, cada momento tiene la luz exacta que maximiza su impacto emocional.</p>
      <p>El director de iluminación diseña la estrategia completa antes del evento, visita el venue, coordina con el fotógrafo, el videógrafo, el DJ o la orquesta y el coordinador del evento. El día del evento, dirige a todos los operadores como un director de cine dirige a su crew. El resultado es un evento donde todo fluye con una coherencia visual que los invitados sienten aunque no puedan explicar.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Seguidor de Luz"
    items={[{ label: "Momento Estelar", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/" }, { label: "2 Seguidores", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" }, { label: "Recepción Completa", href: "/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/seguidor-de-luz/produccion.avif" alt="Setup de producción completa con 4 seguidores de luz en boda de gran formato CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/seguidor-de-luz.avif" alt="Director de iluminación coordinando equipo de seguidores de luz en evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/operador.avif" alt="Crew de operadores de spotlight profesional en producción de evento" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/spotlight-vals.avif" alt="4 seguidores de luz iluminando escena de gran formato en salón" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/seguidor-de-luz/sell/equipo-575w.avif" alt="Setup profesional completo de producción de seguidor de luz para evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Producción — 4+ Spotlights · Director de Iluminación</span>
            <h2 class="prod-info__title">Producción Cinematográfica de Seguidor de Luz — El Nivel Más Alto</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$16,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 4+ equipos, operadores, director de iluminación, diseño de cobertura y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cuando el evento tiene que quedar como producción de televisión — este es el paquete</h2>
            <p class="prod-selling__intro">Hay eventos que merecen más que buena iluminación. Merecen producción. El paquete Producción no es "más seguidores" — es una categoría distinta: un director de iluminación que diseña cada escena de tu evento como si fuera un espectáculo, que entiende que la luz no solo ilumina sino que cuenta la historia. Para los eventos donde el presupuesto en producción no es un gasto sino una inversión en el recuerdo más importante de una vida.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Director de iluminación en sitio — diseño creativo, no solo operación</h3>
                  <p class="prod-hl__desc">El director diseña la estrategia completa antes del evento, visita el venue, mapea cada momento del programa y asigna recursos exactos a cada escena. El día del evento dirige a todos los operadores en tiempo real. Es la diferencia entre tener equipo de luz y tener producción de luz.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">4+ seguidores cubriendo cada zona del salón simultáneamente</h3>
                  <p class="prod-hl__desc">Con 4 o más spotlights no hay zona del salón que quede sin cobertura. La entrada, la pista de baile, la mesa de honor, la zona de los novios durante la cena — todo puede ser iluminado con spotlight profesional de forma simultánea. El resultado visual es una cohesión que impresiona a los mejores fotógrafos.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Coordinación total con fotógrafo, videógrafo, DJ y coordinador</h3>
                  <p class="prod-hl__desc">El director de iluminación habla el mismo idioma que el fotógrafo y el videógrafo. Se coordinan antes del evento para saber qué ángulos necesitan luz, cuándo necesitan más intensidad y cuándo menos. El resultado es que el material visual de tu evento es notablemente superior al de cualquier evento sin dirección de iluminación.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Visita previa al venue — nada se improvisa el día del evento</h3>
                  <p class="prod-hl__desc">El director visita el salón semanas antes para evaluar altura de techos, puntos de anclaje, posiciones óptimas para cada seguidor y limitaciones del espacio. El día del evento todo ya está diseñado: no hay improviso, no hay sorpresas, no hay segundos perdidos reposicionando equipo durante el evento.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">4+ seguidores de luz 575W profesionales</div>
              <div class="prod-feat">Director de iluminación en sitio</div>
              <div class="prod-feat">Operadores especializados por equipo</div>
              <div class="prod-feat">Diseño personalizado de cobertura</div>
              <div class="prod-feat">Visita previa al venue</div>
              <div class="prod-feat">Coordinación con fotógrafo y videógrafo</div>
              <div class="prod-feat">Comunicación por radio entre todo el crew</div>
              <div class="prod-feat">Revisión de programa con coordinador</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Consulta inicial — diseñamos la producción juntos</h4>
                  <p class="prod-step__desc">Agenda una llamada con nuestro director de iluminación. Compartimos el programa del evento, el venue y las expectativas. Con esa información diseñamos la estrategia de cobertura y cotizamos en detalle.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Visita al venue y diseño de cobertura</h4>
                  <p class="prod-step__desc">El director visita el salón para evaluar el espacio, definir posiciones exactas de cada equipo y diseñar la secuencia de cobertura. Entregamos un plano de iluminación antes de confirmar la reserva.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Coordinación previa con todos tus proveedores</h4>
                  <p class="prod-step__desc">El director contacta al fotógrafo, videógrafo, DJ u orquesta y coordinador del evento para alinear el programa y las necesidades de iluminación de cada uno. Todo coordinado antes del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Ejecución el día del evento — todo bajo control</h4>
                  <p class="prod-step__desc">Llegamos 3 horas antes, instalamos todo el equipo, hacemos pruebas y el director dirige al crew durante todo el evento. Cada transición entre momentos es controlada, cada movimiento de cámara tiene su luz. Al terminar, desmontamos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">Recepción con operadores vs con director de iluminación</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Sin director</span>
                <ul class="prod-compare__list">
                  <li>Cada operador trabaja por su cuenta</li>
                  <li>Sin diseño previo de cobertura</li>
                  <li>El fotógrafo y el spotlight no se coordinan</li>
                  <li>Hay momentos sin luz o con luz incorrecta</li>
                  <li>El evento se ve "bien iluminado", no producido</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Con Director de Iluminación</span>
                <ul class="prod-compare__list">
                  <li>Todos los operadores coordinados en tiempo real</li>
                  <li>Cada escena diseñada de antemano</li>
                  <li>Fotógrafo y spotlight trabajan juntos</li>
                  <li>Cobertura perfecta en cada transición</li>
                  <li>El evento se ve como producción de TV</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Tenía miedo de gastar en el paquete Producción pero fue lo mejor que hice. El director de iluminación nos visitó un mes antes, habló con nuestro fotógrafo, diseñó el plan completo y el día de la boda todo fluyó perfecto. Cada momento tenía exactamente la luz correcta. Nuestro fotógrafo — que lleva 15 años en bodas — nos dijo que fue la primera vez que trabajó con dirección de iluminación profesional y que la diferencia en las fotos era abismal. El álbum parece de revista."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Andrés y Sofía Castellanos</span>
                <span class="prod-quote__event">Boda en Casino Español — 300 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Seguidores</dt><dd>4+ unidades</dd></div>
              <div class="ps-specs__row"><dt>Potencia</dt><dd>575W c/u</dd></div>
              <div class="ps-specs__row"><dt>Director</dt><dd>Incluido en sitio</dd></div>
              <div class="ps-specs__row"><dt>Operadores</dt><dd>Uno por equipo</dd></div>
              <div class="ps-specs__row"><dt>Visita previa</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Diseño previo</dt><dd>Plano de iluminación</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Nacional</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas de gran formato</span>
              <span class="ps-tag">200+ invitados</span>
              <span class="ps-tag">XV años de lujo</span>
              <span class="ps-tag">Eventos corporativos VIP</span>
              <span class="ps-tag">Producciones profesionales</span>
              <span class="ps-tag">Con orquesta en vivo</span>
              <span class="ps-tag">Salones de 5 estrellas</span>
              <span class="ps-tag">Cobertura nacional</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-momento-estelar/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/momento-estelar.avif" alt="Momento Estelar" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Momento Estelar</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-2-seguidores/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/2-seguidores.avif" alt="2 Seguidores" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">2 Seguidores</span>
                <span class="ps-pkg__price">$6,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/seguidor-de-luz/paquete-recepcion-completa/" class="ps-pkg">
              <img src="/img/paquetes/seguidor-de-luz/recepcion-completa.avif" alt="Recepción Completa" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Recepción Completa</span>
                <span class="ps-pkg__price">$9,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento fuera de CDMX o con requerimientos especiales? Contáctanos — diseñamos producción personalizada para cualquier destino.</p>
              <a href={WHATSAPP_URL_MSG} class="ps-upsell__link" target="_blank" rel="noopener">Cotizar producción a medida →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu producción</h3>
            <p class="ps-widget__desc">Consulta personalizada con nuestro director de iluminación. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Solicitar Consulta</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
