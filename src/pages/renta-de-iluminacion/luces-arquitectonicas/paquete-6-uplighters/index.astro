---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 6 Uplighters de Luces Arquitectónicas?',
    respuesta: 'Incluye 6 uplighters LED RGB de alta potencia, posicionamiento estratégico en columnas o entrada principal, transporte, instalación profesional, técnico en sitio durante el evento y desmontaje. Puedes elegir el color que combine con tu decoración.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 6 Uplighters?',
    respuesta: 'El paquete 6 Uplighters tiene un precio desde $3,000 MXN + IVA. Incluye transporte, instalación, operación durante el evento y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Puedo elegir el color de los uplighters?',
    respuesta: 'Sí, los uplighters LED son de color variable RGB. Puedes elegir el color exacto que combine con tu decoración — azul marino para una boda elegante, rosa para XV años, blanco cálido para un corporativo, o cualquier color de tu paleta. También pueden cambiar de color durante el evento.'
  },
  {
    pregunta: '¿Para qué se usan 6 uplighters?',
    respuesta: 'Con 6 uplighters puedes iluminar la entrada principal del venue (1-2 columnas a cada lado), crear acentos de color en la mesa principal, bañar un árbol o fachada clave en el exterior, o hacer una pared de acento en el salón. Es un número ideal para un impacto focal en un área específica.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 6 Uplighters?',
    respuesta: 'Cubrimos CDMX y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '6 Uplighters — Luces Arquitectónicas | REDEIL',
    description: 'Renta de 6 uplighters LED RGB para acentos de color en entrada, columnas o mesa principal. Instalación profesional en CDMX desde $3,000 MXN.',
    image: SITE_URL + '/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/main.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3000',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luces-arquitectonicas/paquete-6-uplighters/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '38',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="6 Uplighters — Renta de Luces Arquitectónicas en CDMX | REDEIL"
  description="Renta de 6 uplighters LED RGB para acentos de color en entrada, columnas o mesa principal. Instalación profesional en CDMX y Edomex desde $3,000 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luces Arquitectónicas', href: '/renta-de-iluminacion/luces-arquitectonicas/' }, { name: '6 Uplighters', href: '/renta-de-iluminacion/luces-arquitectonicas/paquete-6-uplighters/' }]} />

  <Hero
    badge="6 Uplighters"
    title="6 Uplighters LED — Acentos de Color para Entrada y Mesa Principal"
    description="El impacto de color justo donde más se nota. 6 uplighters LED posicionados en columnas, entrada principal o mesa de honor transforman cualquier venue con un acento de luz que define el ambiente del evento."
    primaryCta={{ text: 'Cotizar $3,000 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luces-arquitectonicas/' }}
  >
    <Fragment slot="hero-seo">
      <p>Los <strong>uplighters LED</strong> son la herramienta más eficiente de la iluminación de eventos para transformar un espacio con color. A diferencia de las luces colgantes o los focos de techo, el uplighting ilumina <strong>de abajo hacia arriba</strong>: columnas, paredes y árboles se convierten en elementos visuales que definen el tono del evento.</p>
      <p>Con 6 uplighters, puedes crear un impacto focal preciso: la <strong>entrada principal</strong> del venue bañada en el color de tu boda, la mesa de honor enmarcada por luz, o los 3 árboles más fotogénicos del jardín iluminados en el color que combinan con tu decoración. Servicio en <strong>CDMX y Estado de México</strong> con instalación y técnico incluidos.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luces Arquitectónicas"
    items={[{ label: "12 Uplighters", href: "/renta-de-iluminacion/luces-arquitectonicas/paquete-12-uplighters/" }, { label: "20 Uplighters", href: "/renta-de-iluminacion/luces-arquitectonicas/paquete-20-uplighters/" }, { label: "Producción", href: "/renta-de-iluminacion/luces-arquitectonicas/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/main.avif" alt="6 uplighters LED iluminando columnas de entrada en boda CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img1.avif" alt="Uplighter LED iluminando columna de hacienda en color azul" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img2.avif" alt="Acento de color con uplighting en mesa principal de boda" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img3.avif" alt="Entrada principal de venue iluminada con uplighters de color" width="300" height="200" loading="lazy" />
              <img src="/img/blog/uplighting-gala.avif" alt="Uplighting LED en gala corporativa CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete 6 Uplighters — Acento focal en zona principal</span>
            <h2 class="prod-info__title">6 Uplighters LED RGB con Color Elegible y Técnico Incluido</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,000</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, color a tu elección, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">Cómo 6 puntos de luz transforman la entrada de tu evento</h2>
            <p class="prod-selling__intro">El uplighting funciona porque el cerebro humano asocia la luz de abajo hacia arriba con grandiosidad — es como se iluminan los monumentos, los palacios y los escenarios de gala. Cuando tus invitados llegan al venue y ven las columnas de la entrada bañadas en el color de tu boda, el mensaje es claro: este evento fue diseñado. Con 6 uplighters tienes los puntos perfectos para ese primer impacto visual en la zona más importante del espacio.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Color exacto a tu elección — RGB completo</h3>
                  <p class="prod-hl__desc">Los uplighters son LED RGB de alta potencia. El técnico los programa al color exacto de tu decoración antes del evento. Si quieres un rosa palo específico, un azul rey o el blanco cálido de la arquitectura que ya tiene el venue — lo tenemos. También pueden cambiar de color durante el evento.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Posicionamiento estratégico en los puntos de mayor impacto</h3>
                  <p class="prod-hl__desc">No es solo poner 6 luces al azar. El técnico evalúa el venue y posiciona los uplighters donde van a generar el mayor impacto visual: la entrada, las columnas flanqueando la pista, la pared detrás del head table, los árboles más fotogénicos del jardín.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Sin instalación visible — la luz parece parte del venue</h3>
                  <p class="prod-hl__desc">Los uplighters se colocan al ras del suelo o muy cerca de la base de lo que iluminan. El cableado va oculto. El resultado es que la luz parece emanar del propio elemento arquitectónico — como si el venue siempre hubiera tenido esa iluminación. Tus fotos lo van a agradecer.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Impacto inmediato en fotos y video</h3>
                  <p class="prod-hl__desc">El uplighting es el efecto que más diferencia hace en las fotos de eventos. Transforma un espacio blanco plano en un ambiente con color, profundidad y carácter. Fotógrafos y videógrafos de bodas buscan activamente venues con uplighting porque les facilita crear imágenes memorables.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">6 uplighters LED RGB de alta potencia</div>
              <div class="prod-feat">Programación de color personalizado</div>
              <div class="prod-feat">Posicionamiento estratégico en venue</div>
              <div class="prod-feat">Cables y extensiones ocultos</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico en sitio durante el evento</div>
              <div class="prod-feat">Ajuste de color en tiempo real</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Soporte técnico incluido</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos qué quieres iluminar</h4>
                  <p class="prod-step__desc">Venue, número de columnas, tipo de espacio y el color de tu decoración o paleta de evento. Si tienes foto del lugar, mejor — planificamos el posicionamiento exacto.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cotización con plan de posicionamiento</h4>
                  <p class="prod-step__desc">En menos de 24h recibes propuesta con precio final y descripción de dónde va cada uplighter. Sin costos ocultos ni sorpresas el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada al instante. El técnico llega al venue con anticipación para instalar y programar el color antes de que lleguen los invitados.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Instalamos, operamos y desmontamos</h4>
                  <p class="prod-step__desc">El técnico pone cada uplighter en posición, oculta el cableado, programa el color y hace prueba de encendido. Permanece durante el evento para ajustes y desmonta al terminar.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">6 uplighters vs 12 uplighters: ¿cuándo necesitas más?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">6 Uplighters — Acento focal</span>
                <ul class="prod-compare__list">
                  <li>Ilumina entrada + mesa principal</li>
                  <li>Impacto en 1-2 zonas del venue</li>
                  <li>Salones hasta 150 m²</li>
                  <li>Eventos íntimos y bodas pequeñas</li>
                  <li>Presupuesto ajustado, máximo impacto</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">12 Uplighters — Cobertura salón</span>
                <ul class="prod-compare__list">
                  <li>Cubre salón o jardín completo</li>
                  <li>Todas las paredes en color</li>
                  <li>Salones de 150 a 300 m²</li>
                  <li>Bodas y XV años estándar</li>
                  <li>Transformación completa del espacio</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Pusimos los 6 uplighters en la entrada y en las columnas del altar. Cuando veo las fotos de la ceremonia, la diferencia con y sin la iluminación es enorme. Las columnas en azul marino combinaban perfectamente con los centros de mesa. Fue la decisión de decoración más barata que tomamos y la que más se nota en fotos."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Sofía y Emilio</span>
                <span class="prod-quote__event">Boda en Hacienda Tlalpan — 80 invitados, CDMX</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Equipos</dt><dd>6 uplighters LED</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>RGB alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Color</dt><dd>A elección del cliente</dd></div>
              <div class="ps-specs__row"><dt>Espacio ideal</dt><dd>Hasta 150 m²</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>Entrada o mesa principal</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>En sitio todo el evento</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas pequeñas</span>
              <span class="ps-tag">Entradas de venues</span>
              <span class="ps-tag">Mesa principal</span>
              <span class="ps-tag">Árbol o fachada focal</span>
              <span class="ps-tag">Altar de ceremonia</span>
              <span class="ps-tag">Cenas íntimas</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Presupuesto ajustado</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-12-uplighters/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-arquitectonica.avif" alt="12 Uplighters para salón mediano" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">12 Uplighters</span>
                <span class="ps-pkg__price">$5,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-20-uplighters/" class="ps-pkg">
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/main.avif" alt="20 Uplighters para hacienda grande" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">20 Uplighters</span>
                <span class="ps-pkg__price">$8,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-produccion/" class="ps-pkg">
              <img src="/img/blog/uplighting-gala.avif" alt="Producción uplighting 30+" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 30+</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda en salón mediano? 12 uplighters cubren todo el perímetro del salón para una transformación completa.</p>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-12-uplighters/" class="ps-upsell__link">Ver 12 Uplighters →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/iluminacion-laser/" class="ps-link">Iluminación Láser</a>
              <a href="/renta-de-iluminacion/proyector-de-gobos/" class="ps-link">Proyector de Gobos</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
