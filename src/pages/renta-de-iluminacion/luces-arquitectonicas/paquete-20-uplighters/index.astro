---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete 20 Uplighters de Luces Arquitectónicas?',
    respuesta: 'Incluye 20 uplighters LED RGBW de alta potencia, controlador DMX profesional, programación de colores personalizada, posicionamiento estratégico en todo el venue, transporte, instalación profesional, técnico operador durante todo el evento y desmontaje. Ideal para haciendas y salones grandes que requieren transformación completa del espacio.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete 20 Uplighters?',
    respuesta: 'El paquete 20 Uplighters tiene un precio desde $8,500 MXN + IVA. Incluye transporte, instalación, controlador DMX, programación de colores, operación durante el evento y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Qué ventaja tiene el controlador DMX incluido en este paquete?',
    respuesta: 'El controlador DMX permite programar y cambiar los colores de los 20 uplighters de forma centralizada y sincronizada. Puedes tener colores distintos por zona, transiciones suaves, cambios de color en momentos específicos del evento (ceremonia, cena, baile) y efectos de fade. Es la diferencia entre uplighting básico y una producción de iluminación real.'
  },
  {
    pregunta: '¿Para cuántos invitados es ideal el paquete 20 Uplighters?',
    respuesta: 'Este paquete está diseñado para eventos de 150 a 300 invitados. Con 20 equipos puedes cubrir el perímetro completo de una hacienda, iluminar fachada + jardín + salón, o crear zonas de color diferenciadas para ceremonia y recepción en el mismo venue.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete 20 Uplighters?',
    respuesta: 'Cubrimos CDMX y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo, Querétaro y cualquier ubicación dentro de 150 km de CDMX con cotización de traslado incluida.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '20 Uplighters — Luces Arquitectónicas | REDEIL',
    description: 'Renta de 20 uplighters LED RGBW con controlador DMX para haciendas y salones grandes. Transformación completa del venue para bodas de 150-300 invitados en CDMX desde $8,500 MXN.',
    image: SITE_URL + '/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/main.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '8500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/luces-arquitectonicas/paquete-20-uplighters/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '27',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="20 Uplighters — Renta de Luces Arquitectónicas para Haciendas en CDMX | REDEIL"
  description="Renta de 20 uplighters LED RGBW con controlador DMX para haciendas y salones grandes. Transformación completa del venue para bodas de 150-300 invitados. Desde $8,500 MXN."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Luces Arquitectónicas', href: '/renta-de-iluminacion/luces-arquitectonicas/' }, { name: '20 Uplighters', href: '/renta-de-iluminacion/luces-arquitectonicas/paquete-20-uplighters/' }]} />

  <Hero
    badge="20 Uplighters — Hacienda y Salón Grande"
    title="20 Uplighters LED RGBW — Transforma Completamente tu Hacienda o Salón"
    description="El paquete para bodas que quieren impacto total. 20 uplighters LED RGBW con controlador DMX cubren el venue completo: fachada, jardín, salón y áreas de ceremonia. Para 150-300 invitados en haciendas, galas y corporativos grandes."
    primaryCta={{ text: 'Cotizar $8,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/luces-arquitectonicas/' }}
  >
    <Fragment slot="hero-seo">
      <p>Con <strong>20 uplighters LED RGBW</strong> y un <strong>controlador DMX</strong> profesional, dejas de hablar de acentos de color y empiezas a hablar de una producción de iluminación real. Cada columna, cada árbol, cada pared del venue queda cubierta. La hacienda no solo "tiene luces de colores" — se convierte en otro espacio.</p>
      <p>Este paquete es el favorito para <strong>bodas en hacienda en CDMX y Edomex</strong> con 150 a 300 invitados: cubre el perímetro completo del salón principal, la fachada exterior y las zonas de jardín. El controlador DMX permite programar cambios de color para cada momento del evento — luz blanca cálida durante la cena, el color de la boda para el primer baile, colores vibrantes para la fiesta.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Luces Arquitectónicas"
    items={[{ label: "6 Uplighters", href: "/renta-de-iluminacion/luces-arquitectonicas/paquete-6-uplighters/" }, { label: "12 Uplighters", href: "/renta-de-iluminacion/luces-arquitectonicas/paquete-12-uplighters/" }, { label: "Producción", href: "/renta-de-iluminacion/luces-arquitectonicas/paquete-produccion/" }]}
  />

  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <div class="prod-main">

          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/main.avif" alt="20 uplighters LED RGBW iluminando hacienda completa en boda CDMX" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img1.avif" alt="Uplighters LED iluminando columnas de hacienda con controlador DMX" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img2.avif" alt="Salón grande transformado con uplighting RGBW en boda de 200 invitados" width="300" height="200" loading="lazy" />
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img3.avif" alt="Fachada de hacienda iluminada con 20 uplighters en color dorado" width="300" height="200" loading="lazy" />
              <img src="/img/blog/uplighting-gala.avif" alt="Uplighting DMX en gala corporativa grande CDMX" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <div class="prod-info">
            <span class="prod-info__badge">Paquete 20 Uplighters — Transformación total del venue</span>
            <h2 class="prod-info__title">20 Uplighters LED RGBW con Controlador DMX y Técnico Especializado</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$8,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, controlador DMX, programación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <div class="prod-selling">
            <h2 class="prod-selling__headline">La diferencia entre "luces de colores" y una producción de iluminación profesional</h2>
            <p class="prod-selling__intro">Cuando tienes 6 o 12 uplighters, iluminas zonas. Cuando tienes 20 uplighters con DMX, iluminas el venue completo y lo controlas en tiempo real. El controlador DMX sincroniza todos los equipos: puedes programar que durante la ceremonia el salón esté en blanco cálido, que cuando entren a la recepción haga fade al color de tu boda, y que a medianoche todo cambie para la fiesta. Un solo técnico opera todo desde una consola. Tus invitados no saben que hay un técnico — solo saben que el evento se siente distinto a todos los que han asistido.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Controlador DMX — cambios de color programados para cada momento</h3>
                  <p class="prod-hl__desc">El DMX es el estándar profesional de la industria de eventos. Permite programar cues de iluminación: en qué momento cambia el color, a qué velocidad hace el fade, qué zonas del venue cambian y cuáles no. Tu evento tiene una narrativa de luz, no solo "uplighters prendidos toda la noche".</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura total de hacienda — fachada, jardín y salón en un paquete</h3>
                  <p class="prod-hl__desc">20 uplighters cubren el perímetro completo de una hacienda de tamaño estándar: 8-10 equipos para el salón principal, 4-6 para la fachada exterior, 4-6 para jardín o área de ceremonia. No hay zona sin tratar. El venue tiene coherencia visual de entrada a salida.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">RGBW — blanco puro además de colores</h3>
                  <p class="prod-hl__desc">Los uplighters RGBW añaden un canal de blanco independiente al RGB estándar. Esto significa que puedes tener blanco puro y limpio (no el blanco rosado que da el RGB mezclado), blanco cálido tipo vela para la ceremonia, y cualquier color saturado para la fiesta. Un solo equipo hace todo el rango.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Diseño previo — sabemos dónde va cada equipo antes de llegar</h3>
                  <p class="prod-hl__desc">Con foto o plano del venue, el técnico diseña el posicionamiento de los 20 equipos antes del día del evento. Llegamos sabiendo exactamente qué va dónde, qué longitudes de cable necesitamos y cuánto tiempo toma la instalación. Sin improvisar el día de tu boda.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">20 uplighters LED RGBW de alta potencia</div>
              <div class="prod-feat">Controlador DMX profesional</div>
              <div class="prod-feat">Programación de cues personalizada</div>
              <div class="prod-feat">Diseño previo de posicionamiento</div>
              <div class="prod-feat">Cables y extensiones ocultos</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador en sitio todo el evento</div>
              <div class="prod-feat">Cambios de color en tiempo real</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
            </div>
          </div>

          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Compártenos el venue y la paleta de colores</h4>
                  <p class="prod-step__desc">Nombre del venue, fotos o plano si tienes, número de invitados y los colores de tu boda o evento. Con eso diseñamos el mapa de posicionamiento de los 20 equipos y los cues de color para cada momento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Propuesta con diseño de iluminación incluido</h4>
                  <p class="prod-step__desc">En menos de 24h recibes cotización con precio final, mapa de posicionamiento de los uplighters y descripción de los cues de color programados para tu evento. Nada improvisado.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Reserva con 50% de anticipo</h4>
                  <p class="prod-step__desc">Tu fecha queda bloqueada. El técnico programa los cues de DMX con anticipación y llega al venue 3-4 horas antes para instalación, cableado y pruebas antes de que lleguen los invitados.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Producción operada en tiempo real</h4>
                  <p class="prod-step__desc">El técnico opera la consola DMX durante todo el evento: ejecuta los cambios de color en el momento indicado, hace ajustes según cómo fluye el evento y resuelve cualquier imprevisto técnico. Al terminar, desmontamos limpiamente.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="prod-compare">
            <h3 class="prod-compare__title">20 uplighters vs 12 uplighters: ¿cuándo necesitas más cobertura?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">12 Uplighters — Salón mediano</span>
                <ul class="prod-compare__list">
                  <li>Cubre perímetro de un salón</li>
                  <li>Ideal hasta 150 invitados</li>
                  <li>Una zona por evento</li>
                  <li>Sin control DMX centralizado</li>
                  <li>Salones hasta 200 m²</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">20 Uplighters — Hacienda completa</span>
                <ul class="prod-compare__list">
                  <li>Cubre fachada + jardín + salón</li>
                  <li>150 a 300 invitados</li>
                  <li>Múltiples zonas diferenciadas</li>
                  <li>Controlador DMX incluido</li>
                  <li>Haciendas y venues grandes</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Nuestra boda fue en Hacienda La Gavia con 220 invitados. El técnico de REDEIL llegó 4 horas antes y cuando entramos al salón estaba todo en blanco cálido, perfecto para la ceremonia. Cuando pasamos a la recepción hicieron el cambio a azul marino — el color de nuestra boda — y fue un momento mágico. A medianoche pusieron los colores más intensos y todo mundo se volvió loco. Valió cada peso."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Valentina y Rodrigo</span>
                <span class="prod-quote__event">Boda en Hacienda La Gavia — 220 invitados, Estado de México</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <aside class="prod-sidebar">

          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Equipos</dt><dd>20 uplighters LED</dd></div>
              <div class="ps-specs__row"><dt>Tipo</dt><dd>RGBW alta potencia</dd></div>
              <div class="ps-specs__row"><dt>Control</dt><dd>Consola DMX incluida</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>150–300 invitados</dd></div>
              <div class="ps-specs__row"><dt>Venue ideal</dt><dd>Hacienda o salón grande</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Técnico</dt><dd>En sitio todo el evento</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">Galas de lujo</span>
              <span class="ps-tag">Corporativos grandes</span>
              <span class="ps-tag">Fiestas de 150+ personas</span>
              <span class="ps-tag">Venues con jardín exterior</span>
              <span class="ps-tag">Múltiples zonas de evento</span>
              <span class="ps-tag">XV años de lujo</span>
              <span class="ps-tag">Producciones con DMX</span>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-6-uplighters/" class="ps-pkg">
              <img src="/img/blog/renta-de-luces-arquitectonicas-para-eventos-cdmx/img3.avif" alt="6 Uplighters para entrada y acento focal" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">6 Uplighters</span>
                <span class="ps-pkg__price">$3,000 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-12-uplighters/" class="ps-pkg">
              <img src="/img/img-index/iluminacion-arquitectonica.avif" alt="12 Uplighters para salón mediano" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">12 Uplighters</span>
                <span class="ps-pkg__price">$5,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-produccion/" class="ps-pkg">
              <img src="/img/blog/uplighting-gala.avif" alt="Producción uplighting 30+ con director" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 30+</span>
                <span class="ps-pkg__price">$15,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Boda de lujo o más de 300 invitados? El paquete Producción incluye 30+ uplighters, director de iluminación y mapeo completo del venue.</p>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/paquete-produccion/" class="ps-upsell__link">Ver Producción →</a>
            </div>
          </div>

          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/guirnaldas/" class="ps-link">Guirnaldas de Luces</a>
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/iluminacion-laser/" class="ps-link">Iluminación Láser</a>
              <a href="/renta-de-iluminacion/proyector-de-gobos/" class="ps-link">Proyector de Gobos</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
            </div>
          </div>

          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
