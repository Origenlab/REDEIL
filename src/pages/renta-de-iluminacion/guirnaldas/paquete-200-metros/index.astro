---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué diferencia al paquete Premium — 200 metros de los demás?',
    respuesta: 'El diferenciador principal son los 2 dimmers independientes y el diseño personalizado del tendido. Esto significa que puedes tener zonas de luz completamente separadas: la terraza de cóctel a brillo alto mientras la pista de baile tiene luz tenue. Además, antes del evento un técnico visita el venue (o revisa fotos/planos) para diseñar exactamente cómo se distribuirán los 200 metros en tu espacio — no es un tendido genérico, es uno hecho para tu hacienda.'
  },
  {
    pregunta: '¿Cuánto espacio cubren 200 metros de guirnaldas?',
    respuesta: '200 metros te permiten cubrir un venue completo de tamaño mediano-grande. Por ejemplo: una hacienda con jardín de 30×40 metros queda completamente cubierta — pérgola, pasillo de ceremonia, zona de mesas y terraza de cóctel. También alcanza para cubrir dos zonas separadas del mismo venue. Para 150-250 invitados, es el paquete que no te deja ningún rincón sin iluminación.'
  },
  {
    pregunta: '¿Cómo funciona el diseño personalizado del tendido?',
    respuesta: 'Una vez confirmada tu reserva, te pedimos fotos o planos del venue. Nuestro equipo traza exactamente la distribución de los 200 metros: puntos de sujeción, alturas, cruces y zonas. El día del evento el equipo llega con el mapa ya resuelto, lo que reduce el tiempo de instalación y garantiza que el resultado visual sea exactamente el que planeamos juntos.'
  },
  {
    pregunta: '¿Los 2 dimmers independientes se pueden controlar por separado durante el evento?',
    respuesta: 'Sí. Cada dimmer controla una zona diferente del tendido. Un técnico se encarga de operar ambos durante el evento siguiendo el programa de la velada. Si la ceremonia pide más luz y la zona de bar pide ambiente tenue, se ajustan de forma independiente sin afectar la otra zona. Todo en tiempo real, sin que tú tengas que pedirlo.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar el paquete Premium?',
    respuesta: 'Para el paquete Premium recomendamos reservar con 6 a 8 semanas de anticipación, especialmente en temporada alta (noviembre-abril). El diseño personalizado del tendido requiere tiempo de planificación previa. Si tu evento es próximo, escríbenos por WhatsApp — verificamos disponibilidad al momento y en casos de urgencia podemos agilizar el proceso.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Premium — 200 metros — Guirnaldas de Luces | REDEIL',
    description: 'Cubre una hacienda entera con 200 metros de guirnaldas LED Edison, 2 dimmers independientes y diseño personalizado del tendido. Para eventos de 150-250 invitados en CDMX y Edomex.',
    image: SITE_URL + '/img/paquetes/guirnaldas/premium.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '10800',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/guirnaldas/paquete-200-metros/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '28',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Premium — 200 metros — Guirnaldas de Luces en CDMX | REDEIL"
  description="200m de guirnaldas LED Edison con 2 dimmers y diseño personalizado. Cubre haciendas completas para 150-250 invitados. Instalación profesional CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Guirnaldas de Luces', href: '/renta-de-iluminacion/guirnaldas/' }, { name: 'Premium — 200 metros', href: '/renta-de-iluminacion/guirnaldas/paquete-200-metros/' }]} />

  <Hero
    badge="Premium — 200 metros"
    title="Premium — 200 metros — Guirnaldas de Luces"
    description="Para cuando el venue es grande y quieres que no quede un solo rincón sin magia. 200 metros de guirnaldas LED Edison con 2 dimmers independientes y diseño personalizado del tendido."
    primaryCta={{ text: 'Cotizar $10,800 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/guirnaldas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete <strong>Premium de 200 metros de guirnaldas LED</strong> está diseñado para haciendas, jardines amplios y venues donde la iluminación necesita cubrir múltiples zonas sin dejar rincones vacíos. Con <strong>2 dimmers independientes</strong>, cada área del venue tiene su propia atmósfera: la ceremonia brillante, el cóctel cálido y la pista de baile íntima — todo en el mismo evento, sin cambiar equipos.</p>
      <p>A diferencia de una renta genérica, el paquete incluye <strong>diseño personalizado del tendido</strong> previo al evento. Nuestro equipo traza la distribución exacta de los 200 metros en tu espacio, calcula puntos de sujeción y alturas, y llega el día del evento con todo resuelto. El resultado: una hacienda completamente transformada, desde la entrada hasta la última mesa.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Guirnaldas de Luces"
    items={[{ label: "Básico — 50 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-50-metros/" }, { label: "Estándar — 100 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-100-metros/" }, { label: "Producción — 500 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-500-metros/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/guirnaldas/premium.avif" alt="Paquete Premium 200 metros guirnaldas Edison en hacienda boda grande" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/paquetes/guirnaldas/estandar.avif" alt="200 metros de guirnaldas cubren jardín completo de hacienda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/dimmer.avif" alt="Dos dimmers independientes para control de zonas distintas" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/focos-edison.avif" alt="Foco Edison LED ámbar 2700K filamento visible" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/montaje.avif" alt="Equipo de dos técnicos instalando guirnaldas en hacienda" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Premium — Cobertura total del venue</span>
            <h2 class="prod-info__title">200 metros de Guirnaldas LED con 2 Dimmers Independientes y Diseño Personalizado</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$10,800</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: 2 dimmers, diseño del tendido, 2 técnicos, transporte, instalación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">La hacienda entera transformada — sin que quede un solo rincón sin luz</h2>
            <p class="prod-selling__intro">200 metros no es el doble de 100 metros — es una categoría diferente. Con esa longitud puedes cubrir entrada, jardín, ceremonia, zona de mesas y terraza de cóctel en el mismo tendido. El foco Edison a 2700K convierte cada espacio en algo que parece salido de una película: la luz cálida y filamentosa rebota en paredes de cantera, en los árboles, en los manteles. Pero el feature que cambia todo son los 2 dimmers independientes: dos zonas, dos atmósferas, un solo evento.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">2 dimmers independientes — dos zonas, dos atmósferas simultáneas</h3>
                  <p class="prod-hl__desc">Mientras en la zona de ceremonia tienes luz completa para que el fotógrafo capture cada detalle, la terraza de cóctel ya tiene un ambiente tenue y cálido. No hay que apagar un área para encender otra. Cada dimmer controla su zona de forma autónoma, operado por un técnico que sigue el programa de tu evento al pie de la letra.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Diseño personalizado del tendido — hecho para tu espacio, no para cualquiera</h3>
                  <p class="prod-hl__desc">Antes del evento diseñamos la distribución exacta de los 200 metros en tu venue. Puntos de sujeción, alturas, cruces de cables, zonas de concentración. No es un tendido genérico de líneas paralelas — es un diseño pensado para la arquitectura de tu espacio. El resultado visual es completamente diferente a una instalación improvisada.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura real para 150-250 invitados sin zonas oscuras</h3>
                  <p class="prod-hl__desc">Un venue de 150-250 invitados tiene muchas zonas: recepción, bar, pista de baile, zona de mesas, paso a los baños. Con 100 metros eso no alcanza — con 200 metros todo queda iluminado de forma coherente. No hay ese efecto de "aquí hay luz y allá ya no", que destruye la fotografía y el ambiente.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Equipo de 2 técnicos — instalación rápida, operación profesional</h3>
                  <p class="prod-hl__desc">Dos técnicos garantizan que la instalación de 200 metros se complete a tiempo sin presionar al coordinador ni al venue. Uno se encarga del montaje estructural, el otro de la conexión eléctrica y dimmers. Durante el evento, uno opera los dimmers y el otro supervisa que todo el tendido funcione correctamente. Sin improvisaciones.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">200 metros de guirnalda LED profesional</div>
              <div class="prod-feat">Focos Edison cálidos con filamento visible</div>
              <div class="prod-feat">2 dimmers de intensidad independientes</div>
              <div class="prod-feat">Cable negro mate profesional</div>
              <div class="prod-feat">Diseño personalizado del tendido</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación con equipo de 2 técnicos</div>
              <div class="prod-feat">Operación de dimmers durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Repuestos en sitio por si acaso</div>
              <div class="prod-feat">Extensiones y adaptadores incluidos</div>
              <div class="prod-feat">Consulta previa de distribución sin costo</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos tu venue y la cantidad de invitados</h4>
                  <p class="prod-step__desc">Fecha, dirección del venue, número de invitados y zonas principales. Con esa info comenzamos a diseñar cómo se distribuirán los 200 metros en tu espacio específico.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Diseño del tendido y cotización en 24h</h4>
                  <p class="prod-step__desc">Recibe la propuesta detallada con el diseño de distribución, precio final y configuración de los 2 dimmers por zona. Sin costos ocultos ni sorpresas el día del evento.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con anticipo del 50%. Tu fecha queda bloqueada y el diseño del tendido personalizado queda agendado con tu información del venue.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">El día del evento: llegamos, instalamos, operamos</h4>
                  <p class="prod-step__desc">El equipo de 2 técnicos llega 4 horas antes, instala según el diseño aprobado, configura ambos dimmers por zona y hace pruebas de encendido. Durante el evento operamos la iluminación según tu programa. Al terminar, desmontamos todo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 200 metros y no 100?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Estándar — 100 metros</span>
                <ul class="prod-compare__list">
                  <li>Cubre una zona del venue</li>
                  <li>Un dimmer para todo el tendido</li>
                  <li>80-120 invitados cómodos</li>
                  <li>Distribución estándar</li>
                  <li>1 técnico operador</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Premium — 200 metros</span>
                <ul class="prod-compare__list">
                  <li>Cubre todo el venue completo</li>
                  <li>2 dimmers para zonas independientes</li>
                  <li>150-250 invitados sin zonas oscuras</li>
                  <li>Diseño personalizado del tendido</li>
                  <li>Equipo de 2 técnicos</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Organizamos la cena anual de la empresa en una hacienda en Tlaxcala para 200 personas. Lo que más me sorprendió fue el diseño previo: recibimos un plano con exactamente cómo iban a quedar los 200 metros distribuidos. El día del evento llegaron puntuales, instalaron en tiempo récord y cuando encendieron ambas zonas a diferentes intensidades, el venue se veía completamente transformado. El director general preguntó quién había hecho la iluminación — tuvimos que dar el contacto tres veces esa noche."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Rodrigo Villanueva</span>
                <span class="prod-quote__event">Cena corporativa en Hacienda Hernández — 200 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Longitud total</dt><dd>200 metros</dd></div>
              <div class="ps-specs__row"><dt>Tipo de foco</dt><dd>Edison LED ámbar</dd></div>
              <div class="ps-specs__row"><dt>Temperatura</dt><dd>2700K cálido</dd></div>
              <div class="ps-specs__row"><dt>Cable</dt><dd>Negro mate profesional</dd></div>
              <div class="ps-specs__row"><dt>Dimmers</dt><dd>2 independientes</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>150-250 invitados</dd></div>
              <div class="ps-specs__row"><dt>Técnicos</dt><dd>2 profesionales</dd></div>
              <div class="ps-specs__row"><dt>Diseño tendido</dt><dd>Personalizado</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas grandes</span>
              <span class="ps-tag">Haciendas</span>
              <span class="ps-tag">Fincas</span>
              <span class="ps-tag">Jardines amplios</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Galas</span>
              <span class="ps-tag">Cenas de empresa</span>
              <span class="ps-tag">Bodas 150-250 invitados</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-50-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/basico.avif" alt="Básico 50m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Básico — 50m</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-100-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/estandar.avif" alt="Estándar 100m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Estándar — 100m</span>
                <span class="ps-pkg__price">$6,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-500-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/produccion.avif" alt="Producción 500m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 500m</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Festival, boda de 300+ o producción audiovisual? El paquete de 500m incluye director de iluminación y 4 dimmers por zona.</p>
              <a href="/renta-de-iluminacion/guirnaldas/paquete-500-metros/" class="ps-upsell__link">Ver paquete Producción →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Diseño del tendido + cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
