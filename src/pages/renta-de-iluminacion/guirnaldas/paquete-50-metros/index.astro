---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import SectionHeader from '../../../../components/SectionHeader.astro';
import ProductShowcase from '../../../../components/ProductShowcase.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    "pregunta": "¿Qué incluye el paquete Básico — 50 metros de Guirnaldas de Luces?",
    "respuesta": "El paquete Básico — 50 metros incluye 50 metros de guirnalda led, focos edison cálidos, instalación y desmontaje. Todo con instalación profesional y desmontaje incluido. Nuestro equipo técnico llega con anticipación para montar y hacer pruebas."
  },
  {
    "pregunta": "¿Cuánto cuesta el paquete Básico — 50 metros?",
    "respuesta": "El paquete Básico — 50 metros de Guirnaldas de Luces tiene un precio desde $3,500 MXN + IVA. Este precio incluye transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México."
  },
  {
    "pregunta": "¿Puedo personalizar el paquete Básico — 50 metros?",
    "respuesta": "Sí, todos nuestros paquetes son personalizables. Podemos agregar o quitar elementos según tus necesidades y presupuesto. Contáctanos por WhatsApp al 55 4937 5172 para una cotización a la medida."
  },
  {
    "pregunta": "¿En qué zonas entregan el paquete Básico — 50 metros?",
    "respuesta": "Cubrimos toda la Ciudad de México y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km de CDMX."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar el paquete Básico — 50 metros?",
    "respuesta": "Recomendamos reservar con 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp para verificar disponibilidad del equipo."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Básico — 50 metros — Guirnaldas de Luces | REDEIL',
    description: 'Paquete ideal para espacios íntimos. 50 metros de guirnaldas LED con focos Edison crean un ambiente cálido y acogedor perfecto para cenas románticas, terrazas pequeñas y rincones especiales en tu evento.',
    image: SITE_URL + '/img/img-index/guirnaldas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/guirnaldas/paquete-50-metros/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '30',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Básico — 50 metros — Guirnaldas de Luces en CDMX | REDEIL"
  description="Paquete ideal para espacios íntimos. 50 metros de guirnaldas LED con focos Edison crean un ambiente cálido y acogedor perfecto para cenas románticas, terra"
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Guirnaldas de Luces', href: '/renta-de-iluminacion/guirnaldas/' }, { name: 'Básico — 50 metros', href: '/renta-de-iluminacion/guirnaldas/paquete-50-metros/' }]} />

  <Hero
    badge="Básico — 50 metros"
    title="Básico — 50 metros — Guirnaldas de Luces"
    description="Paquete ideal para espacios íntimos. 50 metros de guirnaldas LED con focos Edison crean un ambiente cálido y acogedor perfecto para cenas románticas, te..."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/guirnaldas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de 50 metros de guirnaldas LED es la opción perfecta para quienes buscan agregar un toque de magia a espacios reducidos. Con focos Edison de luz cálida, cada metro de cable negro profesional se integra discretamente en la decoración de tu evento en CDMX o Estado de México.</p>
      <p>Este paquete incluye instalación y desmontaje profesional, garantizando que las guirnaldas queden perfectamente colocadas. Ideal para decorar pérgolas, techos de terrazas y marcos de fotografía en bodas íntimas y cenas al aire libre.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Guirnaldas de Luces"
    items={[{ label: "Estándar — 100 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-100-metros/" }, { label: "Premium — 200 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-200-metros/" }, { label: "Producción — 500 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-500-metros/" }]}
  />

    <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/guirnaldas/basico.avif" alt="Paquete Básico 50 metros guirnaldas Edison" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/guirnaldas.avif" alt="Guirnaldas Edison en jardín de boda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/focos-edison.avif" alt="Detalle foco Edison LED ámbar" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/montaje.avif" alt="Guirnaldas instaladas entre árboles" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/todo-incluido.avif" alt="Setup completo guirnaldas listo para evento" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Básico</span>
            <h2 class="prod-info__title">50 metros de Guirnaldas LED con Focos Edison</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$3,500</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">50 metros que transforman cualquier rincón en el lugar que todos quieren fotografiar</h2>
            <p class="prod-selling__intro">Este no es solo un tendido de luces. Son 50 metros de atmósfera: focos Edison con filamento visible que proyectan una luz ámbar cálida, montados sobre cable negro profesional que desaparece contra el cielo nocturno. El resultado es ese efecto de jardín europeo que ves en Pinterest — pero real, en tu evento, en CDMX.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Luz ámbar cálida sin deslumbrar</h3>
                  <p class="prod-hl__desc">Los focos Edison LED emiten 2700K — la temperatura exacta que favorece los tonos de piel en fotografías y crea intimidad sin oscurecer el espacio. Tus invitados se ven bien, tu evento se siente bien.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cable negro profesional: invisible de noche</h3>
                  <p class="prod-hl__desc">No usamos cable blanco ni transparente que refleja flash. El cable negro mate se mimetiza con el cielo nocturno, dejando visible solo la luz. El efecto: focos flotando en el aire.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Instalación a medida de tu espacio</h3>
                  <p class="prod-hl__desc">Nuestro técnico evalúa la estructura del lugar — pérgolas, árboles, postes, techos — y diseña el recorrido óptimo de las guirnaldas. No es colgar cable: es iluminar arquitectura.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Servicio puerta a puerta sin que muevas un dedo</h3>
                  <p class="prod-hl__desc">Llegamos 3 horas antes, instalamos, hacemos pruebas de encendido, operamos durante el evento y desmontamos al final. Tú llegas, todo está listo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">50 metros de guirnalda LED profesional</div>
              <div class="prod-feat">Focos Edison cálidos con filamento visible</div>
              <div class="prod-feat">Cable negro mate profesional</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Repuestos en sitio por si acaso</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento y cuántos invitados esperas. Con esos datos diseñamos la propuesta exacta para tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada por WhatsApp con precio final, lo que incluye y opciones de personalización. Sin costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Nosotros nos encargamos de todo</h4>
                  <p class="prod-step__desc">Llegamos 3 horas antes, instalamos las guirnaldas según el diseño acordado, hacemos pruebas y operamos durante el evento. Al terminar, desmontamos todo.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa rápida -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué guirnaldas Edison y no series de luces normales?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Series de luces comerciales</span>
                <ul class="prod-compare__list">
                  <li>Luz blanca fría — parece bodega</li>
                  <li>Cable visible y plástico delgado</li>
                  <li>Se funden a mitad del evento</li>
                  <li>Tú instalas, tú resuelves</li>
                  <li>Focos pequeños sin carácter</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Guirnaldas Edison REDEIL</span>
                <ul class="prod-compare__list">
                  <li>Luz ámbar 2700K — favorece fotos</li>
                  <li>Cable negro mate invisible</li>
                  <li>LED profesional, cero fallas</li>
                  <li>Técnico opera todo el evento</li>
                  <li>Focos Edison con filamento visible</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Las guirnaldas fueron el detalle que todos nuestros invitados comentaron. El jardín parecía sacado de una revista. El equipo de REDEIL llegó temprano, montó todo en silencio y cuando empezó la cena el efecto era impresionante."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Andrea y Carlos</span>
                <span class="prod-quote__event">Boda en Jardín Santa Fe — 45 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Longitud total</dt><dd>50 metros</dd></div>
              <div class="ps-specs__row"><dt>Tipo de foco</dt><dd>Edison LED ámbar</dd></div>
              <div class="ps-specs__row"><dt>Temperatura</dt><dd>2700K cálido</dd></div>
              <div class="ps-specs__row"><dt>Cable</dt><dd>Negro mate profesional</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>30-50 invitados</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas íntimas en jardín</span>
              <span class="ps-tag">Cenas al aire libre</span>
              <span class="ps-tag">Pedidas de mano</span>
              <span class="ps-tag">Aniversarios</span>
              <span class="ps-tag">Baby showers</span>
              <span class="ps-tag">Terrazas privadas</span>
              <span class="ps-tag">Marcos de fotografía</span>
              <span class="ps-tag">Pérgolas y pasillos</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-100-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/estandar.avif" alt="Estándar 100m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Estándar — 100m</span>
                <span class="ps-pkg__price">$6,200 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-200-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/premium.avif" alt="Premium 200m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Premium — 200m</span>
                <span class="ps-pkg__price">$10,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-500-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/produccion.avif" alt="Producción 500m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 500m</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <!-- Upsell -->
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Tu espacio es más grande? El Estándar de 100m duplica cobertura e incluye dimmer.</p>
              <a href="/renta-de-iluminacion/guirnaldas/paquete-100-metros/" class="ps-upsell__link">Ver paquete Estándar →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-iluminacion/cabezas-moviles/" class="ps-link">Cabezas Móviles</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>


  <FaqSection items={faqItems} />

  <!-- CTA FINAL -->

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info (badge + title + price + CTAs) ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }

  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }

  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }

  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }

  /* ── Includes ── */
  .prod-includes { background: var(--color-bg); border-radius: 14px; padding: 1.75rem 2rem; }
