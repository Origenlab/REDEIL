---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import SectionHeader from '../../../../components/SectionHeader.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    "pregunta": "¿Qué incluye el paquete Básico — 50 metros de Guirnaldas de Luces?",
    "respuesta": "El paquete Básico — 50 metros incluye 50 metros de guirnalda led, focos edison cálidos, instalación y desmontaje. Todo con instalación profesional y desmontaje incluido. Nuestro equipo técnico llega con anticipación para montar y hacer pruebas."
  },
  {
    "pregunta": "¿Cuánto cuesta el paquete Básico — 50 metros?",
    "respuesta": "El paquete Básico — 50 metros de Guirnaldas de Luces tiene un precio desde $3,500 MXN + IVA. Este precio incluye transporte, instalación, operación y desmontaje dentro de CDMX y Estado de México."
  },
  {
    "pregunta": "¿Puedo personalizar el paquete Básico — 50 metros?",
    "respuesta": "Sí, todos nuestros paquetes son personalizables. Podemos agregar o quitar elementos según tus necesidades y presupuesto. Contáctanos por WhatsApp al 55 4937 5172 para una cotización a la medida."
  },
  {
    "pregunta": "¿En qué zonas entregan el paquete Básico — 50 metros?",
    "respuesta": "Cubrimos toda la Ciudad de México y Estado de México sin costo adicional de traslado. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km de CDMX."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar el paquete Básico — 50 metros?",
    "respuesta": "Recomendamos reservar con 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp para verificar disponibilidad del equipo."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Básico — 50 metros — Guirnaldas de Luces | REDEIL',
    description: 'Paquete ideal para espacios íntimos. 50 metros de guirnaldas LED con focos Edison crean un ambiente cálido y acogedor perfecto para cenas románticas, terrazas pequeñas y rincones especiales en tu evento.',
    image: SITE_URL + '/img/img-index/guirnaldas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '3500',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/guirnaldas/paquete-50-metros/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '30',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Básico — 50 metros — Guirnaldas de Luces en CDMX | REDEIL"
  description="Paquete ideal para espacios íntimos. 50 metros de guirnaldas LED con focos Edison crean un ambiente cálido y acogedor perfecto para cenas románticas, terra"
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Guirnaldas de Luces', href: '/renta-de-iluminacion/guirnaldas/' }, { name: 'Básico — 50 metros', href: '/renta-de-iluminacion/guirnaldas/paquete-50-metros/' }]} />

  <Hero
    badge="Básico — 50 metros"
    title="Básico — 50 metros — Guirnaldas de Luces"
    description="Paquete ideal para espacios íntimos. 50 metros de guirnaldas LED con focos Edison crean un ambiente cálido y acogedor perfecto para cenas románticas, te..."
    primaryCta={{ text: 'Cotizar $3,500 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/guirnaldas/' }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de 50 metros de guirnaldas LED es la opción perfecta para quienes buscan agregar un toque de magia a espacios reducidos. Con focos Edison de luz cálida, cada metro de cable negro profesional se integra discretamente en la decoración de tu evento en CDMX o Estado de México.</p>
      <p>Este paquete incluye instalación y desmontaje profesional, garantizando que las guirnaldas queden perfectamente colocadas. Ideal para decorar pérgolas, techos de terrazas y marcos de fotografía en bodas íntimas y cenas al aire libre.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Guirnaldas de Luces"
    items={[{ label: "Estándar — 100 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-100-metros/" }, { label: "Premium — 200 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-200-metros/" }, { label: "Producción — 500 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-500-metros/" }]}
  />

  <!-- PRODUCTO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="producto-layout">
        <!-- LEFT: Imagen + galería -->
        <div class="producto__visual">
          <div class="producto__img-main">
            <img src="/img/paquetes/guirnaldas/basico.avif" alt="Paquete Básico 50 metros de guirnaldas Edison" width="600" height="400" loading="eager" />
          </div>
          <div class="producto__img-grid">
            <img src="/img/img-index/pro/guirnaldas.avif" alt="Guirnaldas Edison en jardín de boda" width="300" height="200" loading="lazy" />
            <img src="/img/paquetes/guirnaldas/sell/focos-edison.avif" alt="Detalle foco Edison LED ámbar" width="300" height="200" loading="lazy" />
          </div>
        </div>

        <!-- RIGHT: Info + pricing + CTA -->
        <div class="producto__info">
          <span class="producto__badge">Paquete Básico</span>
          <h2 class="producto__title">50 metros de Guirnaldas LED</h2>
          <p class="producto__desc">El paquete ideal para bodas íntimas en jardín, cenas al aire libre y terrazas pequeñas. 50 metros de guirnalda con focos Edison de luz ámbar que transforman cualquier espacio en algo memorable. Nuestro equipo llega, instala, opera y desmonta — tú solo disfrutas.</p>

          <div class="producto__price-box">
            <div class="producto__price">
              <span class="producto__amount">$3,500</span>
              <span class="producto__currency">MXN + IVA</span>
            </div>
            <p class="producto__price-note">Instalación profesional incluida en CDMX y Edomex</p>
          </div>

          <div class="producto__includes">
            <h3>Lo que incluye:</h3>
            <div class="producto__features">
              <div class="producto__feat">50 metros de guirnalda LED profesional</div>
              <div class="producto__feat">Focos Edison cálidos con filamento visible</div>
              <div class="producto__feat">Cable negro profesional (invisible entre árboles)</div>
              <div class="producto__feat">Transporte + instalación + desmontaje</div>
              <div class="producto__feat">Técnico operador durante todo el evento</div>
            </div>
          </div>

          <div class="producto__ctas">
            <a href={WHATSAPP_URL_MSG} class="producto__btn producto__btn--primary" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
            <a href="/renta-de-iluminacion/guirnaldas/" class="producto__btn producto__btn--ghost">Ver todos los paquetes</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿PARA QUIÉN? -->
  <section class="section section--bg">
    <div class="container">
      <SectionHeader
        badge="¿Es para ti?"
        title="¿Para qué tipo de evento es el paquete de 50 metros?"
        subtitle="50 metros de guirnaldas cubren perfectamente una pérgola, un pasillo de ceremonia o una terraza para 30-50 invitados. Es el paquete más solicitado para cenas íntimas al aire libre, pedidas de mano, aniversarios y baby showers en jardines privados de CDMX."
        subtitle2="Si tu evento es más grande o necesitas cubrir más área, el paquete Estándar de 100 metros duplica la cobertura con dimmer incluido. Pero si buscas ese rincón especial que todos van a fotografiar — este paquete es exactamente lo que necesitas."
        id="para-quien-title"
      />
    </div>
  </section>

  <FaqSection<FaqSection items={faqItems} />

  <!-- CTA FINAL -->

  <Footer />
  <WhatsAppBubble />
</Base>
<style>
  .producto-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .producto-layout { grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  }
  .producto__visual { display: flex; flex-direction: column; gap: 0.75rem; }
  .producto__img-main { border-radius: 14px; overflow: hidden; }
  .producto__img-main img { width: 100%; height: auto; display: block; }
  .producto__img-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .producto__img-grid img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; aspect-ratio: 3/2; }
  .producto__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: #D4A04A; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.375rem 1rem; background: rgba(212,160,74,0.1); border-radius: 6px; margin-bottom: 0.75rem; }
  .producto__title { font-size: 1.75rem; font-weight: 800; color: #0F172A; line-height: 1.2; margin: 0 0 1rem; }
  .producto__desc { font-size: 1rem; color: #475569; line-height: 1.7; margin: 0 0 1.5rem; }
  .producto__price-box { background: #F8F9FA; border-radius: 12px; padding: 1.25rem; margin-bottom: 1.5rem; border-left: 4px solid #D4A04A; }
  .producto__price { display: flex; align-items: baseline; gap: 0.5rem; }
  .producto__amount { font-size: 2.25rem; font-weight: 800; color: #D4A04A; line-height: 1; }
  .producto__currency { font-size: 0.875rem; color: #94A3B8; font-weight: 500; }
  .producto__price-note { font-size: 0.8125rem; color: #64748B; margin: 0.5rem 0 0; }
  .producto__includes h3 { font-size: 1rem; font-weight: 700; color: #0F172A; margin: 0 0 0.75rem; }
  .producto__features { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
  .producto__feat { font-size: 0.9375rem; color: #475569; padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .producto__feat::before { content: ""; position: absolute; left: 0; top: 0.5rem; width: 6px; height: 6px; border-radius: 50%; background: #D4A04A; }
  .producto__ctas { display: flex; flex-direction: column; gap: 0.75rem; }
  .producto__btn { display: block; text-align: center; padding: 0.875rem 1.5rem; border-radius: 10px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s; }
  .producto__btn--primary { background: #25D366; color: #fff; }
  .producto__btn--primary:hover { background: #1DA851; }
  .producto__btn--ghost { background: none; color: #0F172A; border: 2px solid #E8E8E8; }
  .producto__btn--ghost:hover { border-color: #D4A04A; color: #D4A04A; }
</style>
