---
import Base from '../../../../layouts/Base.astro';
import TopBar from '../../../../components/TopBar.astro';
import Header from '../../../../components/Header.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import Footer from '../../../../components/Footer.astro';
import WhatsAppBubble from '../../../../components/WhatsAppBubble.astro';
import { faqSchema } from '../../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';

const faqItems = [
  {
    pregunta: '¿Qué incluye el paquete Estándar — 100 metros de Guirnaldas de Luces?',
    respuesta: 'Incluye 100 metros de guirnalda LED con focos Edison ámbar, dimmer de intensidad, cable negro profesional, transporte, instalación profesional, técnico operador durante el evento, desmontaje y repuestos en sitio. Nuestro equipo llega con anticipación para montar y hacer pruebas de encendido.'
  },
  {
    pregunta: '¿Cuánto cuesta el paquete Estándar — 100 metros?',
    respuesta: 'El paquete tiene un precio desde $6,200 MXN + IVA. Este precio incluye todo: transporte, instalación, dimmer, operación y desmontaje dentro de CDMX y Estado de México. Sin costos ocultos.'
  },
  {
    pregunta: '¿Puedo personalizar el paquete Estándar — 100 metros?',
    respuesta: 'Sí. Podemos agregar más metros, combinar con uplighting o cascadas LED, ajustar el diseño del tendido según tu espacio. Escríbenos por WhatsApp al 55 4937 5172 para una cotización a la medida.'
  },
  {
    pregunta: '¿En qué zonas entregan el paquete Estándar — 100 metros?',
    respuesta: 'Cubrimos toda la Ciudad de México y Estado de México sin costo adicional. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX.'
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos 4 a 6 semanas de anticipación, especialmente en temporada alta (noviembre-febrero). Para fechas próximas, contáctanos por WhatsApp — verificamos disponibilidad al momento.'
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Estándar — 100 metros — Guirnaldas de Luces | REDEIL',
    description: 'El paquete más popular para bodas y eventos medianos. 100 metros de guirnaldas LED Edison con dimmer de intensidad para crear la atmósfera perfecta en jardines y salones de CDMX.',
    image: SITE_URL + '/img/img-index/guirnaldas.avif',
    brand: { '@type': 'Brand', name: 'REDEIL' },
    offers: {
      '@type': 'Offer',
      price: '6200',
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      url: SITE_URL + '/renta-de-iluminacion/guirnaldas/paquete-100-metros/',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '42',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title="Estándar — 100 metros — Guirnaldas de Luces en CDMX | REDEIL"
  description="El paquete más popular para bodas. 100 metros de guirnaldas LED Edison con dimmer incluido. Instalación profesional en jardines, haciendas y salones de CDMX y Edomex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Guirnaldas de Luces', href: '/renta-de-iluminacion/guirnaldas/' }, { name: 'Estándar — 100 metros', href: '/renta-de-iluminacion/guirnaldas/paquete-100-metros/' }]} />

  <Hero
    badge="Estándar — 100 metros"
    title="Estándar — 100 metros — Guirnaldas de Luces"
    description="El paquete más popular para bodas y eventos medianos. 100 metros de guirnaldas LED Edison con dimmer de intensidad incluido. Instalación profesional en CDMX y Edomex."
    primaryCta={{ text: 'Cotizar $6,200 + IVA', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: '/renta-de-iluminacion/guirnaldas/' }}
  >
    <Fragment slot="hero-seo">
      <p>Nuestro paquete de <strong>100 metros de guirnaldas LED</strong> es el favorito de las parejas que celebran su boda en jardines y haciendas de <strong>CDMX y Estado de México</strong>. Con control de intensidad mediante dimmer, puedes ajustar la luz desde un brillo funcional para la cena hasta un ambiente tenue y romántico para el primer baile.</p>
      <p>La instalación profesional garantiza que cada tramo quede a la altura y tensión correcta. El cable negro se camufla con el cielo nocturno, haciendo que los focos Edison parezcan estrellas flotantes. Incluye transporte, montaje, operación durante el evento y desmontaje.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Otros paquetes de Guirnaldas de Luces"
    items={[{ label: "Básico — 50 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-50-metros/" }, { label: "Premium — 200 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-200-metros/" }, { label: "Producción — 500 metros", href: "/renta-de-iluminacion/guirnaldas/paquete-500-metros/" }]}
  />

  <!-- PRODUCTO CON SIDEBAR UNIFICADO -->
  <section class="section" id="producto">
    <div class="container">
      <div class="prod-layout">

        <!-- ═══ COLUMNA PRINCIPAL ═══ -->
        <div class="prod-main">

          <!-- Galería -->
          <div class="prod-gallery">
            <div class="prod-gallery__main">
              <img src="/img/paquetes/guirnaldas/estandar.avif" alt="Paquete Estándar 100 metros guirnaldas Edison en boda jardín" width="600" height="400" loading="eager" />
            </div>
            <div class="prod-gallery__side">
              <img src="/img/img-index/pro/guirnaldas.avif" alt="100 metros de guirnaldas Edison en hacienda" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/focos-edison.avif" alt="Detalle foco Edison LED ámbar filamento visible" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/montaje.avif" alt="Técnico instalando guirnaldas entre árboles" width="300" height="200" loading="lazy" />
              <img src="/img/paquetes/guirnaldas/sell/todo-incluido.avif" alt="Setup completo guirnaldas con dimmer listo" width="300" height="200" loading="lazy" />
            </div>
          </div>

          <!-- Badge + Título + Precio + CTA -->
          <div class="prod-info">
            <span class="prod-info__badge">Paquete Estándar — El más popular</span>
            <h2 class="prod-info__title">100 metros de Guirnaldas LED con Focos Edison y Dimmer</h2>

            <div class="prod-price">
              <span class="prod-price__amount">$6,200</span>
              <span class="prod-price__currency">MXN + IVA</span>
              <p class="prod-price__note">Todo incluido: transporte, instalación, dimmer, operación y desmontaje en CDMX y Edomex</p>
            </div>

            <div class="prod-ctas">
              <a href={WHATSAPP_URL_MSG} class="prod-btn prod-btn--wa" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
              <a href="/cotizar/" class="prod-btn prod-btn--outline">Solicitar cotización formal</a>
            </div>
          </div>

          <!-- Selling Points -->
          <div class="prod-selling">
            <h2 class="prod-selling__headline">El paquete que eligen 7 de cada 10 bodas en jardín</h2>
            <p class="prod-selling__intro">100 metros de guirnaldas cubren un jardín completo para 80-120 invitados. Lo que hace diferente a este paquete no es solo la longitud — es el dimmer. Controlas la intensidad de la luz en tiempo real: brillo completo durante la cena, media intensidad para los discursos, luz tenue para el primer baile. Tu evento tiene tres ambientes distintos con un solo paquete.</p>

            <div class="prod-highlights">
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Dimmer de intensidad incluido — tres ambientes en uno</h3>
                  <p class="prod-hl__desc">Con el control de intensidad gradual, pasas de luz funcional a romántica en segundos. Nuestro técnico ajusta la luz según el momento: cena, brindis, baile, fotos. Sin que tú tengas que pedir nada.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Cobertura completa para jardines y haciendas</h3>
                  <p class="prod-hl__desc">100 metros cubren un perímetro de jardín de hasta 25×25 metros, un pasillo de ceremonia completo más la zona de recepción, o un techo de palapa de extremo a extremo. Es el paquete que no te deja corto.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Focos Edison LED de filamento visible — el efecto vintage real</h3>
                  <p class="prod-hl__desc">No son LEDs redondos genéricos. Son focos Edison con filamento visible que emiten 2700K — la temperatura que hace que todo se vea cálido, íntimo y fotogénico. Tus invitados se ven bien, tu decoración se luce.</p>
                </div>
              </div>
              <div class="prod-hl">
                <div class="prod-hl__bar"></div>
                <div class="prod-hl__content">
                  <h3 class="prod-hl__title">Técnico profesional opera todo el evento</h3>
                  <p class="prod-hl__desc">No solo instalamos y nos vamos. Un técnico permanece durante tu evento para operar el dimmer, hacer ajustes y resolver cualquier imprevisto. Tú disfrutas, nosotros cuidamos la luz.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lo que incluye -->
          <div class="prod-includes">
            <h3 class="prod-includes__title">Lo que incluye este paquete</h3>
            <div class="prod-includes__grid">
              <div class="prod-feat">100 metros de guirnalda LED profesional</div>
              <div class="prod-feat">Focos Edison cálidos con filamento visible</div>
              <div class="prod-feat">Dimmer de intensidad graduable</div>
              <div class="prod-feat">Cable negro mate profesional</div>
              <div class="prod-feat">Transporte ida y vuelta</div>
              <div class="prod-feat">Instalación profesional</div>
              <div class="prod-feat">Técnico operador durante el evento</div>
              <div class="prod-feat">Desmontaje al finalizar</div>
              <div class="prod-feat">Repuestos en sitio por si acaso</div>
              <div class="prod-feat">Extensiones y adaptadores incluidos</div>
            </div>
          </div>

          <!-- Cómo funciona -->
          <div class="prod-process">
            <h3 class="prod-process__title">Así funciona el servicio</h3>
            <div class="prod-steps">
              <div class="prod-step">
                <span class="prod-step__num">1</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Cuéntanos sobre tu evento</h4>
                  <p class="prod-step__desc">Fecha, lugar, tipo de evento y cuántos invitados esperas. Con esos datos diseñamos la distribución exacta de los 100 metros en tu espacio.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">2</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Recibe tu cotización en menos de 24h</h4>
                  <p class="prod-step__desc">Te enviamos propuesta detallada con precio final, distribución del tendido y opciones de personalización. Sin compromiso ni costos ocultos.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">3</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Aparta tu fecha con anticipo</h4>
                  <p class="prod-step__desc">Reserva con un anticipo del 50% por transferencia, efectivo o tarjeta. Tu fecha queda bloqueada y confirmada al instante.</p>
                </div>
              </div>
              <div class="prod-step">
                <span class="prod-step__num">4</span>
                <div class="prod-step__content">
                  <h4 class="prod-step__name">Nosotros nos encargamos de todo</h4>
                  <p class="prod-step__desc">Llegamos 3 horas antes, instalamos según el diseño acordado, configuramos el dimmer, hacemos pruebas y operamos durante todo el evento. Al terminar, desmontamos.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparativa -->
          <div class="prod-compare">
            <h3 class="prod-compare__title">¿Por qué 100 metros y no 50?</h3>
            <div class="prod-compare__grid">
              <div class="prod-compare__col prod-compare__col--them">
                <span class="prod-compare__label">Paquete Básico — 50 metros</span>
                <ul class="prod-compare__list">
                  <li>Cubre una zona del evento</li>
                  <li>Ideal para espacios reducidos</li>
                  <li>Sin control de intensidad</li>
                  <li>30-50 invitados máximo</li>
                  <li>Un solo ambiente de luz</li>
                </ul>
              </div>
              <div class="prod-compare__col prod-compare__col--us">
                <span class="prod-compare__label">Estándar — 100 metros</span>
                <ul class="prod-compare__list">
                  <li>Cubre jardín completo</li>
                  <li>Ceremonia + recepción + foto</li>
                  <li>Dimmer de intensidad incluido</li>
                  <li>80-120 invitados cómodos</li>
                  <li>Tres ambientes en un evento</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Social proof -->
          <div class="prod-proof">
            <blockquote class="prod-quote">
              <p class="prod-quote__text">"Contratamos el paquete de 100 metros para nuestra boda en una hacienda en Tepoztlán. Lo que más nos sorprendió fue el dimmer: durante la cena teníamos buena luz para ver, y cuando empezó el baile bajaron la intensidad y se sintió completamente diferente. Nuestro fotógrafo nos dijo que las fotos con esa luz quedaron increíbles."</p>
              <footer class="prod-quote__footer">
                <span class="prod-quote__name">Mariana y Diego</span>
                <span class="prod-quote__event">Boda en Hacienda San Gabriel — 95 invitados</span>
              </footer>
            </blockquote>
          </div>

        </div>

        <!-- ═══ SIDEBAR UNIFICADO ═══ -->
        <aside class="prod-sidebar">

          <!-- 1. Specs técnicas -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Especificaciones</h3>
            <dl class="ps-specs">
              <div class="ps-specs__row"><dt>Longitud total</dt><dd>100 metros</dd></div>
              <div class="ps-specs__row"><dt>Tipo de foco</dt><dd>Edison LED ámbar</dd></div>
              <div class="ps-specs__row"><dt>Temperatura</dt><dd>2700K cálido</dd></div>
              <div class="ps-specs__row"><dt>Cable</dt><dd>Negro mate profesional</dd></div>
              <div class="ps-specs__row"><dt>Dimmer</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Cobertura</dt><dd>80-120 invitados</dd></div>
              <div class="ps-specs__row"><dt>Instalación</dt><dd>Incluida</dd></div>
              <div class="ps-specs__row"><dt>Desmontaje</dt><dd>Incluido</dd></div>
              <div class="ps-specs__row"><dt>Zona</dt><dd>CDMX + Edomex</dd></div>
            </dl>
          </div>

          <!-- 2. Ideal para -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Ideal para</h3>
            <div class="ps-tags">
              <span class="ps-tag">Bodas en jardín</span>
              <span class="ps-tag">Bodas en hacienda</span>
              <span class="ps-tag">XV años</span>
              <span class="ps-tag">Eventos corporativos</span>
              <span class="ps-tag">Cenas de gala</span>
              <span class="ps-tag">Fiestas en terraza</span>
              <span class="ps-tag">Graduaciones</span>
              <span class="ps-tag">Palapas y pérgolas grandes</span>
            </div>
          </div>

          <!-- 3. Otros paquetes -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Otros paquetes</h3>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-50-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/basico.avif" alt="Básico 50m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Básico — 50m</span>
                <span class="ps-pkg__price">$3,500 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-200-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/premium.avif" alt="Premium 200m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Premium — 200m</span>
                <span class="ps-pkg__price">$10,800 MXN</span>
              </div>
            </a>
            <a href="/renta-de-iluminacion/guirnaldas/paquete-500-metros/" class="ps-pkg">
              <img src="/img/paquetes/guirnaldas/produccion.avif" alt="Producción 500m" width="80" height="60" loading="lazy" class="ps-pkg__img" />
              <div class="ps-pkg__info">
                <span class="ps-pkg__name">Producción — 500m</span>
                <span class="ps-pkg__price">$22,000 MXN</span>
              </div>
            </a>
            <div class="ps-upsell">
              <p class="ps-upsell__text">¿Evento más grande o producción profesional? El Premium de 200m incluye 2 dimmers y diseño personalizado.</p>
              <a href="/renta-de-iluminacion/guirnaldas/paquete-200-metros/" class="ps-upsell__link">Ver paquete Premium →</a>
            </div>
          </div>

          <!-- 4. CTA -->
          <div class="ps-widget ps-widget--dark">
            <h3 class="ps-widget__title ps-widget__title--light">Cotiza tu evento</h3>
            <p class="ps-widget__desc">Cotización personalizada en menos de 24 horas. Sin compromiso.</p>
            <a href="/cotizar/" class="ps-widget__btn">Cotizar Gratis</a>
            <a href={WHATSAPP_URL_MSG} class="ps-widget__btn ps-widget__btn--wa" target="_blank" rel="noopener">WhatsApp: 55 4937 5172</a>
          </div>

          <!-- 5. Servicios relacionados -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Servicios relacionados</h3>
            <div class="ps-links">
              <a href="/renta-de-iluminacion/cascadas-led/" class="ps-link">Cascadas LED</a>
              <a href="/renta-de-iluminacion/luces-arquitectonicas/" class="ps-link">Uplighting</a>
              <a href="/renta-de-iluminacion/luz-neon/" class="ps-link">Luz Neón LED</a>
              <a href="/renta-de-bocinas/bocinas-para-bodas/" class="ps-link">Bocinas para Bodas</a>
              <a href="/equipos-para-eventos/humo-bajo/" class="ps-link">Humo Bajo</a>
              <a href="/equipos-para-eventos/maquina-de-confeti/" class="ps-link">Confeti</a>
            </div>
          </div>

          <!-- 6. Contacto -->
          <div class="ps-widget">
            <h3 class="ps-widget__title">Contacto</h3>
            <div class="ps-contact">
              <p><a href="tel:+525549375172">55 4937 5172</a></p>
              <p><a href="mailto:contacto@redeil.com">contacto@redeil.com</a></p>
              <p>Lun-Vie 9:00-19:00 | Sáb 10:00-15:00</p>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  /* ── Layout ── */
  .prod-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .prod-layout { grid-template-columns: 1fr 340px; gap: 2.5rem; } }

  /* ── Gallery ── */
  .prod-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 2rem; border-radius: 14px; overflow: hidden; }
  .prod-gallery__main { grid-row: span 2; }
  .prod-gallery__main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-gallery__side { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .prod-gallery__side img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3/2; }

  /* ── Product Info ── */
  .prod-info { margin-bottom: 2.5rem; }
  .prod-info__badge { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 1rem; background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.12); border-radius: 6px; margin-bottom: 0.75rem; }
  .prod-info__title { font-size: clamp(1.375rem, 3vw, 1.75rem); font-weight: 800; color: var(--color-text); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1.25rem; }
  .prod-price { background: var(--color-bg); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid var(--color-accent); }
  .prod-price__amount { font-size: 2.25rem; font-weight: 800; color: var(--color-primary); font-variant-numeric: tabular-nums; }
  .prod-price__currency { font-size: 0.875rem; color: var(--color-text-light); margin-left: 0.5rem; }
  .prod-price__note { font-size: 0.8125rem; color: var(--color-text-light); margin: 0.5rem 0 0; }
  .prod-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .prod-btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 1.75rem; border-radius: 6px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.2s ease, border-color 0.2s ease; }
  .prod-btn--wa { background: #25D366; color: #fff; }
  .prod-btn--wa:hover { background: #1DA851; }
  .prod-btn--outline { background: none; color: var(--color-text); border: 2px solid var(--color-border); }
  .prod-btn--outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Selling Points ── */
  .prod-selling { margin-bottom: 2.5rem; }
  .prod-selling__headline { font-size: clamp(1.25rem, 3vw, 1.5rem); font-weight: 800; color: var(--color-text); line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 0.75rem; }
  .prod-selling__intro { font-size: 0.9375rem; color: var(--color-text-light); line-height: 1.75; margin: 0 0 1.75rem; max-width: 65ch; }
  .prod-highlights { display: flex; flex-direction: column; gap: 1.25rem; }
  .prod-hl { display: flex; gap: 1rem; align-items: stretch; }
  .prod-hl__bar { flex-shrink: 0; width: 3px; background: var(--color-accent); border-radius: 2px; }
  .prod-hl__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .prod-hl__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.3; }
  .prod-hl__desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.65; margin: 0; }

