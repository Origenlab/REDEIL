---
import Base from '../../../layouts/Base.astro';
import TopBar from '../../../components/TopBar.astro';
import Header from '../../../components/Header.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import CategoryCard from '../../../components/CategoryCard.astro';
import FaqSection from '../../../components/FaqSection.astro';
import Footer from '../../../components/Footer.astro';
import WhatsAppBubble from '../../../components/WhatsAppBubble.astro';
import { faqSchema, breadcrumbSchema } from '../../../lib/seo';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../../lib/config';

const paquetes = [
  {
    "nombre": "Básico — 50 metros",
    "slug": "paquete-50-metros",
    "precio": 3500,
    "imagen": "/img/paquetes/guirnaldas/basico.avif",
    "badge": "",
    "features": [
      "50 metros de guirnalda LED",
      "Focos Edison cálidos",
      "Instalación y desmontaje",
      "Cable negro profesional",
      "Operación durante evento"
    ]
  },
  {
    "nombre": "Estándar — 100 metros",
    "slug": "paquete-100-metros",
    "precio": 6200,
    "imagen": "/img/paquetes/guirnaldas/estandar.avif",
    "badge": "Más popular",
    "features": [
      "100 metros de guirnalda LED",
      "Focos Edison cálidos",
      "Instalación y desmontaje",
      "Cable negro profesional",
      "Dimmer de intensidad",
      "Operación durante evento"
    ]
  },
  {
    "nombre": "Premium — 200 metros",
    "slug": "paquete-200-metros",
    "precio": 10800,
    "imagen": "/img/paquetes/guirnaldas/premium.avif",
    "badge": "",
    "features": [
      "200 metros de guirnalda LED",
      "Focos Edison cálidos",
      "Instalación y desmontaje",
      "Cable negro profesional",
      "Dimmer de intensidad",
      "Extensiones adicionales",
      "Operación durante evento"
    ]
  },
  {
    "nombre": "Producción — 500 metros",
    "slug": "paquete-500-metros",
    "precio": 22000,
    "imagen": "/img/paquetes/guirnaldas/produccion.avif",
    "badge": "",
    "features": [
      "500 metros de guirnalda LED",
      "Focos Edison cálidos",
      "Instalación y desmontaje",
      "Cable negro profesional",
      "Dimmer de intensidad",
      "Extensiones adicionales",
      "Diseño personalizado",
      "2 técnicos durante evento"
    ]
  }
];

const faqItems = [
  {
    "pregunta": "¿Cuánto cuesta la renta de guirnaldas de luces en CDMX?",
    "respuesta": "Los precios de guirnaldas de luces van desde $3,500 MXN hasta $22,000 MXN + IVA, dependiendo del paquete. Todos incluyen instalación profesional y desmontaje."
  },
  {
    "pregunta": "¿Qué paquetes de guirnaldas de luces ofrecen?",
    "respuesta": "Ofrecemos 4 paquetes: Básico — 50 metros, Estándar — 100 metros, Premium — 200 metros, Producción — 500 metros. Cada uno está diseñado para diferentes tamaños de evento y presupuesto."
  },
  {
    "pregunta": "¿La instalación de guirnaldas de luces está incluida?",
    "respuesta": "Sí, todos nuestros paquetes de guirnaldas de luces incluyen transporte, instalación profesional, operación durante el evento y desmontaje. No hay costos ocultos."
  },
  {
    "pregunta": "¿En qué tipo de eventos se usa guirnaldas de luces?",
    "respuesta": "Guirnaldas de Luces es popular en bodas, XV años, fiestas de cumpleaños, eventos corporativos, conferencias y celebraciones privadas. Adaptamos cada paquete al tipo de evento."
  },
  {
    "pregunta": "¿Cubren servicio de guirnaldas de luces en Estado de México?",
    "respuesta": "Sí, cubrimos CDMX y todo el Estado de México. También llegamos a Cuernavaca, Tepoztlán, Valle de Bravo y ubicaciones dentro de 100 km sin costo adicional."
  },
  {
    "pregunta": "¿Con cuánta anticipación debo reservar guirnaldas de luces?",
    "respuesta": "Recomendamos reservar con 4-6 semanas de anticipación, especialmente en temporada alta. Para fechas próximas, escríbenos por WhatsApp al 55 4937 5172."
  },
  {
    "pregunta": "¿Puedo combinar guirnaldas de luces con otros servicios?",
    "respuesta": "Por supuesto. Ofrecemos descuentos especiales al combinar servicios de iluminación, audio y equipos. Diseñamos paquetes integrales a la medida de tu evento."
  },
  {
    "pregunta": "¿Qué marcas de equipo usan para guirnaldas de luces?",
    "respuesta": "Trabajamos con marcas líderes como JBL, QSC, Martin Professional, Chauvet y Elation. Nuestro inventario se actualiza constantemente para ofrecer la mejor tecnología disponible."
  }
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Renta de Guirnaldas de Luces — REDEIL',
    description: 'Luces vintage con focos Edison para bodas en jardín y eventos elegantes.',
    provider: {
      '@type': 'LocalBusiness',
      name: 'REDEIL',
      url: SITE_URL,
    },
    areaServed: { '@type': 'City', name: 'Ciudad de México' },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Paquetes de Guirnaldas de Luces',
      itemListElement: paquetes.map(p => ({
        '@type': 'Offer',
        name: p.nombre,
        price: p.precio,
        priceCurrency: 'MXN',
        url: SITE_URL + '/renta-de-iluminacion/guirnaldas/' + p.slug + '/',
      })),
    },
  },
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Renta de Iluminación', url: '/renta-de-iluminacion/' },
    { name: 'Guirnaldas de Luces', url: '/renta-de-iluminacion/guirnaldas/' },
  ]),
  faqSchema(faqItems),
];
---

<Base
  title="Renta de Guirnaldas de Luces para Eventos en CDMX | REDEIL"
  description="Luces vintage con focos Edison para bodas en jardín y eventos elegantes. 4 paquetes desde $3,500 MXN. Instalación profesional incluida en CDMX y EdoMex."
  structuredData={structuredData}
>
  <TopBar />
  <Header />
  <Breadcrumb items={[{ name: 'Renta de Iluminación', href: '/renta-de-iluminacion/' }, { name: 'Guirnaldas de Luces', href: '/renta-de-iluminacion/guirnaldas/' }]} />

  <Hero
    badge="Renta de Guirnaldas de Luces"
    title="Renta de Guirnaldas de Luces para Eventos en CDMX"
    description="Luces vintage con focos Edison para bodas en jardín y eventos elegantes. Ofrecemos 4 paquetes profesionales con instalación incluida para bodas, XV años..."
    primaryCta={{ text: 'Cotizar Guirnaldas de Luces', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver Paquetes', href: '#paquetes' }}
  >
    <Fragment slot="hero-seo">
      <p>La <strong>renta de guirnaldas de luces</strong> es uno de los servicios más solicitados en <strong>REDEIL</strong>. Luces vintage con focos Edison para bodas en jardín y eventos elegantes. Cada paquete incluye transporte, instalación profesional, operación durante el evento y desmontaje en <strong>CDMX y Estado de México</strong>.</p>
      <p>Con más de 10 años de experiencia, hemos llevado guirnaldas de luces a cientos de <strong>bodas, XV años, fiestas privadas y eventos corporativos</strong>. Trabajamos con equipo de marcas líderes y un equipo técnico capacitado que garantiza resultados impecables en cada evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    headline="Elige tu paquete de Guirnaldas de Luces"
    items={paquetes.map(p => ({
      label: p.nombre,
      href: '/renta-de-iluminacion/guirnaldas/' + p.slug + '/',
    }))}
  />

  <!-- GRID DE PAQUETES -->
  <section class="section" id="paquetes">
    <div class="container">
      <SectionHeader
        badge="4 paquetes"
        title="Paquetes de Guirnaldas de Luces"
        subtitle="Desde eventos íntimos hasta producciones de gran escala. Elige el paquete perfecto para tu evento."
        id="paquetes-title"
      />
      <div class="pkg-grid">
        {paquetes.map((p: any) => (
          <article class={`pkg ${p.badge ? 'pkg--featured' : ''}`}>
            <div class="pkg__img-wrap">
              <img src={p.imagen} alt={p.nombre} width="600" height="400" loading="lazy" class="pkg__img" />
              {p.badge && <span class="pkg__badge">{p.badge}</span>}
            </div>
            <div class="pkg__body">
              <h3 class="pkg__name">{p.nombre}</h3>
              <div class="pkg__pricing">
                <span class="pkg__amount">${p.precio.toLocaleString()}</span>
                <span class="pkg__tax">MXN + IVA</span>
              </div>
              <ul class="pkg__features">
                {p.features.map((f: string) => (
                  <li>{f}</li>
                ))}
              </ul>
              <a href={'/renta-de-iluminacion/guirnaldas/' + p.slug + '/'} class="pkg__cta">
                Cotizar este paquete
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTENIDO SEO -->
  <section class="section section--bg">
    <div class="container content-prose">
      <h2>¿Por qué rentar guirnaldas de luces con REDEIL?</h2>
      <p>Luces vintage con focos Edison para bodas en jardín y eventos elegantes. En REDEIL nos especializamos en ofrecer equipamiento profesional para eventos de todos los tamaños en la Ciudad de México y área metropolitana. Nuestro equipo técnico capacitado se encarga de cada detalle para que tú solo te preocupes por disfrutar.</p>

      <h3>¿Qué incluye la renta de guirnaldas de luces?</h3>
      <p>Cada paquete de guirnaldas de luces incluye mucho más que solo equipo. Ofrecemos un servicio completo que abarca la logística de transporte, la instalación profesional en tu venue, la configuración y pruebas antes del evento, la operación técnica durante toda la celebración y el desmontaje al finalizar. No hay costos ocultos ni sorpresas.</p>

      <h3>¿Qué equipo profesional usan para guirnaldas de luces?</h3>
      <p>Trabajamos con las mejores marcas del mercado: JBL, QSC, Martin Professional, Chauvet y Elation. Nuestro inventario se actualiza constantemente para ofrecerte la tecnología más reciente. Cada equipo pasa por revisiones periódicas de mantenimiento para garantizar un funcionamiento impecable.</p>

      <h3>¿En qué zonas de CDMX rentan guirnaldas de luces?</h3>
      <p>Nuestro servicio de renta de guirnaldas de luces cubre toda la Ciudad de México y el Estado de México. También llegamos a destinos populares para eventos como Cuernavaca, Tepoztlán, Valle de Bravo y cualquier ubicación dentro de 100 km de CDMX sin costo adicional de traslado.</p>
    </div>
  </section>

  
  <!-- Zonas de servicio -->
  <section class="section">
    <div class="container">
      <h2 class="section__title">¿En qué zonas de CDMX ofrecemos guirnaldas de luces?</h2>
      <p class="section__subtitle">Llevamos guirnaldas de luces a toda la Ciudad de México y Estado de México. Estas son algunas de nuestras zonas de cobertura.</p>
      <div class="zonas-servicio">
        <a href="/zonas/polanco/" class="zona-link">Renta de guirnaldas de luces en Polanco</a>
        <a href="/zonas/condesa/" class="zona-link">Renta de guirnaldas de luces en Condesa</a>
        <a href="/zonas/santa-fe/" class="zona-link">Renta de guirnaldas de luces en Santa Fe</a>
      </div>
      <p style="margin-top: var(--spacing-md); text-align: center;"><a href="/zonas/" style="color: var(--color-accent); font-weight: 600;">Ver todas las zonas de cobertura →</a></p>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <!-- CTA FINAL -->

  <Footer />
  <WhatsAppBubble />
</Base>

<style>
  .pkg-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
  }
  .pkg-card__header {
    padding: 1.5rem;
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
  }
  .pkg-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .pkg-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
  }
  .pkg-card__amount {
    font-size: var(--font-size-2xl);
    font-weight: 800;
  }
  .pkg-card__currency {
    font-size: var(--font-size-sm);
    opacity: 0.8;
  }
  .pkg-card__features {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
  }
  .pkg-card__feature {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--color-bg);
  }
  .pkg-card__feature:last-child {
    border-bottom: none;
  }
  .pkg-card__btn {
    display: block;
    margin: 0 1.5rem 1.5rem;
    padding: 0.875rem;
    text-align: center;
    font-size: var(--font-size-sm);
    font-weight: 600;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: background 0.2s;
  }
  .pkg-card__btn:hover {
    background: var(--color-accent-dark);
  }
  .content-prose {
    max-width: 800px;
    margin: 0 auto;
  }
  .content-prose h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .content-prose h3 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }
  .content-prose p {
    font-size: var(--font-size-base);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .zonas-servicio {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-sm);
  }
  .zonas-servicio .zona-link,
  .zona-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 600;
    font-size: var(--font-size-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .zona-link:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }
</style>
<style>
  /* Package cards - redesigned */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .pkg {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 8px 24px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .pkg:hover { border-color: #D4A04A; }
  .pkg--featured { border-color: #D4A04A; }
  .pkg__img-wrap {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .pkg__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pkg__badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #D4A04A;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .pkg__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .pkg__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }
  .pkg__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #E8E8E8;
  }
  .pkg__amount {
    font-size: 1.75rem;
    font-weight: 800;
    color: #D4A04A;
    line-height: 1;
  }
  .pkg__tax {
    font-size: 0.75rem;
    color: #94A3B8;
    font-weight: 500;
  }
  .pkg__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .pkg__features li {
    font-size: 0.875rem;
    color: #475569;
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .pkg__features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #D4A04A;
  }
  .pkg__cta {
    display: block;
    text-align: center;
    padding: 0.875rem;
    background: #1A1A2E;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s;
    margin-top: auto;
  }
  .pkg__cta:hover { background: #D4A04A; }
  .pkg--featured .pkg__cta { background: #D4A04A; }
  .pkg--featured .pkg__cta:hover { background: #B8862D; }
</style>
